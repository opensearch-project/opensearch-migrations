# Steady ingest load
#
# Usage:
#   docker-compose run --rm --env-file k6-config/ingest-steady.env k6 \
#     run --out=experimental-prometheus-rw /scripts/scenarios/ingest.js
#
# Tune INGEST_RATE upward until Kafka lag or proxy latency starts rising
# to find the saturation point.

CAPTURE_PROXY_URL=https://capture-proxy:9200

# Arrival rate: target requests per second sent to the proxy
INGEST_RATE=50

# VU pool: each VU holds one keep-alive TCP connection to the proxy.
# Pre-allocate enough to sustain INGEST_RATE; k6 will spin up to MAX if needed.
INGEST_VUS=20
INGEST_MAX_VUS=100

# How long to run the scenario
DURATION=5m

# Documents per _bulk call (controls request body size)
BULK_BATCH_SIZE=20

# Expected document count in the index after seeding
SEED_DOC_COUNT=100000
