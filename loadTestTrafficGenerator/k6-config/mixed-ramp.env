# Mixed ramp profile — Phase 5
#
# Both ingest and search streams ramp independently:
#   - Ingest: 0 → 80 req/s over 2m, hold 3m, ramp down 1m
#   - Search: 0 → 50 req/s over 2m, hold 3m, ramp down 1m
#
# Both streams run for the same total duration (6 minutes) but are otherwise
# independent — ingest and search VUs do not synchronise across streams.
#
# The Redis ID ring fills during the ingest ramp-up. Consistency reads begin
# landing on real documents once the ring has at least one entry (~15 s into
# the run at 80 req/s × 25.5% single-doc ≈ 20 IDs/s). During ramp-up the
# mixed_search_consistency_misses counter will be elevated; this is expected.
#
# Use this to observe:
#   - How ingest throughput and search latency interact under combined ramp load
#   - Whether write-then-read consistency degrades as ingest rate rises
#   - Whether Kafka consumer lag accumulates proportionally to combined traffic
#
# Total test duration: 6 minutes (sum of stage durations for each stream).

CAPTURE_PROXY_URL=https://capture-proxy:9200
INDEX_NAME=nyc_taxis
EXECUTOR=ramping-arrival-rate
INGEST_RAMP_STAGES=[{"duration":"2m","target":80},{"duration":"3m","target":80},{"duration":"1m","target":0}]
SEARCH_RAMP_STAGES=[{"duration":"2m","target":50},{"duration":"3m","target":50},{"duration":"1m","target":0}]

INGEST_VUS=30
INGEST_MAX_VUS=150
SEARCH_VUS=20
SEARCH_MAX_VUS=100

BULK_BATCH_SIZE=20
SEQUENCE_FRACTION=0.15
CONSISTENCY_FRACTION=0.10
CONNECTION_MODE=pinned
WEBDIS_URL=http://webdis:7379
REGISTRY_ENABLED=true

# Delay search VUs until the ring holds ~50 IDs to reduce warmup misses.
# At 80 req/s ingest × 25.5% single-doc ≈ 20 IDs/s → ~3s delay.
# Increase (e.g. MIN_RING_FILL=200) to tolerate slower ramp-up phases.
MIN_RING_FILL=50
