# Deep-paging search load — Phase 3
#
# Activates the deep-paging fraction (5% of iterations run scroll or search_after sequences).
# Lower rate vs. search-steady.env because multi-step sequences are more expensive per iteration.
#
# Usage:
#   env_flags=()
#   while IFS= read -r line || [[ -n "$line" ]]; do
#     [[ -z "$line" || "$line" =~ ^[[:space:]]*# ]] && continue
#     env_flags+=(-e "$line")
#   done < k6-config/search-deep-paging.env
#   docker compose run --rm "${env_flags[@]}" k6 \
#     run --out=experimental-prometheus-rw /scripts/scenarios/search.js
#
# Swap PAGING_MODE to "search_after" to compare replay memory footprint between modes.

CAPTURE_PROXY_URL=https://capture-proxy:9200
INDEX_NAME=nyc_taxis

SEARCH_RATE=20
SEARCH_VUS=20
SEARCH_MAX_VUS=80
DURATION=5m
SEED_DOC_COUNT=100000

# Deep paging ON — 5% of iterations run multi-step scroll or search_after sequences
DEEP_PAGING_ENABLED=true
PAGING_MODE=scroll
SCROLL_PAGES=5
SEARCH_AFTER_PAGES=5

CONNECTION_MODE=pinned
