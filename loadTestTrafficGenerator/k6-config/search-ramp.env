# Ramp search profile
#
# Ramps from 0 to 150 req/s over 2 minutes, holds for 3 minutes, then ramps
# back to 0 over 1 minute. Use this to find the Capture Proxy saturation point
# under read-heavy load and observe how latency degrades as search rate rises.
#
# Usage:
#   env_flags=()
#   while IFS= read -r line || [[ -n "$line" ]]; do
#     [[ -z "$line" || "$line" =~ ^[[:space:]]*# ]] && continue
#     env_flags+=(-e "$line")
#   done < k6-config/search-ramp.env
#   docker compose run --rm "${env_flags[@]}" \
#     k6 run --out=opentelemetry /scripts/scenarios/search.js
#
# Total test duration: 6 minutes (sum of all stage durations).
# DURATION is ignored when EXECUTOR=ramping-arrival-rate.
#
# Watch Grafana (http://localhost:3000) for:
#   - Request Rate by Type: ramp-up curve across flat / agg / update operation mix
#   - Latency tiles: agg queries (p95 < 5000 ms) will breach first as rate rises
#   - Capture Proxy latency: proxy-side overhead vs OpenSearch response time
#   - Kafka offset: search does not write to Kafka but consistency reads do — offset
#     growth should stay flat unless WRITE_FRACTION or UPDATE_FRACTION is active

CAPTURE_PROXY_URL=https://capture-proxy:9200
EXECUTOR=ramping-arrival-rate
RAMP_STAGES=[{"duration":"2m","target":150},{"duration":"3m","target":150},{"duration":"1m","target":0}]

# VU pool: ramp scenarios need more headroom than constant-rate runs.
SEARCH_VUS=50
SEARCH_MAX_VUS=200

SEED_DOC_COUNT=100000
DEEP_PAGING_ENABLED=false
CONNECTION_MODE=pinned
