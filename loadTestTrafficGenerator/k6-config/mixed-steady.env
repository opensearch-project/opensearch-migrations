# Steady mixed load — Phase 4 defaults
#
# Runs both the ingest stream (Profile 1) and the search stream (Profile 2)
# concurrently. The Redis ID ring connects them: ingest VUs register newly-
# created doc IDs; CONSISTENCY_FRACTION of search VUs draw from the ring to
# verify write-then-read consistency through the pipeline.
#
# Usage:
#   env_flags=()
#   while IFS= read -r line || [[ -n "$line" ]]; do
#     [[ -z "$line" || "$line" =~ ^[[:space:]]*# ]] && continue
#     env_flags+=(-e "$line")
#   done < k6-config/mixed-steady.env
#   docker compose run --rm "${env_flags[@]}" \
#     k6 run --out=experimental-prometheus-rw /scripts/scenarios/mixed.js
#
# Seeding prerequisite: run the DataGenerator against the proxy before this test
# to populate seed documents for the search stream's partial-update operation.
# See DESIGN.md §7.1.

CAPTURE_PROXY_URL=https://capture-proxy:9200
INDEX_NAME=nyc_taxis

# Independent arrival rates for each stream. Dial these separately to stress
# specific pipeline components (e.g. higher INGEST_RATE to saturate Kafka).
INGEST_RATE=30
SEARCH_RATE=20

# VU pools for each stream. Each VU holds one keep-alive TCP connection.
INGEST_VUS=15
INGEST_MAX_VUS=75
SEARCH_VUS=15
SEARCH_MAX_VUS=75

# Both streams run for the same duration.
DURATION=5m

# Ingest stream: documents per _bulk call and sequence fraction.
BULK_BATCH_SIZE=20
SEQUENCE_FRACTION=0.15

# Search stream: fraction of iterations that query a recently-ingested doc via
# the Redis ring buffer. The remaining (1 - CONSISTENCY_FRACTION) run the
# standard Profile 2 mix (flat / agg / update / write).
CONSISTENCY_FRACTION=0.10

# Connection mode: "pinned" (keep-alive, default) or "spread" (Connection: close).
CONNECTION_MODE=pinned

# Expected document count in the seeded index (informs seed sampling in setup).
SEED_DOC_COUNT=100000

# Webdis HTTP-to-Redis proxy URL (must match the docker-compose service name).
WEBDIS_URL=http://webdis:7379
