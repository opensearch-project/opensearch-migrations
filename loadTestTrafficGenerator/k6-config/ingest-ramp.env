# Ramp ingest profile — Phase 5
#
# Ramps from 0 to 150 req/s over 2 minutes, holds for 3 minutes, then ramps
# back to 0 over 1 minute. Use this to find the Capture Proxy saturation point
# and observe Kafka consumer lag accumulation under increasing load.
#
# Usage:
#   env_flags=()
#   while IFS= read -r line || [[ -n "$line" ]]; do
#     [[ -z "$line" || "$line" =~ ^[[:space:]]*# ]] && continue
#     env_flags+=(-e "$line")
#   done < k6-config/ingest-ramp.env
#   docker compose run --rm "${env_flags[@]}" \
#     k6 run --out=experimental-prometheus-rw /scripts/scenarios/ingest.js
#
# Total test duration: 6 minutes (sum of all stage durations).
# DURATION is ignored when EXECUTOR=ramping-arrival-rate.
#
# Watch Grafana (http://localhost:3000) for:
#   - Throughput panel: should show a ramp-up curve, plateau, then ramp-down
#   - Error rate panel: expect spikes if proxy saturates around 120–150 req/s
#   - Kafka consumer lag (requires Traffic Replayer): lag accumulates on ramp-up
#     and drains (or doesn't) during hold — the drain rate reveals replay capacity

CAPTURE_PROXY_URL=https://capture-proxy:9200
INDEX_NAME=nyc_taxis
EXECUTOR=ramping-arrival-rate
RAMP_STAGES=[{"duration":"2m","target":150},{"duration":"3m","target":150},{"duration":"1m","target":0}]

# VU pool: ramp scenarios need more headroom than constant-rate runs because
# k6 must spin up VUs ahead of the rate curve to avoid dropped iterations.
INGEST_VUS=50
INGEST_MAX_VUS=200

BULK_BATCH_SIZE=20
SEQUENCE_FRACTION=0.15
CONNECTION_MODE=pinned
