# Steady search load — Phase 3 defaults
#
# Usage:
#   env_flags=()
#   while IFS= read -r line || [[ -n "$line" ]]; do
#     [[ -z "$line" || "$line" =~ ^[[:space:]]*# ]] && continue
#     env_flags+=(-e "$line")
#   done < k6-config/search-steady.env
#   docker compose run --rm "${env_flags[@]}" k6 \
#     run --out=experimental-prometheus-rw /scripts/scenarios/search.js
#
# Seeding prerequisite: run the DataGenerator against the proxy before this test.

CAPTURE_PROXY_URL=https://capture-proxy:9200

# Arrival rate: target requests per second sent to the proxy
SEARCH_RATE=50

# VU pool: each VU holds one keep-alive TCP connection to the proxy.
SEARCH_VUS=30
SEARCH_MAX_VUS=150

# How long to run the scenario
DURATION=5m

# Expected document count in the seeded index (informs setup sampling)
SEED_DOC_COUNT=100000

# Deep paging: off by default — use search-deep-paging.env to enable
DEEP_PAGING_ENABLED=false
PAGING_MODE=scroll
SCROLL_PAGES=3
SEARCH_AFTER_PAGES=3

# Connection mode: "pinned" (keep-alive, default) or "spread" (Connection: close)
CONNECTION_MODE=pinned
