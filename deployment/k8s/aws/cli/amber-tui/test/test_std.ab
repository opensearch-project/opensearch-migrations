// test_std.ab — coverage for src/std.ab, mirroring test_std.bats.

import { assert, assert_eq } from "std/test"
import {
    trim, trim_quotes, starts_with, ends_with, contains,
    split_csv, join_by, regex_capture, regex_match, count_lines_var,
    array_contains, dedupe, path_join, is_macos, is_linux,
    optional_cmd, parse_flag_value, parse_flag_rest
} from "../src/std.ab"
import { env_var_set, env_var_unset } from "std/env"
import { require_var } from "../src/std.ab"

// ---- strings ----

test "trim strips leading + trailing whitespace" {
    assert_eq(trim("  hello world  "), "hello world")
    assert_eq(trim(""), "")
    assert_eq(trim("no-ws"), "no-ws")
}

test "trim_quotes strips matched single OR double quotes" {
    assert_eq(trim_quotes("\"hello\""), "hello")
    assert_eq(trim_quotes("'hello'"), "hello")
    // asymmetric → unchanged
    assert_eq(trim_quotes("\"only-leading"), "\"only-leading")
    assert_eq(trim_quotes("only-trailing\""), "only-trailing\"")
}

test "starts_with / ends_with / contains" {
    assert(starts_with("abc", "abcdef"))
    assert(not starts_with("xyz", "abcdef"))
    assert(ends_with("def", "abcdef"))
    assert(not ends_with("xyz", "abcdef"))
    assert(contains("cd", "abcdef"))
    assert(not contains("zz", "abcdef"))
}

test "split_csv splits on commas" {
    let parts = split_csv("a,b,c")
    assert_eq(len parts, 3)
    assert_eq(parts[0], "a")
    assert_eq(parts[2], "c")
}

test "join_by joins with separator" {
    assert_eq(join_by(",", ["a", "b", "c"]), "a,b,c")
    assert_eq(join_by(" | ", ["one", "two", "three"]), "one | two | three")
    assert_eq(join_by(",", ["single"]), "single")
}

test "regex_capture extracts a group" {
    assert_eq(regex_capture("name: my-job, kind: Job", "name: ([A-Za-z0-9_-]+),", 1), "my-job")
    assert_eq(regex_capture("abc=123", "([a-z]+)=([0-9]+)", 2), "123")
}

test "regex_match is a boolean" {
    assert(regex_match("abc=123", "[0-9]+"))
    assert(not regex_match("no digits", "[0-9]+"))
}

test "count_lines_var counts lines" {
    assert_eq(count_lines_var("a\nb\nc"), 3)
    assert_eq(count_lines_var(""), 0)
    assert_eq(count_lines_var("a\nb\n"), 2)
    assert_eq(count_lines_var("one-line-no-newline"), 1)
}

// ---- collections ----

test "array_contains finds / rejects" {
    assert(array_contains("beta", ["alpha", "beta", "gamma"]))
    assert(not array_contains("delta", ["alpha", "beta", "gamma"]))
}

test "dedupe drops duplicate lines, keeps order" {
    let out = dedupe("a\nb\na\nc\nb")
    assert_eq(len out, 3)
    assert_eq(out[0], "a")
    assert_eq(out[1], "b")
    assert_eq(out[2], "c")
}

// ---- path ----

test "path_join collapses slashes" {
    assert_eq(path_join(["/var", "log", "migrate.log"]), "/var/log/migrate.log")
    assert_eq(path_join(["/foo/", "/bar"]), "/foo/bar")
    assert_eq(path_join(["foo", "bar", "baz"]), "foo/bar/baz")
}

// ---- environment ----

test "is_macos / is_linux mutually exclusive" {
    assert(is_macos() or is_linux())
    assert(not (is_macos() and is_linux()))
}

test "optional_cmd: present vs missing" {
    assert(optional_cmd("bash"))
    assert(not optional_cmd("this-command-definitely-does-not-exist-9876"))
}

test "require_var: set+nonempty vs empty/unset" {
    env_var_set("STD_TEST_VAR", "ok")
    assert(require_var("STD_TEST_VAR"))
    env_var_unset("STD_TEST_VAR")
    assert(not require_var("STD_TEST_VAR"))
}

// ---- flag parsing ----

test "parse_flag_value: space form" {
    let v = parse_flag_value("--foo", ["--non-interactive", "--foo", "myval", "--bar", "x"])
    assert_eq(v, "myval")
}
test "parse_flag_value: equals form" {
    let v = parse_flag_value("--foo", ["--foo=combined", "extra"])
    assert_eq(v, "combined")
}
test "parse_flag_value: absent → empty" {
    let v = parse_flag_value("--missing", ["a", "b", "c"])
    assert_eq(v, "")
}
test "parse_flag_rest: removes flag+value (space form)" {
    let rest = parse_flag_rest("--foo", ["--non-interactive", "--foo", "myval", "--bar", "x"])
    assert_eq(len rest, 3)
    assert_eq(rest[0], "--non-interactive")
    assert_eq(rest[1], "--bar")
    assert_eq(rest[2], "x")
}
test "parse_flag_rest: equals form leaves one extra" {
    let rest = parse_flag_rest("--foo", ["--foo=combined", "extra"])
    assert_eq(len rest, 1)
    assert_eq(rest[0], "extra")
}
