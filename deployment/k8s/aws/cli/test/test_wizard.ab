// test_wizard.ab — e2e coverage for wizard.ab (wizard_collect + the adopt-stack
// selector _wizard_offer_existing_stack).
//
// Style (see test/TEST_GUIDE.md): drive the real wizard entrypoint
// non-interactively against a per-test world, then assert on what it PRODUCED —
// the four deploy inputs it persisted to the on-disk state.env (AWS_REGION,
// STAGE_NAME, MIRROR_IMAGES, MA_VERSION) + the resume checkpoint. The world
// (test/support/world.ab) gives each block an isolated STAGE_DIR; the wizard's
// state_save() writes state.env there, which we read back to verify the outcome.
//
// ── Why the persisted state.env is the observable channel ────────────────────
// wizard_collect() drives ui.ab prompts; world_noninteractive() flips the CLI
// non-interactive so ui_prompt returns its fallback and ui_confirm collapses to
// its default — the wizard then runs end-to-end on its pre-fill defaults with no
// TTY. Its OUTPUT is the state.env / state.json it writes via state_save() into
// the world's STAGE_DIR. We read state.env back and assert the four inputs.
//
// Region + MA version defaults are steered through process-global ENV
// (AWS_REGION / AWS_DEFAULT_REGION / MA_VERSION), which the wizard reads at run
// time. The fresh_world() helper here pins MA_VERSION offline so the version
// prompt's default never hits the GitHub releases API (ma_default_version's
// explicit-override branch short-circuits before curl), and clears the
// region/resume env so each block starts from a known baseline (env leaks across
// `amber test` blocks).
//
// ── The adopt-existing path under `amber test` ───────────────────────────────
// wizard_collect() reads CFN_MA_STACKS from its OWN state store, never calling
// state_load() itself — so under `amber test` that store is empty and the
// in-wizard adopt branch does not engage (the resume fast-path likewise can't see
// the wizard-side inputs). The adopt LOGIC is still fully covered because
// _wizard_offer_existing_stack is PURE w.r.t. its <list> argument (it takes the
// stack list as a param, not from state): single-stack adopt, multi-stack
// default-pick, and whitespace word-split are asserted directly + deterministically
// as return-value units.

import { assert, assert_eq } from "std/test"
import { env_var_set, env_var_unset } from "std/env"
import { file_read } from "std/fs"
import { text_contains, join } from "std/text"
import { regex_match } from "../src/std.ab"
import { fresh_world, world_noninteractive } from "./support/world.ab"
import { wizard_collect, _wizard_offer_existing_stack, fmt_deploy_plan, wizard_show_plan } from "../src/wizard.ab"
import { state_set } from "../src/state.ab"

// ---- file-local helpers (ABOVE the test blocks: define-before-use; the
// test-file tree shaker keeps only deps that textually precede each block) ----

// wizard_world — a fresh isolated world wired for a deterministic, offline wizard
// run: non-interactive (prompts → defaults), region/resume env cleared to a known
// baseline (env leaks across blocks), and MA_VERSION pinned so the version default
// never touches the network. Returns the world dir (= STAGE_DIR) so a test can
// read the state.env the wizard persists there.
fun wizard_world(): Text {
    let w = fresh_world()
    world_noninteractive()
    // Clear region + resume env so each block starts from a known baseline; a
    // leftover from another block must not leak in (env is process-wide). Tests
    // that need these set them explicitly.
    trust env_var_unset("MIGRATE_RESUMING")
    trust env_var_unset("AWS_REGION")
    trust env_var_unset("AWS_DEFAULT_REGION")
    // Pin MA_VERSION so the version prompt's default short-circuits before curl.
    trust env_var_set("MA_VERSION", "2.4.0")
    return w
}

// state_env — the state.env wizard_collect persisted under <world>, or "".
fun state_env(world: Text): Text {
    return file_read("{world}/state.env") failed { "" }
}

// ---- wizard_collect: fresh deploy persists the four inputs ------------------

test "wizard collects region, stage, mirror + version, then marks wizard_done" {
    let w = wizard_world()
    // Pre-fill defaults with nothing seeded:
    //   region  → resolve_region_default(): no saved, no env → "us-east-1"
    //   stage   → "ma" (the saved-STAGE_NAME default)
    //   mirror  → ui_confirm default Y → "Y"
    //   version → MA_VERSION env "2.4.0" (override branch)
    wizard_collect()

    let body = state_env(w)
    // state_save serializes each input as KEY="VALUE".
    assert(text_contains(body, "AWS_REGION=\"us-east-1\""))
    assert(text_contains(body, "STAGE_NAME=\"ma\""))
    assert(text_contains(body, "MIRROR_IMAGES=\"Y\""))
    assert(text_contains(body, "MA_VERSION=\"2.4.0\""))
    // wizard marks the resume checkpoint so a later run skips the prompts.
    assert(text_contains(body, "last_step=\"wizard_done\""))
}

test "wizard defaults the region from AWS_DEFAULT_REGION when no AWS_REGION" {
    let w = wizard_world()
    // No saved AWS_REGION, no AWS_REGION env, but AWS_DEFAULT_REGION set →
    // resolve_region_default() falls through to it.
    trust env_var_set("AWS_DEFAULT_REGION", "eu-west-1")
    wizard_collect()
    assert(text_contains(state_env(w), "AWS_REGION=\"eu-west-1\""))
    trust env_var_unset("AWS_DEFAULT_REGION")
}

test "wizard prefers AWS_REGION over AWS_DEFAULT_REGION for the region default" {
    let w = wizard_world()
    // resolve_region_default() prefers AWS_REGION over AWS_DEFAULT_REGION.
    trust env_var_set("AWS_REGION", "ap-southeast-2")
    trust env_var_set("AWS_DEFAULT_REGION", "eu-west-1")
    wizard_collect()
    assert(text_contains(state_env(w), "AWS_REGION=\"ap-southeast-2\""))
    trust env_var_unset("AWS_REGION")
    trust env_var_unset("AWS_DEFAULT_REGION")
}

test "wizard sources the version from the MA_VERSION env override" {
    let w = wizard_world()
    // Override the pin to prove the version comes from the env
    // (ma_default_version's explicit-override branch), not a hardcode.
    trust env_var_set("MA_VERSION", "7.7.7")
    wizard_collect()
    assert(text_contains(state_env(w), "MA_VERSION=\"7.7.7\""))
    trust env_var_set("MA_VERSION", "2.4.0")
}

// ---- wizard_collect: resume flag -------------------------------------------
//
// The resume fast-path returns BEFORE any state_save (writing NO state.env) only
// when all four wizard-side inputs are already in its store. Under `amber test`
// the wizard's store is empty, so the guard's state_get(...)!="" checks are all
// false → the fast-path does NOT engage and normal collection runs, persisting
// the file. We assert that reachable contract: the resume flag ALONE does not
// suppress collection when the wizard-side inputs are absent.

test "wizard still collects + persists when resuming with an empty store" {
    let w = wizard_world()
    trust env_var_set("MIGRATE_RESUMING", "1")
    wizard_collect()
    assert(text_contains(state_env(w), "last_step=\"wizard_done\""))
    assert(text_contains(state_env(w), "MA_VERSION=\"2.4.0\""))
    trust env_var_unset("MIGRATE_RESUMING")
}

// ---- _wizard_offer_existing_stack: the adopt selector (pure in <list>) ------

test "offer-existing returns empty for an empty or whitespace-only list" {
    wizard_world()
    assert_eq(_wizard_offer_existing_stack(""), "")
    // whitespace-only also word-splits to zero tokens → empty.
    assert_eq(_wizard_offer_existing_stack("   "), "")
}

test "offer-existing adopts the sole stack under the default-Y confirm" {
    wizard_world()
    // n==1 → ui_confirm default Y (non-interactive) → adopt that stack.
    assert_eq(_wizard_offer_existing_stack("MigrationAssistant-prod"), "MigrationAssistant-prod")
}

test "offer-existing picks the first stack on the default index when many" {
    wizard_world()
    // n>1 → ui_prompt("Pick","1") returns "1" (non-interactive) → arr[0].
    let chosen = _wizard_offer_existing_stack("MigrationAssistant-a MigrationAssistant-b MigrationAssistant-c")
    assert_eq(chosen, "MigrationAssistant-a")
}

test "offer-existing word-splits runs of whitespace between stack names" {
    wizard_world()
    // Runs of whitespace collapse (the bash `arr=($list)` word-split), so the
    // first token is intact (no empty leading token) and gets adopted.
    let chosen = _wizard_offer_existing_stack("  MigrationAssistant-x    MigrationAssistant-y  ")
    assert_eq(chosen, "MigrationAssistant-x")
}

// ---- unit: the numeric-index regex the menu pick is guarded by (pure) -------
//
// The multi-stack menu accepts an index only if it matches ^[0-9]+$ AND is in
// range; the wizard guards the pick with regex_match(pick, "^[0-9]+$"). Cover
// that classifier directly so the adopt selector's "non-numeric input declines"
// edge is pinned without a TTY.

test "menu-pick regex matches only bare digit runs" {
    assert(regex_match("1", "^[0-9]+$"))
    assert(regex_match("42", "^[0-9]+$"))
    assert(not regex_match("", "^[0-9]+$"))
    assert(not regex_match("1a", "^[0-9]+$"))
    assert(not regex_match("none", "^[0-9]+$"))
}

// ---- deploy plan / confirm gate --------------------------------------------
//
// fmt_deploy_plan() is the pure pre-flight summary (reads the state store, returns
// the panel lines). Seed the store with a create-vpc deploy and assert the plan
// surfaces account/region/stack/what-gets-created/images/version + the time hint
// — the first-run operator's one consolidated view before a resource-creating run.

test "deploy plan summarizes account/region/stack/creates for a fresh create-vpc deploy" {
    // fmt_deploy_plan is a pure function of its args (no store) → no world needed.
    let plan = fmt_deploy_plan("123456789012", "us-east-1", "prod", "MigrationAssistant-prod", "create-vpc", "Y", "2.4.0", false)
    let blob = join(plan, "\n")
    assert(text_contains(blob, "123456789012"))
    assert(text_contains(blob, "us-east-1"))
    assert(text_contains(blob, "MigrationAssistant-prod"))
    // create-vpc names the VPC + EKS + ECR + IAM resources it will create.
    assert(text_contains(blob, "VPC, EKS cluster, ECR repos, IAM roles"))
    assert(text_contains(blob, "mirrored to your private ECR"))
    assert(text_contains(blob, "2.4.0"))
    assert(text_contains(blob, "~20-30 min"))
}

test "deploy plan calls out an adopted stack (CFN deploy skipped)" {
    // adopting=true → the plan names the adopt and advertises NO resource creation.
    let blob = join(fmt_deploy_plan("123456789012", "us-west-2", "qa", "MigrationAssistant-qa", "create-vpc", "N", "2.4.0", true), "\n")
    assert(text_contains(blob, "adopting existing"))
    assert(not text_contains(blob, "Creates       :"))
    // mirror=N surfaces the public-pull path
    assert(text_contains(blob, "public.ecr.aws"))
}

test "wizard_show_plan auto-proceeds in non-interactive mode" {
    wizard_world()   // world_noninteractive() flips MIGRATE_NONINTERACTIVE=1
    state_set("AWS_REGION", "us-east-1")
    state_set("STAGE_NAME", "ma")
    // No TTY + non-interactive → the gate renders the plan and returns true
    // (CI / scripted runs never block).
    assert(wizard_show_plan())
}
