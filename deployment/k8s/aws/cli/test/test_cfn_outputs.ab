// test_cfn_outputs.ab — coverage for src/cfn_outputs.ab (cfn_outputs /
// cfn_output_value / _cfn_extract_exports / _cfn_pick).
//
// Style (see test/TEST_GUIDE.md): the cfn_outputs / cfn_output_value tests drive
// the real entrypoint against the shared mock fleet — `aws cloudformation
// describe-stacks` is the ONE external command, so we program its stdout with
// mock_respond and assert on what the parser returned. _cfn_extract_exports and
// _cfn_pick are genuinely PURE (no world/AWS), so they stay as direct
// return-value unit asserts.
//
// Bug history this guards (caught in production): helm.sh did
// `cfn_outputs … | awk '/EKSClusterName/'`, but the real opensearch-migrations
// stack publishes a single output named MigrationsExportString — a long bash
// `export VAR=…; export …;` blob. No EKSClusterName key ever existed → the helm
// step died with "could not read EKSClusterName from CFN outputs". The
// real-payload tests feed the EXACT sanitized payload and assert the parser
// expands it; the helm/crane lookup-chain tests reproduce the exact fallback
// chains those callers use against that shape.
//
// describe-stacks is keyed on the "describe-stacks" arg token (the mock matches
// the first arg token with a fixture). The OutputValue carries an embedded TAB
// (\t) + the export blob exactly as `aws … --output text` emits it; Amber's Text
// literal turns \t into a real TAB, which mock_respond writes verbatim. The
// empty-AWS case just leaves describe-stacks unprogrammed → the shim emits
// nothing and exits 0 (the bash `|| true` path).

import { assert, assert_eq } from "std/test"
import { fresh_world, world_seed } from "./support/world.ab"
import { mock_install, mock_respond } from "./support/mock.ab"
import { array_contains } from "../src/std.ab"
import { text_contains } from "std/text"
import {
    cfn_outputs, cfn_output_value, _cfn_extract_exports, _cfn_pick
} from "../src/cfn_outputs.ab"

// ---- helpers (define-before-use: must precede the test blocks) -------------

// Sanitized copy of the user's real stack output: one TAB-separated
// <OutputKey>\t<OutputValue> row, where the OutputValue is one big string of
// bash `export VAR=…; export …;` clauses. The \t is a literal TAB in the Text
// literal — exactly what `aws … --output text` emits.
const REAL_PAYLOAD = "MigrationsExportString\texport MIGRATIONS_APP_REGISTRY_ARN=arn:aws:servicecatalog:us-east-1:629003556176:/applications/0152ij6laz8tjhttvf5rg0jrql; export MIGRATIONS_USER_AGENT=AwsSolution/SO0290/Unknown; export MIGRATIONS_EKS_CLUSTER_NAME=migration-eks-cluster-default-us-east-1; export MIGRATIONS_ECR_REGISTRY=629003556176.dkr.ecr.us-east-1.amazonaws.com/migration-ecr-default-us-east-1; export AWS_ACCOUNT=629003556176; export AWS_CFN_REGION=us-east-1; export VPC_ID=vpc-0bc345db0dee70e9e; export EKS_CLUSTER_SECURITY_GROUP=sg-07cc74efd34551fb1; export SNAPSHOT_ROLE=arn:aws:iam::629003556176:role/migration-eks-cluster-default-us-east-1-snapshot-role; export STAGE=default"

// outputs_world — a world whose faked `aws cloudformation describe-stacks` emits
// the real MigrationsExportString row, so cfn_outputs / cfn_output_value see the
// production payload. The shape behind the full-cycle + lookup-chain tests.
fun outputs_world(): Text {
    let w = fresh_world()
    world_seed(w, "STAGE_NAME", "ma")
    mock_install(["aws"])
    mock_respond(w, "aws", "describe-stacks", REAL_PAYLOAD)
    return w
}

// has_exact — is <needle> present as an exact element of <rows>? Mirrors the
// bats `grep -qx` whole-line checks (stricter than substring).
// (Param is `rows`, not `lines`: `lines` is a reserved Amber keyword.)
fun has_exact(rows: [Text], needle: Text): Bool {
    return array_contains(needle, rows)
}

// has_sub — does any element of <rows> CONTAIN <needle>? Mirrors `grep -q`.
fun has_sub(rows: [Text], needle: Text): Bool {
    for row in rows {
        if text_contains(row, needle) { return true }
    }
    return false
}

// ---- _cfn_extract_exports (pure: the bash-export-blob splitter) ------------

test "_cfn_extract_exports parses semicolon-joined exports into KEY=VALUE" {
    const out = _cfn_extract_exports("export A=one; export B=two; export C=three")
    assert(has_exact(out, "A=one"))
    assert(has_exact(out, "B=two"))
    assert(has_exact(out, "C=three"))
}

test "_cfn_extract_exports preserves '=' inside values (URLs, ARNs)" {
    const out = _cfn_extract_exports("export ARN=arn:aws:iam::1:role/x=y; export URL=https://h/p?q=r")
    // Whole-line exact match: the embedded '=' must NOT split key from value.
    assert(has_exact(out, "ARN=arn:aws:iam::1:role/x=y"))
    assert(has_exact(out, "URL=https://h/p?q=r"))
}

test "_cfn_extract_exports tolerates leading whitespace and a missing 'export '" {
    const out = _cfn_extract_exports("   export A=1;   B=2; export C=3")
    assert(has_exact(out, "A=1"))
    assert(has_exact(out, "B=2"))
    assert(has_exact(out, "C=3"))
}

test "_cfn_extract_exports drops malformed entries silently" {
    const out = _cfn_extract_exports("   ; ; bogus line; export OK=yes; ")
    assert(has_exact(out, "OK=yes"))
    // "bogus line" has no '=' → must NOT survive as any KEY=VALUE line.
    assert(not has_sub(out, "bogus"))
}

// ---- cfn_outputs: full cycle against the real describe-stacks payload ------

test "cfn_outputs emits the raw OutputKey AND every embedded export" {
    let w = outputs_world()
    const out = cfn_outputs("MigrationAssistant-ma", "us-east-1")

    // Pass A: the raw OutputKey=OutputValue line still surfaces (so older callers
    // that read a flat output don't regress). The raw line starts with the key.
    assert(has_sub(out, "MigrationsExportString="))

    // Pass B: every important export expanded into a flat KEY=VALUE line.
    assert(has_exact(out, "MIGRATIONS_EKS_CLUSTER_NAME=migration-eks-cluster-default-us-east-1"))
    assert(has_exact(out, "MIGRATIONS_ECR_REGISTRY=629003556176.dkr.ecr.us-east-1.amazonaws.com/migration-ecr-default-us-east-1"))
    assert(has_exact(out, "AWS_ACCOUNT=629003556176"))
    assert(has_exact(out, "AWS_CFN_REGION=us-east-1"))
    assert(has_exact(out, "VPC_ID=vpc-0bc345db0dee70e9e"))
    assert(has_exact(out, "STAGE=default"))
}

test "cfn_output_value retrieves a single named export, '' when absent" {
    let w = outputs_world()
    assert_eq(
        cfn_output_value("MigrationAssistant-ma", "us-east-1", "MIGRATIONS_EKS_CLUSTER_NAME"),
        "migration-eks-cluster-default-us-east-1")
    assert_eq(
        cfn_output_value("MigrationAssistant-ma", "us-east-1", "MIGRATIONS_ECR_REGISTRY"),
        "629003556176.dkr.ecr.us-east-1.amazonaws.com/migration-ecr-default-us-east-1")
    // Missing key → empty.
    assert_eq(
        cfn_output_value("MigrationAssistant-ma", "us-east-1", "DOES_NOT_EXIST"), "")
}

// ---- cfn_outputs: empty / failed AWS response (regression) -----------------

test "cfn_outputs returns [] on an empty AWS response without crashing" {
    let w = fresh_world()
    world_seed(w, "STAGE_NAME", "ma")
    // describe-stacks is left unprogrammed → the shim emits nothing, exits 0
    // (the bash `… 2>/dev/null || true` + `[[ -z ]] && return 0` path).
    mock_install(["aws"])
    const out = cfn_outputs("Stack", "region")
    assert_eq(len out, 0)
}

// ---- _cfn_pick (pure: the fallback-key chain) ------------------------------

test "_cfn_pick picks the first key that resolves to a non-empty value" {
    const outputs = ["MIGRATIONS_EKS_CLUSTER_NAME=cluster-A", "EKSClusterName=cluster-B"]
    assert_eq(_cfn_pick(outputs, ["MIGRATIONS_EKS_CLUSTER_NAME", "EKSClusterName"]), "cluster-A")

    // First key absent → the second wins.
    const outputs2 = ["EKSClusterName=cluster-B"]
    assert_eq(_cfn_pick(outputs2, ["MIGRATIONS_EKS_CLUSTER_NAME", "EKSClusterName"]), "cluster-B")
}

test "_cfn_pick returns '' when no key matches" {
    assert_eq(_cfn_pick(["OTHER=foo"], ["A", "B", "C"]), "")
}

// ---- end-to-end: helm / crane lookup chains against the real shape ---------

test "helm lookup chain finds the cluster name in the real CFN payload" {
    let w = outputs_world()
    const outputs = cfn_outputs("MigrationAssistant-ma", "us-east-1")
    // The exact fallback chain helm.sh uses (renamed key → flat key).
    assert_eq(
        _cfn_pick(outputs, ["MIGRATIONS_EKS_CLUSTER_NAME", "EKSClusterName"]),
        "migration-eks-cluster-default-us-east-1")
}

test "crane lookup chain finds the ECR registry in the real CFN payload" {
    let w = outputs_world()
    const outputs = cfn_outputs("MigrationAssistant-ma", "us-east-1")
    assert_eq(
        _cfn_pick(outputs, ["MIGRATIONS_ECR_REGISTRY", "ECRRegistry"]),
        "629003556176.dkr.ecr.us-east-1.amazonaws.com/migration-ecr-default-us-east-1")
}
