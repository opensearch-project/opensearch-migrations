// test_ui.ab — coverage for src/ui.ab (terminal UI chrome + prompts).
//
// ui.ab is pure chrome + non-interactive prompt defaults: it never shells out to
// aws/kubectl/helm, so there is no external fleet to fake here (no mock.ab). Two
// layers get tested:
//
//   * UNIT (pure): the color accessors (sgr gating on term_interactive) and the
//     banner/table FORMATTERS return Text — asserted directly on the return value,
//     no world needed. The test runner sets MIGRATE_FORCE_TTY=1, so term_detect()
//     reports interactive and chrome shows ESC color; we pin that per block.
//
//   * PROMPT PATH: ui_prompt / ui_confirm / ui_select honor MIGRATE_NONINTERACTIVE
//     (return their default, never read /dev/tty). Each such block mints its OWN
//     fresh_world() + world_noninteractive() so the flag is set the supported way
//     and never leaks/races across blocks (env vars are process-global).
//
// Mirrors the old test_ui_confirm.bats + stdout-discipline intent. NO `return`
// inside a test block (branch with if).

import { assert, assert_eq } from "std/test"
import { text_contains } from "std/text"
import { term_detect } from "../src/core.ab"
import {
    ui_banner, ui_table, ui_prompt, ui_confirm, ui_select,
    ui_red, ui_reset, ui_green
} from "../src/ui.ab"
import { fresh_world, world_noninteractive } from "./support/world.ab"

// interactive_block — pin this test block to interactive mode the way the runner
// does (MIGRATE_FORCE_TTY=1), so sgr()/chrome emit real ESC color. term_detect()
// caches into module-level state, which resets per block — so call it per block.
fun interactive_block(): Null {
    term_detect()
}

// ---- color accessors: sgr gates on interactivity --------------------------

test "color accessors emit ESC sequences when the terminal is interactive" {
    interactive_block()
    let esc_seq = ui_red()
    // Non-empty + carries the SGR red code; reset carries the [0m terminator.
    assert(esc_seq != "")
    assert(text_contains(esc_seq, "[31m"))
    assert(text_contains(ui_green(), "[32m"))
    assert(text_contains(ui_reset(), "[0m"))
}

// ---- banner + table: pure Text formatters ---------------------------------

test "ui_banner draws rule bars around the title" {
    interactive_block()
    let out = ui_banner("Migration Assistant")
    assert(text_contains(out, "Migration Assistant"))
    assert(text_contains(out, "━"))
}

test "ui_table renders the header and every row" {
    interactive_block()
    let out = ui_table("NAME STATUS", ["vpc ready", "eks pending"])
    assert(text_contains(out, "NAME STATUS"))
    assert(text_contains(out, "vpc ready"))
    assert(text_contains(out, "eks pending"))
}

// ---- prompt path: non-interactive returns the default, never reads tty -----

test "ui_prompt returns its fallback under non-interactive mode" {
    fresh_world()
    world_noninteractive()
    assert_eq(ui_prompt("Region", "us-east-1"), "us-east-1")
}

test "ui_prompt returns the empty fallback when no default is given" {
    fresh_world()
    world_noninteractive()
    assert_eq(ui_prompt("Optional", ""), "")
}

test "ui_confirm yields yes for a Y default with no input" {
    fresh_world()
    world_noninteractive()
    assert(ui_confirm("Resume?", "Y"))
}

test "ui_confirm yields no for an N default with no input" {
    fresh_world()
    world_noninteractive()
    assert(not ui_confirm("Wipe everything?", "N"))
}

test "ui_select returns the first option (default 1) under non-interactive" {
    fresh_world()
    world_noninteractive()
    interactive_block()
    let pick = ui_select("Choose mode", ["Manual", "Agent"])
    assert_eq(pick, "Manual")
}
