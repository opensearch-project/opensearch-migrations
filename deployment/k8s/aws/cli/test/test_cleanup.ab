// test_cleanup.ab — e2e coverage for cleanup.ab (cmd_cleanup + cmd_clear).
//
// Reference example for the e2e-focused style (see test/TEST_GUIDE.md): drive the
// real cmd_* entrypoint against the faked external world, then assert on what the
// CLI DID — which commands it issued (mock_called) and how state changed — rather
// than poking internals. The mock fleet + per-test world come from test/support/.
//
// State reconciles through the on-disk state.env: the world seeds it, cmd_cleanup
// calls state_load() at entry. Both resolve the same stage dir from the pinned
// MIGRATE_HOME/STAGE the world sets. NO `return` inside a test block.

import { assert, assert_eq } from "std/test"
import { file_exists, dir_exists } from "std/fs"
import { fresh_world, world_seed, world_noninteractive, world_stage } from "./support/world.ab"
import {
    mock_install_default, mock_respond, mock_fail,
    mock_called, mock_call_count
} from "./support/mock.ab"
import { cmd_cleanup, cmd_clear, _cmd_clear_agent_paths_for } from "../src/cleanup.ab"

// deployed_world — a world with a fully-deployed stage on disk (stack + release +
// region seeded) and the fleet faked to succeed. The shape behind most tests.
fun deployed_world(): Text {
    let w = fresh_world()
    world_noninteractive()
    world_seed(w, "STAGE_NAME", "ma")
    world_seed(w, "CFN_STACK_NAME", "MigrationAssistant-ma")
    world_seed(w, "HELM_RELEASE", "ma")
    world_seed(w, "AWS_REGION", "us-east-1")
    mock_install_default()
    mock_respond(w, "helm", "uninstall", "release \"ma\" uninstalled")
    mock_respond(w, "aws", "delete-stack", "")
    mock_respond(w, "aws", "wait", "")
    return w
}

// ---- cmd_cleanup: the deploy-teardown flow --------------------------------

test "cleanup uninstalls helm, deletes the CFN stack, then archives state" {
    let w = deployed_world()
    let rc = cmd_cleanup(["--non-interactive", "--stage", world_stage()])
    assert_eq(rc, 0)
    assert(mock_called(w, "helm", "uninstall"))
    assert(mock_called(w, "aws", "delete-stack"))
    assert(dir_exists("{w}/archive"))
}

test "cleanup targets the saved release, namespace, stack + region" {
    let w = deployed_world()
    cmd_cleanup(["--non-interactive", "--stage", world_stage()])
    assert(mock_called(w, "helm", "uninstall"))
    assert(mock_called(w, "aws", "MigrationAssistant-ma"))
    assert(mock_called(w, "aws", "us-east-1"))
}

test "cleanup tolerates a failed helm uninstall and still deletes the stack" {
    let w = fresh_world()
    world_noninteractive()
    world_seed(w, "STAGE_NAME", "ma")
    world_seed(w, "CFN_STACK_NAME", "MigrationAssistant-ma")
    world_seed(w, "HELM_RELEASE", "ma")
    world_seed(w, "AWS_REGION", "us-east-1")
    mock_install_default()
    mock_fail(w, "helm", "uninstall", "1", "Error: release: not found")
    mock_respond(w, "aws", "delete-stack", "")
    let rc = cmd_cleanup(["--non-interactive", "--stage", world_stage()])
    assert_eq(rc, 0)
    assert(mock_called(w, "helm", "uninstall"))
    assert(mock_called(w, "aws", "delete-stack"))
}

test "cleanup is a no-op when state has nothing deployed" {
    let w = fresh_world()
    world_noninteractive()
    world_seed(w, "STAGE_NAME", "ma")
    mock_install_default()
    let rc = cmd_cleanup(["--non-interactive", "--stage", world_stage()])
    assert_eq(rc, 0)
    assert_eq(mock_call_count(w, "helm"), 0)
    assert(not mock_called(w, "aws", "delete-stack"))
}

// ---- cmd_clear: wipe LOCAL state only (no AWS / k8s) ----------------------

test "clear wipes local state without touching AWS or kubernetes" {
    let w = fresh_world()
    world_noninteractive()
    world_seed(w, "STAGE_NAME", "ma")
    mock_install_default()
    assert(file_exists("{w}/state.env"))
    let rc = cmd_clear(["--stage", world_stage(), "-y"])
    assert_eq(rc, 0)
    assert_eq(mock_call_count(w, "helm"), 0)
    assert_eq(mock_call_count(w, "aws"), 0)
}

// ---- unit: the agent-session path encoder (pure) --------------------------

test "clear's agent-path encoder returns a list (empty when no session dir)" {
    let paths = _cmd_clear_agent_paths_for("/tmp/proj.x/stage-1")
    assert(len paths >= 0)
}
