// test_deploy_e2e.ab — HOLISTIC end-to-end coverage of the full deploy spine.
//
// Everything else in test/ exercises ONE step in isolation (cfn_deploy_or_skip,
// crane_mirror_or_skip, helm_install_or_upgrade, console_exec …). This file is the
// missing FLOW layer the audit flagged: it drives the real entry point
// `cmd_resume` straight through manual_path's whole pipeline —
//
//   discover_os → discover_aws → ensure_tools_basic → discover_resources →
//   ensure_tools_extended → wizard_collect → wizard_show_plan →
//   cfn_deploy_or_skip → helm_kubeconfig_setup → build_images_or_skip →
//   crane_mirror_or_skip → helm_install_or_upgrade → console_exec
//
// — against the faked external world, and asserts on what the CLI DID across the
// WHOLE run: the commands each stage issued (mock_called) and the terminal state
// it persisted (last_step). This catches step-ordering / state-advancement /
// early-abort regressions that the per-step unit tests structurally cannot — the
// byos EKS test is the only other thing that exercises the spine end to end, and
// it costs ~40 minutes of real AWS. (See test/TEST_GUIDE.md "Flow layer".)
//
// Style: NON-interactive (-y → MIGRATE_NONINTERACTIVE=1 so the wizard prompts fall
// to defaults and wizard_show_plan auto-proceeds), --mode Manual (bypass the
// picker). The world fixtures below compose the proven per-step recipes
// (test_cfn_deploy_decision.ab, test_helm_install_e2e.ab) into one running spine.
// NO `return` inside a test block — branch with `if` (Amber).

import { assert, assert_eq } from "std/test"
import { file_write, file_read } from "std/fs"
import { dir_create } from "std/fs"
import { env_var_set } from "std/env"
import { fresh_world, world_seed, world_noninteractive } from "./support/world.ab"
import { mock_install_default, mock_respond, mock_respond_rc, mock_called, mock_call_count } from "./support/mock.ab"
import { state_load, state_get } from "../src/state.ab"
import { cmd_resume } from "../src/resume.ab"

// ---- shared fixtures (ABOVE the blocks: define-before-use across imports) ----

const MA_VER = "3.2.1"
const ECR_REGISTRY = "111.dkr.ecr.us-east-1.amazonaws.com/migration-ecr-ma-us-east-1"

// fake_chart_dir — a local helm chart DIRECTORY so helm_install takes the
// --ma-chart-dir branch (Chart.yaml present) and skips the artifact/network fetch.
// (Lifted verbatim from test_helm_install_e2e.ab's proven recipe.)
fun fake_chart_dir(world: Text): Text {
    let chart = "{world}/chart"
    trust dir_create(chart)
    trust file_write("{chart}/Chart.yaml", "apiVersion: v2\nname: migration-assistant\nversion: 0.0.0\n")
    trust file_write("{chart}/values.yaml", "# base values\nfoo: bar\n")
    trust file_write("{chart}/valuesEks.yaml", "# eks values\nbaz: qux\n")
    return chart
}

// spine_world — a world wired so the FULL manual_path pipeline runs to rc 0:
//   * the four wizard inputs + stack/account/version seeded (so the non-interactive
//     wizard fast-resumes and the plan/deploy have their inputs);
//   * NOT parked at last_step=ready and the console pod check is left to fail, so
//     the ready→console fast-path does NOT engage — the real spine executes;
//   * CFN reports CREATE_COMPLETE (healthy) so cfn_deploy_or_skip takes its real
//     describe-stacks decision path and skips the 17-min create without a SKIP flag;
//   * MIRROR_IMAGES=N so crane_mirror_or_skip takes its real skip decision without
//     fetching the image manifest over the network (the genuine mirror — crane
//     login + per-image copy — is covered by test_crane.ab + test_helm_install_e2e;
//     here we exercise the spine's ORCHESTRATION, not re-test the mirror internals);
//   * helm installs from the local chart dir; kubectl wait + notes poll succeed;
//   * SKIP_CONSOLE_EXEC=Y so console_exec returns 0 without an interactive shell.
// The aws/kubectl/helm fleet defaults to exit-0/empty, so unprogrammed calls
// (kubectl create/wait, helm list/upgrade/get) just succeed.
fun spine_world(): Text {
    let w = fresh_world()
    world_noninteractive()
    // wizard inputs (MIGRATE_RESUMING lets the wizard reuse these w/o prompting)
    world_seed(w, "MIGRATE_RESUMING", "1")
    world_seed(w, "STAGE_NAME", "ma")
    world_seed(w, "AWS_REGION", "us-east-1")
    world_seed(w, "AWS_ACCOUNT", "111")
    world_seed(w, "MA_VERSION", MA_VER)
    world_seed(w, "MIRROR_IMAGES", "N")
    world_seed(w, "CFN_STACK_NAME", "MigrationAssistant-ma")
    world_seed(w, "MA_CHART_DIR", fake_chart_dir(w))
    world_seed(w, "SKIP_CONSOLE_EXEC", "Y")
    mock_install_default()
    // CFN stack already CREATE_COMPLETE → cfn_deploy_or_skip's health check skips
    // the create (real decision path, no SKIP_CFN_DEPLOY flag); the SAME
    // describe-stacks fixture carries the CFN outputs the later stages read:
    // MIGRATIONS_EKS_CLUSTER_NAME (kubeconfig setup) + MIGRATIONS_ECR_REGISTRY
    // (crane mirror + helm image flags). `--output text` rows are TAB-separated
    // OutputKey\tOutputValue; the leading CREATE_COMPLETE line answers the health
    // probe (which greps the stack status).
    mock_respond(w, "aws", "describe-stacks", "CREATE_COMPLETE\nMIGRATIONS_EKS_CLUSTER_NAME\teks-cluster-1\nMIGRATIONS_ECR_REGISTRY\t{ECR_REGISTRY}")
    // discover_aws runs `aws sts get-caller-identity --output json` and parses
    // .Account/.Arn — key the mock on get-caller-identity with the REALISTIC JSON
    // fixture (same one test_discover uses) so discovery populates a valid account.
    let sts = file_read("test/fixtures/sts_caller_identity.json") failed { "" }
    mock_respond(w, "aws", "get-caller-identity", sts)
    // notes ConfigMap poll: don't sleep.
    trust env_var_set("INSTALLER_NOTES_POLL_S", "0")
    trust env_var_set("INSTALLER_NOTES_TIMEOUT_S", "0")
    return w
}

// ---- the full happy-path spine ----------------------------------------------

test "full manual_path spine runs discover→cfn→mirror→helm→console to rc 0" {
    let w = spine_world()
    let rc = cmd_resume(["--mode", "Manual", "-y"])
    assert_eq(rc, 0)

    // Every stage left its fingerprint on the real command log, proving the spine
    // ran the WHOLE pipeline in order: discovery probed identity; CFN was consulted
    // (health decision); kubeconfig was updated for the cluster; the chart was
    // installed and the console pod waited on; identity printed at handoff.
    assert(mock_called(w, "aws", "get-caller-identity"))   // discover_aws + console handoff
    assert(mock_called(w, "aws", "describe-stacks"))       // cfn health decision
    assert(mock_called(w, "aws", "update-kubeconfig"))     // helm_kubeconfig_setup
    assert(mock_called(w, "helm", "upgrade"))              // chart install
    assert(mock_called(w, "helm", "--install"))
    assert(mock_called(w, "kubectl", "wait"))              // waited for migration-console-0
    assert(mock_called(w, "kubectl", "migration-console-0"))
    // crane mirror was SKIPPED (MIRROR_IMAGES=N) — the spine honored the decision.
    assert_eq(mock_call_count(w, "crane"), 0)

    // Terminal state: the spine advanced all the way to the console handoff.
    state_load()
    assert_eq(state_get("last_step", ""), "console_handoff")
}

// NB: the ready→console FAST-PATH is intentionally NOT re-tested here — its
// contract (skip the spine, land console_handoff) is owned by test_resume.ab's
// "cmd_resume fast-path skips the deploy spine and re-enters the console", which
// builds the same world and asserts a strict superset. THIS file's unique value
// is the full-spine run above, which nothing else exercises short of the byos
// integration test.
