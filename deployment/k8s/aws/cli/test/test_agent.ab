// test_agent.ab — e2e coverage for agent.ab (the port of bash lib/agent.sh).
//
// Style (see test/TEST_GUIDE.md): drive the REAL entrypoints — cmd_agent /
// agent_setup / discover_agents — against the faked external world, then assert
// on what the CLI DID: which agent binary it exec'd (mock_called), how state
// advanced (state_get), and what config files it wrote into the stage. The
// per-test world + mock fleet come from test/support/, so this file does NOT
// hand-roll a stub fleet / mktemp / PATH dance.
//
// How the e2e flow wires up:
//   * fresh_world() pins MIGRATE_HOME / STAGE / STAGE_DIR into a unique sandbox;
//     _agent_stage_dir() resolves to that world, so every Startup.md / .mcp.json /
//     .claude/settings.json / .codex / .kiro the agent writers emit lands there.
//   * cmd_agent's stage guard reads STAGE_NAME from the on-disk state.env →
//     world_seed(w, "STAGE_NAME", "ma") so the happy path runs (the missing-stage
//     branch die()s = exits the process, so it is NOT exercised here).
//   * The chosen agent's binary is faked onto PATH via mock_install([... "claude"]).
//     agent_exec's final `exec <bin> …` runs in a `$…$` subshell, so it replaces
//     the SUBSHELL (recording the call), not the test process — cmd_agent returns
//     and post-call asserts run.
//   * jq stays REAL (the MCP writers hard-dep it, exactly like bash) — the fleet
//     only fakes aws/kubectl/helm/<agent>/uvx, never jq.
//   * uvx is faked so aws-mcp's `requires:[uvx]` resolves without the install
//     prompt; the manifest is pointed at test/fixtures/agent_manifest.json and
//     AWS_REGION is set so the ${AWS_REGION} arg substitutes.
//
// Behaviors preserved from the prior unit-style file + the bats original:
//   * _mcp_norm_envvar (pure formatter) and _agent_bins_for / _mcp_pretty.
//   * agent_setup claude drops Startup.md + the operator skill tree into
//     .claude/skills/ (now driven through the full cmd_agent flow as well).
//   * the codex config.toml gets the [mcp_servers.<name>] section + command.
//   * region-substituted MCP args (mcp-proxy-for-aws@latest, AWS_REGION=<region>)
//     are asserted on the claude .mcp.json — the same manifest_mcp_args /
//     ${AWS_REGION} substitution path the codex writer also uses, but via the
//     robust jq --argjson encoder rather than codex's brittle TOML-array jq line.
//
// NB (AMBER_IDIOMS): NO `return` inside a test block — branch with `if`. JSON is
// brace-heavy, so canned manifests live in test/fixtures/*.json, never inline.

import { assert, assert_eq } from "std/test"
import { file_exists, file_read, file_write, dir_create } from "std/fs"
import { env_var_set, env_var_unset } from "std/env"
import { text_contains } from "std/text"
import { fresh_world, world_seed, world_noninteractive, world_stage } from "./support/world.ab"
import { mock_install, mock_install_default, mock_called, mock_call_count } from "./support/mock.ab"
import { array_contains } from "../src/std.ab"
import { state_load, state_set, state_get, state_save } from "../src/state.ab"
import {
    discover_agents, _agent_bin_for, _agent_bins_for,
    _mcp_norm_envvar, _mcp_pretty,
    _mcp_write_codex, _agent_print_install_hints_for_missing, _agent_has_session,
    mcp_install_from_manifest, agent_setup, cmd_agent
} from "../src/agent.ab"

// Pointed at by the e2e tests that need a manifest (mcpServers + branding).
const AGENT_MANIFEST = "test/fixtures/agent_manifest.json"

// ---- file-local helpers (ABOVE the test blocks: define-before-use across the
// import boundary; the test-file tree-shaker keeps only deps textually preceding
// their use). Kept thin — skill-source layout has no support-lib equivalent. ----

// seed_skills — lay down a Startup.md + skill tree the agent setup copies from,
// and point _agent_skills_src() at it (MIGRATE_SKILLS_SRC override, with an empty
// LIB_DIR so the release/dev candidates miss). Mirrors the bundle's skills/ shape:
// Startup.md at the root, per-skill <name>/SKILL.md subdirs (the auto-discovered
// tree), the operator skill's steering docs, and a kiro/ config subtree.
fun seed_skills(): Text {
    let base = trust $mktemp -d$
    let skills = "{base}/skills"
    trust dir_create(skills)
    trust file_write("{skills}/Startup.md", "# Startup runbook\nhello\n")

    trust dir_create("{skills}/migration-assistant-operator")
    trust file_write("{skills}/migration-assistant-operator/SKILL.md", "# operator skill\n")
    trust file_write("{skills}/migration-assistant-operator/workflow.md", "# workflow\n")
    trust file_write("{skills}/migration-assistant-operator/deployment.md", "# deployment\n")
    trust file_write("{skills}/migration-assistant-operator/product.md", "# product\n")

    trust dir_create("{skills}/another-skill")
    trust file_write("{skills}/another-skill/SKILL.md", "# another skill\n")

    // Upstream kiro config tree (agent_setup kiro copies skills/kiro/. into .kiro/).
    trust dir_create("{skills}/kiro/agents")
    trust file_write("{skills}/kiro/agents/opensearch.json", "agent-config\n")

    let emptylib = "{base}/emptylib"
    trust dir_create(emptylib)
    trust env_var_set("LIB_DIR", emptylib)
    trust env_var_set("MIGRATE_SKILLS_SRC", skills)
    return skills
}

// handoff_world <agent_bin> — a world ready for a cmd_agent handoff to <agent_bin>:
// a deployed stage on disk (STAGE_NAME=ma so the guard passes), the skill source +
// manifest + region wired, and the fleet faked to succeed (aws/kubectl/helm for the
// kctx + identity calls, the agent binary so the exec resolves, uvx so aws-mcp's
// requires resolves without a prompt). Returns the WORLD.
fun handoff_world(agent_bin: Text): Text {
    let w = fresh_world()
    world_noninteractive()
    world_seed(w, "STAGE_NAME", "ma")
    seed_skills()
    trust env_var_set("MIGRATE_MANIFEST", AGENT_MANIFEST)
    trust env_var_set("AWS_REGION", "us-east-1")
    mock_install(["aws", "kubectl", "helm", agent_bin, "uvx"])
    return w
}

// ---- discover_agents: probe the PATH for installed agents -------------------
//
// Host-robust: real claude/kiro may be on the developer's PATH, and exact
// count/membership of a cross-import array is flaky, so we assert that a freshly
// FAKED agent (codex — not normally installed) shows up, not an exact set.

test "discover_agents includes a freshly-installed agent on PATH" {
    let w = fresh_world()
    world_noninteractive()
    mock_install(["codex"])
    let agents = discover_agents()
    assert(array_contains("codex", agents))
}

test "agent binary resolution: present resolves to a path, absent resolves to empty" {
    let w = fresh_world()
    world_noninteractive()
    mock_install(["codex"])
    // codex is faked onto PATH → command -v resolves an absolute path.
    assert(_agent_bin_for("codex") != "")
    // a canonical name with no candidate binary anywhere → "".
    assert_eq(_agent_bin_for("no-such-agent"), "")
}

// ---- cmd_agent: the standalone handoff entrypoint ---------------------------

test "cmd_agent claude sets up skills + MCP, persists state, then execs claude" {
    let w = handoff_world("claude")
    cmd_agent(["claude"])
    // The handoff was recorded in state.
    state_load()
    assert_eq(state_get("AGENT", ""), "claude")
    assert_eq(state_get("last_step", ""), "agent_handoff")
    // The agent binary was exec'd with the fresh-handoff prompt (the manifest's
    // agentFreshPrompt: "Hello from the test manifest.").
    assert(mock_called(w, "claude", "Hello from the test manifest"))
    // Skills + project-scope config landed in the stage.
    assert(file_exists("{w}/CLAUDE.md"))
    assert(file_exists("{w}/.claude/skills/opensearch-migration/Startup.md"))
    assert(file_exists("{w}/.mcp.json"))
    assert(file_exists("{w}/.claude/settings.json"))
    env_var_unset("MIGRATE_MANIFEST")
}

test "cmd_agent claude writes a .mcp.json with the region-substituted server args" {
    let w = handoff_world("claude")
    cmd_agent(["claude"])
    // _mcp_write_claude → jq --argjson encodes the manifest server; the args carry
    // the ${AWS_REGION}-substituted endpoint metadata (the manifest_mcp_args path).
    let body = file_read("{w}/.mcp.json") failed { "" }
    assert(text_contains(body, "mcpServers"))
    assert(text_contains(body, "aws-mcp"))
    assert(text_contains(body, "uvx"))
    assert(text_contains(body, "mcp-proxy-for-aws@latest"))
    assert(text_contains(body, "AWS_REGION=us-east-1"))
    env_var_unset("MIGRATE_MANIFEST")
}

test "cmd_agent claude writes settings.json with the CLI allowlist + manifest perms" {
    let w = handoff_world("claude")
    cmd_agent(["claude"])
    // _agent_write_claude_settings merges the CLI read-only allowlist with the
    // manifest's permissionsAllow (deduped) into the canonical settings.json.
    let body = file_read("{w}/.claude/settings.json") failed { "" }
    assert(text_contains(body, "permissions"))
    assert(text_contains(body, "aws eks list-clusters"))                 // CLI allowlist
    assert(text_contains(body, "mcp__aws-mcp__aws___read_documentation")) // manifest perm
    env_var_unset("MIGRATE_MANIFEST")
}

test "cmd_agent kiro builds the .kiro tree + settings/mcp.json, then execs kiro-cli" {
    // kiro's installed binary is `kiro-cli` (one of its candidate bins).
    let w = handoff_world("kiro-cli")
    cmd_agent(["kiro"])
    state_load()
    assert_eq(state_get("AGENT", ""), "kiro")
    // The .kiro config tree: Startup as the first steering doc + the upstream tree.
    assert(file_exists("{w}/.kiro/steering/00-Startup.md"))
    assert(file_exists("{w}/.kiro/agents/opensearch.json"))
    // MCP registered project-scope under .kiro/settings/mcp.json.
    assert(file_exists("{w}/.kiro/settings/mcp.json"))
    let body = file_read("{w}/.kiro/settings/mcp.json") failed { "" }
    assert(text_contains(body, "aws-mcp"))
    // The kiro-cli binary was exec'd (resolved from its candidate list).
    assert(mock_called(w, "kiro-cli", "chat"))
    env_var_unset("MIGRATE_MANIFEST")
}

test "cmd_agent picks the saved AGENT from state when no name is passed" {
    let w = handoff_world("claude")
    world_seed(w, "AGENT", "claude")
    // No agent name on the argv → cmd_agent reads AGENT from state and hands off.
    cmd_agent([""])
    assert(mock_called(w, "claude", "Hello from the test manifest"))
    state_load()
    assert_eq(state_get("last_step", ""), "agent_handoff")
    env_var_unset("MIGRATE_MANIFEST")
}

test "cmd_agent --stage repoints to the named stage's state and hands off" {
    let w = handoff_world("claude")
    // --stage <world's stage> → STAGE/STAGE_DIR point at the seeded stage so the
    // STAGE_NAME guard passes and the handoff runs against it.
    cmd_agent(["claude", "--stage", world_stage()])
    assert(mock_called(w, "claude", "Hello from the test manifest"))
    assert(file_exists("{w}/.mcp.json"))
    env_var_unset("MIGRATE_MANIFEST")
}

// ---- agent_setup: skills + config without the handoff -----------------------

test "agent_setup claude drops Startup.md + the operator skill tree into .claude/skills" {
    let w = fresh_world()
    world_noninteractive()
    seed_skills()
    // Skip MCP so this stays a pure skills-layout check (no uvx / jq needed).
    trust env_var_set("MIGRATE_SKIP_MCP", "1")
    agent_setup("claude")
    // Startup runbook at the stage root under all three auto-load names.
    assert(file_exists("{w}/Startup.md"))
    assert(file_exists("{w}/CLAUDE.md"))
    assert(file_exists("{w}/AGENTS.md"))
    // Claude's auto-loadable skill + the auto-discovered tree.
    assert(file_exists("{w}/.claude/skills/opensearch-migration/Startup.md"))
    assert(file_exists("{w}/skills/migration-assistant-operator/SKILL.md"))
    assert(file_exists("{w}/skills/another-skill/SKILL.md"))
    env_var_unset("MIGRATE_SKIP_MCP")
}

test "agent_setup codex drops AGENTS.md at the root + a copy in .codex" {
    let w = fresh_world()
    world_noninteractive()
    seed_skills()
    trust env_var_set("MIGRATE_SKIP_MCP", "1")
    agent_setup("codex")
    assert(file_exists("{w}/AGENTS.md"))
    assert(file_exists("{w}/.codex/Startup.md"))
    env_var_unset("MIGRATE_SKIP_MCP")
}

// ---- MCP registration -------------------------------------------------------

test "codex MCP registration writes the [mcp_servers.<name>] section + command" {
    let w = fresh_world()
    world_noninteractive()
    trust env_var_set("MIGRATE_MANIFEST", AGENT_MANIFEST)
    trust env_var_set("AWS_REGION", "ca-central-1")
    _mcp_write_codex("aws-mcp")
    // The section header + command line are plain-text file_append (jq-independent).
    // The region-substituted args content is covered on the claude .mcp.json above.
    let body = file_read("{w}/.codex/config.toml") failed { "" }
    assert(text_contains(body, "[mcp_servers.aws-mcp]"))
    assert(text_contains(body, "command = \"uvx\""))
    env_var_unset("MIGRATE_MANIFEST")
}

test "mcp_install_from_manifest is a no-op when MIGRATE_SKIP_MCP=1" {
    let w = fresh_world()
    world_noninteractive()
    trust env_var_set("MIGRATE_MANIFEST", AGENT_MANIFEST)
    trust env_var_set("MIGRATE_SKIP_MCP", "1")
    mcp_install_from_manifest("claude")
    // No project-scope config written when MCP registration is skipped wholesale.
    assert(not file_exists("{w}/.mcp.json"))
    env_var_unset("MIGRATE_SKIP_MCP")
    env_var_unset("MIGRATE_MANIFEST")
}

test "mcp_install_from_manifest honors a per-MCP skip var (MIGRATE_SKIP_MCP_<NAME>)" {
    let w = fresh_world()
    world_noninteractive()
    trust env_var_set("MIGRATE_MANIFEST", AGENT_MANIFEST)
    trust env_var_set("AWS_REGION", "us-east-1")
    // Skip just aws-mcp (normalized to AWS_MCP) → nothing registered for codex,
    // and (crucially) uvx is never required, so no install prompt is reached.
    trust env_var_set("MIGRATE_SKIP_MCP_AWS_MCP", "1")
    mcp_install_from_manifest("codex")
    assert(not file_exists("{w}/.codex/config.toml"))
    env_var_unset("MIGRATE_SKIP_MCP_AWS_MCP")
    env_var_unset("MIGRATE_MANIFEST")
}

// ---- pure / near-pure units -------------------------------------------------

test "_mcp_norm_envvar uppercases and maps non-alpha to underscore" {
    assert_eq(_mcp_norm_envvar("aws-mcp"), "AWS_MCP")
    assert_eq(_mcp_norm_envvar("my.org/secrets"), "MY_ORG_SECRETS")
}

test "_agent_bins_for lists a canonical name's candidate binaries" {
    // kiro probes kiro-cli first, then kiro (comma-joined for diagnostics).
    assert_eq(_agent_bins_for("kiro"), "kiro-cli,kiro")
    assert_eq(_agent_bins_for("claude"), "claude")
}

test "_mcp_pretty abbreviates a path under HOME to ~/…" {
    trust env_var_set("HOME", "/home/op")
    assert_eq(_mcp_pretty("/home/op/.mcp.json"), "~/.mcp.json")
    // A path outside HOME is returned verbatim.
    assert_eq(_mcp_pretty("/etc/hosts"), "/etc/hosts")
}

test "install hints for missing agents run without error" {
    let w = fresh_world()
    world_noninteractive()
    // claude already installed → only codex + kiro hints are surfaced (to stderr);
    // this exercises the missing-set computation + dispatch (returns Null).
    _agent_print_install_hints_for_missing(["claude"])
    assert(true)
}

test "_agent_has_session is optimistically true for non-claude agents" {
    let w = fresh_world()
    world_noninteractive()
    // Only claude has an inspectable per-cwd session dir; every other agent
    // returns true (its resume is harmless on no history).
    assert(_agent_has_session("codex"))
    assert(_agent_has_session("kiro"))
}
