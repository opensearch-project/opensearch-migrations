// test_discover.ab — e2e-focused coverage for discover.ab (read-only AWS + OS
// discovery).
//
// Style (see test/TEST_GUIDE.md): drive the real discover_* entrypoints against
// the faked external world and assert on what the CLI DID — which aws sub-commands
// it issued (mock_called) and what facts it published — rather than poking
// internals. The mock fleet + per-test world come from test/support/.
//
// discover.ab does NOT round-trip through the on-disk state.env: it publishes its
// findings into a module-local parallel-array store (disc_state_*). So these tests
// assert via disc_state_get after driving the real fn, and reset that store at the
// top of each block (module `let` resets per block, but the store is the module's,
// not the test's). The AWS region is read from the AWS_REGION env var, set per
// block (never relied upon to leak from another block).
//
// Coverage:
//   * discover_aws — happy path (parses sts → account/arn/region), aws-missing
//     (return 1), and bad-credentials (aws exits non-zero → return 1).
//   * discover_resources — issues the read-only eks/cfn list calls and stores the
//     tab→space-normalized results; skips cleanly when no region is known.
//   * discover_os — classifies the host OS and always sets a known PKG_MGR
//     (environment-dependent → kept light).
//   * disc_state_* — the pure parallel-array store (round-trip + update-in-place).

import { assert, assert_eq } from "std/test"
import { file_read } from "std/fs"
import { env_var_set } from "std/env"
import { fresh_world } from "./support/world.ab"
import {
    mock_install_default, mock_respond, mock_respond_rc,
    mock_called, mock_call_count
} from "./support/mock.ab"
import {
    discover_os, discover_aws, discover_resources,
    disc_state_set, disc_state_get, disc_state_has, disc_state_reset
} from "../src/discover.ab"

// ---- helpers (ABOVE the tests: Amber define-before-use across imports) -------

// aws_world — a world with the mock fleet installed, AWS_REGION pinned, and the
// disc_state store reset. The shape behind the discover_aws / discover_resources
// e2e tests. The caller programs the aws responses it cares about.
fun aws_world(region: Text): Text {
    let w = fresh_world()
    mock_install_default()
    trust env_var_set("AWS_REGION", region)
    disc_state_reset()
    return w
}

// empty_path_world — a world whose PATH points only at an empty dir, so `aws` is
// not resolvable anywhere (the "aws CLI not installed" scenario). No mock fleet.
fun empty_path_world(): Text {
    let w = fresh_world()
    let empty = trust $mktemp -d$
    trust env_var_set("PATH", empty)
    disc_state_reset()
    return w
}

// host_os — the OS this test is running on, computed independently of the module
// under test, so the discover_os assertion is a real cross-check.
fun host_os(): Text {
    let k = trust $uname -s 2>/dev/null$
    if k == "Darwin" { return "darwin" }
    if k == "Linux" { return "linux" }
    return "other"
}

// ---- discover_aws: identity discovery via sts get-caller-identity ----------

test "discover_aws parses the sts caller identity and publishes account/arn/region" {
    let w = aws_world("us-east-1")
    // Program `aws sts get-caller-identity` to return a real (flat) sts payload.
    // Loaded from an on-disk fixture so the JSON braces aren't interpolated.
    let sts = trust file_read("test/fixtures/sts_caller_identity.json")
    mock_respond(w, "aws", "get-caller-identity", sts)

    let rc = discover_aws()
    assert_eq(rc, 0)
    // It issued the read-only identity call ...
    assert(mock_called(w, "aws", "get-caller-identity"))
    // ... and published the parsed facts (stronger than the old bats $status-only).
    assert_eq(disc_state_get("AWS_ACCOUNT"), "123456789012")
    assert_eq(disc_state_get("AWS_USER_ARN"), "arn:aws:iam::123456789012:user/alice")
    assert_eq(disc_state_get("AWS_REGION"), "us-east-1")
}

test "discover_aws returns 1 and publishes nothing when the aws CLI is absent" {
    let w = empty_path_world()
    let rc = discover_aws()
    assert(rc != 0)
    // Nothing was discovered — the early no-CLI guard fired before any sts call.
    assert(not disc_state_has("AWS_ACCOUNT"))
}

test "discover_aws returns 1 when credentials are not configured" {
    let w = aws_world("us-east-1")
    // aws is on PATH but `sts get-caller-identity` exits non-zero (no/bad creds).
    mock_respond(w, "aws", "get-caller-identity", "")
    mock_respond_rc(w, "aws", "get-caller-identity", "255")

    let rc = discover_aws()
    assert(rc != 0)
    // It did try the identity call, then bailed without publishing an account.
    assert(mock_called(w, "aws", "get-caller-identity"))
    assert(not disc_state_has("AWS_ACCOUNT"))
}

// ---- discover_resources: read-only EKS + MA-CFN inventory ------------------

test "discover_resources lists eks clusters + MA stacks and stores them tab-normalized" {
    let w = aws_world("us-west-2")
    // discover_resources reads the region from the disc_state store (not env), so
    // seed it the way discover_aws would have.
    disc_state_set("AWS_REGION", "us-west-2")
    // `aws --output text` separates list items with TABs; both list calls answer
    // with two tab-separated names so we can assert the tab→space normalization.
    mock_respond(w, "aws", "list-clusters", "alpha\tbeta")
    mock_respond(w, "aws", "list-stacks", "MigrationAssistant-ma\tMigrationAssistant-qa")

    let rc = discover_resources()
    assert_eq(rc, 0)
    // It issued both read-only list calls against the discovered region.
    assert(mock_called(w, "aws", "list-clusters"))
    assert(mock_called(w, "aws", "list-stacks"))
    assert(mock_called(w, "aws", "us-west-2"))
    // ... and stored the tab→space-normalized results.
    assert_eq(disc_state_get("EKS_CLUSTERS"), "alpha beta")
    assert_eq(disc_state_get("CFN_MA_STACKS"), "MigrationAssistant-ma MigrationAssistant-qa")
}

test "discover_resources skips (returns 0) and issues no aws calls when no region is known" {
    let w = aws_world("")
    // No AWS_REGION in the disc_state store → the region guard short-circuits.
    let rc = discover_resources()
    assert_eq(rc, 0)
    assert(not disc_state_has("EKS_CLUSTERS"))
    // Skipped before any list call.
    assert_eq(mock_call_count(w, "aws"), 0)
}

// ---- discover_os: host classification (environment-dependent → light) ------

test "discover_os classifies the host OS and always sets a known package manager" {
    let w = fresh_world()
    disc_state_reset()
    let rc = discover_os()
    assert_eq(rc, 0)
    let os = disc_state_get("OS_NAME")
    let host = host_os()
    if {
        host == "darwin" { assert_eq(os, "darwin") }
        // On Linux the host may be plain linux or WSL — both acceptable.
        host == "linux" { assert(os == "linux" or os == "wsl") }
        else { assert(false) }
    }
    // PKG_MGR is always set to one of the known values (never empty).
    let pm = disc_state_get("PKG_MGR")
    assert(pm == "brew" or pm == "apt" or pm == "dnf" or pm == "yum" or pm == "none")
}

// ---- unit: the parallel-array state store (pure) ---------------------------

test "disc_state set/get/has round-trips and updates a key in place" {
    disc_state_reset()
    assert(not disc_state_has("K"))
    disc_state_set("K", "v1")
    assert(disc_state_has("K"))
    assert_eq(disc_state_get("K"), "v1")
    // update must not break lookup (overwrite, not duplicate)
    disc_state_set("K", "v2")
    assert_eq(disc_state_get("K"), "v2")
    // unknown key → ""
    assert_eq(disc_state_get("NOPE"), "")
}
