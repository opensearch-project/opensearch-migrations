// test_cfn_deploy_params.ab — pure param-building units for cfn_deploy.ab (the
// DEPLOY half of the bash cfn.sh port).
//
// This is one of two parts split out of the original test_cfn_deploy.ab (which
// compiled to ~176KB and tripped Linux's 128KB MAX_ARG_STRLEN cap on the
// `eval "<compiled script>"` amber uses per test). This part holds the pure
// param-building / route-table units; the cfn_deploy_or_skip decision + spine
// blocks live in test_cfn_deploy_decision.ab.
//
// Reference style (see test/TEST_GUIDE.md): the mock fleet + per-test world come
// from test/support/. Each test mints its OWN fresh_world() and never depends on
// another block.
//
// What's covered here:
//   * _cfn_import_vpc_endpoint_params — kept as a direct unit (pure param
//     building): the eval-array-append the bash version did is now a returned
//     [Text]; assert the Create*Endpoint=true list per requested endpoint, plus
//     the s3 gateway's resolved route-table ids.
//   * _cfn_subnet_route_table_ids — direct unit for the S3-gateway route-table
//     resolution (per-subnet lookup, None→main fallback, dedup, comma-join).
//
// DEPLOY-PATH NOTE — these units run against an import-vpc world (deploy_world):
// region + VPC/subnet inputs seeded, the aws + curl fleet faked to succeed, the
// template cache pre-seeded. cfn_deploy.ab's CFN_TEMPLATE_CREATE_VPC `const` is
// dropped by Amber 0.6's per-symbol tree-shaker across the import boundary
// (AMBER_IDIOMS gotcha 2), while IMPORT_VPC survives — so the helpers + their
// world stay on the import-vpc variant.
//
// NB (AMBER_IDIOMS): no `return` inside a `test` block — branch with `if`.
// Helpers live ABOVE the tests (define-before-use across the import boundary).

import { assert, assert_eq } from "std/test"
import { dir_create, file_write } from "std/fs"
import { is_command } from "std/env"
import { split_words } from "std/text"
import { fresh_world, world_seed, world_noninteractive } from "./support/world.ab"
import { mock_install, mock_respond } from "./support/mock.ab"
import { array_contains } from "../src/std.ab"
import {
    _cfn_subnet_route_table_ids, _cfn_import_vpc_endpoint_params
} from "../src/cfn_deploy.ab"

// The MA artifact version the deploy tests seed + the import-vpc template name
// (the variant whose const survives import; see the DEPLOY-PATH NOTE). The cache
// pre-seed keys on the URL artifacts_fetch builds: <base>/<version>/<name>.
const MA_VER = "3.2.1"
const CFN_TEMPLATE_IMPORT_VPC = "Migration-Assistant-Infra-Import-VPC-eks.template.json"
const ART_BASE = "https://github.com/opensearch-project/opensearch-migrations/releases/download"

// sha256_url — the cache key artifacts.ab derives for a resolved URL: hex sha256
// of the URL string, first whitespace field of the hasher output. Reproduces
// artifacts.ab's sha256_of_string (sha256sum on Linux, shasum -a 256 on macOS).
fun sha256_url(url: Text): Text {
    let raw = ""
    if is_command("sha256sum") {
        raw = trust $printf '%s' "{url}" | sha256sum$
    } else {
        raw = trust $printf '%s' "{url}" | shasum -a 256$
    }
    let words = split_words(raw)
    if len words == 0 { return "" }
    return words[0]
}

// seed_template_cache — pre-create an artifact cache HIT for the import-vpc
// template inside the world's stage dir, so artifacts_fetch returns its cached
// symlink immediately (payload + .verified marker present) without any network.
// artifacts_fetch resolves the GitHub release URL first (the default curl probe
// succeeds), so we cache under THAT url's key; both files are required for a hit.
fun seed_template_cache(world: Text): Null {
    let url = "{ART_BASE}/{MA_VER}/{CFN_TEMPLATE_IMPORT_VPC}"
    let key = sha256_url(url)
    let cache_dir = "{world}/artifacts/.cache/{key}"
    trust dir_create(cache_dir)
    trust dir_create("{world}/artifacts")
    trust file_write("{cache_dir}/{CFN_TEMPLATE_IMPORT_VPC}", "\{\}")
    trust file_write("{cache_dir}/.verified", "")
}

// deploy_world — a world ready to drive the import-vpc variant: region +
// VPC/subnet inputs seeded, the aws + curl fleet faked to succeed, the template
// cache pre-seeded. describe-stacks defaults to DOES_NOT_EXIST; the background
// deploy + the event poller both exit 0 with empty stdout by default.
fun deploy_world(): Text {
    let w = fresh_world()
    world_noninteractive()
    world_seed(w, "STAGE_NAME", "ma")
    world_seed(w, "AWS_REGION", "us-east-1")
    world_seed(w, "MA_VERSION", MA_VER)
    world_seed(w, "CFN_TEMPLATE_VARIANT", "import-vpc")
    world_seed(w, "IMPORT_VPC_ID", "vpc-1")
    world_seed(w, "IMPORT_SUBNET_IDS", "subnet-a")
    // curl is faked too: artifacts_fetch probes the release URL with `curl -fsSIL`
    // (default mock exits 0 → reachable) and resolves to the URL we pre-seeded the
    // cache under; the cache hit short-circuits BEFORE the GET / .sha256 download.
    mock_install(["aws", "curl"])
    seed_template_cache(w)
    mock_respond(w, "aws", "describe-stacks", "DOES_NOT_EXIST")
    return w
}

// ---- _cfn_import_vpc_endpoint_params (pure param building) ----------------

test "import-vpc endpoint params map each named endpoint to Create*Endpoint=true" {
    let w = deploy_world()
    let extras = _cfn_import_vpc_endpoint_params("vpc-1", "subnet-a", "us-east-1", "ecr,ecrDocker,cloudwatchLogs,efs,sts,eksAuth")
    assert(array_contains("CreateECREndpoint=true", extras))
    assert(array_contains("CreateECRDockerEndpoint=true", extras))
    assert(array_contains("CreateCloudWatchLogsEndpoint=true", extras))
    assert(array_contains("CreateEFSEndpoint=true", extras))
    assert(array_contains("CreateSTSEndpoint=true", extras))
    assert(array_contains("CreateEKSAuthEndpoint=true", extras))
    // No s3 requested → no gateway/route-table params.
    assert(not array_contains("CreateS3Endpoint=true", extras))
}

test "import-vpc endpoint params return [] when nothing is requested" {
    let w = deploy_world()
    let extras = _cfn_import_vpc_endpoint_params("vpc-1", "subnet-a", "us-east-1", "")
    // Bind `len` to a local first: in 0.6 a `len arr` passed DIRECTLY as a call
    // arg mis-resolves the array length var in a test block ("bad array subscript").
    let n = len extras
    assert_eq(n, 0)
}

test "import-vpc endpoint params ignore unknown entries, keep the known ones" {
    let w = deploy_world()
    let extras = _cfn_import_vpc_endpoint_params("vpc-1", "subnet-a", "us-east-1", "bogus,ecr")
    assert(array_contains("CreateECREndpoint=true", extras))
    let n = len extras
    assert_eq(n, 1)
}

test "import-vpc s3 endpoint adds the gateway + resolved route-table ids" {
    let w = deploy_world()
    // s3 is a Gateway endpoint → it resolves route-table ids per subnet. The mock
    // matches whole arg tokens, and the subnet id rides inside the --filters value
    // `Name=association.subnet-id,Values=<id>` (one shell arg), so key on the full
    // filter token, not the bare id.
    mock_respond(w, "aws", "Name=association.subnet-id,Values=subnet-a", "rtb-aaa")
    mock_respond(w, "aws", "Name=association.subnet-id,Values=subnet-b", "rtb-bbb")
    let extras = _cfn_import_vpc_endpoint_params("vpc-1", "subnet-a,subnet-b", "us-east-1", "s3")
    assert(array_contains("CreateS3Endpoint=true", extras))
    assert(array_contains("S3EndpointRouteTableIds=rtb-aaa,rtb-bbb", extras))
}

// ---- _cfn_subnet_route_table_ids (pure resolution) ------------------------

test "subnet route-table ids are resolved, de-duped, and comma-joined" {
    let w = deploy_world()
    mock_respond(w, "aws", "Name=association.subnet-id,Values=subnet-a", "rtb-aaa")
    mock_respond(w, "aws", "Name=association.subnet-id,Values=subnet-b", "rtb-bbb")
    let rt = _cfn_subnet_route_table_ids("vpc-1", "subnet-a,subnet-b", "us-east-1")
    assert_eq(rt, "rtb-aaa,rtb-bbb")
}

test "subnet route-table ids de-dupe repeated entries" {
    let w = deploy_world()
    // Both subnets resolve to the same route table → one entry after dedup.
    mock_respond(w, "aws", "Name=association.subnet-id,Values=subnet-a", "rtb-aaa")
    mock_respond(w, "aws", "Name=association.subnet-id,Values=subnet-dup", "rtb-aaa")
    let rt = _cfn_subnet_route_table_ids("vpc-1", "subnet-a,subnet-dup", "us-east-1")
    assert_eq(rt, "rtb-aaa")
}

test "subnet route-table ids fall back to the VPC main route table" {
    let w = deploy_world()
    // subnet-none has no explicit association → its per-subnet lookup yields None,
    // so the helper falls back to the VPC main route table (the second filter set,
    // keyed on its association.main token).
    mock_respond(w, "aws", "Name=association.subnet-id,Values=subnet-none", "None")
    mock_respond(w, "aws", "Name=association.main,Values=true", "rtb-main")
    let rt = _cfn_subnet_route_table_ids("vpc-1", "subnet-none", "us-east-1")
    assert_eq(rt, "rtb-main")
}
