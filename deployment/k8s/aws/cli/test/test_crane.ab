// test_crane.ab — e2e-focused coverage for src/crane.ab (image mirroring).
//
// crane.ab mirrors images from public registries into a private ECR with retry +
// fatal-error classification. We drive the REAL crane.ab functions against the
// shared mock fleet (test/support/mock.ab) — every `crane`/`aws` invocation hits
// a recording shim — and assert on what the CLI DID: which commands it issued
// (mock_called / mock_call_count) and what it returned. Per-test isolation +
// env-pinning come from test/support/world.ab (no hand-rolled mktemp/PATH/stub).
//
// SEAM NOTE (why not crane_mirror_or_skip directly). In Amber 0.6 each importer
// gets its OWN copy of an imported module's globals, so the state.ab store this
// test could seed is a DIFFERENT instance from the one crane.ab reads — and,
// unlike cmd_cleanup, crane_mirror_or_skip never calls state_load() at entry, so
// there is no on-disk channel to reconcile through. The established peer-module
// pattern (test_build.ab / test_cfn_deploy.ab) therefore drives the ARG-DRIVEN
// flow functions that crane_mirror_or_skip composes — they take the
// state-derived registry/version/region as PARAMETERS, so the same external
// behavior is exercised end-to-end against the mock fleet:
//   * _crane_copy_retry        — the per-image copy + retry/backoff + fatal-class
//                                bail loop (what crane_mirror_or_skip calls once
//                                per image).
//   * _crane_mirror_ma_images  — the 4-image MA-team copy loop (parallel-array
//                                src/dst PAIRS → disambiguating tags).
//   * _ecr_login               — the aws ecr get-login-password → crane auth
//                                login authentication step.
//
// What's covered (behaviors, not internals):
//   * _crane_copy_retry: a clean copy issues exactly one `crane copy` and returns
//     0; a fatal NAME_UNKNOWN bails after a SINGLE call (no retry); a persistent
//     transient failure retries up to CRANE_RETRY_ATTEMPTS times then gives up.
//   * _crane_mirror_ma_images: issues one `crane copy` per MA image (4) under the
//     disambiguating-tag scheme and succeeds when every copy does; returns 1 when
//     copies fail.
//   * _ecr_login: authenticates via aws + crane (issues get-login-password +
//     crane auth login) → 0; fails fast (→ 1) when crane is not on PATH.
//   * URL builders _dst_for / _ecr_repo_for + the manifest parser
//     _crane_load_manifest stay PURE unit asserts (no world/mock needed).
//
// CRANE_RETRY_ATTEMPTS + CRANE_RETRY_INITIAL_S=0 keep the retry loop instant
// (0s sleeps doubling stay 0). NO `return` inside a test block — branch with if.

import { assert, assert_eq } from "std/test"
import { env_var_set } from "std/env"
import { dir_create, file_write } from "std/fs"
import { text_contains } from "std/text"
import { fresh_world } from "./support/world.ab"
import {
    mock_install, mock_respond, mock_fail,
    mock_called, mock_call_count, mock_calls
} from "./support/mock.ab"
import {
    _dst_for, _ecr_repo_for, _crane_load_manifest,
    _crane_copy_retry, _ecr_login, _crane_mirror_ma_images
} from "../src/crane.ab"

// ---- file-local helpers (ABOVE the test blocks: Amber tree-shakes per imported
// symbol + keeps only deps textually preceding their use across the import
// boundary, so helpers used by `test` blocks must come first) -----------------

// mirror_world — a fresh sandbox with the crane + aws shims installed and the
// retry knobs pinned fast (<attempts> tries, 0s initial sleep). The shape behind
// every mirror test: callers then program the per-tool responses they want.
fun mirror_world(attempts: Text): Text {
    let w = fresh_world()
    mock_install(["crane", "aws"])
    trust env_var_set("CRANE_RETRY_ATTEMPTS", attempts)
    trust env_var_set("CRANE_RETRY_INITIAL_S", "0")
    return w
}

// write_manifest <cli_root> — drop a vendored skills/privateEcrManifest.sh whose
// IMAGES var holds two real entries, a blank line, and a comment line (which must
// be dropped). A `{` in an Amber Text is interpolation, so the bash body is
// brace-free and written via file_write (no $...$ braces involved).
fun write_manifest(cli_root: Text): Null {
    trust dir_create("{cli_root}/skills")
    let body = "#!/usr/bin/env bash
IMAGES=\"
quay.io/jetstack/cert-manager-controller:v1.17.2
public.ecr.aws/strimzi/kafka:0.50.1
# a comment that must be skipped

\"
"
    trust file_write("{cli_root}/skills/privateEcrManifest.sh", body)
}

// ---- _crane_copy_retry: the per-image copy + retry/classify loop ------------

test "crane copy issues a single copy and returns 0 on a clean mirror" {
    let w = mirror_world("5")
    mock_respond(w, "crane", "copy", "")
    assert_eq(_crane_copy_retry("quay.io/strimzi/kafka:0.50.1", "ecr/mirrored/quay.io/strimzi/kafka:0.50.1"), 0)
    // Exactly one copy — a clean copy must NOT spin the retry loop.
    assert_eq(mock_call_count(w, "crane"), 1)
    assert(mock_called(w, "crane", "copy"))
}

test "crane copy bails immediately on a fatal NAME_UNKNOWN without retrying" {
    let w = mirror_world("5")
    // NAME_UNKNOWN is the unrecoverable-class token: the loop must short-circuit
    // on attempt 1 even though 5 attempts are allowed (retrying changes nothing).
    mock_fail(w, "crane", "copy", "1", "NAME_UNKNOWN: repository does not exist")
    let rc = _crane_copy_retry("src:tag", "dst:tag")
    assert(rc != 0)
    // The bail-early class means EXACTLY one call — no backoff, no retries.
    assert_eq(mock_call_count(w, "crane"), 1)
}

test "crane copy retries a transient failure up to the configured attempts" {
    let w = mirror_world("3")
    // A non-fatal ("transient") failure is retried: the loop runs the full
    // attempt budget (3), backing off between each, then gives up non-zero.
    mock_fail(w, "crane", "copy", "1", "transient network error")
    let rc = _crane_copy_retry("src:tag", "dst:tag")
    assert(rc != 0)
    assert_eq(mock_call_count(w, "crane"), 3)
}

// ---- _crane_mirror_ma_images: the 4-image MA-team copy loop -----------------

test "ma-image mirror issues a copy per MA image under disambiguating tags" {
    let w = mirror_world("3")
    mock_respond(w, "crane", "copy", "")
    let rc = _crane_mirror_ma_images("111.dkr.ecr.us-east-1.amazonaws.com/migration-ecr", "3.2.1", "us-east-1")
    assert_eq(rc, 0)
    // One crane copy per MA-team image: capture_proxy / traffic_replayer /
    // reindex_from_snapshot / migration_console.
    assert_eq(mock_call_count(w, "crane"), 4)
    // Sources are the public.ecr.aws MA repos at the requested version…
    let calls = mock_calls(w, "crane")
    assert(text_contains(calls, "public.ecr.aws/opensearchproject/opensearch-migrations-traffic-capture-proxy:3.2.1"))
    assert(text_contains(calls, "public.ecr.aws/opensearchproject/opensearch-migrations-console:3.2.1"))
    // …and the destinations carry the build-name-disambiguating tags.
    assert(text_contains(calls, "111.dkr.ecr.us-east-1.amazonaws.com/migration-ecr:migrations_capture_proxy_3.2.1"))
    assert(text_contains(calls, "111.dkr.ecr.us-east-1.amazonaws.com/migration-ecr:migrations_migration_console_3.2.1"))
}

test "ma-image mirror returns 1 when the copies fail" {
    let w = mirror_world("2")
    mock_fail(w, "crane", "copy", "1", "transient network error")
    let rc = _crane_mirror_ma_images("111.dkr.ecr.us-east-1.amazonaws.com/migration-ecr", "3.2.1", "us-east-1")
    assert_eq(rc, 1)
}

// ---- _ecr_login: authenticate crane against the private ECR -----------------

test "ecr login fetches a token via aws then logs crane in" {
    let w = fresh_world()
    mock_install(["crane", "aws"])
    // aws ecr (and ecr-public) get-login-password must emit a NON-empty token —
    // _ecr_login treats an empty password as a failure.
    mock_respond(w, "aws", "get-login-password", "fake-ecr-token")
    let rc = _ecr_login("111.dkr.ecr.us-east-1.amazonaws.com/migration-ecr", "us-east-1")
    assert_eq(rc, 0)
    // It pulled the registry password and then logged crane in.
    assert(mock_called(w, "aws", "get-login-password"))
    assert(mock_called(w, "crane", "login"))
}

test "ecr login fails fast when crane is not on PATH" {
    let w = fresh_world()
    // Only aws is faked — crane resolves to nothing → is_command("crane") false.
    mock_install(["aws"])
    let rc = _ecr_login("111.dkr.ecr.us-east-1.amazonaws.com/migration-ecr", "us-east-1")
    assert_eq(rc, 1)
}

// ---- pure units: URL builders + manifest parser (no world/mock) -------------

test "_dst_for prepends mirrored/ under the ecr host" {
    assert_eq(
        _dst_for("quay.io/strimzi/kafka:0.50.1-kafka-4.0.0", "111.dkr.ecr.us-east-1.amazonaws.com"),
        "111.dkr.ecr.us-east-1.amazonaws.com/mirrored/quay.io/strimzi/kafka:0.50.1-kafka-4.0.0")
}

test "_ecr_repo_for strips the tag and prepends mirrored/" {
    assert_eq(
        _ecr_repo_for("quay.io/strimzi/kafka:0.50.1-kafka-4.0.0"),
        "mirrored/quay.io/strimzi/kafka")
}

test "_ecr_repo_for tolerates an untagged image" {
    // No ':' → the bash `${src%:*}` is a no-op; we keep the whole ref.
    assert_eq(
        _ecr_repo_for("public.ecr.aws/foo/bar"),
        "mirrored/public.ecr.aws/foo/bar")
}

test "_crane_load_manifest reads the vendored manifest, dropping blanks + comments" {
    let root = trust $mktemp -d$
    write_manifest(root)
    trust env_var_set("CLI_ROOT", root)

    let out = _crane_load_manifest("3.2.1")
    // The two real images survive…
    assert(text_contains(out, "quay.io/jetstack/cert-manager-controller:v1.17.2"))
    assert(text_contains(out, "public.ecr.aws/strimzi/kafka:0.50.1"))
    // …and the comment line does NOT.
    assert(not text_contains(out, "a comment"))
    assert(not text_contains(out, "#"))
}
