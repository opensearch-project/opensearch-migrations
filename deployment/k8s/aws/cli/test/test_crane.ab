// test_crane.ab — coverage for src/crane.ab, mirroring test_crane.bats.
//
// crane.sh mirrors images to a private ECR with retry + error classification.
// The external commands are crane / aws (and, for manifest resolution, an
// on-disk privateEcrManifest.sh). We stub crane / aws via a PATH-shadow temp
// dir — write an executable shim with file_write + file_chmod, then prepend the
// dir to PATH (env_var_set). The shims' behavior is steered per-test by env
// vars (CRANE_STUB_MODE, AWS_STUB_*) so one byte-identical content is installed
// each call (amber test runs every block in one shared process+PATH — separate
// rewrites of the same shim path would race; see test_cfn_outputs.ab's note).
//
// What's covered:
//   * _dst_for / _ecr_repo_for — pure string transforms (no stub needed).
//   * _crane_load_manifest — reads a vendored privateEcrManifest.sh; we point
//     CLI_ROOT at a temp dir holding skills/privateEcrManifest.sh and assert the
//     image list is parsed (blanks/comments dropped, field 1 kept).
//   * _crane_copy_retry — crane stub steered by CRANE_STUB_MODE: ok / fatal
//     (NAME_UNKNOWN bails with no retry) / flaky (fail then succeed) / always
//     (exhaust attempts). CRANE_RETRY_ATTEMPTS + CRANE_RETRY_INITIAL_S keep it
//     fast (initial 0s sleeps).
//   * _ecr_login — crane-not-on-PATH → 1; full happy path with crane+aws stubs → 0.
//   * _crane_mirror_ma_images — the parallel-array (src,dst) PAIRS produce the
//     disambiguating tags; all-success → 0.
//
// No network, no real cloud: every crane/aws invocation hits a stub. STAGE_DIR
// is pinned to a temp dir per test (so crane.log writes land somewhere real).
// NO `return` inside test blocks (wrap in if) per the porting rules.

import { assert, assert_eq } from "std/test"
import { file_write, file_chmod, dir_create } from "std/fs"
import { env_var_set, env_var_get } from "std/env"
import { text_contains } from "std/text"
import {
    _dst_for, _ecr_repo_for, _crane_load_manifest,
    _crane_copy_retry, _ecr_login, _crane_mirror_ma_images
} from "../src/crane.ab"

// ---- helpers (ABOVE the test blocks: define-before-use; the test-file tree-
// shaker keeps only deps textually preceding their use) ----------------------

// __seq — monotonic counter so each test gets a distinct STAGE_DIR / CLI_ROOT
// even within the same second.
let __seq = 0

// STUB_DIR — the single PATH-shadow dir. Shared across tests (one process, one
// PATH); the shims are content-stable and steered by env vars, so re-installing
// is idempotent and race-free.
const STUB_DIR = "/tmp/amber_crane_stub"

// install_stubs — write the crane + aws shims into STUB_DIR and prepend it to
// PATH (once). The shims are BRACE-FREE bash (a `{` in an Amber Text literal is
// interpolation) and steer behavior off env vars rather than ${var} expansions.
//
// crane shim:
//   * `crane copy SRC DST` honors CRANE_STUB_MODE:
//       ok      → exit 0
//       fatal   → print NAME_UNKNOWN to stderr, exit 1 (must NOT be retried)
//       flaky   → fail (rc 1) until the attempt count file hits CRANE_STUB_OK_AT,
//                 then succeed — proves the retry loop eventually wins
//       always  → always fail rc 1 (no fatal token → loop exhausts attempts)
//   * `crane auth login …` → drain stdin, exit 0 (login always succeeds)
// aws shim:
//   * `ecr get-login-password`        → print a fake token, exit 0
//   * `ecr-public get-login-password` → print a fake token, exit 0
//   * `ecr create-repository`         → exit 0 (idempotent create)
//   * anything else                   → exit 0
fun install_stubs(): Null {
    trust dir_create(STUB_DIR)

    let crane = "#!/usr/bin/env bash
sub=\"$1\"
if [ \"$sub\" = \"auth\" ]; then
  cat > /dev/null 2>&1 || true
  exit 0
fi
if [ \"$sub\" = \"copy\" ]; then
  mode=\"$CRANE_STUB_MODE\"
  case \"$mode\" in
    fatal)
      printf 'NAME_UNKNOWN: repository does not exist\\n' >&2
      exit 1 ;;
    flaky)
      cnt=0
      if [ -f \"$CRANE_STUB_COUNT\" ]; then cnt=$(cat \"$CRANE_STUB_COUNT\"); fi
      cnt=$((cnt + 1))
      printf '%s' \"$cnt\" > \"$CRANE_STUB_COUNT\"
      if [ \"$cnt\" -ge \"$CRANE_STUB_OK_AT\" ]; then exit 0; fi
      printf 'transient error\\n' >&2
      exit 1 ;;
    always)
      printf 'transient error\\n' >&2
      exit 1 ;;
    *)
      exit 0 ;;
  esac
fi
exit 0
"
    trust file_write("{STUB_DIR}/crane", crane)
    trust file_chmod("{STUB_DIR}/crane", "755")

    let aws = "#!/usr/bin/env bash
svc=\"$1\"
op=\"$2\"
if [ \"$svc\" = \"ecr\" ] && [ \"$op\" = \"get-login-password\" ]; then
  printf 'fake-private-token\\n'
  exit 0
fi
if [ \"$svc\" = \"ecr-public\" ] && [ \"$op\" = \"get-login-password\" ]; then
  printf 'fake-public-token\\n'
  exit 0
fi
if [ \"$svc\" = \"ecr\" ] && [ \"$op\" = \"create-repository\" ]; then
  exit 0
fi
exit 0
"
    trust file_write("{STUB_DIR}/aws", aws)
    trust file_chmod("{STUB_DIR}/aws", "755")

    let oldpath = env_var_get("PATH") failed { "" }
    if not text_contains(oldpath, "{STUB_DIR}:") {
        trust env_var_set("PATH", "{STUB_DIR}:{oldpath}")
    }
}

// fresh_stage — mint + export a unique STAGE_DIR with a log/ subdir (so crane.log
// writes land somewhere real). Returns the dir.
fun fresh_stage(): Text {
    __seq += 1
    let base = trust $mktemp -d$
    let dir = "{base}/stage-{__seq}"
    trust dir_create(dir)
    trust dir_create("{dir}/log")
    trust env_var_set("STAGE_DIR", dir)
    return dir
}

// fast_retry — pin the retry knobs so _crane_copy_retry runs quickly: <n>
// attempts, 0-second initial sleep (doubling 0 stays 0).
fun fast_retry(n: Text): Null {
    trust env_var_set("CRANE_RETRY_ATTEMPTS", n)
    trust env_var_set("CRANE_RETRY_INITIAL_S", "0")
}

// write_manifest <cli_root> — write skills/privateEcrManifest.sh holding an
// IMAGES var with two real entries, a blank line, and a comment line (which must
// be dropped). Braces here would be Amber interpolation, so the IMAGES value is
// a plain newline-joined heredoc-free assignment built as a Text and written via
// file_write (no $...$ braces involved).
fun write_manifest(cli_root: Text): Null {
    trust dir_create("{cli_root}/skills")
    // The sourced bash reads $IMAGES; we build it with literal newlines. No '{'.
    let body = "#!/usr/bin/env bash
IMAGES=\"
quay.io/jetstack/cert-manager-controller:v1.17.2
public.ecr.aws/strimzi/kafka:0.50.1
# a comment that must be skipped

\"
"
    trust file_write("{cli_root}/skills/privateEcrManifest.sh", body)
}

// ---- _dst_for (pure) -------------------------------------------------------

test "_dst_for prepends mirrored/ under the ecr host" {
    assert_eq(
        _dst_for("quay.io/strimzi/kafka:0.50.1-kafka-4.0.0", "111.dkr.ecr.us-east-1.amazonaws.com"),
        "111.dkr.ecr.us-east-1.amazonaws.com/mirrored/quay.io/strimzi/kafka:0.50.1-kafka-4.0.0")
}

// ---- _ecr_repo_for (pure) --------------------------------------------------

test "_ecr_repo_for strips the tag and prepends mirrored/" {
    assert_eq(
        _ecr_repo_for("quay.io/strimzi/kafka:0.50.1-kafka-4.0.0"),
        "mirrored/quay.io/strimzi/kafka")
}

test "_ecr_repo_for tolerates an untagged image" {
    // No ':' → the bash `${src%:*}` is a no-op; we keep the whole ref.
    assert_eq(
        _ecr_repo_for("public.ecr.aws/foo/bar"),
        "mirrored/public.ecr.aws/foo/bar")
}

// ---- _crane_load_manifest --------------------------------------------------

test "_crane_load_manifest reads the vendored manifest, drops blanks + comments" {
    __seq += 1
    let root = trust $mktemp -d$
    write_manifest(root)
    trust env_var_set("CLI_ROOT", root)

    let out = _crane_load_manifest("3.2.1")
    // The two real images survive…
    assert(text_contains(out, "quay.io/jetstack/cert-manager-controller:v1.17.2"))
    assert(text_contains(out, "public.ecr.aws/strimzi/kafka:0.50.1"))
    // …and the comment line does NOT.
    assert(not text_contains(out, "a comment"))
    assert(not text_contains(out, "#"))
}

// ---- _crane_copy_retry -----------------------------------------------------

test "_crane_copy_retry returns 0 on a clean copy" {
    install_stubs()
    fresh_stage()
    fast_retry("5")
    trust env_var_set("CRANE_STUB_MODE", "ok")
    assert_eq(_crane_copy_retry("src:tag", "dst:tag"), 0)
}

test "_crane_copy_retry bails early on a fatal NAME_UNKNOWN (no retry)" {
    install_stubs()
    fresh_stage()
    // 5 attempts allowed, but a fatal class must short-circuit on attempt 1.
    fast_retry("5")
    trust env_var_set("CRANE_STUB_MODE", "fatal")
    let rc = _crane_copy_retry("src:tag", "dst:tag")
    // Non-zero (the stub's rc 1); the assertion is that it returned the failure,
    // not that it spun 5 times (the no-retry behavior is the bail-early class).
    assert(rc != 0)
}

test "_crane_copy_retry eventually succeeds across transient failures" {
    install_stubs()
    let dir = fresh_stage()
    fast_retry("5")
    trust env_var_set("CRANE_STUB_MODE", "flaky")
    // Steer the flaky stub to succeed on the 3rd attempt.
    let counter = "{dir}/flaky.count"
    trust $rm -f "{counter}"$
    trust env_var_set("CRANE_STUB_COUNT", counter)
    trust env_var_set("CRANE_STUB_OK_AT", "3")
    assert_eq(_crane_copy_retry("src:tag", "dst:tag"), 0)
}

test "_crane_copy_retry exhausts attempts on persistent failure" {
    install_stubs()
    fresh_stage()
    fast_retry("3")
    trust env_var_set("CRANE_STUB_MODE", "always")
    let rc = _crane_copy_retry("src:tag", "dst:tag")
    assert(rc != 0)
}

// ---- _ecr_login ------------------------------------------------------------

test "_ecr_login fails when crane is not on PATH" {
    fresh_stage()
    // Point PATH at an empty dir so neither crane nor aws resolves → return 1.
    __seq += 1
    let empty = trust $mktemp -d$
    let old = env_var_get("PATH") failed { "" }
    trust env_var_set("PATH", empty)
    let rc = _ecr_login("111.dkr.ecr.us-east-1.amazonaws.com/repo", "us-east-1")
    // Restore PATH for the remaining tests (shared process).
    trust env_var_set("PATH", old)
    assert_eq(rc, 1)
}

test "_ecr_login succeeds with stubbed crane + aws" {
    install_stubs()
    fresh_stage()
    let rc = _ecr_login("111.dkr.ecr.us-east-1.amazonaws.com/migration-ecr-default-us-east-1", "us-east-1")
    assert_eq(rc, 0)
}

// ---- _crane_mirror_ma_images -----------------------------------------------

test "_crane_mirror_ma_images mirrors all 4 MA images on success" {
    install_stubs()
    fresh_stage()
    fast_retry("3")
    trust env_var_set("CRANE_STUB_MODE", "ok")
    // No MA_IMAGES_SOURCE → public.ecr.aws source path. All copies succeed → 0.
    let rc = _crane_mirror_ma_images("111.dkr.ecr.us-east-1.amazonaws.com/migration-ecr-default-us-east-1", "3.2.1", "us-east-1")
    assert_eq(rc, 0)
}

test "_crane_mirror_ma_images returns 1 when a copy fails" {
    install_stubs()
    fresh_stage()
    fast_retry("2")
    trust env_var_set("CRANE_STUB_MODE", "always")
    let rc = _crane_mirror_ma_images("111.dkr.ecr.us-east-1.amazonaws.com/migration-ecr-default-us-east-1", "3.2.1", "us-east-1")
    assert_eq(rc, 1)
}
