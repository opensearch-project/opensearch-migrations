// test_log.ab — coverage for src/log.ab (the append-only file logger + the
// synchronous stream tee).
//
// Style (see test/TEST_GUIDE.md): pure formatters and the rotation predicate are
// asserted as direct return-value UNITS (no I/O), while the impure file/stream
// paths (log_init, log_stream, log_<level>, log_announce*) are driven inside a
// fresh_world() sandbox — MIGRATE_HOME/STAGE_DIR/STAGE pinned to a unique temp
// dir, so migrate.log lands in the world and never near a real workspace. The
// streamed command is a real cmd run against the shared mock fleet (aws), so we
// assert BOTH that the CLI issued the command (mock_called) AND that log_stream
// teed the tool's output into the file as STREAM[prefix] lines — the same
// file-content contract the old bats suite grepped for.
//
// Each test block mints its OWN world; nothing leaks across blocks. NO `return`
// inside a test block (branch with `if`). Helpers live ABOVE the tests
// (define-before-use across the import boundary).

import { assert, assert_eq } from "std/test"
import { file_read, file_exists, file_append } from "std/fs"
import { text_contains } from "std/text"
import { fresh_world, world_noninteractive } from "./support/world.ab"
import {
    mock_install_default, mock_respond,
    mock_called, mock_call_count
} from "./support/mock.ab"
import {
    fmt_log_line, fmt_stream_line, fmt_stream_chrome,
    log_init, log_file, log_stream,
    log_info, log_announce, log_announce_exit
} from "../src/log.ab"

// streaming_world — a fresh world with the mock fleet installed and an `aws`
// response programmed, then log_init() so LOG_FILE points at <world>/log/migrate.log.
// The shape behind the log_stream e2e tests: stream `aws <key>` and the shim emits
// the fixture stdout, which log_stream tees into the file.
fun streaming_world(): Text {
    let w = fresh_world()
    world_noninteractive()
    mock_install_default()
    log_init()
    return w
}

// ---- pure formatters: the byte-exact line shapes (units) -------------------
//
// These are the tested seam — the impure log_*/log_stream wrappers just route
// them to file_append + stderr, so the formatting contract is asserted here with
// no TTY or file. The literal tokens ("STREAM[<prefix>]", the │ bar) are what the
// original bats greps depended on, so they must stay byte-exact.

test "fmt_log_line builds the [ts] LEVEL msg line" {
    assert_eq(fmt_log_line("2026-05-26T22:00:00+0000", "INFO", "hello"),
              "[2026-05-26T22:00:00+0000] INFO hello")
}

test "fmt_stream_line carries the STREAM[bucket] token after the timestamp" {
    let line = fmt_stream_line("2026-05-26T22:00:00+0000", "test", "hello world")
    assert(text_contains(line, "[2026-05-26T22:00:00+0000]"))
    assert(text_contains(line, "STREAM[test] hello world"))
}

test "fmt_stream_chrome wraps the bucket name and content around a bar" {
    let c = fmt_stream_chrome("myop", "line-1")
    assert(text_contains(c, "myop"))
    assert(text_contains(c, "│"))
    assert(text_contains(c, "line-1"))
}

// ---- log_init: file placement, creation, rotation -------------------------

test "log_init points LOG_FILE at <world>/log/migrate.log and seeds the session header" {
    let w = fresh_world()
    log_init()
    assert_eq(log_file(), "{w}/log/migrate.log")
    assert(file_exists(log_file()))
    // The session-separator banner is appended, so the file is non-empty.
    let body = file_read(log_file()) failed { "" }
    assert(text_contains(body, "migration-assistant session"))
}

test "log_init rotates an oversized migrate.log to migrate.log.1" {
    let w = fresh_world()
    // Pre-create migrate.log >5 MiB so log_init's rotation predicate fires. The
    // world already made <w>/log; write a chunk well past the 5_242_880 threshold.
    let big = "{w}/log/migrate.log"
    trust $head -c 6000000 /dev/zero > "{big}"$
    assert(not file_exists("{big}.1"))
    log_init()
    // Rotation moved the old file aside (single-generation), then re-created the
    // active log fresh with the session header.
    assert(file_exists("{big}.1"))
    assert(file_exists("{big}"))
    let body = file_read("{big}") failed { "" }
    assert(text_contains(body, "migration-assistant session"))
}

test "log_init does NOT rotate a small migrate.log" {
    let w = fresh_world()
    let small = "{w}/log/migrate.log"
    trust file_append(small, "tiny prior content\n")
    log_init()
    // Under-threshold file is kept in place; no .1 generation is created.
    assert(not file_exists("{small}.1"))
    let body = file_read(small) failed { "" }
    assert(text_contains(body, "tiny prior content"))
    assert(text_contains(body, "migration-assistant session"))
}

// ---- log_stream: run a real cmd against the mock fleet, tee to the file -----

test "log_stream runs the command and tees its stdout into the log file" {
    let w = streaming_world()
    mock_respond(w, "aws", "describe-stacks", "hello world")
    let rc = log_stream("test", "aws describe-stacks")
    assert_eq(rc, 0)
    // The CLI issued the command...
    assert(mock_called(w, "aws", "describe-stacks"))
    // ...and log_stream teed the tool's stdout into the file as a STREAM[ ] line.
    let body = file_read(log_file()) failed { "" }
    assert(text_contains(body, "STREAM[test] hello world"))
}

test "log_stream merges stderr into the file too (2>&1 capture)" {
    let w = streaming_world()
    // A bare shell command that writes only to stderr — the 2>&1 capture still
    // routes it through the STREAM tee into the file.
    let rc = log_stream("errchan", "printf 'boom\\n' >&2")
    assert_eq(rc, 0)
    let body = file_read(log_file()) failed { "" }
    assert(text_contains(body, "STREAM[errchan] boom"))
}

test "log_stream propagates a non-zero exit code and logs the exit marker" {
    let w = streaming_world()
    let rc = log_stream("bad", "echo nope; exit 7")
    assert_eq(rc, 7)
    let body = file_read(log_file()) failed { "" }
    // The streamed line and the final `stream[bad] exit=7` INFO marker both land.
    assert(text_contains(body, "STREAM[bad] nope"))
    assert(text_contains(body, "stream[bad] exit=7"))
}

test "log_stream prefixes every output line with the bucket name in the file" {
    let w = streaming_world()
    let rc = log_stream("myop", "for i in 1 2 3; do printf 'line-%d\\n' \"$i\"; done")
    assert_eq(rc, 0)
    let body = file_read(log_file()) failed { "" }
    assert(text_contains(body, "STREAM[myop] line-1"))
    assert(text_contains(body, "STREAM[myop] line-2"))
    assert(text_contains(body, "STREAM[myop] line-3"))
}

// ---- log_<level> + log_announce family -------------------------------------

test "log_info appends a level-prefixed line to the file" {
    let w = fresh_world()
    log_init()
    log_info("a probe message")
    let body = file_read(log_file()) failed { "" }
    assert(text_contains(body, "INFO a probe message"))
}

test "log_announce startup, exit, and on-exit hook forms run without error" {
    fresh_world()
    world_noninteractive()
    log_init()
    // These emit chrome to stderr (return Null); the contract under test is "don't
    // abort". --exit form, the on-exit hook on success (rc 0), and on failure (rc 1).
    log_announce("")
    log_announce("--exit")
    log_announce_exit(0)
    log_announce_exit(1)
    assert(true)
}
