// test_helm_install.ab — e2e-focused coverage for src/helm_install.ab (the
// install-orchestration quarter of the bash helm.sh port).
//
// Reference style (see test/TEST_GUIDE.md): drive the real helm_install_or_upgrade
// entrypoint against the faked external world, then assert on what the CLI DID —
// which commands it issued (mock_called / mock_calls) and how on-disk state
// changed — rather than poking internals. The mock fleet + per-test world come
// from test/support/ (no hand-rolled mktemp/PATH/stub bash).
//
// State reconciles through the on-disk state.env: the world seeds it, and
// helm_install_or_upgrade calls state_load() at entry (so does _helm_tls_flags).
// Both resolve the same stage dir from the pinned MIGRATE_HOME/STAGE the world
// sets. The flow's separate state.ab instance writes HELM_RELEASE / last_step to
// the file on success; the test re-state_load()s to observe them.
//
// What's covered (behaviors, then pure units):
//   E2E — helm_install_or_upgrade through the full mocked fleet:
//     * issues `helm upgrade --install` for release/namespace "ma", waits for
//       migration-console-0, advances state to last_step=helm_done + HELM_RELEASE.
//     * mirrored image path (MIRROR_IMAGES=Y + a CFN-provisioned registry): the
//       --set image flags point all five images at that registry with the
//       disambiguating tags.
//     * public image path (MIRROR_IMAGES=N): the --set image flags point at
//       public.ecr.aws/opensearchproject at the MA version.
//     * a failed helm upgrade collects diagnostics + does NOT advance state.
//   Pure units (formatters/builders — no world/mock needed):
//     * _helm_build_public_image_flags / _helm_build_mirrored_image_flags — the
//       [Text] --set repository/tag builders (installer→console reuse, mirrored
//       disambiguating-tag layout).
//     * _helm_tls_flags — driven via on-disk state (TLS_MODE / PCA_ARN): none/
//       self-signed → empty; pca-existing → arn+region; pca-create → both
//       controllers + create.
//     * _write_helm_values — the generated per-stage overrides header.
//     * _helm_extract_chart_values — a --ma-chart-dir DIRECTORY's value files are
//       copied into <stage>/chart-values.
//     * helm_watch_pods — the pod-snapshot one-line summary (counts + name lists)
//       and the empty-namespace waiting branch.
//     * _helm_apply_disable_general_purpose_pool — the post-install EKS Auto Mode
//       toggle (node role arn → rc 0; no Auto Mode config → rc 0 short-circuit).
//     * HELM_RELEASE_NAME / HELM_NAMESPACE — the pinned "ma" constants.
//
// NB (AMBER_IDIOMS): no `return` inside a `test` block — branch with `if`. Helpers
// live ABOVE the test blocks (define-before-use across the import boundary).

import { assert, assert_eq } from "std/test"
import { file_write, file_read, dir_create } from "std/fs"
import { env_var_set } from "std/env"
import { text_contains } from "std/text"
import { array_contains } from "../src/std.ab"
import { fresh_world, world_seed, world_noninteractive } from "./support/world.ab"
import {
    mock_install_default, mock_install, mock_respond, mock_fail,
    mock_called, mock_call_count, mock_calls
} from "./support/mock.ab"
import { state_load, state_get } from "../src/state.ab"
// The pinned release/namespace constants are owned by helm_ctx.ab (the install
// flow imports them from there); the test asserts the same source of truth.
import { HELM_RELEASE_NAME, HELM_NAMESPACE } from "../src/helm_ctx.ab"
import {
    _helm_build_public_image_flags, _helm_build_mirrored_image_flags,
    _helm_tls_flags, _write_helm_values, _helm_extract_chart_values,
    helm_watch_pods, _helm_apply_disable_general_purpose_pool,
    helm_install_or_upgrade
} from "../src/helm_install.ab"

// ---- helpers (ABOVE the test blocks: define-before-use across imports) ------

// The MA artifact version the install tests seed, and the CFN-provisioned ECR
// registry the describe-stacks fixture surfaces (the mirrored-image path target).
const MA_VER = "3.2.1"
const ECR_REGISTRY = "111.dkr.ecr.us-east-1.amazonaws.com/migration-ecr-ma-us-east-1"

// fake_chart_dir <world> — build a local helm chart DIRECTORY inside the world so
// the install flow takes the --ma-chart-dir branch (Chart.yaml present) and skips
// the artifact/network fetch entirely. _helm_extract_chart_values copies the two
// value files out of it. Returns the chart dir path.
fun fake_chart_dir(world: Text): Text {
    let chart = "{world}/chart"
    trust dir_create(chart)
    trust file_write("{chart}/Chart.yaml", "apiVersion: v2\nname: migration-assistant\nversion: 0.0.0\n")
    trust file_write("{chart}/values.yaml", "# base values\nfoo: bar\n")
    trust file_write("{chart}/valuesEks.yaml", "# eks values\nbaz: qux\n")
    return chart
}

// installed_world — a world set up to drive helm_install_or_upgrade end to end:
//   * region + stack + MA version + local chart dir seeded in state;
//   * the aws/kubectl/helm fleet faked to SUCCEED (describe-stacks emits the ECR
//     registry output so the mirrored path has a target; kubectl/helm default to
//     exit 0 with empty stdout → namespace settles, no orphan jobs, release absent
//     → recovery is a no-op, helm upgrade + kubectl wait both succeed);
//   * the installation-notes poll pinned to 0s so the (immediately-satisfied)
//     ConfigMap loop never sleeps.
// MIRROR_IMAGES defaults to "Y" (the chart's mirrored path) unless a test overrides
// it. Returns the WORLD.
fun installed_world(): Text {
    let w = fresh_world()
    world_noninteractive()
    world_seed(w, "STAGE_NAME", "ma")
    world_seed(w, "CFN_STACK_NAME", "MigrationAssistant-ma")
    world_seed(w, "AWS_REGION", "us-east-1")
    world_seed(w, "AWS_ACCOUNT", "111")
    world_seed(w, "MA_VERSION", MA_VER)
    world_seed(w, "MA_CHART_DIR", fake_chart_dir(w))
    mock_install_default()
    // describe-stacks → one TAB-separated OutputKey\tOutputValue row carrying the
    // ECR registry (cfn_outputs parses `--output text` rows split on the tab).
    mock_respond(w, "aws", "describe-stacks", "MIGRATIONS_ECR_REGISTRY\t{ECR_REGISTRY}")
    // The notes ConfigMap probe is satisfied by the default kubectl shim (exit 0);
    // pin the poll/timeout to 0 so _helm_dump_install_notes never sleeps.
    trust env_var_set("INSTALLER_NOTES_POLL_S", "0")
    trust env_var_set("INSTALLER_NOTES_TIMEOUT_S", "0")
    return w
}

// ---- e2e: helm_install_or_upgrade ------------------------------------------

test "install issues helm upgrade --install for ma and advances state to helm_done" {
    let w = installed_world()
    let rc = helm_install_or_upgrade()
    assert_eq(rc, 0)
    // It ran the upgrade --install and waited for the console pod.
    assert(mock_called(w, "helm", "upgrade"))
    assert(mock_called(w, "helm", "--install"))
    assert(mock_called(w, "kubectl", "wait"))
    // State advanced + persisted: re-load THIS instance to read the file the
    // install flow's own state instance wrote.
    state_load()
    assert_eq(state_get("last_step", ""), "helm_done")
    assert_eq(state_get("HELM_RELEASE", ""), "ma")
}

test "install targets release ma in namespace ma" {
    let w = installed_world()
    let rc = helm_install_or_upgrade()
    assert_eq(rc, 0)
    let calls = mock_calls(w, "helm")
    // The recorded args are shell-word-split (the shim records "$*"), so the
    // quotes are gone: the upgrade names the pinned release + namespace (both "ma").
    assert(text_contains(calls, "upgrade --install ma "))
    assert(text_contains(calls, "--namespace ma "))
}

test "install uses the mirrored registry images when MIRROR_IMAGES=Y + a registry" {
    let w = installed_world()
    world_seed(w, "MIRROR_IMAGES", "Y")
    let rc = helm_install_or_upgrade()
    assert_eq(rc, 0)
    let calls = mock_calls(w, "helm")
    // Every image's repository is the CFN-provisioned ECR registry…
    assert(text_contains(calls, "images.captureProxy.repository={ECR_REGISTRY}"))
    assert(text_contains(calls, "images.migrationConsole.repository={ECR_REGISTRY}"))
    // …with the disambiguating tags (build-name + MA version).
    assert(text_contains(calls, "images.captureProxy.tag=migrations_capture_proxy_{MA_VER}"))
    assert(text_contains(calls, "images.migrationConsole.tag=migrations_migration_console_{MA_VER}"))
    // NOT the public.ecr.aws path.
    assert(not text_contains(calls, "public.ecr.aws/opensearchproject"))
}

test "install uses the public.ecr.aws images when MIRROR_IMAGES=N" {
    let w = installed_world()
    world_seed(w, "MIRROR_IMAGES", "N")
    let rc = helm_install_or_upgrade()
    assert_eq(rc, 0)
    let calls = mock_calls(w, "helm")
    // The public path points all images at public.ecr.aws/opensearchproject at the
    // MA version, NOT the mirrored ECR registry.
    assert(text_contains(calls, "images.captureProxy.repository=public.ecr.aws/opensearchproject/opensearch-migrations-traffic-capture-proxy"))
    assert(text_contains(calls, "images.migrationConsole.tag={MA_VER}"))
    assert(not text_contains(calls, ECR_REGISTRY))
}

test "install collects diagnostics and does not advance state when helm fails" {
    let w = installed_world()
    // The helm upgrade fails; the flow dumps diagnostics + returns the rc.
    mock_fail(w, "helm", "upgrade", "1", "Error: UPGRADE FAILED: timed out waiting")
    let rc = helm_install_or_upgrade()
    assert(rc != 0)
    assert(mock_called(w, "helm", "upgrade"))
    // A failed upgrade short-circuits before the readiness wait + state advance.
    assert(not mock_called(w, "kubectl", "wait"))
    state_load()
    assert_eq(state_get("last_step", ""), "")
}

// ---- pure unit: _helm_build_public_image_flags -----------------------------

test "_helm_build_public_image_flags points all five images at public.ecr.aws" {
    let flags = _helm_build_public_image_flags("3.2.1")
    // 5 images × (2 --set + 2 values) = 20 elements.
    let n = len flags
    assert_eq(n, 20)
    assert(array_contains("images.captureProxy.repository=public.ecr.aws/opensearchproject/opensearch-migrations-traffic-capture-proxy", flags))
    assert(array_contains("images.captureProxy.tag=3.2.1", flags))
    assert(array_contains("images.trafficReplayer.repository=public.ecr.aws/opensearchproject/opensearch-migrations-traffic-replayer", flags))
    assert(array_contains("images.reindexFromSnapshot.repository=public.ecr.aws/opensearchproject/opensearch-migrations-reindex-from-snapshot", flags))
    assert(array_contains("images.migrationConsole.repository=public.ecr.aws/opensearchproject/opensearch-migrations-console", flags))
    // installer reuses the console image (bash pairs map installer→console).
    assert(array_contains("images.installer.repository=public.ecr.aws/opensearchproject/opensearch-migrations-console", flags))
    assert(array_contains("images.installer.tag=3.2.1", flags))
}

// ---- pure unit: _helm_build_mirrored_image_flags ---------------------------

test "_helm_build_mirrored_image_flags uses the single repo + disambiguating tags" {
    let reg = "111.dkr.ecr.us-east-1.amazonaws.com/migration-ecr-default-us-east-1"
    let flags = _helm_build_mirrored_image_flags(reg, "3.2.1")
    let n = len flags
    assert_eq(n, 20)
    // Every image's repository is the SAME single registry.
    assert(array_contains("images.captureProxy.repository={reg}", flags))
    assert(array_contains("images.migrationConsole.repository={reg}", flags))
    // The disambiguating tag layout: migrations_<build_name>_<ver>.
    assert(array_contains("images.captureProxy.tag=migrations_capture_proxy_3.2.1", flags))
    assert(array_contains("images.trafficReplayer.tag=migrations_traffic_replayer_3.2.1", flags))
    assert(array_contains("images.reindexFromSnapshot.tag=migrations_reindex_from_snapshot_3.2.1", flags))
    assert(array_contains("images.migrationConsole.tag=migrations_migration_console_3.2.1", flags))
    // installer reuses the console build-name tag.
    assert(array_contains("images.installer.tag=migrations_migration_console_3.2.1", flags))
}

// ---- pure unit: _helm_tls_flags --------------------------------------------
//
// _helm_tls_flags reads TLS_MODE / PCA_ARN / AWS_REGION via state.ab and
// state_load()s at its start, so seeding via the world's on-disk state.env (which
// the pinned STAGE_DIR resolves to) round-trips through its own state instance —
// the same channel helm_install_or_upgrade uses.

test "_helm_tls_flags is empty for unset/none/self-signed" {
    let w = fresh_world()
    // UNSET: TLS_MODE absent → state_get default "" → the no-flags branch. (We do
    // NOT persist TLS_MODE="" — state.ab's serializer would round-trip an empty
    // quoted value as a stray quote, a pre-existing state.ab quirk out of scope.)
    world_seed(w, "AWS_REGION", "us-east-1")
    let f0 = _helm_tls_flags()
    let n0 = len f0
    assert_eq(n0, 0)

    world_seed(w, "TLS_MODE", "none")
    let f1 = _helm_tls_flags()
    let n1 = len f1
    assert_eq(n1, 0)
}

test "_helm_tls_flags self-signed adds no flags" {
    let w = fresh_world()
    world_seed(w, "AWS_REGION", "us-east-1")
    world_seed(w, "TLS_MODE", "self-signed")
    let f = _helm_tls_flags()
    let n = len f
    assert_eq(n, 0)
}

test "_helm_tls_flags pca-existing sets the issuer + arn + region" {
    let w = fresh_world()
    world_seed(w, "TLS_MODE", "pca-existing")
    world_seed(w, "PCA_ARN", "arn:aws:acm-pca:us-east-1:111:ca/abc")
    world_seed(w, "AWS_REGION", "us-east-1")
    let flags = _helm_tls_flags()
    assert(array_contains("conditionalPackageInstalls.aws-privateca-issuer=true", flags))
    assert(array_contains("awsPrivateCA.arn=arn:aws:acm-pca:us-east-1:111:ca/abc", flags))
    assert(array_contains("awsPrivateCA.region=us-east-1", flags))
}

test "_helm_tls_flags pca-create enables both controllers + create" {
    let w = fresh_world()
    world_seed(w, "TLS_MODE", "pca-create")
    world_seed(w, "AWS_REGION", "us-west-2")
    let flags = _helm_tls_flags()
    assert(array_contains("conditionalPackageInstalls.aws-privateca-issuer=true", flags))
    assert(array_contains("conditionalPackageInstalls.ack-acmpca-controller=true", flags))
    assert(array_contains("awsPrivateCA.create=true", flags))
    assert(array_contains("awsPrivateCA.region=us-west-2", flags))
}

// ---- pure unit: _write_helm_values -----------------------------------------

test "_write_helm_values writes the per-stage overrides header" {
    let w = fresh_world()
    let out = "{w}/helm-values.yaml"
    _write_helm_values(out)
    let body = file_read(out) failed { "" }
    assert(text_contains(body, "Generated by migration-assistant"))
    assert(text_contains(body, "Per-stage overrides go here"))
}

// ---- pure unit: _helm_extract_chart_values (directory path) ----------------

test "_helm_extract_chart_values copies a --ma-chart-dir's value files" {
    let w = fresh_world()
    let chart = fake_chart_dir(w)
    let extracted = _helm_extract_chart_values(chart)
    // Returns the <stage>/chart-values dir.
    assert_eq(extracted, "{w}/chart-values")
    // Both value files landed.
    let v = file_read("{extracted}/values.yaml") failed { "" }
    let ve = file_read("{extracted}/valuesEks.yaml") failed { "" }
    assert(text_contains(v, "foo: bar"))
    assert(text_contains(ve, "baz: qux"))
}

// ---- pure unit: helm_watch_pods --------------------------------------------

test "helm_watch_pods summarizes the pod snapshot counts + names" {
    let w = fresh_world()
    mock_install(["kubectl"])
    // A 3-pod snapshot: 1 Running+ready, 1 Pending, 1 Failed — exercises every
    // counter + name list.
    mock_respond(w, "kubectl", "pods", "migration-console-0 Running true\nma-helm-installer-xyz Pending <none>\nbroken-pod Failed false\n")
    let summary = helm_watch_pods("ma")
    assert(text_contains(summary, "pods total=3"))
    assert(text_contains(summary, "running=1"))
    assert(text_contains(summary, "pending=1"))
    assert(text_contains(summary, "failed=1"))
    // The Pending + Failed pods are named in their lists.
    assert(text_contains(summary, "pending=[ma-helm-installer-xyz]"))
    assert(text_contains(summary, "failed=[broken-pod]"))
}

test "helm_watch_pods returns the waiting line when no pods exist" {
    let w = fresh_world()
    mock_install(["kubectl"])
    // No `pods` fixture → the kubectl shim emits empty stdout → the waiting branch.
    let summary = helm_watch_pods("ma")
    assert_eq(summary, "")
}

// ---- _helm_apply_disable_general_purpose_pool ------------------------------

test "_helm_apply_disable_general_purpose_pool succeeds with a node role arn" {
    let w = fresh_world()
    mock_install(["aws"])
    // describe-cluster yields a nodeRoleArn; update-cluster-config exits 0.
    mock_respond(w, "aws", "describe-cluster", "arn:aws:iam::111:role/node-role")
    let rc = _helm_apply_disable_general_purpose_pool("good-cluster", "us-east-1")
    assert_eq(rc, 0)
    assert(mock_called(w, "aws", "update-cluster-config"))
}

test "_helm_apply_disable_general_purpose_pool short-circuits when no Auto Mode config" {
    let w = fresh_world()
    mock_install(["aws"])
    // describe-cluster returns "None" → nothing to disable → rc 0, no update call.
    mock_respond(w, "aws", "describe-cluster", "None")
    let rc = _helm_apply_disable_general_purpose_pool("none-cluster", "us-east-1")
    assert_eq(rc, 0)
    assert(not mock_called(w, "aws", "update-cluster-config"))
}

// ---- HELM_RELEASE_NAME / HELM_NAMESPACE constants --------------------------

test "release name + namespace are pinned to ma" {
    assert_eq(HELM_RELEASE_NAME, "ma")
    assert_eq(HELM_NAMESPACE, "ma")
}
