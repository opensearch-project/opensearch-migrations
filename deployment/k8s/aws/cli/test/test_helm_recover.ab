// test_helm_recover.ab — e2e coverage for helm_recover.ab (the stuck-release
// recovery slice of the bash helm.sh port).
//
// e2e-focused style (see test/TEST_GUIDE.md): drive the real recovery
// entrypoints (helm_recover_if_stuck / helm_ensure_namespace /
// helm_recover_orphan_jobs) against the faked helm+kubectl fleet, then assert on
// what the CLI DID — which helm/kubectl subcommands it issued (mock_called) —
// rather than poking internals. The per-test world + mock fleet come from
// test/support/; each block mints its OWN fresh_world() and steers helm/kubectl
// per-world via mock_respond, so nothing races under the parallel runner (the
// old file steered through shared HELM_STUB_* / KUBECTL_* env vars — replaced).
//
// State (KUBECTL_CONTEXT for the ctx binding) reconciles through the world's
// on-disk state.env: world pins STAGE_DIR/MIGRATE_HOME/STAGE, helm_kctx_init()
// loads state from there. world_noninteractive() makes ui_prompt/ui_confirm take
// their defaults, so the recovery prompts auto-answer ("Y" → yes; "Choose" → 1 =
// rollback) and the paths run unattended.
//
// What's covered:
//   * helm_ctx binding (owned by helm_ctx.ab; recovery reads it): KUBECTL_CONTEXT
//     in state → "--kube-context X" / "--context X"; unset → "".
//   * _helm_release_status (unit on the status fixture): parses an existing
//     release's status, deployed, and "" when the release is absent.
//   * _helm_wait_namespace_settled: gone → true, Active → true, Terminating →
//     false after a short timeout.
//   * helm_ensure_namespace e2e: absent → issues `kubectl create namespace`;
//     Active → issues NO create.
//   * helm_recover_orphan_jobs e2e: a stuck "<release>-helm-*" Job with no
//     completion → `kubectl delete job`; a completed / non-matching Job → none.
//   * helm_recover_if_stuck e2e: deployed/absent/unknown status → 0 (no recovery
//     action); pending-install → issues `helm uninstall`; pending-upgrade →
//     issues `helm rollback` (the menu's default pick [1]).
//
// NB: no `return` inside test blocks (AMBER_IDIOMS — branch with `if`). The
// status JSON the helm `status` mock emits has literal `{}` which Amber captures
// as interpolation, so it is built brace-escaped (\{ \}) — see helm_status_json.

import { assert, assert_eq } from "std/test"
import { fresh_world, world_noninteractive } from "./support/world.ab"
import {
    mock_install_default, mock_respond, mock_respond_rc, mock_fail,
    mock_called, mock_call_count
} from "./support/mock.ab"
import { state_set, state_save } from "../src/state.ab"
// The context binding lives in helm_ctx.ab (the whole helm tree imports it from
// there); helm_recover.ab uses it but does NOT re-export it. helm_kctx_init()
// loads state from disk then derives the flags (the state-loading variant a
// sibling module uses), so the ctx surface is imported from helm_ctx.ab directly.
import {
    helm_kctx_init, helm_ctx_flags, kubectl_ctx_flags
} from "../src/helm_ctx.ab"
import {
    _helm_release_status, _helm_wait_namespace_settled,
    helm_ensure_namespace, helm_recover_orphan_jobs, helm_recover_if_stuck
} from "../src/helm_recover.ab"

// ---- helpers (ABOVE the test blocks: define-before-use; the test-file tree-
// shaker keeps only deps textually preceding their use) ----------------------

// helm_status_json — the `{"info":{"status":"<st>"}}` blob the real helm emits
// for `status -o json`, which _helm_release_status parses via jq. A literal `{`
// in an Amber Text is interpolation, so the JSON braces are escaped (\{ \}).
fun helm_status_json(st: Text): Text {
    return "\{\"info\":\{\"status\":\"{st}\"}}"
}

// world_with_helm_status — a fresh, non-interactive world with the full fleet
// faked and `helm status` steered to <st>. "" → the status lookup FAILS (rc 1),
// the same "release absent" signal the live helm gives (Amber's `failed {""}`).
// kubectl `get jobs` returns nothing so the orphan-jobs pre-pass is a no-op.
fun world_with_helm_status(st: Text): Text {
    let w = fresh_world()
    world_noninteractive()
    mock_install_default()
    helm_kctx_init()
    if st == "" {
        // Absent release: empty stdout + non-zero exit → _helm_release_status "".
        mock_fail(w, "helm", "status", "1", "")
    } else {
        mock_respond(w, "helm", "status", helm_status_json(st))
    }
    // No orphan helm-hook Jobs by default (recover_if_stuck always pre-checks).
    mock_respond(w, "kubectl", "jobs", "")
    return w
}

// ---- helm_ctx binding (owned by helm_ctx.ab; recovery calls read it) -------

test "ctx binding derives helm + kubectl context flags from saved KUBECTL_CONTEXT" {
    let w = fresh_world()
    state_set("KUBECTL_CONTEXT", "my-eks-ctx")
    state_save()
    helm_kctx_init()
    assert_eq(helm_ctx_flags(), "--kube-context my-eks-ctx")
    assert_eq(kubectl_ctx_flags(), "--context my-eks-ctx")
}

test "ctx binding collapses to empty flags when no context is saved" {
    let w = fresh_world()
    state_save()
    helm_kctx_init()
    assert_eq(helm_ctx_flags(), "")
    assert_eq(kubectl_ctx_flags(), "")
}

// ---- _helm_release_status (unit on the helm status fixture) ----------------

test "_helm_release_status parses the status of an existing release" {
    let w = world_with_helm_status("pending-upgrade")
    assert_eq(_helm_release_status("ma", "ma"), "pending-upgrade")
}

test "_helm_release_status reads a deployed release" {
    let w = world_with_helm_status("deployed")
    assert_eq(_helm_release_status("ma", "ma"), "deployed")
}

test "_helm_release_status is empty when the release is absent" {
    let w = world_with_helm_status("")
    assert_eq(_helm_release_status("ma", "ma"), "")
}

// ---- _helm_wait_namespace_settled ------------------------------------------

test "_helm_wait_namespace_settled is true once the namespace is gone" {
    let w = fresh_world()
    mock_install_default()
    helm_kctx_init()
    // `get namespace -o jsonpath` fails (rc 1) → Amber reads "" → namespace gone.
    mock_fail(w, "kubectl", "namespace", "1", "")
    assert(_helm_wait_namespace_settled("ma", 5))
}

test "_helm_wait_namespace_settled is true when the namespace is Active" {
    let w = fresh_world()
    mock_install_default()
    helm_kctx_init()
    mock_respond(w, "kubectl", "namespace", "Active")
    assert(_helm_wait_namespace_settled("ma", 5))
}

test "_helm_wait_namespace_settled times out on a stuck Terminating namespace" {
    let w = fresh_world()
    mock_install_default()
    helm_kctx_init()
    mock_respond(w, "kubectl", "namespace", "Terminating")
    // 1s timeout → one poll, then the elapsed check trips → false. (The poll
    // sleeps 5s once, so this block takes ~5s; acceptable for the contract.)
    assert(not _helm_wait_namespace_settled("ma", 1))
}

// ---- helm_ensure_namespace (e2e: assert the issued kubectl create) ---------

test "helm_ensure_namespace creates the namespace when it is absent" {
    let w = fresh_world()
    world_noninteractive()
    mock_install_default()
    helm_kctx_init()
    // `get namespace` fails → settle sees gone (true) AND the existence check
    // exits non-zero (absent) → the create branch runs.
    mock_fail(w, "kubectl", "namespace", "1", "")
    // `create namespace` shares the `namespace` token, so anchor a succeeding
    // `create` key — it sorts before `namespace` in the args, so the create
    // call resolves rc 0 instead of inheriting the absent-namespace failure.
    mock_respond_rc(w, "kubectl", "create", "0")
    helm_ensure_namespace("ma")
    assert(mock_called(w, "kubectl", "create"))
    assert(mock_called(w, "kubectl", "namespace"))
}

test "helm_ensure_namespace skips create when the namespace is Active" {
    let w = fresh_world()
    world_noninteractive()
    mock_install_default()
    helm_kctx_init()
    // Active → settle true AND get-namespace exits 0 (present) → no create.
    mock_respond(w, "kubectl", "namespace", "Active")
    helm_ensure_namespace("ma")
    assert(not mock_called(w, "kubectl", "create"))
}

// ---- helm_recover_orphan_jobs (e2e: assert the issued kubectl delete) ------

test "helm_recover_orphan_jobs deletes a stuck helm-hook Job" {
    let w = fresh_world()
    world_noninteractive()
    mock_install_default()
    helm_kctx_init()
    // A helm-hook Job for release "ma" with no successful completion ("<none>").
    mock_respond(w, "kubectl", "jobs", "ma-helm-installer   <none>")
    helm_recover_orphan_jobs("ma", "ma")
    assert(mock_called(w, "kubectl", "delete"))
    assert(mock_called(w, "kubectl", "ma-helm-installer"))
}

test "helm_recover_orphan_jobs leaves a completed Job alone" {
    let w = fresh_world()
    world_noninteractive()
    mock_install_default()
    helm_kctx_init()
    // Completion count "1" → succeeded → not a stuck orphan → no delete issued.
    mock_respond(w, "kubectl", "jobs", "ma-helm-installer   1")
    helm_recover_orphan_jobs("ma", "ma")
    assert(not mock_called(w, "kubectl", "delete"))
}

test "helm_recover_orphan_jobs ignores Jobs that don't match the release prefix" {
    let w = fresh_world()
    world_noninteractive()
    mock_install_default()
    helm_kctx_init()
    // Name doesn't start with "ma-helm-" → skipped even with no completion.
    mock_respond(w, "kubectl", "jobs", "other-job   <none>")
    helm_recover_orphan_jobs("ma", "ma")
    assert(not mock_called(w, "kubectl", "delete"))
}

// ---- helm_recover_if_stuck (e2e through the public recovery entry) ---------

test "helm_recover_if_stuck is a clean no-op for a deployed release" {
    let w = world_with_helm_status("deployed")
    let rc = helm_recover_if_stuck("ma", "ma")
    assert_eq(rc, 0)
    assert_eq(mock_call_count(w, "helm"), 1)   // status check only; no recovery
    assert(not mock_called(w, "helm", "uninstall"))
    assert(not mock_called(w, "helm", "rollback"))
}

test "helm_recover_if_stuck is a clean no-op for an absent release" {
    let w = world_with_helm_status("")
    let rc = helm_recover_if_stuck("ma", "ma")
    assert_eq(rc, 0)
    assert(not mock_called(w, "helm", "uninstall"))
    assert(not mock_called(w, "helm", "rollback"))
}

test "helm_recover_if_stuck proceeds (0) without acting on an unknown status" {
    let w = world_with_helm_status("weird-unhandled-state")
    let rc = helm_recover_if_stuck("ma", "ma")
    assert_eq(rc, 0)
    assert(not mock_called(w, "helm", "uninstall"))
    assert(not mock_called(w, "helm", "rollback"))
}

test "helm_recover_if_stuck uninstalls a pending-install release" {
    let w = world_with_helm_status("pending-install")
    // pending-install → ui_confirm defaults to Yes (noninteractive) → uninstall.
    let rc = helm_recover_if_stuck("ma", "ma")
    assert_eq(rc, 0)
    assert(mock_called(w, "helm", "uninstall"))
}

test "helm_recover_if_stuck rolls back a pending-upgrade release (menu default [1])" {
    let w = world_with_helm_status("pending-upgrade")
    // pending-upgrade → the recovery menu; ui_prompt("Choose","1") returns the
    // default "1" in non-interactive mode → helm rollback is issued.
    let rc = helm_recover_if_stuck("ma", "ma")
    assert_eq(rc, 0)
    assert(mock_called(w, "helm", "rollback"))
}
