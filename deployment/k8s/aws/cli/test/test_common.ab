// test_common.ab — coverage for src/common.ab (shell-hardening + helpers loaded
// first by the CLI: die/require_cmd, the signal-PID + on-exit registries,
// arch_os, the env-resolved globals, and stage_dir_init).
//
// common.ab is the foundation layer — it does NOT shell out to the aws/kubectl/
// helm fleet, so there is no cmd_* to drive end to end here. Its surface splits
// into two kinds, tested accordingly (see test/TEST_GUIDE.md):
//   * PURE UNITS — direct return-value asserts, no world needed: arch_os (the
//     uname-driven os/arch classifier), the signal-PID registry (track/untrack/
//     count + the MIGRATE_SIG_PIDS export the bash trap reads), the on-exit
//     registry, and require_cmd's success path (a PATH-shadow stub via the mock
//     fleet — no real binary needed).
//   * SANDBOXED — needs the per-test world: the env-resolved globals
//     (migrate_home/stage/stage_dir/migrate_noninteractive) and stage_dir_init
//     (a real mkdir tree). fresh_world() pins MIGRATE_HOME/STAGE into a unique
//     temp dir the way the CLI computes paths, so these read a real sandbox
//     instead of hand-rolled /tmp paths.
//
// Two cross-cutting facts drive the structure:
//   * common.ab CACHES the globals on first read, so any test that observes them
//     calls common_reset_cache() after pinning env (the world sets env, but a
//     prior block may have populated the cache — env leaks across blocks, the
//     module cache resets per block, so reset to be safe + explicit).
//   * die/require_cmd's FAILURE paths call exit(1)/exit(127) which would kill the
//     test runner, so only require_cmd's SUCCESS path is exercised in-process.

import { assert, assert_eq } from "std/test"
import {
    require_cmd, arch_os, fmt_next_hint,
    on_signal_track_pid, on_signal_untrack_pid, on_signal_tracked_count,
    on_exit_register, on_exit_registered_count,
    migrate_home, stage, stage_dir, migrate_noninteractive, common_reset_cache,
    stage_dir_init
} from "../src/common.ab"
import { env_var_set, env_var_unset, env_var_get, is_command } from "std/env"
import { dir_exists } from "std/fs"
import { text_contains, starts_with, ends_with } from "std/text"
import { fresh_world } from "./support/world.ab"
import { mock_install } from "./support/mock.ab"

// ---- arch_os: uname → "<os>/<arch>" release-binary classifier (pure) --------

test "arch_os returns a supported os/arch pair in the release convention" {
    let ao = arch_os()
    // On any supported test host (mac or linux CI) it must be one of these.
    let ok = ao == "darwin/arm64"
        or ao == "darwin/amd64"
        or ao == "linux/amd64"
        or ao == "linux/arm64"
    assert(ok)
    // Structurally "<os>/<arch>": exactly one slash, both halves non-empty.
    assert(text_contains(ao, "/"))
    assert(not starts_with(ao, "/"))
    assert(not ends_with(ao, "/"))
}

// ---- signal-PID registry: track / untrack / count (pure) -------------------
//
// The seed-slot parallel-array store the bash trap's kill sweep reads. Each
// block starts from a clean registry (module-level state resets per block) and
// drains what it adds so its assertions stand alone.

test "tracking three pids then untracking one keeps the logical count exact" {
    assert_eq(on_signal_tracked_count(), 0)
    on_signal_track_pid("100")
    on_signal_track_pid("200")
    on_signal_track_pid("300")
    assert_eq(on_signal_tracked_count(), 3)
    // Untrack the middle one — count drops, the others remain.
    on_signal_untrack_pid("200")
    assert_eq(on_signal_tracked_count(), 2)
    // Untracking a non-member is a no-op.
    on_signal_untrack_pid("999")
    assert_eq(on_signal_tracked_count(), 2)
    on_signal_untrack_pid("100")
    on_signal_untrack_pid("300")
    assert_eq(on_signal_tracked_count(), 0)
}

test "tracking an empty pid is ignored" {
    assert_eq(on_signal_tracked_count(), 0)
    on_signal_track_pid("")
    assert_eq(on_signal_tracked_count(), 0)
}

test "the first real pid overwrites the seed slot (no phantom row)" {
    assert_eq(on_signal_tracked_count(), 0)
    // A single append must yield count 1, not 2 from a stale placeholder.
    on_signal_track_pid("42")
    assert_eq(on_signal_tracked_count(), 1)
    on_signal_untrack_pid("42")
    assert_eq(on_signal_tracked_count(), 0)
}

test "track / untrack keep MIGRATE_SIG_PIDS in sync for the trap body" {
    on_signal_track_pid("777")
    on_signal_track_pid("888")
    // The INT/TERM trap is a raw bash string that loops over $MIGRATE_SIG_PIDS;
    // track/untrack export it space-separated so the signal-time sweep sees the
    // live set. Both pids must be listed.
    let exported = env_var_get("MIGRATE_SIG_PIDS") failed { "" }
    assert(text_contains(exported, "777"))
    assert(text_contains(exported, "888"))
    // Untracking drops only that pid from the export.
    on_signal_untrack_pid("777")
    let exported2 = env_var_get("MIGRATE_SIG_PIDS") failed { "" }
    assert(not text_contains(exported2, "777"))
    assert(text_contains(exported2, "888"))
    on_signal_untrack_pid("888")
    assert_eq(on_signal_tracked_count(), 0)
}

// ---- on-exit registry: cleanup-callback names (pure) -----------------------

test "on_exit_register accumulates names and ignores the empty name" {
    let before = on_exit_registered_count()
    on_exit_register("cleanup_a")
    on_exit_register("cleanup_b")
    assert_eq(on_exit_registered_count(), before + 2)
    on_exit_register("")
    assert_eq(on_exit_registered_count(), before + 2)
}

// ---- require_cmd: success path via a PATH-shadow stub ----------------------

test "require_cmd returns without exiting for a command on PATH" {
    // mock_install drops a 755 shim for the name onto PATH, so is_command finds
    // it. require_cmd must then return (no exit). If it had exited, this process
    // would die and the block would report failed — so reaching the assert is
    // itself the proof of the contract.
    fresh_world()
    mock_install(["migrate_stub_tool_xyz"])
    assert(is_command("migrate_stub_tool_xyz"))
    require_cmd("migrate_stub_tool_xyz", "should not need a hint")
    assert(true)
}

// ---- die_hint's pure next-action formatter ---------------------------------

test "fmt_next_hint renders a next-action line for a hint and nothing for none" {
    // empty hint → empty line (die() delegates with "" → a plain error, no arrow)
    assert_eq(fmt_next_hint(""), "")
    // a real hint → a "→ next: …" line carrying the operator's instruction; the
    // dim SGR brackets it but the actionable text is always present (CI-readable).
    let line = fmt_next_hint("run `aws configure`")
    assert(text_contains(line, "→ next: run `aws configure`"))
}

// ---- env-resolved globals (cached) -----------------------------------------
//
// Each block mints its OWN world (unique sandbox; MIGRATE_HOME + STAGE pinned)
// and resets the common.ab cache so the accessor reads the world's env. The
// default-fallback cases instead UNSET the env to exercise the bash `:=default`
// branch — the world's value would mask it.

test "migrate_home honors the MIGRATE_HOME the world pins" {
    fresh_world()
    common_reset_cache()
    // fresh_world set MIGRATE_HOME to the world's temp root; the accessor reads it.
    assert_eq(migrate_home(), env_var_get("MIGRATE_HOME") failed { "" })
    // And it is a real, non-empty directory under the sandbox.
    assert(migrate_home() != "")
    assert(dir_exists(migrate_home()))
}

test "migrate_home defaults to PWD/migration-assistant-workspace when unset" {
    trust env_var_unset("MIGRATE_HOME")
    common_reset_cache()
    assert(ends_with(migrate_home(), "/migration-assistant-workspace"))
}

test "stage defaults to 'default' when unset and honors the STAGE env" {
    trust env_var_unset("STAGE")
    common_reset_cache()
    assert_eq(stage(), "default")
    common_reset_cache()
    trust env_var_set("STAGE", "prod-cutover")
    assert_eq(stage(), "prod-cutover")
    trust env_var_unset("STAGE")
    common_reset_cache()
}

test "stage_dir composes migrate_home over the active stage" {
    fresh_world()
    common_reset_cache()
    // The world pins both halves; stage_dir is their join — and it is exactly the
    // world's stage dir on disk.
    assert_eq(stage_dir(), "{migrate_home()}/{stage()}")
    assert(dir_exists(stage_dir()))
}

test "migrate_noninteractive reflects the MIGRATE_NONINTERACTIVE flag" {
    trust env_var_unset("MIGRATE_NONINTERACTIVE")
    common_reset_cache()
    assert(not migrate_noninteractive())
    common_reset_cache()
    trust env_var_set("MIGRATE_NONINTERACTIVE", "1")
    assert(migrate_noninteractive())
    trust env_var_unset("MIGRATE_NONINTERACTIVE")
    common_reset_cache()
}

// ---- stage_dir_init: the real mkdir tree (sandboxed) -----------------------

test "stage_dir_init creates the full stage subtree and is idempotent" {
    fresh_world()
    common_reset_cache()
    let base = stage_dir()
    stage_dir_init()
    // The seven subdirs (plus base) must all exist.
    assert(dir_exists(base))
    assert(dir_exists("{base}/log"))
    assert(dir_exists("{base}/artifacts"))
    assert(dir_exists("{base}/artifacts/.cache"))
    assert(dir_exists("{base}/skills"))
    assert(dir_exists("{base}/plan"))
    assert(dir_exists("{base}/history"))
    assert(dir_exists("{base}/archive"))
    // A second call must not fail (mkdir -p semantics).
    stage_dir_init()
    assert(dir_exists(base))
}
