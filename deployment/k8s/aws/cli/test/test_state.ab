// test_state.ab — coverage for src/state.ab (per-stage state I/O).
//
// state.ab is a filesystem-only module: it reads/writes state.env + state.json
// under the stage dir and has NO external-tool calls — so these tests need the
// shared per-test world (the on-disk sandbox) but not the mock fleet. Each test
// mints its OWN fresh_world(); the world pins MIGRATE_HOME/STAGE/STAGE_DIR into a
// unique temp dir, and state.ab resolves the stage dir from that env on every op.
//
// What's verified (coverage preserved from the prior file):
//   * the load → set → save → reload round-trip (state persists across a fresh
//     in-memory store, simulating a new process)
//   * state_get's default-when-absent contract
//   * state_save writes BOTH artifacts (state.env + state.json) with the right
//     serialization in each
//   * values bearing spaces AND embedded quotes survive the escape round-trip
//     (the esc_for_env / unescape_quotes inverse pair)
//   * state_archive relocates the live files under archive/<ts> and clears memory
//   * state_resumable_step accessor (empty + populated)
//   * the parallel-array store primitives: state_has / state_unset / state_count
//
// NO `return` inside a test block; helpers live ABOVE the blocks (define-before-
// use across the import boundary).

import { assert, assert_eq } from "std/test"
import { file_read, file_exists, dir_exists } from "std/fs"
import { text_contains } from "std/text"
import { fresh_world } from "./support/world.ab"
import {
    state_load, state_set, state_get, state_has, state_unset,
    state_save, state_archive, state_resumable_step, state_count
} from "../src/state.ab"

// ---- helpers (ABOVE the test blocks: define-before-use) --------------------

// seeded_world — a fresh on-disk sandbox with the in-memory store reset to match
// it. state_load() both creates the stage subtree and clears module state, which
// is the equivalent of a brand-new process pointed at a clean dir. Returns the
// world dir so a test can probe the on-disk artifacts.
fun seeded_world(): Text {
    let w = fresh_world()
    state_load()
    return w
}

// ---- round-trip: the persistence spine -------------------------------------

test "set then save then reload round-trips a value" {
    seeded_world()
    state_set("FOO", "bar")
    state_save()
    // Drop the in-memory store and reload from disk — the new-process simulation.
    state_load()
    assert_eq(state_get("FOO", ""), "bar")
}

test "save persists across multiple keys and a reload" {
    seeded_world()
    state_set("REGION", "us-west-2")
    state_set("STAGE_NAME", "ma")
    state_set("last_step", "cfn_done")
    state_save()
    state_load()
    assert_eq(state_count(), 3)
    assert_eq(state_get("REGION", ""), "us-west-2")
    assert_eq(state_get("STAGE_NAME", ""), "ma")
    assert_eq(state_get("last_step", ""), "cfn_done")
}

test "reloaded values bearing spaces and embedded quotes survive intact" {
    seeded_world()
    let v = "arn:aws:iam::1234:user/\"john doe\""
    state_set("NOTE", v)
    state_save()
    state_load()
    assert_eq(state_get("NOTE", ""), v)
}

// ---- accessors --------------------------------------------------------------

test "get returns the supplied default when the key is absent" {
    seeded_world()
    assert_eq(state_get("MISSING", "fallback"), "fallback")
}

test "has and unset compact the store without corrupting siblings" {
    seeded_world()
    state_set("A", "1")
    state_set("B", "2")
    state_set("C", "3")
    assert_eq(state_count(), 3)
    assert(state_has("B"))
    state_unset("B")
    assert(not state_has("B"))
    assert_eq(state_count(), 2)
    // surviving keys keep their values (no slot corruption from the compaction).
    assert_eq(state_get("A", ""), "1")
    assert_eq(state_get("C", ""), "3")
}

// ---- on-disk artifacts ------------------------------------------------------

test "save writes both state.env and state.json with matching serialization" {
    let w = seeded_world()
    state_set("REGION", "us-west-2")
    state_save()
    assert(file_exists("{w}/state.env"))
    assert(file_exists("{w}/state.json"))
    let env_body = file_read("{w}/state.env") failed { "" }
    let json_body = file_read("{w}/state.json") failed { "" }
    // state.env serializes KEY="VALUE"; state.json an object of "key": "value".
    assert(text_contains(env_body, "REGION=\"us-west-2\""))
    assert(text_contains(json_body, "\"REGION\""))
    assert(text_contains(json_body, "\"us-west-2\""))
}

// ---- archive ----------------------------------------------------------------

test "archive moves the live state under archive then clears memory" {
    let w = seeded_world()
    state_set("FOO", "bar")
    state_save()
    state_archive()
    // live files are gone; the in-memory store is empty; archive holds the env.
    assert(not file_exists("{w}/state.env"))
    assert(not file_exists("{w}/state.json"))
    assert(dir_exists("{w}/archive"))
    assert_eq(state_count(), 0)
    let found = trust $find "{w}/archive" -name 'state.env' | wc -l | tr -d ' '$
    assert_eq(found, "1")
}

// ---- resume accessor --------------------------------------------------------

test "resumable_step is empty when last_step was never set" {
    seeded_world()
    assert_eq(state_resumable_step(), "")
}

test "resumable_step reads back the persisted last_step" {
    seeded_world()
    state_set("last_step", "helm_done")
    state_save()
    state_load()
    assert_eq(state_resumable_step(), "helm_done")
}
