// test_pack.ab — coverage for src/pack.ab (cmd_pack + the _pack_* helpers).
//
// e2e-focused style (see test/TEST_GUIDE.md, test/test_cleanup.ab): the primary
// tests drive the real cmd_pack entrypoint against a fixture CLI tarball and then
// assert on what it PRODUCED — they extract the repacked tarball and read back the
// rewritten manifest (branding/MCPs/skills/build.packs) + the renamed top-level
// dir. The manifest-merge helpers (_pack_add_mcp / _pack_apply_branding /
// _pack_apply_brand_flags / _pack_append_entry), the validator (_pack_validate),
// and the bundle-root finder (_pack_resolve_root) stay as focused units — they are
// pure jq transforms over a manifest with no observable side effect beyond the
// file, so a direct read-back assert is the clearest contract.
//
// pack is READ-ONLY against the operator's environment: its only external commands
// are local file tools (jq/tar/find/cp/mktemp/mv/date). There are NO aws/kubectl/
// helm/crane/docker calls, so there is nothing to fake through the mock fleet — the
// real host binaries touch only the per-test sandbox we build, giving faithful,
// deterministic results. What we DO take from the shared support lib is the
// isolation: every block mints its OWN fresh_world() (support/world.ab) as the
// scratch root, so concurrent blocks under the parallel runner never collide on a
// path (the old file hand-partitioned a shared /tmp dir by suffix; the world is the
// per-test-unique channel instead).
//
// JSON IS BRACE-HEAVY: a literal `{` starts interpolation in BOTH Amber Text
// literals AND inside `$...$` commands. So no JSON ever appears inline — canned
// manifests/fragments live in test/fixtures/*.json and are `cp`'d into the world.
//
// die() exits the process, so the hard-error paths (missing --input, invalid JSON,
// the --strict escalation) are NOT asserted from inside a test block — an exit
// would abort the whole run. We cover the success paths + the soft (non-fatal)
// unknown-mode-id branch, mirroring the bats split of the fatal/non-fatal cases.
//
// Helpers + imports are ABOVE the test blocks (define-before-use across the import
// boundary). NO `return` inside a test block — branch with `if`.

import { assert, assert_eq } from "std/test"
import { file_exists, dir_create } from "std/fs"
import { text_contains } from "std/text"
import { fresh_world } from "./support/world.ab"
import {
    cmd_pack, _pack_resolve_root, _pack_add_skill, _pack_add_mcp,
    _pack_apply_branding, _pack_apply_brand_flags, _pack_validate,
    _pack_append_entry
} from "../src/pack.ab"

// ---- file-local helpers (ABOVE the tests: define-before-use across the import
// boundary, and the tree-shaker keeps only deps preceding their use) ------------

// FIX — on-disk JSON fixtures (paths relative to the repo root; amber test runs
// from amber-tui/). JSON stays out of Amber literals → brace-safe.
const FIX = "test/fixtures"

// cp_fixture <fixture_name> <dest> — copy a fixtures/*.json into place (real cp).
fun cp_fixture(name: Text, dest: Text): Null {
    trust $cp "{FIX}/{name}" "{dest}"$
}

// jq_field <path> <filter> — read a scalar out of a JSON file (test assertion
// helper only; the production code never calls this). Real jq on the host.
fun jq_field(path: Text, filter: Text): Text {
    return trust $jq -r "{filter}" "{path}" 2>/dev/null$
}

// m_of <bundle_root> — the manifest path inside an extracted bundle root.
fun m_of(root: Text): Text {
    return "{root}/manifest.json"
}

// staged_bundle <world> → root of an EXTRACTED CLI bundle laid out under the
// world (root/manifest.json + root/skills/ + root/lib/ + root/bin/). This is the
// "already-extracted bundle" shape the manifest-merge + resolve-root units work
// against — analogous to built_repo() in test_build.ab. The manifest is the
// baseline fixture copied in. Returns the bundle root dir.
fun staged_bundle(w: Text): Text {
    let root = "{w}/bundle/migration-assistant-cli-3.2.1"
    trust dir_create(root)
    trust dir_create("{root}/skills")
    trust dir_create("{root}/lib")
    trust dir_create("{root}/bin")
    cp_fixture("pack_manifest_base.json", "{root}/manifest.json")
    return root
}

// input_tarball <world> → path to a .tar.gz of a baseline bundle (top-level dir
// migration-assistant-cli-3.2.1), for cmd_pack --input. Real tar over the bundle
// staged_bundle() lays down. This is the deployed-world equivalent for pack: the
// realistic input the operator feeds the repacker.
fun input_tarball(w: Text): Text {
    staged_bundle(w)
    let tarball = "{w}/input.tar.gz"
    trust $tar -czf "{tarball}" -C "{w}/bundle" "migration-assistant-cli-3.2.1"$
    return tarball
}

// make_skill <world> <name> → a skill dir whose BASENAME is exactly <name>
// (mirrors `--add-skill ./my-runbook`, where basename → "my-runbook"). Lives under
// a per-world parent so the basename is the bare <name>; _pack_add_skill copies it
// under skills/<name>/. SKILL.md body is brace-free → shell printf.
fun make_skill(w: Text, name: Text): Text {
    let d = "{w}/skillsrc/{name}"
    trust dir_create(d)
    trust $printf '# %s\n' "{name}" > "{d}/SKILL.md"$
    return d
}

// extract_output <world> <output_tarball> → the repacked bundle's root dir, by
// extracting the produced tarball into a probe dir under the world. The e2e tests
// read the rewritten manifest back from here. <top> is the expected top-level dir
// name (it can be renamed when binaryName changes).
fun extract_output(w: Text, output: Text, top: Text): Text {
    let probe = "{w}/probe"
    trust dir_create(probe)
    trust $tar -xzf "{output}" -C "{probe}"$
    return "{probe}/{top}"
}

// =====================================================================
// cmd_pack — the end-to-end repack flow (primary coverage)
// =====================================================================

test "pack repacks a tarball with a new skill, MCP, and branding, then records the pack entry" {
    let w = fresh_world()
    let tarball = input_tarball(w)
    let skill = make_skill(w, "my-runbook")
    let mcp = "{w}/mcp-frag.json"
    cp_fixture("pack_mcp_frag.json", mcp)
    let brand = "{w}/brand.json"
    cp_fixture("pack_brand_app.json", brand)
    let output = "{w}/out.tar.gz"

    let rc = cmd_pack([
        "--input", tarball,
        "--output", output,
        "--pack-name", "myorg",
        "--pack-version", "1.0.0",
        "--add-skill", skill,
        "--add-mcp", mcp,
        "--branding", brand
    ])
    assert_eq(rc, 0)
    assert(file_exists(output))

    // Inspect the PRODUCED tarball — the full operator-observable contract.
    let root = extract_output(w, output, "migration-assistant-cli-3.2.1")
    let m = "{root}/manifest.json"
    assert(file_exists(m))
    // Branding was deep-merged into the manifest.
    assert_eq(jq_field(m, ".branding.appName"), "Acme Migrate")
    // The new MCP server landed alongside the baseline one.
    let mcp_keys = jq_field(m, ".mcpServers | keys | join(\",\")")
    assert(text_contains(mcp_keys, "aws"))
    assert(text_contains(mcp_keys, "secrets"))
    // The skill was copied under skills/<basename>/.
    assert(file_exists("{root}/skills/my-runbook/SKILL.md"))
    // The pack entry was appended with identity + brandingChanged.
    assert_eq(jq_field(m, ".build.packs | length"), "1")
    assert_eq(jq_field(m, ".build.packs[0].name"), "myorg")
    assert_eq(jq_field(m, ".build.packs[0].version"), "1.0.0")
    assert_eq(jq_field(m, ".build.packs[0].addedSkills[0]"), "my-runbook")
    assert_eq(jq_field(m, ".build.packs[0].addedMcpServers[0]"), "secrets")
    assert_eq(jq_field(m, ".build.packs[0].brandingChanged"), "true")
}

test "pack accepts the --flag=value form and writes the pack version through to the manifest" {
    let w = fresh_world()
    let tarball = input_tarball(w)
    let output = "{w}/out.tar.gz"

    let rc = cmd_pack([
        "--input={tarball}",
        "--output={output}",
        "--pack-name=myorg",
        "--pack-version=2.0"
    ])
    assert_eq(rc, 0)
    assert(file_exists(output))

    let root = extract_output(w, output, "migration-assistant-cli-3.2.1")
    assert_eq(jq_field(m_of(root), ".build.packs[0].version"), "2.0")
}

test "pack renames the top-level dir when --brand-binary changes binaryName" {
    let w = fresh_world()
    let tarball = input_tarball(w)
    let output = "{w}/out.tar.gz"

    let rc = cmd_pack([
        "--input", tarball,
        "--output", output,
        "--pack-name", "myorg",
        "--pack-version", "1.0",
        "--brand-binary", "acme-migrate"
    ])
    assert_eq(rc, 0)
    // The tarball's top-level dir self-describes the rebrand.
    let listing = trust $tar -tzf "{output}"$
    assert(text_contains(listing, "acme-migrate-cli-3.2.1/"))
    // And the rebranded binaryName is in the repacked manifest.
    let root = extract_output(w, output, "acme-migrate-cli-3.2.1")
    assert_eq(jq_field(m_of(root), ".branding.binaryName"), "acme-migrate")
}

test "pack tolerates an unknown mode id without --strict (returns 0, keeps the mode)" {
    let w = fresh_world()
    let tarball = input_tarball(w)
    let brand = "{w}/brand-unknown.json"
    cp_fixture("pack_brand_unknown.json", brand)
    let output = "{w}/out.tar.gz"

    // Without --strict the unknown id ("Console") is a soft warning only → rc 0.
    // (--strict would escalate to a die() that aborts the run, so it is not
    // asserted here — mirrors the bats fatal/non-fatal split.)
    let rc = cmd_pack([
        "--input", tarball,
        "--output", output,
        "--pack-name", "myorg",
        "--pack-version", "1.0",
        "--branding", brand
    ])
    assert_eq(rc, 0)
    let root = extract_output(w, output, "migration-assistant-cli-3.2.1")
    let mode_ids = jq_field(m_of(root), "[.branding.modes[].id] | join(\",\")")
    assert(text_contains(mode_ids, "Console"))
}

// =====================================================================
// _pack_resolve_root — the single-bundle-root finder
// =====================================================================

test "resolve_root finds the one CLI-bundle subdir under the stage" {
    let w = fresh_world()
    staged_bundle(w)
    let found = _pack_resolve_root("{w}/bundle")
    assert(text_contains(found, "migration-assistant-cli-3.2.1"))
}

test "resolve_root returns empty when no dir carries a bundle marker" {
    let w = fresh_world()
    trust dir_create("{w}/bundle/random-dir")
    let found = _pack_resolve_root("{w}/bundle")
    assert_eq(found, "")
}

// =====================================================================
// _pack_add_skill — validate + copy a skill into the bundle
// =====================================================================

test "add_skill copies a valid skill dir under skills/<basename>" {
    let w = fresh_world()
    let root = staged_bundle(w)
    let skill = make_skill(w, "my-runbook")
    _pack_add_skill(root, skill)
    assert(file_exists("{root}/skills/my-runbook/SKILL.md"))
}

// =====================================================================
// _pack_add_mcp — deep-merge an MCP fragment into mcpServers
// =====================================================================

test "add_mcp deep-merges a fragment, preserving the existing server" {
    let w = fresh_world()
    let root = staged_bundle(w)
    let m = "{root}/manifest.json"
    let frag = "{w}/mcp-frag.json"
    cp_fixture("pack_mcp_frag.json", frag)
    _pack_add_mcp(m, frag)
    let keys = jq_field(m, ".mcpServers | keys | join(\",\")")
    assert(text_contains(keys, "aws"))       // baseline server survives
    assert(text_contains(keys, "secrets"))   // fragment merged in
    assert_eq(jq_field(m, ".mcpServers.secrets.command"), "npx")
}

// =====================================================================
// _pack_apply_branding — deep-merge branding (modes REPLACED when given)
// =====================================================================

test "apply_branding deep-merges fields and REPLACES modes when the fragment declares them" {
    let w = fresh_world()
    let root = staged_bundle(w)
    let m = "{root}/manifest.json"
    let frag = "{w}/brand-modes.json"
    cp_fixture("pack_brand_modes.json", frag)
    _pack_apply_branding(m, frag)
    assert_eq(jq_field(m, ".branding.appName"), "Acme Migrate")
    assert_eq(jq_field(m, ".branding.tagline"), "ship it")
    // modes[] REPLACED (not merged) — only the fragment's single entry remains.
    assert_eq(jq_field(m, ".branding.modes | length"), "1")
}

test "apply_branding keeps the existing modes when the fragment omits them" {
    let w = fresh_world()
    let root = staged_bundle(w)
    let m = "{root}/manifest.json"
    let frag = "{w}/brand-nomodes.json"
    cp_fixture("pack_brand_nomodes.json", frag)
    _pack_apply_branding(m, frag)
    assert_eq(jq_field(m, ".branding.appName"), "NoModes")
    // Original two modes survive (no modes in fragment → not replaced).
    assert_eq(jq_field(m, ".branding.modes | length"), "2")
}

// =====================================================================
// _pack_apply_brand_flags — the convenience --brand-*/--mode-* flags
// =====================================================================

test "apply_brand_flags sets name/binary/tagline and picks the single default mode" {
    let w = fresh_world()
    let root = staged_bundle(w)
    let m = "{root}/manifest.json"
    _pack_apply_brand_flags(m, "Acme", "acme-migrate", "tag", "Agent", "")
    assert_eq(jq_field(m, ".branding.appName"), "Acme")
    assert_eq(jq_field(m, ".branding.binaryName"), "acme-migrate")
    assert_eq(jq_field(m, ".branding.tagline"), "tag")
    // --mode-default Agent → Agent.default==true, Manual.default==false.
    assert_eq(jq_field(m, ".branding.modes[] | select(.id==\"Agent\") | .default"), "true")
    assert_eq(jq_field(m, ".branding.modes[] | select(.id==\"Manual\") | .default"), "false")
}

test "apply_brand_flags reorders modes to match --mode-order" {
    let w = fresh_world()
    let root = staged_bundle(w)
    let m = "{root}/manifest.json"
    _pack_apply_brand_flags(m, "", "", "", "", "Agent,Manual")
    assert_eq(jq_field(m, ".branding.modes[0].id"), "Agent")
    assert_eq(jq_field(m, ".branding.modes[1].id"), "Manual")
}

// =====================================================================
// _pack_validate — the post-merge sanity checker
// =====================================================================

test "validate accepts a well-formed manifest" {
    let w = fresh_world()
    let root = staged_bundle(w)
    assert(_pack_validate("{root}/manifest.json", 0))
}

test "validate (non-strict) tolerates an unknown mode id as a soft warning" {
    let w = fresh_world()
    let root = staged_bundle(w)
    let m = "{root}/manifest.json"
    let frag = "{w}/brand-unknown.json"
    cp_fixture("pack_brand_unknown.json", frag)
    // Inject the unknown visible id ("Console") via apply_branding: SOFT — not
    // escalated unless --strict. Single default preserved → no hard error → true.
    _pack_apply_branding(m, frag)
    assert(_pack_validate(m, 0))
}

// =====================================================================
// _pack_append_entry — append a build.packs[] record
// =====================================================================

test "append_entry records the pack identity, added skills and MCP servers" {
    let w = fresh_world()
    let root = staged_bundle(w)
    let m = "{root}/manifest.json"
    let skill = make_skill(w, "my-runbook")
    let frag = "{w}/append-mcp.json"
    cp_fixture("pack_mcp_frag_empty.json", frag)
    // skills_csv / mcps_csv are the SPACE-joined input lists (the bash form).
    _pack_append_entry(m, "myorg", "1.0.0", skill, frag, 1)
    assert_eq(jq_field(m, ".build.packs | length"), "1")
    assert_eq(jq_field(m, ".build.packs[0].name"), "myorg")
    assert_eq(jq_field(m, ".build.packs[0].version"), "1.0.0")
    // addedSkills = basename of the skill path; addedMcpServers = fragment keys.
    assert_eq(jq_field(m, ".build.packs[0].addedSkills[0]"), "my-runbook")
    assert_eq(jq_field(m, ".build.packs[0].addedMcpServers[0]"), "secrets")
    // brandingChanged derives from the int flag (1 → true).
    assert_eq(jq_field(m, ".build.packs[0].brandingChanged"), "true")
}

test "append_entry with no additions yields empty arrays and brandingChanged=false" {
    let w = fresh_world()
    let root = staged_bundle(w)
    let m = "{root}/manifest.json"
    _pack_append_entry(m, "barepack", "0.1", "", "", 0)
    assert_eq(jq_field(m, ".build.packs[0].addedSkills | length"), "0")
    assert_eq(jq_field(m, ".build.packs[0].addedMcpServers | length"), "0")
    assert_eq(jq_field(m, ".build.packs[0].brandingChanged"), "false")
}
