// test_agent_handoff.ab — e2e coverage for agent.ab (the port of bash lib/agent.sh),
// part 3 of 3: cmd_agent, the standalone handoff entrypoint.
//
// Split out of the former test_agent.ab so each part's compiled script stays
// under the Linux MAX_ARG_STRLEN cap (amber runs each test via `eval "<script>"`;
// a single arg is capped at ~128KB on Linux, so each test FILE must compile to
// <~120KB). This part holds the HEAVY tier — cmd_agent — which inlines the full
// discover → setup → MCP → helm-context → exec call graph.
//
// How the e2e flow wires up:
//   * fresh_world() pins MIGRATE_HOME / STAGE / STAGE_DIR into a unique sandbox;
//     _agent_stage_dir() resolves to that world, so every Startup.md / .mcp.json /
//     .claude/settings.json / .codex / .kiro the agent writers emit lands there.
//   * cmd_agent's stage guard reads STAGE_NAME from the on-disk state.env →
//     world_seed(w, "STAGE_NAME", "ma") so the happy path runs (the missing-stage
//     branch die()s = exits the process, so it is NOT exercised here).
//   * The chosen agent's binary is faked onto PATH via mock_install([... "claude"]).
//     agent_exec's final `exec <bin> …` runs in a `$…$` subshell, so it replaces
//     the SUBSHELL (recording the call), not the test process — cmd_agent returns
//     and post-call asserts run.
//   * jq stays REAL (the MCP writers hard-dep it, exactly like bash) — the fleet
//     only fakes aws/kubectl/helm/<agent>/uvx, never jq.
//   * uvx is faked so aws-mcp's `requires:[uvx]` resolves without the install
//     prompt; the manifest is pointed at test/fixtures/agent_manifest.json and
//     AWS_REGION is set so the ${AWS_REGION} arg substitutes.
//
// NB (AMBER_IDIOMS): NO `return` inside a test block — branch with `if`. JSON is
// brace-heavy, so canned manifests live in test/fixtures/*.json, never inline.

import { assert, assert_eq } from "std/test"
import { file_exists, file_read } from "std/fs"
import { env_var_set, env_var_unset } from "std/env"
import { text_contains } from "std/text"
import { fresh_world, world_seed, world_noninteractive, world_stage, seed_skills } from "./support/world.ab"
import { mock_install, mock_called } from "./support/mock.ab"
import { state_load, state_get } from "../src/state.ab"
import { cmd_agent } from "../src/agent.ab"

// Pointed at by the e2e tests that need a manifest (mcpServers + branding).
const AGENT_MANIFEST = "test/fixtures/agent_manifest.json"

// ---- file-local helpers (ABOVE the test blocks: define-before-use across the
// import boundary; the test-file tree-shaker keeps only deps textually preceding
// their use). seed_skills() (the skill-tree fixture builder) now lives in
// ./support/world.ab — imported above and shared with the setup suite. ----

// handoff_world <agent_bin> — a world ready for a cmd_agent handoff to <agent_bin>:
// a deployed stage on disk (STAGE_NAME=ma so the guard passes), the skill source +
// manifest + region wired, and the fleet faked to succeed (aws/kubectl/helm for the
// kctx + identity calls, the agent binary so the exec resolves, uvx so aws-mcp's
// requires resolves without a prompt). Returns the WORLD.
fun handoff_world(agent_bin: Text): Text {
    let w = fresh_world()
    world_noninteractive()
    world_seed(w, "STAGE_NAME", "ma")
    seed_skills()
    trust env_var_set("MIGRATE_MANIFEST", AGENT_MANIFEST)
    trust env_var_set("AWS_REGION", "us-east-1")
    mock_install(["aws", "kubectl", "helm", agent_bin, "uvx"])
    return w
}

// ---- cmd_agent: the standalone handoff entrypoint ---------------------------

test "cmd_agent claude sets up skills + MCP, persists state, then execs claude" {
    let w = handoff_world("claude")
    cmd_agent(["claude"])
    // The handoff was recorded in state.
    state_load()
    assert_eq(state_get("AGENT", ""), "claude")
    assert_eq(state_get("last_step", ""), "agent_handoff")
    // The agent binary was exec'd with the fresh-handoff prompt (the manifest's
    // agentFreshPrompt: "Hello from the test manifest.").
    assert(mock_called(w, "claude", "Hello from the test manifest"))
    // Skills + project-scope config landed in the stage.
    assert(file_exists("{w}/CLAUDE.md"))
    assert(file_exists("{w}/.claude/skills/opensearch-migration/Startup.md"))
    assert(file_exists("{w}/.mcp.json"))
    assert(file_exists("{w}/.claude/settings.json"))
    env_var_unset("MIGRATE_MANIFEST")
}

test "cmd_agent claude writes a .mcp.json with the region-substituted server args" {
    let w = handoff_world("claude")
    cmd_agent(["claude"])
    // _mcp_write_claude → jq --argjson encodes the manifest server; the args carry
    // the ${AWS_REGION}-substituted endpoint metadata (the manifest_mcp_args path).
    let body = file_read("{w}/.mcp.json") failed { "" }
    assert(text_contains(body, "mcpServers"))
    assert(text_contains(body, "aws-mcp"))
    assert(text_contains(body, "uvx"))
    assert(text_contains(body, "mcp-proxy-for-aws@latest"))
    assert(text_contains(body, "AWS_REGION=us-east-1"))
    env_var_unset("MIGRATE_MANIFEST")
}

test "cmd_agent claude writes settings.json with the CLI allowlist + manifest perms" {
    let w = handoff_world("claude")
    cmd_agent(["claude"])
    // _agent_write_claude_settings merges the CLI read-only allowlist with the
    // manifest's permissionsAllow (deduped) into the canonical settings.json.
    let body = file_read("{w}/.claude/settings.json") failed { "" }
    assert(text_contains(body, "permissions"))
    assert(text_contains(body, "aws eks list-clusters"))                 // CLI allowlist
    assert(text_contains(body, "mcp__aws-mcp__aws___read_documentation")) // manifest perm
    env_var_unset("MIGRATE_MANIFEST")
}

test "cmd_agent kiro builds the .kiro tree + settings/mcp.json, then execs kiro-cli" {
    // kiro's installed binary is `kiro-cli` (one of its candidate bins).
    let w = handoff_world("kiro-cli")
    cmd_agent(["kiro"])
    state_load()
    assert_eq(state_get("AGENT", ""), "kiro")
    // The .kiro config tree: Startup as the first steering doc + the upstream tree.
    assert(file_exists("{w}/.kiro/steering/00-Startup.md"))
    assert(file_exists("{w}/.kiro/agents/opensearch.json"))
    // MCP registered project-scope under .kiro/settings/mcp.json.
    assert(file_exists("{w}/.kiro/settings/mcp.json"))
    let body = file_read("{w}/.kiro/settings/mcp.json") failed { "" }
    assert(text_contains(body, "aws-mcp"))
    // The kiro-cli binary was exec'd (resolved from its candidate list).
    assert(mock_called(w, "kiro-cli", "chat"))
    env_var_unset("MIGRATE_MANIFEST")
}

test "cmd_agent picks the saved AGENT from state when no name is passed" {
    let w = handoff_world("claude")
    world_seed(w, "AGENT", "claude")
    // No agent name on the argv → cmd_agent reads AGENT from state and hands off.
    cmd_agent([""])
    assert(mock_called(w, "claude", "Hello from the test manifest"))
    state_load()
    assert_eq(state_get("last_step", ""), "agent_handoff")
    env_var_unset("MIGRATE_MANIFEST")
}

test "cmd_agent --stage repoints to the named stage's state and hands off" {
    let w = handoff_world("claude")
    // --stage <world's stage> → STAGE/STAGE_DIR point at the seeded stage so the
    // STAGE_NAME guard passes and the handoff runs against it.
    cmd_agent(["claude", "--stage", world_stage()])
    assert(mock_called(w, "claude", "Hello from the test manifest"))
    assert(file_exists("{w}/.mcp.json"))
    env_var_unset("MIGRATE_MANIFEST")
}
