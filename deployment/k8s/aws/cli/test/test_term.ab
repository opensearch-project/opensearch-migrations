// test_term.ab — coverage for src/term.ab, mirroring test_term.bats.
//
// Strategy: term_panel / term_progress / term_link RETURN the Text they emit,
// so we force interactive mode (MIGRATE_FORCE_TTY=1 in the test runner env) and
// assert on the returned string — no real TTY needed. Pure helpers
// (repeat_char, clip, term_spinner_frame) are asserted directly.

import { assert, assert_eq } from "std/test"
import { esc, term_detect } from "../src/core.ab"
import {
    repeat_char, clip, term_spinner_frame, term_panel, term_progress,
    term_link, term_set_geometry, term_lines, term_columns
} from "../src/term.ab"
import { text_contains, starts_with, ends_with } from "std/text"

// ---- pure helpers ----------------------------------------------------------

test "repeat_char emits N copies (UTF-8 codepoints)" {
    assert_eq(repeat_char("x", 5), "xxxxx")
    assert_eq(repeat_char("█", 3), "███")
}
test "repeat_char with n<=0 emits nothing" {
    assert_eq(repeat_char("#", 0), "")
    assert_eq(repeat_char("#", -3), "")
}
test "clip truncates with ellipsis past width" {
    assert_eq(clip("hello", 10), "hello")
    assert_eq(clip("hello world", 5), "hell…")
}
test "clip counts codepoints not bytes" {
    // 5 codepoints, well under width → unchanged even though it's many bytes.
    assert_eq(clip("café☕", 10), "café☕")
}
test "term_spinner_frame cycles and wraps at 10" {
    assert(term_spinner_frame(0) != term_spinner_frame(1))
    assert_eq(term_spinner_frame(10), term_spinner_frame(0))
}

// ---- geometry --------------------------------------------------------------

test "term_set_geometry round-trips" {
    term_set_geometry(42, 120)
    assert_eq(term_lines(), 42)
    assert_eq(term_columns(), 120)
}

// ---- visual emitters (assert on returned Text) -----------------------------

test "term_link emits OSC 8 when interactive" {
    term_detect()
    let e = esc()
    let out = term_link("https://example.com", "click me")
    assert(text_contains(out, "{e}]8;;https://example.com"))
    assert(text_contains(out, "click me"))
}

test "term_panel renders UTF-8 box when interactive" {
    term_detect()
    term_set_geometry(24, 80)
    let out = term_panel("Cleanup will remove", ["alpha", "beta"])
    assert(text_contains(out, "┏"))
    assert(text_contains(out, "┃"))
    assert(text_contains(out, "┗"))
    assert(text_contains(out, "alpha"))
    assert(text_contains(out, "beta"))
    assert(text_contains(out, "Cleanup will remove"))
}

test "term_progress emits sticky-bottom sequence + pct + counts" {
    term_detect()
    term_set_geometry(24, 80)
    let e = esc()
    let out = term_progress(5, 10, "step msg")
    assert(text_contains(out, "{e}7"))   // save cursor
    assert(text_contains(out, "{e}8"))   // restore cursor
    assert(text_contains(out, "50%"))
    assert(text_contains(out, "[5/10]"))
    assert(text_contains(out, "step msg"))
}
