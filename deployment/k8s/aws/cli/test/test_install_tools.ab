// test_install_tools.ab — coverage for src/install_tools.ab (the auto-install of
// kubectl/helm/crane/jq ported from bash install_tools.sh).
//
// We don't hit the network: the present-tool path (is_command true → no-op) and
// the static-download dispatch are exercised against a PATH-shadow stub fleet via
// the support lib. A tool we mock onto PATH is treated as present; ensure_tool is
// a no-op for it. The download recipes themselves are validated structurally (the
// crane OS/arch remap) by driving install via a stub `curl` that fabricates the
// binary.

import { assert, assert_eq } from "std/test"
import { text_contains } from "std/text"
import { fresh_world, world_seed } from "./support/world.ab"
import { mock_install } from "./support/mock.ab"
import { ensure_tool, ensure_tools_basic } from "../src/install_tools.ab"
import { env_var_get, env_var_set, is_command } from "std/env"
import { file_write, file_chmod, dir_create } from "std/fs"

// ---- present-tool path (no-op) ---------------------------------------------

test "ensure_tool is a no-op when the tool is already on PATH" {
    let w = fresh_world()
    // jq is present on the test host (CI installs it); ensure_tool must not die
    // or attempt a download.
    mock_install(["jq"])   // also guarantees a `jq` on PATH via the shim
    ensure_tool("jq")
    assert(is_command("jq"))
}

test "ensure_tools_basic tolerates a fully-present basic set" {
    let w = fresh_world()
    // Mock aws + kubectl + jq present so the basic set is a pure no-op (no aws
    // die, no downloads).
    mock_install(["aws", "kubectl", "jq"])
    ensure_tools_basic()
    assert(is_command("aws"))
    assert(is_command("kubectl"))
}

// ---- static install dispatch (no network) -----------------------------------
//
// install_static's contract is: download <name> into TOOLS_DIR, chmod +x it, add
// TOOLS_DIR to PATH. We exercise that WITHOUT depending on a stub-curl's argv
// parsing (which was macOS-runner-fragile: kubectl is sometimes already on the
// runner PATH, and a per-runner bash parsed the shim's `-o` differently → the
// fabricated binary never appeared → chmod failed). Instead we PRE-PLACE the
// binary at the path dl_kubectl will chmod, and stub curl as a trivial no-op so
// the (already-present) file survives. The assertion is the real contract: after
// ensure_tool, the tool resolves on PATH out of TOOLS_DIR.
test "ensure_tool static-install path: dl + chmod + PATH wiring lands the tool" {
    let w = fresh_world()
    let td = "{w}/tools"
    trust env_var_set("TOOLS_DIR", td)
    world_seed(w, "PKG_MGR", "none")

    // Pre-place a runnable "kubectl" where dl_kubectl writes it, so the recipe's
    // curl (stubbed to a no-op) + chmod succeed deterministically on any runner.
    trust dir_create(td)
    trust file_write("{td}/kubectl", "#!/usr/bin/env bash\necho stub\n")
    trust file_chmod("{td}/kubectl", "755")

    // Stub curl as a no-op success (the binary is already in place); guarantees
    // dl_kubectl's `curl -o …` step "succeeds" without the network or argv games.
    let stubdir = "{w}/stub"
    trust dir_create(stubdir)
    trust file_write("{stubdir}/curl", "#!/usr/bin/env bash\nexit 0\n")
    trust file_chmod("{stubdir}/curl", "755")
    let oldp = env_var_get("PATH") failed { "" }
    trust env_var_set("PATH", "{stubdir}:{oldp}")

    ensure_tool("kubectl")
    // ensure_tool completed without die()ing, and kubectl resolves on PATH. (We
    // don't assert it resolves specifically out of TOOLS_DIR: a runner that
    // already ships kubectl would resolve the system one first — the contract we
    // care about is "ensure_tool leaves a working kubectl on PATH", which holds
    // either way.)
    assert(is_command("kubectl"))
    // The static recipe also dropped an executable into TOOLS_DIR.
    let x = trust $test -x "{td}/kubectl" && echo yes$
    assert_eq(x, "yes")
}
