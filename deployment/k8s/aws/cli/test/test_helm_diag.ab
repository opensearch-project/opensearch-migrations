// test_helm_diag.ab — e2e coverage for helm_diag.ab (the diagnostics-dump half of
// the bash helm.sh port).
//
// Style (see test/TEST_GUIDE.md): drive the real helm_diag entry points against
// the faked external world, then assert on what the CLI DID — which helm/kubectl
// commands it issued (mock_called) — rather than poking internals. The per-test
// world + the external-tool mock fleet come from test/support/. These dumps are
// SYNCHRONOUS post-hoc captures, so the contract is "which commands were issued",
// which mock_called over the recorded call log verifies directly.
//
// Context threading: every dump entry point calls helm_ctx's helm_kctx_init() at
// entry, which state_load()s from the world's pinned stage dir and binds THIS
// module-instance's helm/kubectl flag prefix from the saved KUBECTL_CONTEXT. The
// world seeds that key (or omits it for the no-context case) — the only channel
// that reaches helm_diag's separate module instance. The binding itself is owned
// + exhaustively tested by test_helm_ctx.ab; here we only verify helm_diag
// THREADS a bound context through to its commands.
//
// What's covered (>= the prior file):
//   * helm_dump_diagnostics — the big on-failure capture: helm status, kubectl
//     get pods -o wide, get events, per-unhealthy-pod describe, stuck-hook-Job
//     describe; and that a bound KUBECTL_CONTEXT threads "--kube-context X" /
//     "--context X" through as argv tokens.
//   * _helm_dump_failed_job — live-pod branch tails the pod's logs; GC'd-pod
//     branch (no pods) issues no `logs` command.
//   * _helm_explain_failure — the helm description's "name: <job>, kind: Job"
//     drives a _helm_dump_failed_job; migration-console-0 status is always queried.
//   * _helm_dump_install_notes — a present ConfigMap (probe exits 0) streams the
//     notes (jsonpath read fires); a never-appearing CM times out fast
//     (INSTALLER_NOTES_TIMEOUT_S=0) without reaching the jsonpath read.
//   * helm_pods_summary — the pure one-awk-pass tally replacement (formatter over
//     a `kubectl get pods` custom-columns snapshot). Kept as direct return-value
//     asserts; exercises the private _first/_second/_third_field extractors.
//
// NO `return` inside a test block (branch with `if`, per AMBER_IDIOMS).

import { assert, assert_eq } from "std/test"
import { file_read } from "std/fs"
import { env_var_set } from "std/env"
import { text_contains } from "std/text"
import { fresh_world, world_seed } from "./support/world.ab"
import {
    mock_install_default, mock_respond, mock_respond_rc,
    mock_called, mock_call_count
} from "./support/mock.ab"
import {
    helm_pods_summary, helm_dump_diagnostics, _helm_dump_failed_job,
    _helm_explain_failure, _helm_dump_install_notes
} from "../src/helm_diag.ab"

// ---- helpers (ABOVE the test blocks: define-before-use across the import
// boundary — the test-file tree-shaker keeps only deps textually preceding their
// use) ------------------------------------------------------------------------

// diag_world — a world wired for a helm/kubectl diagnostics dump: the fleet faked
// and (optionally) a KUBECTL_CONTEXT seeded so helm_kctx_init binds the flag
// prefix. Pass "" for the bare (no-context) case — we simply don't seed the key,
// so state_get falls back to "" → bare helm/kubectl (avoiding the empty-string
// state round-trip). Returns the world dir. The shape behind every e2e test here.
fun diag_world(ctx: Text): Text {
    let w = fresh_world()
    mock_install_default()
    if ctx != "" {
        world_seed(w, "KUBECTL_CONTEXT", ctx)
    }
    return w
}

// ============================================================================
// helm_dump_diagnostics — the on-failure capture; assert the commands issued.
// ============================================================================

test "helm_dump_diagnostics captures helm status, pods, events, and per-resource describe" {
    let w = diag_world("")
    // One unhealthy pod (Pending) and one stuck Job so the per-pod describe + the
    // per-job describe branches both fire. (Tokens `pods` / `jobs` steer these.)
    mock_respond(w, "kubectl", "pods", "stuck-pod Pending")
    mock_respond(w, "kubectl", "jobs", "ma-helm-installer <none>")

    helm_dump_diagnostics("ma", "ma")

    assert(mock_called(w, "helm", "status"))
    assert(mock_called(w, "kubectl", "get pods"))
    assert(mock_called(w, "kubectl", "-o wide"))
    assert(mock_called(w, "kubectl", "get events"))
    assert(mock_called(w, "kubectl", "describe pod stuck-pod"))
    assert(mock_called(w, "kubectl", "describe job ma-helm-installer"))
}

test "helm_dump_diagnostics threads a bound kube-context through helm and kubectl" {
    let w = diag_world("prod-ctx")

    helm_dump_diagnostics("ma", "ma")

    // The context flags reached helm + kubectl as argv tokens (shell word-split
    // of the unquoted "--kube-context prod-ctx" / "--context prod-ctx" prefix).
    assert(mock_called(w, "helm", "--kube-context prod-ctx"))
    assert(mock_called(w, "kubectl", "--context prod-ctx"))
}

// ============================================================================
// _helm_dump_failed_job — live-pod (tail logs) vs GC'd-pod (no logs) branches.
// ============================================================================

test "_helm_dump_failed_job tails the Job pod's logs when the pod still exists" {
    let w = diag_world("")
    // The Job's pods resolve by selector (token `pods`) → the live pod name.
    mock_respond(w, "kubectl", "pods", "ma-helm-installer-xyz12")

    _helm_dump_failed_job("ma-helm-installer", "ma")

    // Job events lookup fired, the pod was resolved by selector, and its logs tailed.
    assert(mock_called(w, "kubectl", "get events"))
    assert(mock_called(w, "kubectl", "involvedObject.name=ma-helm-installer"))
    assert(mock_called(w, "kubectl", "logs ma-helm-installer-xyz12"))
    assert(mock_called(w, "kubectl", "--tail=50"))
}

test "_helm_dump_failed_job handles a GC'd pod (no pods found) without issuing logs" {
    let w = diag_world("")
    // No `pods` fixture → the selector lookup returns empty → the GC'd-pod hint
    // branch (no `logs` command issued).

    _helm_dump_failed_job("ma-helm-installer", "ma")

    assert(mock_called(w, "kubectl", "get pods"))
    assert(not mock_called(w, "kubectl", "logs ma-helm-installer-"))
}

// ============================================================================
// _helm_explain_failure — the helm-description-driven failed-Job dump.
// ============================================================================

test "_helm_explain_failure dumps the Job named in the helm description and queries the console pod" {
    let w = diag_world("")
    // helm status -o json returns a description naming a failed Job (the canonical
    // "name: <job>, kind: Job" shape). Loaded from an on-disk fixture so the JSON
    // braces don't have to be escaped inline.
    let status_json = trust file_read("test/fixtures/helm_status_failed_job.json")
    mock_respond(w, "helm", "status", status_json)

    _helm_explain_failure("ma", "ma")

    assert(mock_called(w, "helm", "status"))
    // The Job name parsed from the description drove the failed-Job event dump —
    // but only when `jq` is on PATH to parse the description. Guard so the test is
    // robust on hosts without jq (the flow must still not error there).
    let have_jq = trust $command -v jq >/dev/null 2>&1 && echo yes || echo no$
    if have_jq == "yes" {
        assert(mock_called(w, "kubectl", "involvedObject.name=ma-helm-installer"))
    }
    // migration-console-0 phase + readiness is queried regardless.
    assert(mock_called(w, "kubectl", "get pod migration-console-0"))
}

// ============================================================================
// _helm_dump_install_notes — present ConfigMap vs never-appearing ConfigMap.
// ============================================================================

test "_helm_dump_install_notes streams the notes when the ConfigMap exists" {
    let w = diag_world("")
    // The CM existence probe exits 0 (default rc) and the jsonpath read returns
    // notes — both keyed on the `configmap` token.
    mock_respond(w, "kubectl", "configmap", "line one\nline two")
    trust env_var_set("INSTALLER_NOTES_TIMEOUT_S", "5")
    trust env_var_set("INSTALLER_NOTES_POLL_S", "0")

    _helm_dump_install_notes("ma", "ma")

    // The existence probe AND the jsonpath notes read both fired against the CM.
    assert(mock_called(w, "kubectl", "get configmap"))
    assert(mock_called(w, "kubectl", "ma-installation-notes"))
    assert(mock_called(w, "kubectl", "jsonpath"))
}

test "_helm_dump_install_notes times out fast when the ConfigMap never appears" {
    let w = diag_world("")
    // The CM probe exits 1 (absent); a 0s timeout → one probe then give up, so the
    // jsonpath notes read is never reached.
    mock_respond_rc(w, "kubectl", "configmap", "1")
    trust env_var_set("INSTALLER_NOTES_TIMEOUT_S", "0")
    trust env_var_set("INSTALLER_NOTES_POLL_S", "0")

    _helm_dump_install_notes("ma", "ma")

    assert(mock_called(w, "kubectl", "get configmap"))
    assert(not mock_called(w, "kubectl", "jsonpath"))
}

// ============================================================================
// helm_pods_summary — the awk-tally replacement (pure formatter; no world/mock).
// ============================================================================

test "helm_pods_summary tallies running/pending/failed with name lists" {
    // NAME  PHASE  READY  — custom-columns output (space-separated).
    let snap = "migration-console-0 Running true\ncapture-proxy-0 Running false\ninstaller-abc Pending <none>\nbad-pod Failed <none>"
    let out = helm_pods_summary(snap)
    assert(text_contains(out, "pods total=4 running=2 pending=1 failed=1"))
    // Pending + failed name lists, and the not-ready (Running but READY=false) one.
    assert(text_contains(out, "pending=[installer-abc]"))
    assert(text_contains(out, "failed=[bad-pod]"))
    assert(text_contains(out, "not_ready=[capture-proxy-0]"))
}

test "helm_pods_summary all-healthy omits the name lists" {
    let snap = "a Running true\nb Running true"
    let out = helm_pods_summary(snap)
    assert(text_contains(out, "pods total=2 running=2 pending=0 failed=0"))
    assert(not text_contains(out, "pending=["))
    assert(not text_contains(out, "failed=["))
    assert(not text_contains(out, "not_ready=["))
}

test "helm_pods_summary returns empty for an empty snapshot" {
    assert_eq(helm_pods_summary(""), "")
    assert_eq(helm_pods_summary("   \n  "), "")
}
