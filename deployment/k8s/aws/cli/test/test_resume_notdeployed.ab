// test_resume_notdeployed.ab — the helm-not-deployed negative branch of
// src/resume.ab's _manual_can_skip_to_console gate.
//
// Split into its own file (see test_resume.ab's header): the helm/kubectl context
// binding (helm_ctx.ab's __helm_ctx_flags_v) is a single process-global shared by
// resume.ab + helm_recover.ab, so a shim steered off it is racy across parallel
// `test` blocks. The fix is ONE consistent shim behavior per file — this file's
// helm shim ALWAYS reports the release as absent (helm `status -o json` exits 0
// with no body → `_helm_release_status` returns "" → not `deployed`), so
// _manual_can_skip_to_console must return false even with last_step=ready +
// STAGE_NAME set.

import { assert } from "std/test"
import { file_write, file_chmod, dir_create } from "std/fs"
import { env_var_set, env_var_get } from "std/env"
import { text_contains } from "std/text"
import { state_load, state_set, state_save } from "../src/state.ab"
import { _manual_can_skip_to_console } from "../src/resume.ab"

let __seq = 0
const STUB_DIR = "/tmp/amber_resume_nd_stub"
let __installed = false

// install_stubs — helm `status … -o json` ALWAYS exits 0 with no body (release
// absent); kubectl get-pod succeeds (irrelevant — the helm check short-circuits
// first). One atomic publish, content-stable, brace-free.
fun install_stubs(): Null {
    trust dir_create(STUB_DIR)
    if __installed {
        let oldp0 = env_var_get("PATH") failed { "" }
        if not text_contains(oldp0, "{STUB_DIR}:") {
            trust env_var_set("PATH", "{STUB_DIR}:{oldp0}")
        }
        return null
    }
    __installed = true

    let kubectl = "#!/usr/bin/env bash
exit 0
"
    let ktmp = trust $mktemp$
    trust file_write(ktmp, kubectl)
    trust file_chmod(ktmp, "755")
    trust $mv -f "{ktmp}" "{STUB_DIR}/kubectl"$

    // status … json → exit 0 with NO output → _helm_release_status sees "" →
    // release absent. status (non-json) → a plausible non-deployed line.
    let helm = "#!/usr/bin/env bash
args=\"$*\"
case \"$args\" in
  *status*json*)
    exit 0 ;;
  *status*)
    printf 'NAME: ma\\nSTATUS: uninstalling\\n' ;;
  *)
    exit 0 ;;
esac
exit 0
"
    let htmp = trust $mktemp$
    trust file_write(htmp, helm)
    trust file_chmod(htmp, "755")
    trust $mv -f "{htmp}" "{STUB_DIR}/helm"$

    let oldpath = env_var_get("PATH") failed { "" }
    if not text_contains(oldpath, "{STUB_DIR}:") {
        trust env_var_set("PATH", "{STUB_DIR}:{oldpath}")
    }
}

fun fresh_stage(): Null {
    __seq += 1
    let base = trust $mktemp -d$
    let dir = "{base}/stage-{__seq}"
    trust dir_create(dir)
    trust dir_create("{dir}/log")
    trust env_var_set("STAGE_DIR", dir)
    trust env_var_set("MIGRATE_HOME", base)
    trust env_var_set("STAGE", "stage-{__seq}")
}

test "_manual_can_skip_to_console is false when the release is not deployed" {
    install_stubs()
    fresh_stage()
    state_load()
    state_set("STAGE_NAME", "ma")
    state_set("last_step", "ready")
    state_save()
    // last_step + STAGE_NAME pass the pre-helm gates, but helm reports absent →
    // _helm_release_status != "deployed" → false.
    assert(not _manual_can_skip_to_console())
}
