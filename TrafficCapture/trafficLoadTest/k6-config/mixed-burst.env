# Burst mixed profile
#
# Both ingest and search streams hold at a quiet baseline for 1 minute, then
# spike together, hold the spike, recover, and hold at baseline again:
#   - Ingest: 20 → 150 req/s spike
#   - Search: 15 → 100 req/s spike
#
# The asymmetric spike targets (ingest higher than search) reflect a write-heavy
# burst — typical for a bulk-load event landing on top of steady query traffic.
#
# Use this to observe:
#   - Whether the Capture Proxy handles combined burst traffic without crash or
#     stuck connections — check the Request Rate vs Captured panel for drops
#   - Kafka offset acceleration during the spike and drain behaviour afterwards
#   - Write-then-read consistency miss rate: the ring fills faster during the
#     burst so consistency_misses should drop, not rise, during the ingest spike
#   - Search latency under combined burst load (agg p95 will breach — expected)
#
# NOTE: k6 will exit non-zero due to threshold breaches during the spike.
# Use Grafana time-series panels, not the exit code, to evaluate behaviour.
#
# Total test duration: 4 minutes 30 seconds.

CAPTURE_PROXY_URL=https://capture-proxy:9200
EXECUTOR=ramping-arrival-rate
INGEST_RAMP_STAGES=[{"duration":"1m","target":20},{"duration":"30s","target":150},{"duration":"30s","target":150},{"duration":"30s","target":20},{"duration":"2m","target":20}]
SEARCH_RAMP_STAGES=[{"duration":"1m","target":15},{"duration":"30s","target":100},{"duration":"30s","target":100},{"duration":"30s","target":15},{"duration":"2m","target":15}]

INGEST_VUS=60
INGEST_MAX_VUS=250
SEARCH_VUS=40
SEARCH_MAX_VUS=150

BULK_BATCH_SIZE=20
SEQUENCE_FRACTION=0.15
CONSISTENCY_FRACTION=0.10
CONNECTION_MODE=pinned
WEBDIS_URL=http://webdis:7379
REGISTRY_ENABLED=true

# Ring is pre-filled during the 1-minute baseline warmup (~20 req/s × 25.5% single-doc ≈ 5 IDs/s).
# MIN_RING_FILL=50 ensures search VUs wait for ~10s of warmup before starting.
MIN_RING_FILL=50
