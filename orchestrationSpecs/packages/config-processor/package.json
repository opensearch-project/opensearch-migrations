{
  "name": "@opensearch-migrations/config-processor",
  "version": "1.0.0",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "type-check": "npx tsgo -p ../../tsconfig.typecheck.processor.json --noEmit",
    "start-initialize": "tsx src/RunMigrationConfigTransformer.ts",
    "start-transform": "tsx src/RunMigrationConfigTransformer.ts",
    "dev-cmd": "tsx src/cliRouter.ts",
    "dev-initialize": "tsx src/runMigrationInitializer.ts",
    "dev-transform": "tsx src/runMigrationConfigTransformer.ts",
    "bundle": "node makeBundle.js",
    "check-and-bundle": "npm run type-check && npm run test && npm run bundle",
    "test": "jest --coverage --config ./jest.config.js",
    "test:integ:crds": "jest --config ./jest.integ.config.js --runTestsByPath tests/integ/generatedMigrationCrds.integ.test.ts"
  },
  "dependencies": {
    "@opensearch-migrations/schemas": "*",
    "ajv": "^8.20.0",
    "ci": "^2.3.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testcontainers/k3s": "^12.0.2",
    "@types/jest": "*",
    "@types/node": "^26.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  }
}
