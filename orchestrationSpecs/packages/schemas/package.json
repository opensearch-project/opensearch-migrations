{
  "name": "@opensearch-migrations/schemas",
  "version": "1.0.0",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./buildUnifiedSchema": "./src/buildUnifiedSchema.ts",
    "./makeSample": "./src/makeSample.ts",
    "./showUserSchema": "./src/showUserSchema.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "echo 'schemas: no build step needed (exports .ts directly)'",
    "type-check": "tsc --noEmit",
    "build-unified-schema": "node --import tsx src/buildUnifiedSchema.ts",
    "build-migration-crds": "node --import tsx src/generateMigrationResources.ts --crds",
    "build-vap-policies": "node --import tsx src/generateMigrationResources.ts --vaps",
    "stage-migration-resources": "node --import tsx src/generateMigrationResources.ts --all",
    "rebuild-kafka-broker-config-schema": "node --import tsx src/generateKafkaBrokerConfigSchema.ts",
    "schema": "tsx src/showUserSchema.ts",
    "argo-schema": "tsx src/showArgoSchema.ts",
    "make-sample": "tsx src/makeSample.ts",
    "test": "jest --coverage"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@opensearch-migrations/strimzi-types": "*",
    "ajv": "^8.20.0",
    "deepmerge": "^4.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/jest": "*",
    "expect-type": "*",
    "testcontainers": "^12.0.2"
  }
}
