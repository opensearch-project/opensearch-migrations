                        "replicas": 3,
                        "config": {
                          "retention.ms": 604800000,
                          "segment.bytes": 1073741824
                        }
                      },
                      "required": [
                        "partitions",
                        "replicas",
                        "config"
                      ]
                    },
                    "label": {
                      "type": "string"
                    },
                    "configChecksum": {
                      "type": "string"
                    },
                    "clusterResourceUid": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "kafkaConnection",
                    "label",
                    "configChecksum"
                  ]
                },
                "replayerConfig": {
                  "type": "object",
                  "properties": {
                    "jvmArgs": {
                      "type": "string",
                      "default": ""
                    },
                    "loggingConfigurationOverrideConfigMap": {
                      "type": "string",
                      "default": ""
                    },
                    "podReplicas": {
                      "type": "number",
                      "default": 1
                    },
                    "resources": {
                      "type": "object",
                      "nullable": true,
                      "properties": {
                        "limits": {
                          "type": "object",
                          "properties": {
                            "cpu": {
                              "type": "string",
                              "pattern": "^[0-9]+m$",
                              "description": "CPU allocation for the container in Kubernetes millicores."
                            },
                            "memory": {
                              "type": "string",
                              "pattern": "^[0-9]+(([EPTGM])i?|Ki|k)$",
                              "description": "Memory allocation for the container."
                            },
                            "ephemeral-storage": {
                              "type": "string",
                              "pattern": "^[0-9]+(([EPTGM])i?|Ki|k)$",
                              "description": "Ephemeral storage allocation for the container. Used for temporary on-disk data such as Lucene index segments during RFS document migration."
                            }
                          },
                          "required": [
                            "cpu",
                            "memory"
                          ],
                          "description": "Maximum resource limits for the container. The container will be terminated if it exceeds these limits."
                        },
                        "requests": {
                          "type": "object",
                          "properties": {
                            "cpu": {
                              "type": "string",
                              "pattern": "^[0-9]+m$",
                              "description": "CPU allocation for the container in Kubernetes millicores."
                            },
                            "memory": {
                              "type": "string",
                              "pattern": "^[0-9]+(([EPTGM])i?|Ki|k)$",
                              "description": "Memory allocation for the container."
                            },
                            "ephemeral-storage": {
                              "type": "string",
                              "pattern": "^[0-9]+(([EPTGM])i?|Ki|k)$",
                              "description": "Ephemeral storage allocation for the container. Used for temporary on-disk data such as Lucene index segments during RFS document migration."
                            }
                          },
                          "required": [
                            "cpu",
                            "memory"
                          ],
                          "description": "Minimum guaranteed resources for the container. Used by the Kubernetes scheduler for pod placement."
                        }
                      },
                      "required": [
                        "limits",
                        "requests"
                      ],
                      "description": "Kubernetes resource limits and requests for the replayer container. Partial overrides are deep-merged with the built-in defaults. By default, limits equal requests, giving the pod 'Guaranteed' QoS (least likely to be evicted). Setting requests lower than limits results in 'Burstable' QoS, allowing the pod to use less resources when idle but burst up to the limit."
                    },
                    "kafkaTrafficEnableMSKAuth": {
                      "type": "boolean",
                      "default": false
                    },
                    "kafkaTrafficPropertyFile": {
                      "type": "string",
                      "description": "[Expert] Path to a Java properties file with additional or overridden Kafka consumer configuration. The file must be mounted into the container by the user (e.g. via Kyverno pod mutation or custom image). Not wired through the workflow by default.",
                      "changeRestriction": "impossible"
                    },
                    "lookaheadTimeSeconds": {
                      "type": "number",
                      "default": 400
                    },
                    "maxConcurrentRequests": {
                      "type": "number",
                      "default": 10000
                    },
                    "numClientThreads": {
                      "type": "number",
                      "default": 0
                    },
                    "nonRetryableDocExceptionTypes": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      },
                      "description": "List of document-level exception types that should not be retried during bulk replay. These errors still count as failures in the output but are not retried because they are deterministic client or mapping errors that will produce the same result on every attempt. When omitted, defaults to a built-in set including version_conflict_engine_exception, mapper_parsing_exception, strict_dynamic_mapping_exception, and others. Set explicitly to override the defaults entirely (not additive). Common values: version_conflict_engine_exception, mapper_parsing_exception, illegal_argument_exception, resource_already_exists_exception."
                    },
                    "observedPacketConnectionTimeout": {
                      "type": "number",
                      "default": 360
                    },
                    "otelCollectorEndpoint": {
                      "type": "string",
                      "default": "http://otel-collector:4317"
                    },
                    "quiescentPeriodMs": {
                      "type": "number",
                      "default": 5000
                    },
                    "removeAuthHeader": {
                      "type": "boolean",
                      "default": false
                    },
                    "speedupFactor": {
                      "type": "number",
                      "default": 1.1
                    },
                    "targetServerResponseTimeoutSeconds": {
                      "type": "number",
                      "default": 150
                    },
                    "transformerConfig": {
                      "type": "string",
                      "description": "Inline request transformer configuration as a JSON string. Request transformers modify each captured HTTP request before it is replayed to the target cluster.",
                      "changeRestriction": "gated"
                    },
                    "transformerConfigEncoded": {
                      "type": "string",
                      "description": "Base64-encoded request transformer configuration, for configurations that would be cumbersome to otherwise encode in a JSON field. Request transformers modify each captured HTTP request before it is replayed to the target cluster.",
                      "changeRestriction": "gated"
                    },
                    "transformerConfigFile": {
                      "type": "string",
                      "description": "Path to a JSON file containing request transformer configuration. Request transformers modify each captured HTTP request before it is replayed to the target cluster. [Expert] The file must be mounted into the container by the user (e.g. via Kyverno pod mutation or custom image). Not wired through the workflow by default.",
                      "changeRestriction": "gated"
                    },
                    "tupleTransformerConfig": {
                      "type": "string",
                      "description": "Inline tuple transformer configuration as a JSON string. Tuple transformers operate on request-response pairs, enabling stateful transformations that depend on the source cluster's response.",
                      "changeRestriction": "gated"
                    },
                    "tupleTransformerConfigBase64": {
                      "type": "string",
                      "description": "Base64-encoded tuple transformer configuration. Tuple transformers operate on request-response pairs, enabling stateful transformations that depend on the source cluster's response.",
                      "changeRestriction": "gated"
                    },
                    "tupleTransformerConfigFile": {
                      "type": "string",
                      "description": "Path to a JSON file containing tuple transformer configuration. Tuple transformers operate on request-response pairs, enabling stateful transformations that depend on the source cluster's response. [Expert] The file must be mounted into the container by the user (e.g. via Kyverno pod mutation or custom image). Not wired through the workflow by default.",
                      "changeRestriction": "gated"
                    },
                    "tupleMaxBufferSeconds": {
                      "type": "number",
                      "default": 60
                    },
                    "tupleMaxFileSizeMb": {
                      "type": "number",
                      "default": 256
                    },
                    "userAgent": {
                      "type": "string",
                      "description": "String appended to the User-Agent header on all replayed requests to the target cluster. Useful for identifying replayed traffic in target cluster logs."
                    }
                  }
                },
                "toTarget": {
                  "type": "object",
                  "properties": {
                    "endpoint": {
                      "type": "string",
                      "pattern": "^https?:\\\\/\\\\/[^:\\\\/\\\\s]+(?::(?:[1-9]\\\\d{0,3}|[1-5]\\\\d{4}|6[0-4]\\\\d{3}|65[0-4]\\\\d{2}|655[0-2]\\\\d|6553[0-5]))?(?:\\\\/)?$",
                      "description": "HTTP(S) endpoint URL for the target cluster (e.g. 'https://target-cluster:9200/'). Required for target clusters."
                    },
                    "allowInsecure": {
                      "type": "boolean",
                      "default": false
                    },
                    "authConfig": {
                      "anyOf": [
                        {
                          "type": "object",
                          "properties": {
                            "basic": {
                              "type": "object",
                              "properties": {
                                "secretName": {
                                  "type": "string",
                                  "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?(\\\\.[a-z0-9]([-a-z0-9]*[a-z0-9])?)*$",
                                  "description": "Name of a Kubernetes Secret containing 'username' and 'password' keys for HTTP Basic authentication."
                                }
                              },
                              "required": [
                                "secretName"
                              ]
                            }
                          },
                          "required": [
                            "basic"
                          ],
                          "description": "HTTP Basic authentication using credentials from a Kubernetes Secret."
                        },
                        {
                          "type": "object",
                          "properties": {
                            "sigv4": {
                              "type": "object",
                              "properties": {
                                "region": {
                                  "type": "string",
                                  "description": "AWS region for SigV4 request signing (e.g. 'us-east-1')."
                                },
                                "service": {
                                  "type": "string",
                                  "default": "es",
                                  "description": "AWS service name for SigV4 signing. Use 'es' for Amazon OpenSearch Service or 'aoss' for OpenSearch Serverless."
                                }
                              },
                              "required": [
                                "region"
                              ]
                            }
                          },
                          "required": [
                            "sigv4"
                          ],
                          "description": "AWS SigV4 request signing authentication. Uses the pod's IAM role credentials via EKS Pod Identity."
                        },
                        {
                          "type": "object",
                          "properties": {
                            "mtls": {
                              "type": "object",
                              "properties": {
                                "caCert": {
                                  "type": "string",
                                  "description": "PEM-encoded CA certificate or path to CA certificate file for verifying the server's TLS certificate."
                                },
                                "clientSecretName": {
                                  "type": "string",
                                  "description": "Name of a Kubernetes TLS Secret containing the client certificate and private key for mutual TLS authentication."
                                }
                              },
                              "required": [
                                "caCert",
                                "clientSecretName"
                              ]
                            }
                          },
                          "required": [
                            "mtls"
                          ],
                          "description": "Mutual TLS (mTLS) authentication using client certificates."
                        }
                      ],
                      "description": "Authentication configuration for connecting to the cluster. Supports HTTP Basic (Kubernetes Secret), AWS SigV4, or mutual TLS."
                    },
                    "label": {
                      "type": "string",
                      "pattern": "^[a-zA-Z0-9_]+$"
                    }
                  },
                  "required": [
                    "endpoint",
                    "label"
                  ]
                },
                "configChecksum": {
                  "type": "string"
                },
                "resourceUid": {
                  "type": "string"
                }
              },
              "required": [
                "name",
                "sourceLabel",
                "dependsOn",
                "dependsOnSnapshotMigrations",
                "fromProxy",
                "fromProxyConfigChecksum",
                "kafkaClusterName",
                "kafkaConfig",
                "replayerConfig",
                "toTarget",
                "configChecksum",
                "resourceUid"
              ]
            },
            "default": []
          }
        }
      }
    }
  },
  "required": [
    "items"
  ]
}"
