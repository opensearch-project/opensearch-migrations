            "default": []
          },
          "snapshots": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "createSnapshotConfig": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "label": {
                        "type": "string"
                      },
                      "snapshotPrefix": {
                        "type": "string"
                      },
                      "config": {
                        "type": "object",
                        "properties": {
                          "jvmArgs": {
                            "type": "string",
                            "default": ""
                          },
                          "loggingConfigurationOverrideConfigMap": {
                            "type": "string",
                            "default": ""
                          },
                          "indexAllowlist": {
                            "type": "array",
                            "items": {
                              "type": "string"
                            },
                            "default": []
                          },
                          "maxSnapshotRateMbPerNode": {
                            "type": "number",
                            "default": 0
                          },
                          "compressionEnabled": {
                            "type": "boolean",
                            "default": false
                          },
                          "includeGlobalState": {
                            "type": "boolean",
                            "default": true
                          }
                        }
                      },
                      "repo": {
                        "type": "object",
                        "properties": {
                          "awsRegion": {
                            "type": "string",
