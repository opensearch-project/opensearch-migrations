        },
        "log.cleaner.dedupe.buffer.size": {
          "type": "integer",
          "description": "The total memory used for log deduplication across all cleaner threads",
          "x-kafka-type": "long",
          "x-kafka-importance": "medium",
          "x-kafka-update-mode": "cluster-wide",
          "default": 134217728
        },
        "log.cleaner.delete.retention.ms": {
          "type": "integer",
          "description": "The amount of time to retain tombstone message markers for log compacted topics. This setting also gives a bound on the time in which a consumer must complete a read if they begin from offset 0 to ensure that they get a valid snapshot of the final stage (otherwise tombstones messages may be collected before a consumer completes their scan).",
          "x-kafka-type": "long",
          "x-kafka-importance": "medium",
          "x-kafka-update-mode": "cluster-wide",
          "x-kafka-valid-values": "[0,...]",
          "default": 86400000
        },
        "log.cleaner.enable": {
          "type": "boolean",
          "description": "This configuration has been deprecated and will be removed in Kafka 5.0. Users should not set it to false to prepare for its future removal. Enable the log cleaner process to run on the server. Should be enabled if using any topics with a cleanup.policy=compact including the internal offsets topic. If disabled those topics will not be compacted and continually grow in size.",
          "x-kafka-type": "boolean",
          "x-kafka-importance": "medium",
          "x-kafka-update-mode": "read-only",
          "default": true
        },
        "log.cleaner.io.buffer.load.factor": {
          "type": "number",
          "description": "Log cleaner dedupe buffer load factor. The percentage full the dedupe buffer can become. A higher value will allow more log to be cleaned at once but will lead to more hash collisions",
          "x-kafka-type": "double",
          "x-kafka-importance": "medium",
          "x-kafka-update-mode": "cluster-wide",
          "default": 0.9
        },
        "log.cleaner.io.buffer.size": {
          "type": "integer",
          "description": "The total memory used for log cleaner I/O buffers across all cleaner threads",
          "x-kafka-type": "int",
          "x-kafka-importance": "medium",
          "x-kafka-update-mode": "cluster-wide",
          "x-kafka-valid-values": "[0,...]",
          "default": 524288
        },
        "log.cleaner.io.max.bytes.per.second": {
          "type": "number",
          "description": "The log cleaner will be throttled so that the sum of its read and write i/o will be less than this value on average",
          "x-kafka-type": "double",
          "x-kafka-importance": "medium",
          "x-kafka-update-mode": "cluster-wide",
          "default": 1.7976931348623157e+308
        },
        "log.cleaner.max.compaction.lag.ms": {
          "type": "integer",
          "description": "The maximum time a message will remain ineligible for compaction in the log. Only applicable for logs that are being compacted.",
          "x-kafka-type": "long",
          "x-kafka-importance": "medium",
          "x-kafka-update-mode": "cluster-wide",
          "x-kafka-valid-values": "[1,...]",
          "default": 9223372036854776000
        },
        "log.cleaner.min.cleanable.ratio": {
          "type": "number",
          "description": "The minimum ratio of dirty log to total log for a log to eligible for cleaning. If the log.cleaner.max.compaction.lag.ms or the log.cleaner.min.compaction.lag.ms configurations are also specified, then the log compactor considers the log eligible for compaction as soon as either: (i) the dirty ratio threshold has been met and the log has had dirty (uncompacted) records for at least the log.cleaner.min.compaction.lag.ms duration, or (ii) if the log has had dirty (uncompacted) records for at most the log.cleaner.max.compaction.lag.ms period.",
          "x-kafka-type": "double",
          "x-kafka-importance": "medium",
          "x-kafka-update-mode": "cluster-wide",
          "x-kafka-valid-values": "[0,...,1]",
          "default": 0.5
        },
        "log.cleaner.min.compaction.lag.ms": {
          "type": "integer",
          "description": "The minimum time a message will remain uncompacted in the log. Only applicable for logs that are being compacted.",
          "x-kafka-type": "long",
          "x-kafka-importance": "medium",
          "x-kafka-update-mode": "cluster-wide",
          "x-kafka-valid-values": "[0,...]",
          "default": 0
        },
        "log.cleaner.threads": {
          "type": "integer",
          "description": "The number of background threads to use for log cleaning",
          "x-kafka-type": "int",
          "x-kafka-importance": "medium",
          "x-kafka-update-mode": "cluster-wide",
          "x-kafka-valid-values": "[0,...]",
          "default": 1
        },
        "log.cleanup.policy": {
          "type": "string",
          "description": "This config designates the retention policy to use on log segments. The \\"delete\\" policy (which is the default) will discard old segments when their retention time or size limit has been reached. The \\"compact\\" policy will enable log compaction , which retains the latest value for each key. It is also possible to specify both policies in a comma-separated list (e.g. \\"delete,compact\\"). In this case, old segments will be discarded per the retention time and size configuration, while retained segments will be compacted. An empty list means infinite retention - no cleanup policies will be applied and log segments will be retained indefinitely. Note that with remote storage enabled, local retention limits (log.local.retention.ms and log.local.retention.bytes) are still applied to local segments.",
          "x-kafka-type": "list",
          "x-kafka-importance": "medium",
          "x-kafka-update-mode": "cluster-wide",
          "x-kafka-valid-values": "[compact, delete]",
          "default": "delete"
        },
        "log.dir.failure.timeout.ms": {
          "type": "integer",
          "description": "If the broker is unable to successfully communicate to the controller that some log directory has failed for longer than this time, the broker will fail and shut down.",
