                      "type": "boolean",
                      "default": false
                    },
                    "kafkaConnection": {
                      "type": "string",
                      "pattern": "^(?:[a-z0-9][-a-z0-9.]*:(?:[1-9]\\\\d{0,3}|[1-5]\\\\d{4}|6[0-4]\\\\d{3}|65[0-4]\\\\d{2}|655[0-2]\\\\d|6553[0-5])(?:,(?!$)|$))*$"
                    },
                    "kafkaTopic": {
                      "type": "string",
                      "default": "",
                      "description": "Default Kafka topic name for this cluster. Can be overridden per-proxy via the capture config's kafkaTopic field."
                    },
                    "managedByWorkflow": {
                      "type": "boolean",
                      "default": false
                    },
