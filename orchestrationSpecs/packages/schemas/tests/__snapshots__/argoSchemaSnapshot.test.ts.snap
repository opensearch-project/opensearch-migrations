          "description": "The socket timeout for network requests. Its value should be at least replica.fetch.wait.max.ms",
          "x-kafka-type": "int",
          "x-kafka-importance": "high",
          "x-kafka-update-mode": "read-only",
          "default": 30000
        },
        "replication.quota.window.num": {
