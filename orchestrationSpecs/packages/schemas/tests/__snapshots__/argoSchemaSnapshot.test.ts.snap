                        "type": "string"
                      },
                      "semaphoreKey": {
                        "type": "string"
                      },
                      "dependsOnProxySetups": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "properties": {
                            "name": {
                              "type": "string"
                            },
                            "configChecksum": {
                              "type": "string"
                            }
                          },
                          "required": [
