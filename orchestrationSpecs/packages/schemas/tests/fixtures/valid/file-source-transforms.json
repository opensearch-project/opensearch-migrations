{
  "sourceClusters": {
    "source": {
      "version": "ES 7.10.2",
      "endpoint": "http://source:9200"
    }
  },
  "targetClusters": {
    "target": {
      "endpoint": "http://target:9200"
    }
  },
  "snapshotMigrationConfigs": [],
  "traffic": {
    "proxies": {
      "proxy": {
        "source": "source",
        "proxyConfig": {
          "listenPort": 9200,
          "tls": {
            "mode": "existingSecret",
            "secretName": "proxy-tls",
            "clientAuth": {
              "trustedClientCaFile": {
                "configMap": "trusted-client-roots",
                "path": "ca.crt"
              }
            }
          }
        }
      }
    },
    "replayers": {
      "replayer": {
        "fromCapturedTraffic": "proxy",
        "toTarget": "target",
        "replayerConfig": {
          "requestTransforms": [
            {
              "entryPoint": {
                "javascriptFile": {
                  "image": "example.com/transforms@sha256:abc123",
                  "path": "request.js"
                }
              },
              "context": {
                "valueDirectories": [
                  {
                    "configMap": "request-context"
                  }
                ],
                "values": {
                  "settings": {
                    "fromFile": {
                      "configMap": "request-context",
                      "path": "settings.json"
                    }
                  }
                }
              }
            }
          ],
          "tupleTransforms": [
            {
              "transformName": "TypeMappingSanitizationTransformerProvider",
              "context": "tuple-context"
            }
          ]
        }
      }
    }
  }
}
