{
  "kafkaClusterConfiguration": {
    "kc-a": {
      "autoCreate": {}
    },
    "kc-b": {
      "autoCreate": {}
    }
  },
  "sourceClusters": {
    "source": {
      "version": "ES 7.10.2",
      "endpoint": "http://source:9200"
    }
  },
  "targetClusters": {
    "target": {
      "endpoint": "http://target:9200"
    },
    "target2": {
      "endpoint": "http://target2:9200"
    }
  },
  "snapshotMigrationConfigs": [],
  "traffic": {
    "proxies": {
      "p1": {
        "source": "source",
        "kafka": "kc-a",
        "kafkaTopic": "shared-topic",
        "proxyConfig": {
          "listenPort": 9201
        }
      },
      "p2": {
        "source": "source",
        "kafka": "kc-b",
        "kafkaTopic": "shared-topic",
        "proxyConfig": {
          "listenPort": 9202
        }
      }
    },
    "replayers": {
      "r1": {
        "fromCapturedTraffic": "p1",
        "toTarget": "target"
      },
      "r2": {
        "fromCapturedTraffic": "p2",
        "toTarget": "target2"
      }
    }
  }
}
