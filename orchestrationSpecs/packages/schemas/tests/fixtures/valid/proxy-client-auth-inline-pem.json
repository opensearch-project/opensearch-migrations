{
  "sourceClusters": {
    "source": {
      "version": "ES 7.10.2",
      "endpoint": "http://source:9200"
    }
  },
  "targetClusters": {
    "target": {
      "endpoint": "http://target:9200"
    }
  },
  "snapshotMigrationConfigs": [],
  "traffic": {
    "proxies": {
      "proxy": {
        "source": "source",
        "proxyConfig": {
          "listenPort": 9200,
          "tls": {
            "mode": "existingSecret",
            "secretName": "proxy-tls",
            "clientAuth": {
              "trustedClientCaPem": "-----BEGIN CERTIFICATE-----\nMIIBtest\n-----END CERTIFICATE-----"
            }
          }
        }
      }
    },
    "replayers": {
      "replayer": {
        "fromCapturedTraffic": "proxy",
        "toTarget": "target"
      }
    }
  }
}
