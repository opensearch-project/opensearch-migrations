{
  "sourceClusters": {
    "source": {
      "version": "ES 7.10.2",
      "endpoint": "http://source:9200"
    }
  },
  "targetClusters": {
    "target": {
      "endpoint": "http://target:9200"
    },
    "target2": {
      "endpoint": "http://target2:9200"
    }
  },
  "snapshotMigrationConfigs": [],
  "traffic": {
    "proxies": {
      "live-capture": {
        "source": "source",
        "proxyConfig": {
          "listenPort": 9201
        }
      }
    },
    "s3Sources": {
      "loaded-dump": {
        "s3Uri": "s3://byo-traffic/kafka_export_slice_10k.proto.gz",
        "awsRegion": "us-east-2",
        "sourceLabel": "source"
      }
    },
    "replayers": {
      "replayLive": {
        "fromCapturedTraffic": "live-capture",
        "toTarget": "target"
      },
      "replayDump": {
        "fromCapturedTraffic": "loaded-dump",
        "toTarget": "target2"
      }
    }
  }
}
