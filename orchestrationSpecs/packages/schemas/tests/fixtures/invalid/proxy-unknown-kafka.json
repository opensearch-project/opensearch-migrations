{
  "sourceClusters": {
    "source": { "version": "ES 7.10.2", "endpoint": "http://source:9200" }
  },
  "targetClusters": {
    "target": { "endpoint": "http://target:9200" }
  },
  "snapshotMigrationConfigs": [],
  "traffic": {
    "kafkaClusters": {
      "my-kafka": { "autoCreate": { "replicas": 1, "storage": { "type": "ephemeral" } } }
    },
    "proxies": {
      "proxy1": {
        "source": "source",
        "kafka": "does-not-exist",
        "listenPort": 9201,
        "proxyConfig": { "listenPort": 9201 }
      }
    },
    "replayers": {
      "replayer1": { "fromCapturedTraffic": "proxy1", "toTarget": "target" }
    }
  }
}
