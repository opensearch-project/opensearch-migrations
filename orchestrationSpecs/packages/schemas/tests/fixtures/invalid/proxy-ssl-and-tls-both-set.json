{
  "sourceClusters": {
    "source": {
      "version": "ES 7.10.2",
      "endpoint": "http://source:9200"
    }
  },
  "targetClusters": {
    "target": {
      "endpoint": "http://target:9200"
    }
  },
  "snapshotMigrationConfigs": [],
  "traffic": {
    "proxies": {
      "proxy1": {
        "source": "source",
        "proxyConfig": {
          "listenPort": 9201,
          "sslConfigFile": "/path/to/ssl.yml",
          "tls": {
            "mode": "existingSecret",
            "secretName": "my-tls-secret"
          }
        }
      }
    },
    "replayers": {}
  }
}
