{
  "sourceClusters": {
    "source": {
      "version": "ES 7.10.2",
      "endpoint": "http://source:9200"
    }
  },
  "targetClusters": {
    "target": {
      "endpoint": "http://target:9200"
    }
  },
  "snapshotMigrationConfigs": [],
  "traffic": {
    "proxies": {
      "proxy": {
        "source": "source",
        "proxyConfig": {
          "listenPort": 9200
        }
      }
    },
    "replayers": {
      "replayer": {
        "fromCapturedTraffic": "proxy",
        "toTarget": "target",
        "replayerConfig": {
          "requestTransforms": [
            {
              "entryPoint": {
                "javascript": "function transformJson(value) { return value; }"
              },
              "context": {
                "values": {
                  "settings": {}
                }
              }
            }
          ]
        }
      }
    }
  }
}
