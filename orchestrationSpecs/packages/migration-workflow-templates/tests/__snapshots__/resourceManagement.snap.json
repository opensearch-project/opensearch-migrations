{
  "apiVersion": "argoproj.io/v1alpha1",
  "kind": "WorkflowTemplate",
  "metadata": {
    "name": "resource-management"
  },
  "spec": {
    "serviceAccountName": "argo-workflow-executor",
    "parallelism": 100,
    "arguments": {
      "parameters": [
        {
          "name": "s3SnapshotConfigMap",
          "value": "s3-snapshot-config"
        },
        {
          "name": "imageConfigMapName",
          "value": "migration-image-config"
        },
        {
          "name": "approvalConfigMapName",
          "value": "approval-config"
        }
      ]
    },
    "templates": [
      {
        "name": "waitforkafkaclustercreated",
        "inputs": {
          "parameters": [
            {
              "name": "resourceName"
            },
            {
              "name": "imageMigrationConsoleLocation"
            },
            {
              "name": "imageMigrationConsolePullPolicy"
            }
          ]
        },
        "container": {
          "env": [],
          "image": "{{inputs.parameters.imageMigrationConsoleLocation}}",
          "imagePullPolicy": "{{inputs.parameters.imageMigrationConsolePullPolicy}}",
          "command": [
            "kubectl"
          ],
          "args": [
            "wait",
            "--for=create",
            "{{='kafka/'+inputs.parameters.resourceName}}",
            "--timeout=31536000s"
          ],
          "resources": {
            "limits": {
              "cpu": "50m",
              "memory": "64Mi"
            },
            "requests": {
              "cpu": "50m",
              "memory": "32Mi"
            }
          }
        },
        "metadata": {
          "annotations": {
            "karpenter.sh/do-not-disrupt": "true"
          }
        },
        "activeDeadlineSeconds": "31536000",
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "waitforkafkaclusterready",
        "inputs": {
          "parameters": [
            {
              "name": "resourceName"
            },
            {
              "name": "configChecksum"
            },
            {
              "name": "imageMigrationConsoleLocation"
            },
            {
              "name": "imageMigrationConsolePullPolicy"
            }
          ]
        },
        "resource": {
          "manifest": "apiVersion: kafka.strimzi.io/v1\nkind: Kafka\nmetadata:\n  name: \"{{inputs.parameters.resourceName}}\"\n",
          "action": "get",
          "successCondition": "{{='status.listeners, metadata.annotations.migration-configChecksum == '+inputs.parameters.configChecksum}}",
          "failureCondition": "status.conditions.0.type == NotReady"
        },
        "retryStrategy": {
          "limit": "6",
          "retryPolicy": "OnError",
          "backoff": {
            "duration": "10",
            "factor": "2",
            "cap": "60"
          }
        },
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "waitforkafkacluster",
        "inputs": {
          "parameters": [
            {
              "name": "resourceName"
            },
            {
              "name": "configChecksum"
            },
            {
              "name": "imageMigrationConsoleLocation"
            },
            {
              "name": "imageMigrationConsolePullPolicy"
            }
          ]
        },
        "steps": [
          [
            {
              "template": "waitforkafkaclustercreated",
              "arguments": {
                "parameters": [
                  {
                    "name": "resourceName",
                    "value": "{{inputs.parameters.resourceName}}"
                  },
                  {
                    "name": "imageMigrationConsoleLocation",
                    "value": "{{inputs.parameters.imageMigrationConsoleLocation}}"
                  },
                  {
                    "name": "imageMigrationConsolePullPolicy",
                    "value": "{{inputs.parameters.imageMigrationConsolePullPolicy}}"
                  }
                ]
              },
              "name": "waitForCreation"
            }
          ],
          [
            {
              "template": "waitforkafkaclusterready",
              "arguments": {
                "parameters": [
                  {
                    "name": "resourceName",
                    "value": "{{inputs.parameters.resourceName}}"
                  },
                  {
                    "name": "configChecksum",
                    "value": "{{inputs.parameters.configChecksum}}"
                  },
                  {
                    "name": "imageMigrationConsoleLocation",
                    "value": "{{inputs.parameters.imageMigrationConsoleLocation}}"
                  },
                  {
                    "name": "imageMigrationConsolePullPolicy",
                    "value": "{{inputs.parameters.imageMigrationConsolePullPolicy}}"
                  }
                ]
              },
              "name": "waitForReady"
            }
          ]
        ],
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "readkafkaconnectionprofile",
        "inputs": {
          "parameters": [
            {
              "name": "resourceName"
            }
          ]
        },
        "resource": {
          "manifest": "apiVersion: kafka.strimzi.io/v1\nkind: Kafka\nmetadata:\n  name: \"{{inputs.parameters.resourceName}}\"\n",
          "action": "get"
        },
        "retryStrategy": {
          "limit": "6",
          "retryPolicy": "OnError",
          "backoff": {
            "duration": "10",
            "factor": "2",
            "cap": "60"
          }
        },
        "outputs": {
          "parameters": [
            {
              "name": "bootstrapServers",
              "valueFrom": {
                "jsonPath": "{.status.listeners[0].bootstrapServers}"
              }
            },
            {
              "name": "listenerName",
              "valueFrom": {
                "jsonPath": "{.status.listeners[0].name}"
              }
            },
            {
              "name": "authType",
              "valueFrom": {
                "jsonPath": "{.spec.kafka.listeners[0].authentication.type}"
              }
            }
          ]
        }
      },
      {
        "name": "waitforkafkatopic",
        "inputs": {
          "parameters": [
            {
              "name": "resourceName"
            },
            {
              "name": "imageMigrationConsoleLocation"
            },
            {
              "name": "imageMigrationConsolePullPolicy"
            }
          ]
        },
        "container": {
          "env": [],
          "image": "{{inputs.parameters.imageMigrationConsoleLocation}}",
          "imagePullPolicy": "{{inputs.parameters.imageMigrationConsolePullPolicy}}",
          "command": [
            "kubectl"
          ],
          "args": [
            "wait",
            "--for=create",
            "{{=''+inputs.parameters.resourceName}}",
            "--timeout=31536000s"
          ],
          "resources": {
            "limits": {
              "cpu": "50m",
              "memory": "64Mi"
            },
            "requests": {
              "cpu": "50m",
              "memory": "32Mi"
            }
          }
        },
        "metadata": {
          "annotations": {
            "karpenter.sh/do-not-disrupt": "true"
          }
        },
        "activeDeadlineSeconds": "31536000",
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "waitforcapturedtraffic",
        "inputs": {
          "parameters": [
            {
              "name": "resourceName"
            },
            {
              "name": "configChecksum"
            },
            {
              "name": "checksumField"
            },
            {
              "name": "imageMigrationConsoleLocation"
            },
            {
              "name": "imageMigrationConsolePullPolicy"
            }
          ]
        },
        "resource": {
          "manifest": "apiVersion: migrations.opensearch.org/v1alpha1\nkind: CapturedTraffic\nmetadata:\n  name: \"{{inputs.parameters.resourceName}}\"\n",
          "action": "get",
          "successCondition": "{{='status.phase == Ready, status.'+inputs.parameters.checksumField+' == '+inputs.parameters.configChecksum}}",
          "failureCondition": "status.phase == Error"
        },
        "retryStrategy": {
          "limit": "6",
          "retryPolicy": "OnError",
          "backoff": {
            "duration": "10",
            "factor": "2",
            "cap": "60"
          }
        },
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "waitfordatasnapshot",
        "inputs": {
          "parameters": [
            {
              "name": "resourceName"
            },
            {
              "name": "configChecksum"
            },
            {
              "name": "checksumField"
            },
            {
              "name": "imageMigrationConsoleLocation"
            },
            {
              "name": "imageMigrationConsolePullPolicy"
            }
          ]
        },
        "resource": {
          "manifest": "apiVersion: migrations.opensearch.org/v1alpha1\nkind: DataSnapshot\nmetadata:\n  name: \"{{inputs.parameters.resourceName}}\"\n",
          "action": "get",
          "successCondition": "{{='status.phase == Completed, status.'+inputs.parameters.checksumField+' == '+inputs.parameters.configChecksum}}",
          "failureCondition": "status.phase == Error"
        },
        "retryStrategy": {
          "limit": "6",
          "retryPolicy": "OnError",
          "backoff": {
            "duration": "10",
            "factor": "2",
            "cap": "60"
          }
        },
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "waitforsnapshotmigration",
        "inputs": {
          "parameters": [
            {
              "name": "resourceName"
            },
            {
              "name": "configChecksum"
            },
            {
              "name": "checksumField"
            },
            {
              "name": "imageMigrationConsoleLocation"
            },
            {
              "name": "imageMigrationConsolePullPolicy"
            }
          ]
        },
        "resource": {
          "manifest": "apiVersion: migrations.opensearch.org/v1alpha1\nkind: SnapshotMigration\nmetadata:\n  name: \"{{inputs.parameters.resourceName}}\"\n",
          "action": "get",
          "successCondition": "{{='status.phase == Completed, status.'+inputs.parameters.checksumField+' == '+inputs.parameters.configChecksum}}",
          "failureCondition": "status.phase == Error"
        },
        "retryStrategy": {
          "limit": "6",
          "retryPolicy": "OnError",
          "backoff": {
            "duration": "10",
            "factor": "2",
            "cap": "60"
          }
        },
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "patchcapturedtrafficready",
        "inputs": {
          "parameters": [
            {
              "name": "resourceName"
            }
          ]
        },
        "resource": {
          "manifest": "apiVersion: migrations.opensearch.org/v1alpha1\nkind: CapturedTraffic\nmetadata:\n  name: \"{{inputs.parameters.resourceName}}\"\nstatus:\n  phase: Ready\n",
          "action": "patch",
          "flags": [
            "--type",
            "merge",
            "--subresource=status"
          ]
        },
        "retryStrategy": {
          "limit": "6",
          "retryPolicy": "OnError",
          "backoff": {
            "duration": "10",
            "factor": "2",
            "cap": "60"
          }
        },
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "patchdatasnapshotready",
        "inputs": {
          "parameters": [
            {
              "name": "resourceName"
            },
            {
              "name": "snapshotName"
            },
            {
              "name": "configChecksum"
            }
          ]
        },
        "resource": {
          "manifest": "apiVersion: migrations.opensearch.org/v1alpha1\nkind: DataSnapshot\nmetadata:\n  name: \"{{inputs.parameters.resourceName}}\"\nstatus:\n  phase: Completed\n  snapshotName: \"{{inputs.parameters.snapshotName}}\"\n  configChecksum: \"{{inputs.parameters.configChecksum}}\"\n  checksumForSnapshotMigration: \"{{inputs.parameters.configChecksum}}\"\n",
          "action": "patch",
          "flags": [
            "--type",
            "merge",
            "--subresource=status"
          ]
        },
        "retryStrategy": {
          "limit": "6",
          "retryPolicy": "OnError",
          "backoff": {
            "duration": "10",
            "factor": "2",
            "cap": "60"
          }
        },
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "patchsnapshotmigrationready",
        "inputs": {
          "parameters": [
            {
              "name": "resourceName"
            },
            {
              "name": "configChecksum"
            },
            {
              "name": "checksumForReplayer"
            }
          ]
        },
        "resource": {
          "manifest": "apiVersion: migrations.opensearch.org/v1alpha1\nkind: SnapshotMigration\nmetadata:\n  name: \"{{inputs.parameters.resourceName}}\"\nstatus:\n  phase: Completed\n  configChecksum: \"{{inputs.parameters.configChecksum}}\"\n  checksumForReplayer: \"{{inputs.parameters.checksumForReplayer}}\"\n",
          "action": "patch",
          "flags": [
            "--type",
            "merge",
            "--subresource=status"
          ]
        },
        "retryStrategy": {
          "limit": "6",
          "retryPolicy": "OnError",
          "backoff": {
            "duration": "10",
            "factor": "2",
            "cap": "60"
          }
        },
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "readdatasnapshotname",
        "inputs": {
          "parameters": [
            {
              "name": "resourceName"
            }
          ]
        },
        "resource": {
          "manifest": "apiVersion: migrations.opensearch.org/v1alpha1\nkind: DataSnapshot\nmetadata:\n  name: \"{{inputs.parameters.resourceName}}\"\n",
          "action": "get"
        },
        "retryStrategy": {
          "limit": "6",
          "retryPolicy": "OnError",
          "backoff": {
            "duration": "10",
            "factor": "2",
            "cap": "60"
          }
        },
        "outputs": {
          "parameters": [
            {
              "name": "snapshotName",
              "valueFrom": {
                "jsonPath": "{.status.snapshotName}"
              }
            }
          ]
        }
      },
      {
        "name": "readresourcephase",
        "inputs": {
          "parameters": [
            {
              "name": "resourceKind"
            },
            {
              "name": "resourceName"
            }
          ]
        },
        "resource": {
          "manifest": "apiVersion: migrations.opensearch.org/v1alpha1\nkind: \"{{inputs.parameters.resourceKind}}\"\nmetadata:\n  name: \"{{inputs.parameters.resourceName}}\"\n",
          "action": "get"
        },
        "retryStrategy": {
          "limit": "6",
          "retryPolicy": "OnError",
          "backoff": {
            "duration": "10",
            "factor": "2",
            "cap": "60"
          }
        },
        "outputs": {
          "parameters": [
            {
              "name": "phase",
              "valueFrom": {
                "jsonPath": "{.status.phase}"
              }
            },
            {
              "name": "configChecksum",
              "valueFrom": {
                "jsonPath": "{.status.configChecksum}"
              }
            }
          ]
        }
      },
      {
        "name": "patchresourcephase",
        "inputs": {
          "parameters": [
            {
              "name": "resourceKind"
            },
            {
              "name": "resourceName"
            },
            {
              "name": "phase"
            },
            {
              "name": "configChecksum",
              "value": ""
            },
            {
              "name": "checksumForSnapshot",
              "value": ""
            },
            {
              "name": "checksumForReplayer",
              "value": ""
            },
            {
              "name": "checksumForSnapshotMigration",
              "value": ""
            }
          ]
        },
        "resource": {
          "manifest": "apiVersion: migrations.opensearch.org/v1alpha1\nkind: \"{{inputs.parameters.resourceKind}}\"\nmetadata:\n  name: \"{{inputs.parameters.resourceName}}\"\nstatus:\n  phase: \"{{inputs.parameters.phase}}\"\n  configChecksum: \"{{inputs.parameters.configChecksum}}\"\n  checksumForSnapshot: \"{{inputs.parameters.checksumForSnapshot}}\"\n  checksumForReplayer: \"{{inputs.parameters.checksumForReplayer}}\"\n  checksumForSnapshotMigration: \"{{inputs.parameters.checksumForSnapshotMigration}}\"\n",
          "action": "patch",
          "flags": [
            "--type",
            "merge",
            "--subresource=status"
          ]
        },
        "retryStrategy": {
          "limit": "6",
          "retryPolicy": "OnError",
          "backoff": {
            "duration": "10",
            "factor": "2",
            "cap": "60"
          }
        },
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "patchconfigchecksumannotation",
        "inputs": {
          "parameters": [
            {
              "name": "resourceApiVersion"
            },
            {
              "name": "resourceKind"
            },
            {
              "name": "resourceName"
            },
            {
              "name": "configChecksum"
            }
          ]
        },
        "resource": {
          "manifest": "apiVersion: \"{{inputs.parameters.resourceApiVersion}}\"\nkind: \"{{inputs.parameters.resourceKind}}\"\nmetadata:\n  name: \"{{inputs.parameters.resourceName}}\"\n  annotations:\n    migration-configChecksum: \"{{inputs.parameters.configChecksum}}\"\n",
          "action": "patch",
          "flags": [
            "--type",
            "merge"
          ]
        },
        "retryStrategy": {
          "limit": "6",
          "retryPolicy": "OnError",
          "backoff": {
            "duration": "10",
            "factor": "2",
            "cap": "60"
          }
        },
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "patchapprovalannotation",
        "inputs": {
          "parameters": [
            {
              "name": "resourceApiVersion"
            },
            {
              "name": "resourceKind"
            },
            {
              "name": "resourceName"
            }
          ]
        },
        "resource": {
          "manifest": "apiVersion: \"{{inputs.parameters.resourceApiVersion}}\"\nkind: \"{{inputs.parameters.resourceKind}}\"\nmetadata:\n  name: \"{{inputs.parameters.resourceName}}\"\n  annotations:\n    migrations.opensearch.org/approved-by-run: \"{{workflow.uid}}\"\n",
          "action": "patch",
          "flags": [
            "--type",
            "merge"
          ]
        },
        "retryStrategy": {
          "limit": "6",
          "retryPolicy": "OnError",
          "backoff": {
            "duration": "10",
            "factor": "2",
            "cap": "60"
          }
        },
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "createapprovalgate",
        "inputs": {
          "parameters": [
            {
              "name": "resourceName"
            }
          ]
        },
        "resource": {
          "manifest": "apiVersion: migrations.opensearch.org/v1alpha1\nkind: ApprovalGate\nmetadata:\n  name: \"{{inputs.parameters.resourceName}}\"\nstatus:\n  phase: Pending\n",
          "action": "apply",
          "setOwnerReference": false
        },
        "retryStrategy": {
          "limit": "6",
          "retryPolicy": "OnError",
          "backoff": {
            "duration": "10",
            "factor": "2",
            "cap": "60"
          }
        },
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "waitforapproval",
        "inputs": {
          "parameters": [
            {
              "name": "resourceName"
            }
          ]
        },
        "resource": {
          "manifest": "apiVersion: migrations.opensearch.org/v1alpha1\nkind: ApprovalGate\nmetadata:\n  name: \"{{inputs.parameters.resourceName}}\"\n",
          "action": "get",
          "successCondition": "status.phase == Approved"
        },
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "waitforteardown",
        "inputs": {
          "parameters": [
            {
              "name": "resourceName"
            },
            {
              "name": "resourceKind"
            }
          ]
        },
        "resource": {
          "manifest": "apiVersion: migrations.opensearch.org/v1alpha1\nkind: \"{{inputs.parameters.resourceKind}}\"\nmetadata:\n  name: \"{{inputs.parameters.resourceName}}\"\n",
          "action": "get",
          "successCondition": "status.phase == Teardown"
        },
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "patchteardown",
        "inputs": {
          "parameters": [
            {
              "name": "resourceName"
            },
            {
              "name": "resourceKind"
            }
          ]
        },
        "resource": {
          "manifest": "apiVersion: migrations.opensearch.org/v1alpha1\nkind: \"{{inputs.parameters.resourceKind}}\"\nmetadata:\n  name: \"{{inputs.parameters.resourceName}}\"\nstatus:\n  phase: Teardown\n",
          "action": "patch",
          "flags": [
            "--type",
            "merge",
            "--subresource=status"
          ]
        },
        "retryStrategy": {
          "limit": "6",
          "retryPolicy": "OnError",
          "backoff": {
            "duration": "10",
            "factor": "2",
            "cap": "60"
          }
        },
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "deletedeployment",
        "inputs": {
          "parameters": [
            {
              "name": "deploymentName"
            }
          ]
        },
        "resource": {
          "manifest": "apiVersion: apps/v1\nkind: Deployment\nmetadata:\n  name: \"{{inputs.parameters.deploymentName}}\"\n",
          "action": "delete",
          "flags": [
            "--ignore-not-found"
          ]
        },
        "retryStrategy": {
          "limit": "6",
          "retryPolicy": "OnError",
          "backoff": {
            "duration": "10",
            "factor": "2",
            "cap": "60"
          }
        },
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "createtrafficreplay",
        "inputs": {
          "parameters": [
            {
              "name": "resourceName"
            }
          ]
        },
        "resource": {
          "manifest": "apiVersion: migrations.opensearch.org/v1alpha1\nkind: TrafficReplay\nmetadata:\n  name: \"{{inputs.parameters.resourceName}}\"\nstatus:\n  phase: Running\n",
          "action": "apply",
          "setOwnerReference": false
        },
        "retryStrategy": {
          "limit": "6",
          "retryPolicy": "OnError",
          "backoff": {
            "duration": "10",
            "factor": "2",
            "cap": "60"
          }
        },
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "patchtrafficreplayready",
        "inputs": {
          "parameters": [
            {
              "name": "resourceName"
            }
          ]
        },
        "resource": {
          "manifest": "apiVersion: migrations.opensearch.org/v1alpha1\nkind: TrafficReplay\nmetadata:\n  name: \"{{inputs.parameters.resourceName}}\"\nstatus:\n  phase: Ready\n",
          "action": "patch",
          "flags": [
            "--type",
            "merge",
            "--subresource=status"
          ]
        },
        "retryStrategy": {
          "limit": "6",
          "retryPolicy": "OnError",
          "backoff": {
            "duration": "10",
            "factor": "2",
            "cap": "60"
          }
        },
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "createkafkacluster",
        "inputs": {
          "parameters": [
            {
              "name": "resourceName"
            }
          ]
        },
        "resource": {
          "manifest": "apiVersion: migrations.opensearch.org/v1alpha1\nkind: KafkaCluster\nmetadata:\n  name: \"{{inputs.parameters.resourceName}}\"\nstatus:\n  phase: Created\n",
          "action": "apply",
          "setOwnerReference": false
        },
        "retryStrategy": {
          "limit": "6",
          "retryPolicy": "OnError",
          "backoff": {
            "duration": "10",
            "factor": "2",
            "cap": "60"
          }
        },
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "createsnapshotmigration",
        "inputs": {
          "parameters": [
            {
              "name": "resourceName"
            }
          ]
        },
        "resource": {
          "manifest": "apiVersion: migrations.opensearch.org/v1alpha1\nkind: SnapshotMigration\nmetadata:\n  name: \"{{inputs.parameters.resourceName}}\"\nstatus:\n  phase: Created\n",
          "action": "apply",
          "setOwnerReference": false
        },
        "retryStrategy": {
          "limit": "6",
          "retryPolicy": "OnError",
          "backoff": {
            "duration": "10",
            "factor": "2",
            "cap": "60"
          }
        },
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "createcapturedtraffic",
        "inputs": {
          "parameters": [
            {
              "name": "resourceName"
            }
          ]
        },
        "resource": {
          "manifest": "apiVersion: migrations.opensearch.org/v1alpha1\nkind: CapturedTraffic\nmetadata:\n  name: \"{{inputs.parameters.resourceName}}\"\nstatus:\n  phase: Created\n",
          "action": "apply",
          "setOwnerReference": false
        },
        "retryStrategy": {
          "limit": "6",
          "retryPolicy": "OnError",
          "backoff": {
            "duration": "10",
            "factor": "2",
            "cap": "60"
          }
        },
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "patchkafkaclusterready",
        "inputs": {
          "parameters": [
            {
              "name": "resourceName"
            }
          ]
        },
        "resource": {
          "manifest": "apiVersion: migrations.opensearch.org/v1alpha1\nkind: KafkaCluster\nmetadata:\n  name: \"{{inputs.parameters.resourceName}}\"\nstatus:\n  phase: Ready\n",
          "action": "patch",
          "flags": [
            "--type",
            "merge",
            "--subresource=status"
          ]
        },
        "retryStrategy": {
          "limit": "6",
          "retryPolicy": "OnError",
          "backoff": {
            "duration": "10",
            "factor": "2",
            "cap": "60"
          }
        },
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "getresourceuid",
        "inputs": {
          "parameters": [
            {
              "name": "resourceName"
            },
            {
              "name": "resourceKind"
            }
          ]
        },
        "resource": {
          "manifest": "apiVersion: migrations.opensearch.org/v1alpha1\nkind: \"{{inputs.parameters.resourceKind}}\"\nmetadata:\n  name: \"{{inputs.parameters.resourceName}}\"\n",
          "action": "get"
        },
        "retryStrategy": {
          "limit": "6",
          "retryPolicy": "OnError",
          "backoff": {
            "duration": "10",
            "factor": "2",
            "cap": "60"
          }
        },
        "outputs": {
          "parameters": [
            {
              "name": "uid",
              "valueFrom": {
                "jsonPath": "{.metadata.uid}"
              }
            },
            {
              "name": "phase",
              "valueFrom": {
                "jsonPath": "{.status.phase}"
              }
            }
          ]
        }
      },
      {
        "name": "waitforcrddeletion",
        "inputs": {
          "parameters": [
            {
              "name": "resourceName"
            },
            {
              "name": "resourceKind"
            },
            {
              "name": "imageMigrationConsoleLocation"
            },
            {
              "name": "imageMigrationConsolePullPolicy"
            }
          ]
        },
        "container": {
          "env": [],
          "image": "{{inputs.parameters.imageMigrationConsoleLocation}}",
          "imagePullPolicy": "{{inputs.parameters.imageMigrationConsolePullPolicy}}",
          "command": [
            "kubectl"
          ],
          "args": [
            "wait",
            "--for=delete",
            "{{=inputs.parameters.resourceKind+'.migrations.opensearch.org/'+inputs.parameters.resourceName}}",
            "--timeout=31536000s"
          ],
          "resources": {
            "limits": {
              "cpu": "50m",
              "memory": "64Mi"
            },
            "requests": {
              "cpu": "50m",
              "memory": "64Mi"
            }
          }
        },
        "metadata": {
          "annotations": {
            "karpenter.sh/do-not-disrupt": "true"
          }
        },
        "retryStrategy": {
          "retryPolicy": "Always",
          "backoff": {
            "duration": "5",
            "factor": "1"
          }
        },
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "deletecrd",
        "inputs": {
          "parameters": [
            {
              "name": "resourceName"
            },
            {
              "name": "resourceKind"
            }
          ]
        },
        "resource": {
          "manifest": "apiVersion: migrations.opensearch.org/v1alpha1\nkind: \"{{inputs.parameters.resourceKind}}\"\nmetadata:\n  name: \"{{inputs.parameters.resourceName}}\"\n",
          "action": "delete",
          "flags": [
            "--ignore-not-found"
          ]
        },
        "retryStrategy": {
          "limit": "6",
          "retryPolicy": "OnError",
          "backoff": {
            "duration": "10",
            "factor": "2",
            "cap": "60"
          }
        },
        "outputs": {
          "parameters": []
        }
      }
    ]
  }
}
