{
  "apiVersion": "argoproj.io/v1alpha1",
  "kind": "WorkflowTemplate",
  "metadata": {
    "name": "setup-capture"
  },
  "spec": {
    "serviceAccountName": "argo-workflow-executor",
    "parallelism": 100,
    "arguments": {
      "parameters": [
        {
          "name": "s3SnapshotConfigMap",
          "value": "s3-snapshot-config"
        },
        {
          "name": "imageConfigMapName",
          "value": "migration-image-config"
        },
        {
          "name": "approvalConfigMapName",
          "value": "approval-config"
        }
      ]
    },
    "templates": [
      {
        "name": "deployproxyservice",
        "inputs": {
          "parameters": [
            {
              "name": "proxyName"
            },
            {
              "name": "listenPort"
            },
            {
              "name": "ownerUid"
            },
            {
              "name": "internetFacing",
              "value": "false"
            }
          ]
        },
        "resource": {
          "manifest": "apiVersion: v1\nkind: Service\nmetadata:\n  name: \"{{inputs.parameters.proxyName}}\"\n  ownerReferences:\n    - apiVersion: migrations.opensearch.org/v1alpha1\n      kind: CaptureProxy\n      name: {{inputs.parameters.proxyName}}\n      uid: {{inputs.parameters.ownerUid}}\n      controller: true\n      blockOwnerDeletion: true\n  annotations:\n    service.beta.kubernetes.io/aws-load-balancer-type: external\n    service.beta.kubernetes.io/aws-load-balancer-nlb-target-type: ip\n    service.beta.kubernetes.io/aws-load-balancer-scheme: \"{{=((fromJSON(inputs.parameters.internetFacing)) ? ('internet-facing') : ('internal'))}}\"\nspec:\n  type: LoadBalancer\n  selector:\n    migrations/proxy: \"{{inputs.parameters.proxyName}}\"\n  ports:\n    - port: {{inputs.parameters.listenPort}}\n      targetPort: {{inputs.parameters.listenPort}}\n      protocol: TCP\n",
          "action": "apply",
          "setOwnerReference": false
        },
        "retryStrategy": {
          "limit": "6",
          "retryPolicy": "OnError",
          "backoff": {
            "duration": "10",
            "factor": "2",
            "cap": "60"
          }
        },
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "deployproxydeployment",
        "inputs": {
          "parameters": [
            {
              "name": "proxyName"
            },
            {
              "name": "jsonConfig"
            },
            {
              "name": "kafkaAuthConfigMapName"
            },
            {
              "name": "kafkaAuthType"
            },
            {
              "name": "kafkaSecretName"
            },
            {
              "name": "kafkaCaSecretName"
            },
            {
              "name": "listenPort"
            },
            {
              "name": "podReplicas"
            },
            {
              "name": "resources"
            },
            {
              "name": "ownerUid"
            },
            {
              "name": "tlsSecretName",
              "value": ""
            },
            {
              "name": "imageCaptureProxyLocation"
            },
            {
              "name": "imageCaptureProxyPullPolicy"
            }
          ]
        },
        "resource": {
          "manifest": "apiVersion: apps/v1\nkind: Deployment\nmetadata:\n  name: \"{{inputs.parameters.proxyName}}\"\n  ownerReferences:\n    - apiVersion: migrations.opensearch.org/v1alpha1\n      kind: CaptureProxy\n      name: {{inputs.parameters.proxyName}}\n      uid: {{inputs.parameters.ownerUid}}\n      controller: true\n      blockOwnerDeletion: true\nspec:\n  replicas: {{=fromJSON(inputs.parameters.podReplicas)}}\n  strategy:\n    type: Recreate\n  selector:\n    matchLabels:\n      migrations/proxy: \"{{inputs.parameters.proxyName}}\"\n  template:\n    metadata:\n      labels:\n        migrations/proxy: \"{{inputs.parameters.proxyName}}\"\n    spec:\n      containers:\n        - name: proxy\n          image: \"{{inputs.parameters.imageCaptureProxyLocation}}\"\n          imagePullPolicy: \"{{inputs.parameters.imageCaptureProxyPullPolicy}}\"\n          args:\n            - ---INLINE-JSON\n            - \"{{=toBase64(inputs.parameters.jsonConfig)}}\"\n          ports:\n            - containerPort: {{inputs.parameters.listenPort}}\n          resources: {{=fromJSON(inputs.parameters.resources)}}\n          env:\n            - name: CAPTURE_PROXY_KAFKA_PASSWORD\n              valueFrom:\n                secretKeyRef:\n                  name: \"{{=((inputs.parameters.kafkaAuthType == 'scram-sha-512') ? (inputs.parameters.kafkaSecretName) : ('empty'))}}\"\n                  key: password\n                  optional: {{=!(inputs.parameters.kafkaAuthType == 'scram-sha-512')}}\n          volumeMounts:\n            - name: kafka-auth-config\n              mountPath: /config/kafka-auth\n              readOnly: true\n            - name: kafka-ca\n              mountPath: /config/kafka-ca\n              readOnly: true\n      volumes:\n        - name: kafka-auth-config\n          configMap:\n            name: \"{{inputs.parameters.kafkaAuthConfigMapName}}\"\n        - name: kafka-ca\n          secret:\n            secretName: \"{{=((inputs.parameters.kafkaAuthType == 'scram-sha-512') ? (inputs.parameters.kafkaCaSecretName) : ('empty'))}}\"\n            optional: {{=!(inputs.parameters.kafkaAuthType == 'scram-sha-512')}}\n",
          "action": "apply",
          "setOwnerReference": false,
          "successCondition": "status.readyReplicas > 0"
        },
        "retryStrategy": {
          "limit": "6",
          "retryPolicy": "OnError",
          "backoff": {
            "duration": "10",
            "factor": "2",
            "cap": "60"
          }
        },
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "deployproxydeploymentwithtls",
        "inputs": {
          "parameters": [
            {
              "name": "proxyName"
            },
            {
              "name": "jsonConfig"
            },
            {
              "name": "kafkaAuthConfigMapName"
            },
            {
              "name": "kafkaAuthType"
            },
            {
              "name": "kafkaSecretName"
            },
            {
              "name": "kafkaCaSecretName"
            },
            {
              "name": "listenPort"
            },
            {
              "name": "podReplicas"
            },
            {
              "name": "resources"
            },
            {
              "name": "tlsSecretName"
            },
            {
              "name": "ownerUid"
            },
            {
              "name": "imageCaptureProxyLocation"
            },
            {
              "name": "imageCaptureProxyPullPolicy"
            }
          ]
        },
        "resource": {
          "manifest": "apiVersion: apps/v1\nkind: Deployment\nmetadata:\n  name: \"{{inputs.parameters.proxyName}}\"\n  ownerReferences:\n    - apiVersion: migrations.opensearch.org/v1alpha1\n      kind: CaptureProxy\n      name: {{inputs.parameters.proxyName}}\n      uid: {{inputs.parameters.ownerUid}}\n      controller: true\n      blockOwnerDeletion: true\nspec:\n  replicas: {{=fromJSON(inputs.parameters.podReplicas)}}\n  strategy:\n    type: Recreate\n  selector:\n    matchLabels:\n      migrations/proxy: \"{{inputs.parameters.proxyName}}\"\n  template:\n    metadata:\n      labels:\n        migrations/proxy: \"{{inputs.parameters.proxyName}}\"\n    spec:\n      containers:\n        - name: proxy\n          image: \"{{inputs.parameters.imageCaptureProxyLocation}}\"\n          imagePullPolicy: \"{{inputs.parameters.imageCaptureProxyPullPolicy}}\"\n          args:\n            - ---INLINE-JSON\n            - \"{{=toBase64(inputs.parameters.jsonConfig)}}\"\n          ports:\n            - containerPort: {{inputs.parameters.listenPort}}\n          resources: {{=fromJSON(inputs.parameters.resources)}}\n          env:\n            - name: CAPTURE_PROXY_KAFKA_PASSWORD\n              valueFrom:\n                secretKeyRef:\n                  name: \"{{=((inputs.parameters.kafkaAuthType == 'scram-sha-512') ? (inputs.parameters.kafkaSecretName) : ('empty'))}}\"\n                  key: password\n                  optional: {{=!(inputs.parameters.kafkaAuthType == 'scram-sha-512')}}\n          volumeMounts:\n            - name: kafka-auth-config\n              mountPath: /config/kafka-auth\n              readOnly: true\n            - name: kafka-ca\n              mountPath: /config/kafka-ca\n              readOnly: true\n            - name: tls-certs\n              mountPath: /etc/proxy-tls\n              readOnly: true\n      volumes:\n        - name: kafka-auth-config\n          configMap:\n            name: \"{{inputs.parameters.kafkaAuthConfigMapName}}\"\n        - name: kafka-ca\n          secret:\n            secretName: \"{{=((inputs.parameters.kafkaAuthType == 'scram-sha-512') ? (inputs.parameters.kafkaCaSecretName) : ('empty'))}}\"\n            optional: {{=!(inputs.parameters.kafkaAuthType == 'scram-sha-512')}}\n        - name: tls-certs\n          secret:\n            secretName: \"{{inputs.parameters.tlsSecretName}}\"\n",
          "action": "apply",
          "setOwnerReference": false,
          "successCondition": "status.readyReplicas > 0"
        },
        "retryStrategy": {
          "limit": "6",
          "retryPolicy": "OnError",
          "backoff": {
            "duration": "10",
            "factor": "2",
            "cap": "60"
          }
        },
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "createkafkaclientpropertiesconfigmap",
        "inputs": {
          "parameters": [
            {
              "name": "name"
            }
          ]
        },
        "resource": {
          "manifest": "apiVersion: v1\nkind: ConfigMap\nmetadata:\n  name: \"{{inputs.parameters.name}}\"\ndata:\n  client.properties: |-\n    ssl.truststore.type=PEM\n    ssl.truststore.location=/config/kafka-ca/ca.crt\n",
          "action": "apply",
          "setOwnerReference": false
        },
        "retryStrategy": {
          "limit": "6",
          "retryPolicy": "OnError",
          "backoff": {
            "duration": "10",
            "factor": "2",
            "cap": "60"
          }
        },
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "provisionproxycert",
        "inputs": {
          "parameters": [
            {
              "name": "certName"
            },
            {
              "name": "secretName"
            },
            {
              "name": "issuerName"
            },
            {
              "name": "issuerKind"
            },
            {
              "name": "issuerGroup"
            },
            {
              "name": "dnsNames"
            },
            {
              "name": "duration"
            },
            {
              "name": "renewBefore"
            },
            {
              "name": "ownerName"
            },
            {
              "name": "ownerUid"
            }
          ]
        },
        "resource": {
          "manifest": "apiVersion: cert-manager.io/v1\nkind: Certificate\nmetadata:\n  name: \"{{inputs.parameters.certName}}\"\n  ownerReferences:\n    - apiVersion: migrations.opensearch.org/v1alpha1\n      kind: CaptureProxy\n      name: {{inputs.parameters.ownerName}}\n      uid: {{inputs.parameters.ownerUid}}\n      controller: true\n      blockOwnerDeletion: true\nspec:\n  secretName: \"{{inputs.parameters.secretName}}\"\n  issuerRef:\n    name: \"{{inputs.parameters.issuerName}}\"\n    kind: \"{{inputs.parameters.issuerKind}}\"\n    group: \"{{inputs.parameters.issuerGroup}}\"\n  dnsNames: {{inputs.parameters.dnsNames}}\n  duration: \"{{inputs.parameters.duration}}\"\n  renewBefore: \"{{inputs.parameters.renewBefore}}\"\n  privateKey:\n    algorithm: RSA\n    encoding: PKCS8\n    size: 2048\n",
          "action": "apply",
          "setOwnerReference": false
        },
        "retryStrategy": {
          "limit": "6",
          "retryPolicy": "OnError",
          "backoff": {
            "duration": "10",
            "factor": "2",
            "cap": "60"
          }
        },
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "waitforcertready",
        "inputs": {
          "parameters": [
            {
              "name": "certName"
            }
          ]
        },
        "resource": {
          "manifest": "apiVersion: cert-manager.io/v1\nkind: Certificate\nmetadata:\n  name: \"{{inputs.parameters.certName}}\"\n",
          "action": "get",
          "successCondition": "status.conditions.0.status == True"
        },
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "setupproxy",
        "inputs": {
          "parameters": [
            {
              "name": "proxyConfig"
            },
            {
              "name": "kafkaClusterName"
            },
            {
              "name": "proxyName"
            },
            {
              "name": "ownerUid"
            },
            {
              "name": "listenPort"
            },
            {
              "name": "podReplicas"
            },
            {
              "name": "resolvedKafkaConnection",
              "value": ""
            },
            {
              "name": "resolvedKafkaListenerName",
              "value": ""
            },
            {
              "name": "resolvedKafkaAuthType",
              "value": ""
            },
            {
              "name": "imageCaptureProxyLocation"
            },
            {
              "name": "imageCaptureProxyPullPolicy"
            }
          ]
        },
        "steps": [
          [
            {
              "template": "createkafkaclientpropertiesconfigmap",
              "arguments": {
                "parameters": [
                  {
                    "name": "name",
                    "value": "{{=inputs.parameters.proxyName+'-kafka-auth'}}"
                  }
                ]
              },
              "name": "createKafkaClientConfig"
            }
          ],
          [
            {
              "template": "deployproxyservice",
              "arguments": {
                "parameters": [
                  {
                    "name": "proxyName",
                    "value": "{{inputs.parameters.proxyName}}"
                  },
                  {
                    "name": "listenPort",
                    "value": "{{inputs.parameters.listenPort}}"
                  },
                  {
                    "name": "internetFacing",
                    "value": "{{=sprig.dig('internetFacing', false, fromJSON(inputs.parameters.proxyConfig)['proxyConfig'])}}"
                  },
                  {
                    "name": "ownerUid",
                    "value": "{{inputs.parameters.ownerUid}}"
                  }
                ]
              },
              "name": "deployService"
            },
            {
              "template": "provisionproxycert",
              "when": "{{=sprig.dig('tls', 'mode', '', fromJSON(inputs.parameters.proxyConfig)['proxyConfig']) == 'certManager'}}",
              "arguments": {
                "parameters": [
                  {
                    "name": "certName",
                    "value": "{{=inputs.parameters.proxyName+'-tls'}}"
                  },
                  {
                    "name": "secretName",
                    "value": "{{=inputs.parameters.proxyName+'-tls'}}"
                  },
                  {
                    "name": "issuerName",
                    "value": "{{=sprig.dig('tls', 'issuerRef', 'name', '', fromJSON(inputs.parameters.proxyConfig)['proxyConfig'])}}"
                  },
                  {
                    "name": "issuerKind",
                    "value": "{{=sprig.dig('tls', 'issuerRef', 'kind', 'ClusterIssuer', fromJSON(inputs.parameters.proxyConfig)['proxyConfig'])}}"
                  },
                  {
                    "name": "issuerGroup",
                    "value": "{{=sprig.dig('tls', 'issuerRef', 'group', 'cert-manager.io', fromJSON(inputs.parameters.proxyConfig)['proxyConfig'])}}"
                  },
                  {
                    "name": "dnsNames",
                    "value": "{{=toJSON(sprig.dig('tls', 'dnsNames', [], fromJSON(inputs.parameters.proxyConfig)['proxyConfig']))}}"
                  },
                  {
                    "name": "duration",
                    "value": "{{=sprig.dig('tls', 'duration', '2160h', fromJSON(inputs.parameters.proxyConfig)['proxyConfig'])}}"
                  },
                  {
                    "name": "renewBefore",
                    "value": "{{=sprig.dig('tls', 'renewBefore', '360h', fromJSON(inputs.parameters.proxyConfig)['proxyConfig'])}}"
                  },
                  {
                    "name": "ownerName",
                    "value": "{{inputs.parameters.proxyName}}"
                  },
                  {
                    "name": "ownerUid",
                    "value": "{{inputs.parameters.ownerUid}}"
                  }
                ]
              },
              "name": "provisionCert"
            }
          ],
          [
            {
              "template": "waitforcertready",
              "when": "{{=sprig.dig('tls', 'mode', '', fromJSON(inputs.parameters.proxyConfig)['proxyConfig']) == 'certManager'}}",
              "arguments": {
                "parameters": [
                  {
                    "name": "certName",
                    "value": "{{=inputs.parameters.proxyName+'-tls'}}"
                  }
                ]
              },
              "name": "waitForCert"
            }
          ],
          [
            {
              "template": "deployproxydeployment",
              "when": "{{=!(sprig.dig('tls', 'mode', '', fromJSON(inputs.parameters.proxyConfig)['proxyConfig']) == 'certManager' || sprig.dig('tls', 'mode', '', fromJSON(inputs.parameters.proxyConfig)['proxyConfig']) == 'existingSecret')}}",
              "arguments": {
                "parameters": [
                  {
                    "name": "proxyName",
                    "value": "{{=fromJSON(inputs.parameters.proxyConfig)['name']}}"
                  },
                  {
                    "name": "listenPort",
                    "value": "{{inputs.parameters.listenPort}}"
                  },
                  {
                    "name": "podReplicas",
                    "value": "{{inputs.parameters.podReplicas}}"
                  },
                  {
                    "name": "ownerUid",
                    "value": "{{inputs.parameters.ownerUid}}"
                  },
                  {
                    "name": "imageCaptureProxyLocation",
                    "value": "{{inputs.parameters.imageCaptureProxyLocation}}"
                  },
                  {
                    "name": "imageCaptureProxyPullPolicy",
                    "value": "{{inputs.parameters.imageCaptureProxyPullPolicy}}"
                  },
                  {
                    "name": "kafkaAuthConfigMapName",
                    "value": "{{=inputs.parameters.proxyName+'-kafka-auth'}}"
                  },
                  {
                    "name": "kafkaAuthType",
                    "value": "{{=((!(inputs.parameters.resolvedKafkaAuthType == '')) ? (inputs.parameters.resolvedKafkaAuthType) : (fromJSON(inputs.parameters.proxyConfig)['kafkaConfig']['authType']))}}"
                  },
                  {
                    "name": "kafkaSecretName",
                    "value": "{{=fromJSON(inputs.parameters.proxyConfig)['kafkaConfig']['secretName']}}"
                  },
                  {
                    "name": "kafkaCaSecretName",
                    "value": "{{=fromJSON(inputs.parameters.proxyConfig)['kafkaConfig']['caSecretName']}}"
                  },
                  {
                    "name": "resources",
                    "value": "{{=toJSON(fromJSON(inputs.parameters.proxyConfig)['proxyConfig']['resources'])}}"
                  },
                  {
                    "name": "jsonConfig",
                    "value": "{{=toJSON(sprig.merge(sprig.omit(fromJSON(inputs.parameters.proxyConfig)['proxyConfig'], 'loggingConfigurationOverrideConfigMap', 'internetFacing', 'podReplicas', 'resources', 'tls'), sprig.merge(((sprig.dig('proxyConfig', 'noCapture', false, fromJSON(inputs.parameters.proxyConfig))) ? (sprig.dict()) : (sprig.dict(\"kafkaConnection\", ((!(inputs.parameters.resolvedKafkaConnection == '')) ? (inputs.parameters.resolvedKafkaConnection) : (fromJSON(inputs.parameters.proxyConfig)['kafkaConfig']['kafkaConnection']))))), sprig.merge(sprig.dict(\"destinationUri\", fromJSON(inputs.parameters.proxyConfig)['sourceEndpoint'], \"insecureDestination\", fromJSON(inputs.parameters.proxyConfig)['sourceAllowInsecure'], \"kafkaTopic\", jsonpath(inputs.parameters.proxyConfig, '$.kafkaConfig.kafkaTopic'), \"kafkaListenerName\", ((!(inputs.parameters.resolvedKafkaListenerName == '')) ? (inputs.parameters.resolvedKafkaListenerName) : (fromJSON(inputs.parameters.proxyConfig)['kafkaConfig']['listenerName'])), \"kafkaAuthType\", ((!(inputs.parameters.resolvedKafkaAuthType == '')) ? (inputs.parameters.resolvedKafkaAuthType) : (fromJSON(inputs.parameters.proxyConfig)['kafkaConfig']['authType'])), \"kafkaSecretName\", fromJSON(inputs.parameters.proxyConfig)['kafkaConfig']['secretName'], \"kafkaUserName\", fromJSON(inputs.parameters.proxyConfig)['kafkaConfig']['kafkaUserName']), ((((!(inputs.parameters.resolvedKafkaAuthType == '')) ? (inputs.parameters.resolvedKafkaAuthType) : (fromJSON(inputs.parameters.proxyConfig)['kafkaConfig']['authType'])) == 'scram-sha-512') ? (sprig.dict(\"kafkaPropertyFile\", '/config/kafka-auth/client.properties')) : (sprig.dict()))))))}}"
                  }
                ]
              },
              "name": "deployProxyNoTls"
            },
            {
              "template": "deployproxydeploymentwithtls",
              "when": "{{=sprig.dig('tls', 'mode', '', fromJSON(inputs.parameters.proxyConfig)['proxyConfig']) == 'certManager' || sprig.dig('tls', 'mode', '', fromJSON(inputs.parameters.proxyConfig)['proxyConfig']) == 'existingSecret'}}",
              "arguments": {
                "parameters": [
                  {
                    "name": "proxyName",
                    "value": "{{=fromJSON(inputs.parameters.proxyConfig)['name']}}"
                  },
                  {
                    "name": "listenPort",
                    "value": "{{inputs.parameters.listenPort}}"
                  },
                  {
                    "name": "podReplicas",
                    "value": "{{inputs.parameters.podReplicas}}"
                  },
                  {
                    "name": "ownerUid",
                    "value": "{{inputs.parameters.ownerUid}}"
                  },
                  {
                    "name": "imageCaptureProxyLocation",
                    "value": "{{inputs.parameters.imageCaptureProxyLocation}}"
                  },
                  {
                    "name": "imageCaptureProxyPullPolicy",
                    "value": "{{inputs.parameters.imageCaptureProxyPullPolicy}}"
                  },
                  {
                    "name": "kafkaAuthConfigMapName",
                    "value": "{{=inputs.parameters.proxyName+'-kafka-auth'}}"
                  },
                  {
                    "name": "kafkaAuthType",
                    "value": "{{=((!(inputs.parameters.resolvedKafkaAuthType == '')) ? (inputs.parameters.resolvedKafkaAuthType) : (fromJSON(inputs.parameters.proxyConfig)['kafkaConfig']['authType']))}}"
                  },
                  {
                    "name": "kafkaSecretName",
                    "value": "{{=fromJSON(inputs.parameters.proxyConfig)['kafkaConfig']['secretName']}}"
                  },
                  {
                    "name": "kafkaCaSecretName",
                    "value": "{{=fromJSON(inputs.parameters.proxyConfig)['kafkaConfig']['caSecretName']}}"
                  },
                  {
                    "name": "resources",
                    "value": "{{=toJSON(fromJSON(inputs.parameters.proxyConfig)['proxyConfig']['resources'])}}"
                  },
                  {
                    "name": "tlsSecretName",
                    "value": "{{=((sprig.dig('tls', 'mode', '', fromJSON(inputs.parameters.proxyConfig)['proxyConfig']) == 'certManager') ? (inputs.parameters.proxyName+'-tls') : (((sprig.dig('tls', 'mode', '', fromJSON(inputs.parameters.proxyConfig)['proxyConfig']) == 'existingSecret') ? (sprig.dig('tls', 'secretName', '', fromJSON(inputs.parameters.proxyConfig)['proxyConfig'])) : (''))))}}"
                  },
                  {
                    "name": "jsonConfig",
                    "value": "{{=toJSON(sprig.merge(sprig.merge(sprig.omit(fromJSON(inputs.parameters.proxyConfig)['proxyConfig'], 'loggingConfigurationOverrideConfigMap', 'internetFacing', 'podReplicas', 'resources', 'tls'), sprig.merge(((sprig.dig('proxyConfig', 'noCapture', false, fromJSON(inputs.parameters.proxyConfig))) ? (sprig.dict()) : (sprig.dict(\"kafkaConnection\", ((!(inputs.parameters.resolvedKafkaConnection == '')) ? (inputs.parameters.resolvedKafkaConnection) : (fromJSON(inputs.parameters.proxyConfig)['kafkaConfig']['kafkaConnection']))))), sprig.merge(sprig.dict(\"destinationUri\", fromJSON(inputs.parameters.proxyConfig)['sourceEndpoint'], \"insecureDestination\", fromJSON(inputs.parameters.proxyConfig)['sourceAllowInsecure'], \"kafkaTopic\", jsonpath(inputs.parameters.proxyConfig, '$.kafkaConfig.kafkaTopic'), \"kafkaListenerName\", ((!(inputs.parameters.resolvedKafkaListenerName == '')) ? (inputs.parameters.resolvedKafkaListenerName) : (fromJSON(inputs.parameters.proxyConfig)['kafkaConfig']['listenerName'])), \"kafkaAuthType\", ((!(inputs.parameters.resolvedKafkaAuthType == '')) ? (inputs.parameters.resolvedKafkaAuthType) : (fromJSON(inputs.parameters.proxyConfig)['kafkaConfig']['authType'])), \"kafkaSecretName\", fromJSON(inputs.parameters.proxyConfig)['kafkaConfig']['secretName'], \"kafkaUserName\", fromJSON(inputs.parameters.proxyConfig)['kafkaConfig']['kafkaUserName']), ((((!(inputs.parameters.resolvedKafkaAuthType == '')) ? (inputs.parameters.resolvedKafkaAuthType) : (fromJSON(inputs.parameters.proxyConfig)['kafkaConfig']['authType'])) == 'scram-sha-512') ? (sprig.dict(\"kafkaPropertyFile\", '/config/kafka-auth/client.properties')) : (sprig.dict()))))), sprig.dict(\"sslCertChainFile\", '/etc/proxy-tls/tls.crt', \"sslKeyFile\", '/etc/proxy-tls/tls.key')))}}"
                  }
                ]
              },
              "name": "deployProxyWithTls"
            }
          ]
        ],
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "reconcilecapturetopicandproxy",
        "inputs": {
          "parameters": [
            {
              "name": "proxyConfig"
            },
            {
              "name": "kafkaClusterName"
            },
            {
              "name": "kafkaTopicName"
            },
            {
              "name": "proxyName"
            },
            {
              "name": "topicCrName"
            },
            {
              "name": "ownerUid"
            },
            {
              "name": "configChecksum"
            },
            {
              "name": "topicConfigChecksum"
            },
            {
              "name": "checksumForSnapshot"
            },
            {
              "name": "checksumForReplayer"
            },
            {
              "name": "listenPort"
            },
            {
              "name": "podReplicas"
            },
            {
              "name": "topicPartitions"
            },
            {
              "name": "topicReplicas"
            },
            {
              "name": "topicConfig"
            },
            {
              "name": "kafkaClusterOwnerUid"
            },
            {
              "name": "imageMigrationConsoleLocation"
            },
            {
              "name": "imageMigrationConsolePullPolicy"
            },
            {
              "name": "imageCaptureProxyLocation"
            },
            {
              "name": "imageCaptureProxyPullPolicy"
            }
          ]
        },
        "steps": [
          [
            {
              "templateRef": {
                "template": "reconcilecapturedtrafficresource",
                "name": "resource-management"
              },
              "arguments": {
                "parameters": [
                  {
                    "name": "topicCrName",
                    "value": "{{inputs.parameters.topicCrName}}"
                  },
                  {
                    "name": "kafkaClusterName",
                    "value": "{{inputs.parameters.kafkaClusterName}}"
                  },
                  {
                    "name": "kafkaTopicName",
                    "value": "{{inputs.parameters.kafkaTopicName}}"
                  },
                  {
                    "name": "partitions",
                    "value": "{{inputs.parameters.topicPartitions}}"
                  },
                  {
                    "name": "replicas",
                    "value": "{{inputs.parameters.topicReplicas}}"
                  },
                  {
                    "name": "topicConfig",
                    "value": "{{inputs.parameters.topicConfig}}"
                  },
                  {
                    "name": "retryGateName",
                    "value": "{{=inputs.parameters.topicCrName+'.capturedtraffic.vapretry'}}"
                  },
                  {
                    "name": "retryGroupName_view",
                    "value": "{{='CapturedTraffic: '+inputs.parameters.topicCrName}}"
                  }
                ]
              },
              "name": "reconcileCapturedTrafficResource"
            }
          ],
          [
            {
              "templateRef": {
                "template": "waitforkafkacluster",
                "name": "resource-management"
              },
              "when": "{{=true && !(steps.reconcileCapturedTrafficResource.outputs.parameters.currentConfigChecksum == inputs.parameters.topicConfigChecksum) && sprig.dig('kafkaConfig', 'managedByWorkflow', false, fromJSON(inputs.parameters.proxyConfig))}}",
              "arguments": {
                "parameters": [
                  {
                    "name": "imageMigrationConsoleLocation",
                    "value": "{{inputs.parameters.imageMigrationConsoleLocation}}"
                  },
                  {
                    "name": "imageMigrationConsolePullPolicy",
                    "value": "{{inputs.parameters.imageMigrationConsolePullPolicy}}"
                  },
                  {
                    "name": "resourceName",
                    "value": "{{inputs.parameters.kafkaClusterName}}"
                  }
                ]
              },
              "name": "waitForKafkaCluster"
            }
          ],
          [
            {
              "templateRef": {
                "template": "createkafkatopic",
                "name": "setup-kafka"
              },
              "when": "{{=true && !(steps.reconcileCapturedTrafficResource.outputs.parameters.currentConfigChecksum == inputs.parameters.topicConfigChecksum) && sprig.dig('kafkaConfig', 'managedByWorkflow', false, fromJSON(inputs.parameters.proxyConfig))}}",
              "arguments": {
                "parameters": [
                  {
                    "name": "clusterName",
                    "value": "{{inputs.parameters.kafkaClusterName}}"
                  },
                  {
                    "name": "topicName",
                    "value": "{{inputs.parameters.kafkaTopicName}}"
                  },
                  {
                    "name": "workflowUid",
                    "value": "{{workflow.uid}}"
                  },
                  {
                    "name": "ownerUid",
                    "value": "{{inputs.parameters.kafkaClusterOwnerUid}}"
                  },
                  {
                    "name": "partitions",
                    "value": "{{inputs.parameters.topicPartitions}}"
                  },
                  {
                    "name": "replicas",
                    "value": "{{inputs.parameters.topicReplicas}}"
                  },
                  {
                    "name": "topicConfig",
                    "value": "{{inputs.parameters.topicConfig}}"
                  }
                ]
              },
              "name": "createKafkaTopic"
            }
          ],
          [
            {
              "templateRef": {
                "template": "patchcapturedtrafficready",
                "name": "resource-management"
              },
              "when": "{{=true && !(steps.reconcileCapturedTrafficResource.outputs.parameters.currentConfigChecksum == inputs.parameters.topicConfigChecksum)}}",
              "arguments": {
                "parameters": [
                  {
                    "name": "resourceName",
                    "value": "{{inputs.parameters.topicCrName}}"
                  },
                  {
                    "name": "phase",
                    "value": "Ready"
                  },
                  {
                    "name": "configChecksum",
                    "value": "{{inputs.parameters.topicConfigChecksum}}"
                  },
                  {
                    "name": "checksumForSnapshot",
                    "value": "{{inputs.parameters.checksumForSnapshot}}"
                  },
                  {
                    "name": "checksumForReplayer",
                    "value": "{{inputs.parameters.checksumForReplayer}}"
                  }
                ]
              },
              "name": "patchCapturedTrafficReady"
            }
          ],
          [
            {
              "templateRef": {
                "template": "reconcilecaptureproxyresource",
                "name": "resource-management"
              },
              "arguments": {
                "parameters": [
                  {
                    "name": "proxyConfig",
                    "value": "{{inputs.parameters.proxyConfig}}"
                  },
                  {
                    "name": "proxyName",
                    "value": "{{inputs.parameters.proxyName}}"
                  },
                  {
                    "name": "topicCrName",
                    "value": "{{inputs.parameters.topicCrName}}"
                  },
                  {
                    "name": "retryGateName",
                    "value": "{{=inputs.parameters.proxyName+'.captureproxy.vapretry'}}"
                  },
                  {
                    "name": "retryGroupName_view",
                    "value": "{{='CaptureProxy: '+inputs.parameters.proxyName}}"
                  }
                ]
              },
              "name": "reconcileCaptureProxyResource"
            }
          ],
          [
            {
              "templateRef": {
                "template": "readkafkaconnectionprofile",
                "name": "resource-management"
              },
              "when": "{{=true && !(steps.reconcileCaptureProxyResource.outputs.parameters.currentConfigChecksum == inputs.parameters.configChecksum) && sprig.dig('kafkaConfig', 'managedByWorkflow', false, fromJSON(inputs.parameters.proxyConfig))}}",
              "arguments": {
                "parameters": [
                  {
                    "name": "resourceName",
                    "value": "{{inputs.parameters.kafkaClusterName}}"
                  }
                ]
              },
              "name": "readKafkaConnectionProfile"
            }
          ],
          [
            {
              "templateRef": {
                "template": "patchcaptureproxyrunning",
                "name": "resource-management"
              },
              "when": "{{=true && !(steps.reconcileCaptureProxyResource.outputs.parameters.currentConfigChecksum == inputs.parameters.configChecksum)}}",
              "arguments": {
                "parameters": [
                  {
                    "name": "resourceName",
                    "value": "{{inputs.parameters.proxyName}}"
                  },
                  {
                    "name": "phase",
                    "value": "Running"
                  }
                ]
              },
              "name": "patchCaptureProxyRunning"
            }
          ],
          [
            {
              "template": "setupproxy",
              "when": "{{=true && !(steps.reconcileCaptureProxyResource.outputs.parameters.currentConfigChecksum == inputs.parameters.configChecksum) && sprig.dig('kafkaConfig', 'managedByWorkflow', false, fromJSON(inputs.parameters.proxyConfig))}}",
              "arguments": {
                "parameters": [
                  {
                    "name": "proxyConfig",
                    "value": "{{inputs.parameters.proxyConfig}}"
                  },
                  {
                    "name": "kafkaClusterName",
                    "value": "{{inputs.parameters.kafkaClusterName}}"
                  },
                  {
                    "name": "proxyName",
                    "value": "{{inputs.parameters.proxyName}}"
                  },
                  {
                    "name": "ownerUid",
                    "value": "{{inputs.parameters.ownerUid}}"
                  },
                  {
                    "name": "listenPort",
                    "value": "{{inputs.parameters.listenPort}}"
                  },
                  {
                    "name": "podReplicas",
                    "value": "{{inputs.parameters.podReplicas}}"
                  },
                  {
                    "name": "imageCaptureProxyLocation",
                    "value": "{{inputs.parameters.imageCaptureProxyLocation}}"
                  },
                  {
                    "name": "imageCaptureProxyPullPolicy",
                    "value": "{{inputs.parameters.imageCaptureProxyPullPolicy}}"
                  },
                  {
                    "name": "resolvedKafkaConnection",
                    "value": "{{steps.readKafkaConnectionProfile.outputs.parameters.bootstrapServers}}"
                  },
                  {
                    "name": "resolvedKafkaListenerName",
                    "value": "{{steps.readKafkaConnectionProfile.outputs.parameters.listenerName}}"
                  },
                  {
                    "name": "resolvedKafkaAuthType",
                    "value": "{{steps.readKafkaConnectionProfile.outputs.parameters.authType}}"
                  }
                ]
              },
              "name": "setupProxy",
              "continueOn": {
                "failed": true
              }
            }
          ],
          [
            {
              "template": "setupproxy",
              "when": "{{=true && !(steps.reconcileCaptureProxyResource.outputs.parameters.currentConfigChecksum == inputs.parameters.configChecksum) && !(sprig.dig('kafkaConfig', 'managedByWorkflow', false, fromJSON(inputs.parameters.proxyConfig)))}}",
              "arguments": {
                "parameters": [
                  {
                    "name": "proxyConfig",
                    "value": "{{inputs.parameters.proxyConfig}}"
                  },
                  {
                    "name": "kafkaClusterName",
                    "value": "{{inputs.parameters.kafkaClusterName}}"
                  },
                  {
                    "name": "proxyName",
                    "value": "{{inputs.parameters.proxyName}}"
                  },
                  {
                    "name": "ownerUid",
                    "value": "{{inputs.parameters.ownerUid}}"
                  },
                  {
                    "name": "listenPort",
                    "value": "{{inputs.parameters.listenPort}}"
                  },
                  {
                    "name": "podReplicas",
                    "value": "{{inputs.parameters.podReplicas}}"
                  },
                  {
                    "name": "imageCaptureProxyLocation",
                    "value": "{{inputs.parameters.imageCaptureProxyLocation}}"
                  },
                  {
                    "name": "imageCaptureProxyPullPolicy",
                    "value": "{{inputs.parameters.imageCaptureProxyPullPolicy}}"
                  }
                ]
              },
              "name": "setupProxyWithConfiguredKafka",
              "continueOn": {
                "failed": true
              }
            }
          ],
          [
            {
              "templateRef": {
                "template": "patchcaptureproxyready",
                "name": "resource-management"
              },
              "when": "{{=steps.setupProxy.status == 'Succeeded' || steps.setupProxyWithConfiguredKafka.status == 'Succeeded'}}",
              "arguments": {
                "parameters": [
                  {
                    "name": "resourceName",
                    "value": "{{inputs.parameters.proxyName}}"
                  },
                  {
                    "name": "phase",
                    "value": "Ready"
                  },
                  {
                    "name": "configChecksum",
                    "value": "{{inputs.parameters.configChecksum}}"
                  },
                  {
                    "name": "checksumForSnapshot",
                    "value": "{{inputs.parameters.checksumForSnapshot}}"
                  },
                  {
                    "name": "checksumForReplayer",
                    "value": "{{inputs.parameters.checksumForReplayer}}"
                  }
                ]
              },
              "name": "patchCaptureProxyReady"
            }
          ],
          [
            {
              "templateRef": {
                "template": "patchcaptureproxyerror",
                "name": "resource-management"
              },
              "when": "{{=steps.setupProxy.status == 'Failed' || steps.setupProxyWithConfiguredKafka.status == 'Failed'}}",
              "arguments": {
                "parameters": [
                  {
                    "name": "resourceName",
                    "value": "{{inputs.parameters.proxyName}}"
                  },
                  {
                    "name": "phase",
                    "value": "Error"
                  }
                ]
              },
              "name": "patchCaptureProxyError"
            }
          ]
        ],
        "outputs": {
          "parameters": []
        }
      }
    ]
  }
}
