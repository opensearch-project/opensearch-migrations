{
  "apiVersion": "argoproj.io/v1alpha1",
  "kind": "WorkflowTemplate",
  "metadata": {
    "name": "setup-capture"
  },
  "spec": {
    "serviceAccountName": "argo-workflow-executor",
    "parallelism": 100,
    "arguments": {
      "parameters": [
        {
          "name": "s3SnapshotConfigMap",
          "value": "s3-snapshot-config"
        },
        {
          "name": "imageConfigMapName",
          "value": "migration-image-config"
        },
        {
          "name": "approvalConfigMapName",
          "value": "approval-config"
        }
      ]
    },
    "templates": [
      {
        "name": "suspendforretry",
        "inputs": {
          "parameters": [
            {
              "name": "name"
            }
          ]
        },
        "suspend": {},
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "applycapturedtraffic",
        "inputs": {
          "parameters": [
            {
              "name": "proxyConfig"
            },
            {
              "name": "proxyName"
            },
            {
              "name": "kafkaClusterName"
            },
            {
              "name": "kafkaTopicName"
            }
          ]
        },
        "resource": {
          "manifest": "apiVersion: migrations.opensearch.org/v1alpha1\nkind: CapturedTraffic\nmetadata:\n  name: \"{{inputs.parameters.proxyName}}\"\n  labels:\n    workflows.argoproj.io/run-uid: \"{{workflow.uid}}\"\nspec:\n  loggingConfigurationOverrideConfigMap: \"{{=sprig.dig('loggingConfigurationOverrideConfigMap', '', fromJSON(inputs.parameters.proxyConfig)['proxyConfig'])}}\"\n  internetFacing: {{=sprig.dig('internetFacing', false, fromJSON(inputs.parameters.proxyConfig)['proxyConfig'])}}\n  podReplicas: {{=sprig.dig('podReplicas', 1, fromJSON(inputs.parameters.proxyConfig)['proxyConfig'])}}\n  resources: {{=fromJSON(inputs.parameters.proxyConfig)['proxyConfig']['resources']}}\n  otelCollectorEndpoint: \"{{=sprig.dig('otelCollectorEndpoint', 'http://otel-collector:4317', fromJSON(inputs.parameters.proxyConfig)['proxyConfig'])}}\"\n  setHeader: {{=sprig.dig('setHeader', [], fromJSON(inputs.parameters.proxyConfig)['proxyConfig'])}}\n  destinationConnectionPoolSize: {{=sprig.dig('destinationConnectionPoolSize', 0, fromJSON(inputs.parameters.proxyConfig)['proxyConfig'])}}\n  destinationConnectionPoolTimeout: \"{{=sprig.dig('destinationConnectionPoolTimeout', 'PT30S', fromJSON(inputs.parameters.proxyConfig)['proxyConfig'])}}\"\n  kafkaClientId: \"{{=sprig.dig('kafkaClientId', 'HttpCaptureProxyProducer', fromJSON(inputs.parameters.proxyConfig)['proxyConfig'])}}\"\n  listenPort: {{=fromJSON(inputs.parameters.proxyConfig)['proxyConfig']['listenPort']}}\n  maxTrafficBufferSize: {{=sprig.dig('maxTrafficBufferSize', 1048576, fromJSON(inputs.parameters.proxyConfig)['proxyConfig'])}}\n  noCapture: {{=sprig.dig('noCapture', false, fromJSON(inputs.parameters.proxyConfig)['proxyConfig'])}}\n  numThreads: {{=sprig.dig('numThreads', 1, fromJSON(inputs.parameters.proxyConfig)['proxyConfig'])}}\n  sslConfigFile: \"{{=sprig.dig('sslConfigFile', '', fromJSON(inputs.parameters.proxyConfig)['proxyConfig'])}}\"\n  tls: {{=sprig.dig('tls', sprig.dict(), fromJSON(inputs.parameters.proxyConfig)['proxyConfig'])}}\n  enableMSKAuth: {{=sprig.dig('enableMSKAuth', false, fromJSON(inputs.parameters.proxyConfig)['proxyConfig'])}}\n  kafkaClusterName: \"{{inputs.parameters.kafkaClusterName}}\"\n  kafkaTopicName: \"{{inputs.parameters.kafkaTopicName}}\"\n  suppressCaptureForHeaderMatch: {{=sprig.dig('suppressCaptureForHeaderMatch', [], fromJSON(inputs.parameters.proxyConfig)['proxyConfig'])}}\n  suppressCaptureForMethod: \"{{=sprig.dig('suppressCaptureForMethod', '', fromJSON(inputs.parameters.proxyConfig)['proxyConfig'])}}\"\n  suppressCaptureForUriPath: \"{{=sprig.dig('suppressCaptureForUriPath', '', fromJSON(inputs.parameters.proxyConfig)['proxyConfig'])}}\"\n  suppressMethodAndPath: \"{{=sprig.dig('suppressMethodAndPath', '', fromJSON(inputs.parameters.proxyConfig)['proxyConfig'])}}\"\n",
          "action": "apply",
          "setOwnerReference": false
        },
        "retryStrategy": {
          "limit": "6",
          "retryPolicy": "OnError",
          "backoff": {
            "duration": "10",
            "factor": "2",
            "cap": "60"
          }
        },
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "applycapturedtrafficwithretry",
        "inputs": {
          "parameters": [
            {
              "name": "proxyConfig"
            },
            {
              "name": "proxyName"
            },
            {
              "name": "kafkaClusterName"
            },
            {
              "name": "kafkaTopicName"
            },
            {
              "name": "retryGroupName_view",
              "value": "Apply"
            }
          ]
        },
        "steps": [
          [
            {
              "template": "applycapturedtraffic",
              "arguments": {
                "parameters": [
                  {
                    "name": "proxyConfig",
                    "value": "{{inputs.parameters.proxyConfig}}"
                  },
                  {
                    "name": "proxyName",
                    "value": "{{inputs.parameters.proxyName}}"
                  },
                  {
                    "name": "kafkaClusterName",
                    "value": "{{inputs.parameters.kafkaClusterName}}"
                  },
                  {
                    "name": "kafkaTopicName",
                    "value": "{{inputs.parameters.kafkaTopicName}}"
                  }
                ]
              },
              "name": "tryApply",
              "continueOn": {
                "failed": true
              }
            }
          ],
          [
            {
              "template": "suspendforretry",
              "when": "{{=steps.tryApply.status == 'Failed'}}",
              "arguments": {
                "parameters": [
                  {
                    "name": "name",
                    "value": "CapturedTraffic"
                  }
                ]
              },
              "name": "waitForFix"
            }
          ],
          [
            {
              "templateRef": {
                "template": "patchapprovalannotation",
                "name": "resource-management"
              },
              "when": "{{=steps.waitForFix.status == 'Succeeded'}}",
              "arguments": {
                "parameters": [
                  {
                    "name": "resourceApiVersion",
                    "value": "migrations.opensearch.org/v1alpha1"
                  },
                  {
                    "name": "resourceKind",
                    "value": "CapturedTraffic"
                  },
                  {
                    "name": "resourceName",
                    "value": "{{inputs.parameters.proxyName}}"
                  }
                ]
              },
              "name": "patchApproval"
            }
          ],
          [
            {
              "template": "applycapturedtrafficwithretry",
              "when": "{{=steps.patchApproval.status == 'Succeeded'}}",
              "arguments": {
                "parameters": [
                  {
                    "name": "proxyConfig",
                    "value": "{{inputs.parameters.proxyConfig}}"
                  },
                  {
                    "name": "proxyName",
                    "value": "{{inputs.parameters.proxyName}}"
                  },
                  {
                    "name": "kafkaClusterName",
                    "value": "{{inputs.parameters.kafkaClusterName}}"
                  },
                  {
                    "name": "kafkaTopicName",
                    "value": "{{inputs.parameters.kafkaTopicName}}"
                  },
                  {
                    "name": "retryGroupName_view",
                    "value": "{{inputs.parameters.retryGroupName_view}}"
                  }
                ]
              },
              "name": "retryLoop"
            }
          ]
        ],
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "deployproxyservice",
        "inputs": {
          "parameters": [
            {
              "name": "proxyName"
            },
            {
              "name": "listenPort"
            },
            {
              "name": "internetFacing",
              "value": "false"
            }
          ]
        },
        "resource": {
          "manifest": "apiVersion: v1\nkind: Service\nmetadata:\n  name: \"{{inputs.parameters.proxyName}}\"\n  annotations:\n    service.beta.kubernetes.io/aws-load-balancer-type: external\n    service.beta.kubernetes.io/aws-load-balancer-nlb-target-type: ip\n    service.beta.kubernetes.io/aws-load-balancer-scheme: \"{{=((fromJSON(inputs.parameters.internetFacing)) ? ('internet-facing') : ('internal'))}}\"\nspec:\n  type: LoadBalancer\n  selector:\n    migrations/proxy: \"{{inputs.parameters.proxyName}}\"\n  ports:\n    - port: {{inputs.parameters.listenPort}}\n      targetPort: {{inputs.parameters.listenPort}}\n      protocol: TCP\n",
          "action": "apply",
          "setOwnerReference": false
        },
        "retryStrategy": {
          "limit": "6",
          "retryPolicy": "OnError",
          "backoff": {
            "duration": "10",
            "factor": "2",
            "cap": "60"
          }
        },
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "deployproxydeployment",
        "inputs": {
          "parameters": [
            {
              "name": "proxyName"
            },
            {
              "name": "jsonConfig"
            },
            {
              "name": "kafkaAuthConfigMapName"
            },
            {
              "name": "kafkaAuthType"
            },
            {
              "name": "kafkaSecretName"
            },
            {
              "name": "kafkaCaSecretName"
            },
            {
              "name": "listenPort"
            },
            {
              "name": "podReplicas"
            },
            {
              "name": "resources"
            },
            {
              "name": "tlsSecretName",
              "value": ""
            },
            {
              "name": "imageCaptureProxyLocation"
            },
            {
              "name": "imageCaptureProxyPullPolicy"
            }
          ]
        },
        "resource": {
          "manifest": "apiVersion: apps/v1\nkind: Deployment\nmetadata:\n  name: \"{{inputs.parameters.proxyName}}\"\nspec:\n  replicas: {{=fromJSON(inputs.parameters.podReplicas)}}\n  strategy:\n    type: Recreate\n  selector:\n    matchLabels:\n      migrations/proxy: \"{{inputs.parameters.proxyName}}\"\n  template:\n    metadata:\n      labels:\n        migrations/proxy: \"{{inputs.parameters.proxyName}}\"\n    spec:\n      containers:\n        - name: proxy\n          image: \"{{inputs.parameters.imageCaptureProxyLocation}}\"\n          imagePullPolicy: \"{{inputs.parameters.imageCaptureProxyPullPolicy}}\"\n          args:\n            - ---INLINE-JSON\n            - \"{{=toBase64(inputs.parameters.jsonConfig)}}\"\n          ports:\n            - containerPort: {{inputs.parameters.listenPort}}\n          resources: {{=fromJSON(inputs.parameters.resources)}}\n          env:\n            - name: CAPTURE_PROXY_KAFKA_PASSWORD\n              valueFrom:\n                secretKeyRef:\n                  name: \"{{=((inputs.parameters.kafkaAuthType == 'scram-sha-512') ? (inputs.parameters.kafkaSecretName) : ('empty'))}}\"\n                  key: password\n                  optional: {{=!(inputs.parameters.kafkaAuthType == 'scram-sha-512')}}\n          volumeMounts:\n            - name: kafka-auth-config\n              mountPath: /config/kafka-auth\n              readOnly: true\n            - name: kafka-ca\n              mountPath: /config/kafka-ca\n              readOnly: true\n      volumes:\n        - name: kafka-auth-config\n          configMap:\n            name: \"{{inputs.parameters.kafkaAuthConfigMapName}}\"\n        - name: kafka-ca\n          secret:\n            secretName: \"{{=((inputs.parameters.kafkaAuthType == 'scram-sha-512') ? (inputs.parameters.kafkaCaSecretName) : ('empty'))}}\"\n            optional: {{=!(inputs.parameters.kafkaAuthType == 'scram-sha-512')}}\n",
          "action": "apply",
          "setOwnerReference": false,
          "successCondition": "status.readyReplicas > 0"
        },
        "retryStrategy": {
          "limit": "6",
          "retryPolicy": "OnError",
          "backoff": {
            "duration": "10",
            "factor": "2",
            "cap": "60"
          }
        },
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "deployproxydeploymentwithtls",
        "inputs": {
          "parameters": [
            {
              "name": "proxyName"
            },
            {
              "name": "jsonConfig"
            },
            {
              "name": "kafkaAuthConfigMapName"
            },
            {
              "name": "kafkaAuthType"
            },
            {
              "name": "kafkaSecretName"
            },
            {
              "name": "kafkaCaSecretName"
            },
            {
              "name": "listenPort"
            },
            {
              "name": "podReplicas"
            },
            {
              "name": "resources"
            },
            {
              "name": "tlsSecretName"
            },
            {
              "name": "imageCaptureProxyLocation"
            },
            {
              "name": "imageCaptureProxyPullPolicy"
            }
          ]
        },
        "resource": {
          "manifest": "apiVersion: apps/v1\nkind: Deployment\nmetadata:\n  name: \"{{inputs.parameters.proxyName}}\"\nspec:\n  replicas: {{=fromJSON(inputs.parameters.podReplicas)}}\n  strategy:\n    type: Recreate\n  selector:\n    matchLabels:\n      migrations/proxy: \"{{inputs.parameters.proxyName}}\"\n  template:\n    metadata:\n      labels:\n        migrations/proxy: \"{{inputs.parameters.proxyName}}\"\n    spec:\n      containers:\n        - name: proxy\n          image: \"{{inputs.parameters.imageCaptureProxyLocation}}\"\n          imagePullPolicy: \"{{inputs.parameters.imageCaptureProxyPullPolicy}}\"\n          args:\n            - ---INLINE-JSON\n            - \"{{=toBase64(inputs.parameters.jsonConfig)}}\"\n          ports:\n            - containerPort: {{inputs.parameters.listenPort}}\n          resources: {{=fromJSON(inputs.parameters.resources)}}\n          env:\n            - name: CAPTURE_PROXY_KAFKA_PASSWORD\n              valueFrom:\n                secretKeyRef:\n                  name: \"{{=((inputs.parameters.kafkaAuthType == 'scram-sha-512') ? (inputs.parameters.kafkaSecretName) : ('empty'))}}\"\n                  key: password\n                  optional: {{=!(inputs.parameters.kafkaAuthType == 'scram-sha-512')}}\n          volumeMounts:\n            - name: kafka-auth-config\n              mountPath: /config/kafka-auth\n              readOnly: true\n            - name: kafka-ca\n              mountPath: /config/kafka-ca\n              readOnly: true\n            - name: tls-certs\n              mountPath: /etc/proxy-tls\n              readOnly: true\n      volumes:\n        - name: kafka-auth-config\n          configMap:\n            name: \"{{inputs.parameters.kafkaAuthConfigMapName}}\"\n        - name: kafka-ca\n          secret:\n            secretName: \"{{=((inputs.parameters.kafkaAuthType == 'scram-sha-512') ? (inputs.parameters.kafkaCaSecretName) : ('empty'))}}\"\n            optional: {{=!(inputs.parameters.kafkaAuthType == 'scram-sha-512')}}\n        - name: tls-certs\n          secret:\n            secretName: \"{{inputs.parameters.tlsSecretName}}\"\n",
          "action": "apply",
          "setOwnerReference": false,
          "successCondition": "status.readyReplicas > 0"
        },
        "retryStrategy": {
          "limit": "6",
          "retryPolicy": "OnError",
          "backoff": {
            "duration": "10",
            "factor": "2",
            "cap": "60"
          }
        },
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "createkafkaclientpropertiesconfigmap",
        "inputs": {
          "parameters": [
            {
              "name": "name"
            }
          ]
        },
        "resource": {
          "manifest": "apiVersion: v1\nkind: ConfigMap\nmetadata:\n  name: \"{{inputs.parameters.name}}\"\ndata:\n  client.properties: |-\n    ssl.truststore.type=PEM\n    ssl.truststore.location=/config/kafka-ca/ca.crt\n",
          "action": "apply",
          "setOwnerReference": false
        },
        "retryStrategy": {
          "limit": "6",
          "retryPolicy": "OnError",
          "backoff": {
            "duration": "10",
            "factor": "2",
            "cap": "60"
          }
        },
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "provisionproxycert",
        "inputs": {
          "parameters": [
            {
              "name": "certName"
            },
            {
              "name": "secretName"
            },
            {
              "name": "issuerName"
            },
            {
              "name": "issuerKind"
            },
            {
              "name": "issuerGroup"
            },
            {
              "name": "dnsNames"
            },
            {
              "name": "duration"
            },
            {
              "name": "renewBefore"
            }
          ]
        },
        "resource": {
          "manifest": "apiVersion: cert-manager.io/v1\nkind: Certificate\nmetadata:\n  name: \"{{inputs.parameters.certName}}\"\nspec:\n  secretName: \"{{inputs.parameters.secretName}}\"\n  issuerRef:\n    name: \"{{inputs.parameters.issuerName}}\"\n    kind: \"{{inputs.parameters.issuerKind}}\"\n    group: \"{{inputs.parameters.issuerGroup}}\"\n  dnsNames: {{inputs.parameters.dnsNames}}\n  duration: \"{{inputs.parameters.duration}}\"\n  renewBefore: \"{{inputs.parameters.renewBefore}}\"\n",
          "action": "apply",
          "setOwnerReference": false
        },
        "retryStrategy": {
          "limit": "6",
          "retryPolicy": "OnError",
          "backoff": {
            "duration": "10",
            "factor": "2",
            "cap": "60"
          }
        },
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "waitforcertready",
        "inputs": {
          "parameters": [
            {
              "name": "certName"
            }
          ]
        },
        "resource": {
          "manifest": "apiVersion: cert-manager.io/v1\nkind: Certificate\nmetadata:\n  name: \"{{inputs.parameters.certName}}\"\n",
          "action": "get",
          "successCondition": "status.conditions.0.status == True",
          "failureCondition": "status.conditions.0.status == False"
        },
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "setupproxy",
        "inputs": {
          "parameters": [
            {
              "name": "proxyConfig"
            },
            {
              "name": "kafkaClusterName"
            },
            {
              "name": "kafkaTopicName"
            },
            {
              "name": "proxyName"
            },
            {
              "name": "listenPort"
            },
            {
              "name": "podReplicas"
            },
            {
              "name": "resolvedKafkaConnection",
              "value": ""
            },
            {
              "name": "resolvedKafkaListenerName",
              "value": ""
            },
            {
              "name": "resolvedKafkaAuthType",
              "value": ""
            },
            {
              "name": "imageCaptureProxyLocation"
            },
            {
              "name": "imageCaptureProxyPullPolicy"
            }
          ]
        },
        "steps": [
          [
            {
              "templateRef": {
                "template": "createkafkatopicwithretry",
                "name": "setup-kafka"
              },
              "arguments": {
                "parameters": [
                  {
                    "name": "clusterName",
                    "value": "{{inputs.parameters.kafkaClusterName}}"
                  },
                  {
                    "name": "topicName",
                    "value": "{{inputs.parameters.kafkaTopicName}}"
                  },
                  {
                    "name": "partitions",
                    "value": "{{=fromJSON(inputs.parameters.proxyConfig)['kafkaConfig']['topicSpecOverrides']['partitions']}}"
                  },
                  {
                    "name": "replicas",
                    "value": "{{=fromJSON(inputs.parameters.proxyConfig)['kafkaConfig']['topicSpecOverrides']['replicas']}}"
                  },
                  {
                    "name": "topicConfig",
                    "value": "{{=toJSON(fromJSON(inputs.parameters.proxyConfig)['kafkaConfig']['topicSpecOverrides']['config'])}}"
                  },
                  {
                    "name": "retryGroupName_view",
                    "value": "{{='KafkaTopic: '+inputs.parameters.kafkaTopicName}}"
                  }
                ]
              },
              "name": "createKafkaTopic"
            }
          ],
          [
            {
              "template": "createkafkaclientpropertiesconfigmap",
              "arguments": {
                "parameters": [
                  {
                    "name": "name",
                    "value": "{{=inputs.parameters.proxyName+'-kafka-auth'}}"
                  }
                ]
              },
              "name": "createKafkaClientConfig"
            }
          ],
          [
            {
              "template": "deployproxyservice",
              "arguments": {
                "parameters": [
                  {
                    "name": "proxyName",
                    "value": "{{inputs.parameters.proxyName}}"
                  },
                  {
                    "name": "listenPort",
                    "value": "{{inputs.parameters.listenPort}}"
                  },
                  {
                    "name": "internetFacing",
                    "value": "{{=sprig.dig('internetFacing', false, fromJSON(inputs.parameters.proxyConfig)['proxyConfig'])}}"
                  }
                ]
              },
              "name": "deployService"
            },
            {
              "template": "provisionproxycert",
              "when": "{{=sprig.dig('tls', 'mode', '', fromJSON(inputs.parameters.proxyConfig)['proxyConfig']) == 'certManager'}}",
              "arguments": {
                "parameters": [
                  {
                    "name": "certName",
                    "value": "{{=inputs.parameters.proxyName+'-tls'}}"
                  },
                  {
                    "name": "secretName",
                    "value": "{{=inputs.parameters.proxyName+'-tls'}}"
                  },
                  {
                    "name": "issuerName",
                    "value": "{{=sprig.dig('tls', 'issuerRef', 'name', '', fromJSON(inputs.parameters.proxyConfig)['proxyConfig'])}}"
                  },
                  {
                    "name": "issuerKind",
                    "value": "{{=sprig.dig('tls', 'issuerRef', 'kind', 'ClusterIssuer', fromJSON(inputs.parameters.proxyConfig)['proxyConfig'])}}"
                  },
                  {
                    "name": "issuerGroup",
                    "value": "{{=sprig.dig('tls', 'issuerRef', 'group', 'cert-manager.io', fromJSON(inputs.parameters.proxyConfig)['proxyConfig'])}}"
                  },
                  {
                    "name": "dnsNames",
                    "value": "{{=toJSON(sprig.dig('tls', 'dnsNames', [], fromJSON(inputs.parameters.proxyConfig)['proxyConfig']))}}"
                  },
                  {
                    "name": "duration",
                    "value": "{{=sprig.dig('tls', 'duration', '2160h', fromJSON(inputs.parameters.proxyConfig)['proxyConfig'])}}"
                  },
                  {
                    "name": "renewBefore",
                    "value": "{{=sprig.dig('tls', 'renewBefore', '360h', fromJSON(inputs.parameters.proxyConfig)['proxyConfig'])}}"
                  }
                ]
              },
              "name": "provisionCert"
            }
          ],
          [
            {
              "template": "waitforcertready",
              "when": "{{=sprig.dig('tls', 'mode', '', fromJSON(inputs.parameters.proxyConfig)['proxyConfig']) == 'certManager'}}",
              "arguments": {
                "parameters": [
                  {
                    "name": "certName",
                    "value": "{{=inputs.parameters.proxyName+'-tls'}}"
                  }
                ]
              },
              "name": "waitForCert"
            }
          ],
          [
            {
              "template": "deployproxydeployment",
              "when": "{{=!(sprig.dig('tls', 'mode', '', fromJSON(inputs.parameters.proxyConfig)['proxyConfig']) == 'certManager' || sprig.dig('tls', 'mode', '', fromJSON(inputs.parameters.proxyConfig)['proxyConfig']) == 'existingSecret')}}",
              "arguments": {
                "parameters": [
                  {
                    "name": "proxyName",
                    "value": "{{=fromJSON(inputs.parameters.proxyConfig)['name']}}"
                  },
                  {
                    "name": "listenPort",
                    "value": "{{inputs.parameters.listenPort}}"
                  },
                  {
                    "name": "podReplicas",
                    "value": "{{inputs.parameters.podReplicas}}"
                  },
                  {
                    "name": "imageCaptureProxyLocation",
                    "value": "{{inputs.parameters.imageCaptureProxyLocation}}"
                  },
                  {
                    "name": "imageCaptureProxyPullPolicy",
                    "value": "{{inputs.parameters.imageCaptureProxyPullPolicy}}"
                  },
                  {
                    "name": "kafkaAuthConfigMapName",
                    "value": "{{=inputs.parameters.proxyName+'-kafka-auth'}}"
                  },
                  {
                    "name": "kafkaAuthType",
                    "value": "{{=((!(inputs.parameters.resolvedKafkaAuthType == '')) ? (inputs.parameters.resolvedKafkaAuthType) : (fromJSON(inputs.parameters.proxyConfig)['kafkaConfig']['authType']))}}"
                  },
                  {
                    "name": "kafkaSecretName",
                    "value": "{{=fromJSON(inputs.parameters.proxyConfig)['kafkaConfig']['secretName']}}"
                  },
                  {
                    "name": "kafkaCaSecretName",
                    "value": "{{=fromJSON(inputs.parameters.proxyConfig)['kafkaConfig']['caSecretName']}}"
                  },
                  {
                    "name": "resources",
                    "value": "{{=toJSON(fromJSON(inputs.parameters.proxyConfig)['proxyConfig']['resources'])}}"
                  },
                  {
                    "name": "jsonConfig",
