      {
        "name": "setupproxywithlifecycle",
        "inputs": {
          "parameters": [
            {
              "name": "proxyConfig"
            },
            {
              "name": "kafkaClusterName"
            },
            {
              "name": "kafkaTopicName"
            },
            {
              "name": "proxyName"
            },
            {
              "name": "configChecksum"
            },
            {
              "name": "checksumForSnapshot"
            },
            {
              "name": "checksumForReplayer"
            },
            {
              "name": "listenPort"
            },
            {
              "name": "podReplicas"
            },
            {
              "name": "imageMigrationConsoleLocation"
            },
            {
              "name": "imageMigrationConsolePullPolicy"
            },
            {
              "name": "imageCaptureProxyLocation"
            },
            {
              "name": "imageCaptureProxyPullPolicy"
            }
          ]
        },
        "steps": [
          [
            {
              "templateRef": {
                "template": "readresourcephase",
                "name": "resource-management"
              },
              "arguments": {
                "parameters": [
                  {
                    "name": "resourceKind",
                    "value": "CapturedTraffic"
                  },
                  {
                    "name": "resourceName",
                    "value": "{{inputs.parameters.proxyName}}"
                  }
                ]
              },
              "name": "checkPhase"
            }
          ],
          [
            {
              "templateRef": {
                "template": "waitforkafkacluster",
                "name": "resource-management"
              },
              "when": "{{=!(steps.checkPhase.outputs.parameters.phase == 'Ready' && steps.checkPhase.outputs.parameters.configChecksum == inputs.parameters.configChecksum) && sprig.dig('kafkaConfig', 'managedByWorkflow', false, fromJSON(inputs.parameters.proxyConfig))}}",
              "arguments": {
                "parameters": [
                  {
                    "name": "configChecksum",
                    "value": "{{=sprig.dig('kafkaConfig', 'configChecksum', '', fromJSON(inputs.parameters.proxyConfig))}}"
                  },
                  {
                    "name": "imageMigrationConsoleLocation",
                    "value": "{{inputs.parameters.imageMigrationConsoleLocation}}"
                  },
                  {
                    "name": "imageMigrationConsolePullPolicy",
                    "value": "{{inputs.parameters.imageMigrationConsolePullPolicy}}"
                  },
                  {
                    "name": "resourceName",
                    "value": "{{inputs.parameters.kafkaClusterName}}"
                  }
                ]
              },
              "name": "waitForKafkaCluster"
            }
          ],
          [
            {
              "templateRef": {
                "template": "readkafkaconnectionprofile",
                "name": "resource-management"
              },
              "when": "{{=!(steps.checkPhase.outputs.parameters.phase == 'Ready' && steps.checkPhase.outputs.parameters.configChecksum == inputs.parameters.configChecksum) && sprig.dig('kafkaConfig', 'managedByWorkflow', false, fromJSON(inputs.parameters.proxyConfig))}}",
              "arguments": {
                "parameters": [
                  {
                    "name": "resourceName",
                    "value": "{{inputs.parameters.kafkaClusterName}}"
                  }
                ]
              },
              "name": "readKafkaConnectionProfile"
            }
          ],
          [
            {
              "template": "applycapturedtrafficwithretry",
              "when": "{{=!(steps.checkPhase.outputs.parameters.phase == 'Ready' && steps.checkPhase.outputs.parameters.configChecksum == inputs.parameters.configChecksum)}}",
              "arguments": {
                "parameters": [
                  {
                    "name": "proxyConfig",
                    "value": "{{inputs.parameters.proxyConfig}}"
                  },
                  {
                    "name": "proxyName",
                    "value": "{{inputs.parameters.proxyName}}"
                  },
                  {
                    "name": "kafkaClusterName",
                    "value": "{{inputs.parameters.kafkaClusterName}}"
                  },
                  {
                    "name": "kafkaTopicName",
                    "value": "{{inputs.parameters.kafkaTopicName}}"
                  },
                  {
                    "name": "retryGroupName_view",
                    "value": "{{='CapturedTraffic: '+inputs.parameters.proxyName}}"
                  }
                ]
              },
              "name": "applyCapturedTraffic"
            }
          ],
          [
            {
              "templateRef": {
                "template": "patchresourcephase",
                "name": "resource-management"
              },
              "when": "{{=!(steps.checkPhase.outputs.parameters.phase == 'Ready' && steps.checkPhase.outputs.parameters.configChecksum == inputs.parameters.configChecksum)}}",
              "arguments": {
                "parameters": [
                  {
                    "name": "resourceKind",
                    "value": "CapturedTraffic"
                  },
                  {
                    "name": "resourceName",
                    "value": "{{inputs.parameters.proxyName}}"
                  },
                  {
                    "name": "phase",
                    "value": "Running"
                  }
                ]
              },
              "name": "markRunning"
            }
          ],
          [
            {
              "template": "setupproxy",
              "when": "{{=!(steps.checkPhase.outputs.parameters.phase == 'Ready' && steps.checkPhase.outputs.parameters.configChecksum == inputs.parameters.configChecksum) && sprig.dig('kafkaConfig', 'managedByWorkflow', false, fromJSON(inputs.parameters.proxyConfig))}}",
              "arguments": {
                "parameters": [
                  {
                    "name": "proxyConfig",
                    "value": "{{inputs.parameters.proxyConfig}}"
                  },
                  {
                    "name": "kafkaClusterName",
                    "value": "{{inputs.parameters.kafkaClusterName}}"
                  },
                  {
                    "name": "kafkaTopicName",
                    "value": "{{inputs.parameters.kafkaTopicName}}"
                  },
                  {
                    "name": "proxyName",
                    "value": "{{inputs.parameters.proxyName}}"
                  },
                  {
                    "name": "listenPort",
                    "value": "{{inputs.parameters.listenPort}}"
                  },
                  {
                    "name": "podReplicas",
                    "value": "{{inputs.parameters.podReplicas}}"
                  },
                  {
                    "name": "imageCaptureProxyLocation",
                    "value": "{{inputs.parameters.imageCaptureProxyLocation}}"
                  },
                  {
                    "name": "imageCaptureProxyPullPolicy",
                    "value": "{{inputs.parameters.imageCaptureProxyPullPolicy}}"
                  },
                  {
                    "name": "resolvedKafkaConnection",
                    "value": "{{steps.readKafkaConnectionProfile.outputs.parameters.bootstrapServers}}"
                  },
                  {
                    "name": "resolvedKafkaListenerName",
                    "value": "{{steps.readKafkaConnectionProfile.outputs.parameters.listenerName}}"
                  },
                  {
                    "name": "resolvedKafkaAuthType",
                    "value": "{{steps.readKafkaConnectionProfile.outputs.parameters.authType}}"
                  }
                ]
              },
              "name": "setupProxy",
              "continueOn": {
                "failed": true
              }
            }
          ],
          [
            {
              "template": "setupproxy",
              "when": "{{=!(steps.checkPhase.outputs.parameters.phase == 'Ready' && steps.checkPhase.outputs.parameters.configChecksum == inputs.parameters.configChecksum) && !(sprig.dig('kafkaConfig', 'managedByWorkflow', false, fromJSON(inputs.parameters.proxyConfig)))}}",
              "arguments": {
                "parameters": [
                  {
                    "name": "proxyConfig",
                    "value": "{{inputs.parameters.proxyConfig}}"
                  },
                  {
                    "name": "kafkaClusterName",
                    "value": "{{inputs.parameters.kafkaClusterName}}"
                  },
                  {
                    "name": "kafkaTopicName",
                    "value": "{{inputs.parameters.kafkaTopicName}}"
                  },
                  {
                    "name": "proxyName",
                    "value": "{{inputs.parameters.proxyName}}"
                  },
                  {
                    "name": "listenPort",
                    "value": "{{inputs.parameters.listenPort}}"
                  },
                  {
                    "name": "podReplicas",
                    "value": "{{inputs.parameters.podReplicas}}"
                  },
                  {
                    "name": "imageCaptureProxyLocation",
                    "value": "{{inputs.parameters.imageCaptureProxyLocation}}"
                  },
                  {
                    "name": "imageCaptureProxyPullPolicy",
                    "value": "{{inputs.parameters.imageCaptureProxyPullPolicy}}"
                  }
                ]
              },
              "name": "setupProxyWithConfiguredKafka",
              "continueOn": {
                "failed": true
              }
            }
          ],
          [
            {
              "templateRef": {
                "template": "patchresourcephase",
                "name": "resource-management"
              },
              "when": "{{=steps.setupProxy.status == 'Succeeded' || steps.setupProxyWithConfiguredKafka.status == 'Succeeded'}}",
              "arguments": {
                "parameters": [
                  {
                    "name": "resourceKind",
                    "value": "CapturedTraffic"
                  },
                  {
                    "name": "resourceName",
                    "value": "{{inputs.parameters.proxyName}}"
                  },
                  {
                    "name": "phase",
                    "value": "Ready"
                  },
                  {
                    "name": "configChecksum",
                    "value": "{{inputs.parameters.configChecksum}}"
                  },
                  {
                    "name": "checksumForSnapshot",
                    "value": "{{inputs.parameters.checksumForSnapshot}}"
                  },
                  {
                    "name": "checksumForReplayer",
                    "value": "{{inputs.parameters.checksumForReplayer}}"
                  }
                ]
              },
              "name": "markReady"
            }
          ],
          [
            {
              "templateRef": {
                "template": "patchresourcephase",
                "name": "resource-management"
              },
              "when": "{{=steps.setupProxy.status == 'Failed' || steps.setupProxyWithConfiguredKafka.status == 'Failed'}}",
              "arguments": {
                "parameters": [
                  {
                    "name": "resourceKind",
                    "value": "CapturedTraffic"
                  },
                  {
                    "name": "resourceName",
                    "value": "{{inputs.parameters.proxyName}}"
                  },
                  {
                    "name": "phase",
                    "value": "Error"
                  }
                ]
              },
              "name": "markError"
            }
          ]
        ],
        "outputs": {
          "parameters": []
        }
      }
    ]
  }
}
