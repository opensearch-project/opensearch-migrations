{
  "apiVersion": "argoproj.io/v1alpha1",
  "kind": "WorkflowTemplate",
  "metadata": {
    "name": "setup-capture"
  },
  "spec": {
    "serviceAccountName": "argo-workflow-executor",
    "parallelism": 100,
    "arguments": {
      "parameters": [
        {
          "name": "s3SnapshotConfigMap",
          "value": "s3-snapshot-config"
        },
        {
          "name": "imageConfigMapName",
          "value": "migration-image-config"
        },
        {
          "name": "approvalConfigMapName",
          "value": "approval-config"
        }
      ]
    },
    "templates": [
      {
        "name": "deployproxyservice",
        "inputs": {
          "parameters": [
            {
              "name": "proxyName"
            },
            {
              "name": "listenPort"
            },
            {
              "name": "crdName"
            },
            {
              "name": "crdUid"
            },
            {
              "name": "internetFacing",
              "value": "false"
            }
          ]
        },
        "resource": {
          "manifest": "apiVersion: v1\nkind: Service\nmetadata:\n  name: \"{{inputs.parameters.proxyName}}\"\n  ownerReferences:\n    - apiVersion: migrations.opensearch.org/v1alpha1\n      kind: CapturedTraffic\n      name: \"{{inputs.parameters.crdName}}\"\n      uid: \"{{inputs.parameters.crdUid}}\"\n      blockOwnerDeletion: true\n      controller: false\n  annotations:\n    service.beta.kubernetes.io/aws-load-balancer-type: external\n    service.beta.kubernetes.io/aws-load-balancer-nlb-target-type: ip\n    service.beta.kubernetes.io/aws-load-balancer-scheme: \"{{=((fromJSON(inputs.parameters.internetFacing)) ? ('internet-facing') : ('internal'))}}\"\nspec:\n  type: LoadBalancer\n  selector:\n    migrations/proxy: \"{{inputs.parameters.proxyName}}\"\n  ports:\n    - port: {{inputs.parameters.listenPort}}\n      targetPort: {{inputs.parameters.listenPort}}\n      protocol: TCP\n",
          "action": "apply",
          "setOwnerReference": false
        },
        "retryStrategy": {
          "limit": "6",
          "retryPolicy": "OnError",
          "backoff": {
            "duration": "10",
            "factor": "2",
            "cap": "60"
          }
        },
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "deployproxydeployment",
        "inputs": {
          "parameters": [
            {
              "name": "proxyName"
            },
            {
              "name": "jsonConfig"
            },
            {
              "name": "kafkaAuthConfigMapName"
            },
            {
              "name": "kafkaAuthType"
            },
            {
              "name": "kafkaSecretName"
            },
            {
              "name": "kafkaCaSecretName"
            },
            {
              "name": "listenPort"
            },
            {
              "name": "podReplicas"
            },
            {
              "name": "resources"
            },
            {
              "name": "crdName"
            },
            {
              "name": "crdUid"
            },
            {
              "name": "tlsSecretName",
              "value": ""
            },
            {
              "name": "imageCaptureProxyLocation"
            },
            {
              "name": "imageCaptureProxyPullPolicy"
            }
          ]
        },
        "resource": {
          "manifest": "apiVersion: apps/v1\nkind: Deployment\nmetadata:\n  name: \"{{inputs.parameters.proxyName}}\"\n  ownerReferences:\n    - apiVersion: migrations.opensearch.org/v1alpha1\n      kind: CapturedTraffic\n      name: \"{{inputs.parameters.crdName}}\"\n      uid: \"{{inputs.parameters.crdUid}}\"\n      blockOwnerDeletion: true\n      controller: false\nspec:\n  replicas: {{=fromJSON(inputs.parameters.podReplicas)}}\n  strategy:\n    type: Recreate\n  selector:\n    matchLabels:\n      migrations/proxy: \"{{inputs.parameters.proxyName}}\"\n  template:\n    metadata:\n      labels:\n        migrations/proxy: \"{{inputs.parameters.proxyName}}\"\n    spec:\n      containers:\n        - name: proxy\n          image: \"{{inputs.parameters.imageCaptureProxyLocation}}\"\n          imagePullPolicy: \"{{inputs.parameters.imageCaptureProxyPullPolicy}}\"\n          args:\n            - ---INLINE-JSON\n            - \"{{=toBase64(inputs.parameters.jsonConfig)}}\"\n          ports:\n            - containerPort: {{inputs.parameters.listenPort}}\n          resources: {{=fromJSON(inputs.parameters.resources)}}\n          env:\n            - name: CAPTURE_PROXY_KAFKA_PASSWORD\n              valueFrom:\n                secretKeyRef:\n                  name: \"{{=((inputs.parameters.kafkaAuthType == 'scram-sha-512') ? (inputs.parameters.kafkaSecretName) : ('empty'))}}\"\n                  key: password\n                  optional: {{=!(inputs.parameters.kafkaAuthType == 'scram-sha-512')}}\n          volumeMounts:\n            - name: kafka-auth-config\n              mountPath: /config/kafka-auth\n              readOnly: true\n            - name: kafka-ca\n              mountPath: /config/kafka-ca\n              readOnly: true\n      volumes:\n        - name: kafka-auth-config\n          configMap:\n            name: \"{{inputs.parameters.kafkaAuthConfigMapName}}\"\n        - name: kafka-ca\n          secret:\n            secretName: \"{{=((inputs.parameters.kafkaAuthType == 'scram-sha-512') ? (inputs.parameters.kafkaCaSecretName) : ('empty'))}}\"\n            optional: {{=!(inputs.parameters.kafkaAuthType == 'scram-sha-512')}}\n",
          "action": "apply",
          "setOwnerReference": false,
          "successCondition": "status.readyReplicas > 0"
        },
        "retryStrategy": {
          "limit": "6",
          "retryPolicy": "OnError",
          "backoff": {
            "duration": "10",
            "factor": "2",
            "cap": "60"
          }
        },
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "deployproxydeploymentwithtls",
        "inputs": {
          "parameters": [
            {
              "name": "proxyName"
            },
            {
              "name": "jsonConfig"
            },
            {
              "name": "kafkaAuthConfigMapName"
            },
            {
              "name": "kafkaAuthType"
            },
            {
              "name": "kafkaSecretName"
            },
            {
              "name": "kafkaCaSecretName"
            },
            {
              "name": "listenPort"
            },
            {
              "name": "podReplicas"
            },
            {
              "name": "resources"
            },
            {
              "name": "tlsSecretName"
            },
            {
              "name": "crdName"
            },
            {
              "name": "crdUid"
            },
            {
              "name": "imageCaptureProxyLocation"
            },
            {
              "name": "imageCaptureProxyPullPolicy"
            }
          ]
        },
        "resource": {
          "manifest": "apiVersion: apps/v1\nkind: Deployment\nmetadata:\n  name: \"{{inputs.parameters.proxyName}}\"\n  ownerReferences:\n    - apiVersion: migrations.opensearch.org/v1alpha1\n      kind: CapturedTraffic\n      name: \"{{inputs.parameters.crdName}}\"\n      uid: \"{{inputs.parameters.crdUid}}\"\n      blockOwnerDeletion: true\n      controller: false\nspec:\n  replicas: {{=fromJSON(inputs.parameters.podReplicas)}}\n  strategy:\n    type: Recreate\n  selector:\n    matchLabels:\n      migrations/proxy: \"{{inputs.parameters.proxyName}}\"\n  template:\n    metadata:\n      labels:\n        migrations/proxy: \"{{inputs.parameters.proxyName}}\"\n    spec:\n      containers:\n        - name: proxy\n          image: \"{{inputs.parameters.imageCaptureProxyLocation}}\"\n          imagePullPolicy: \"{{inputs.parameters.imageCaptureProxyPullPolicy}}\"\n          args:\n            - ---INLINE-JSON\n            - \"{{=toBase64(inputs.parameters.jsonConfig)}}\"\n          ports:\n            - containerPort: {{inputs.parameters.listenPort}}\n          resources: {{=fromJSON(inputs.parameters.resources)}}\n          env:\n            - name: CAPTURE_PROXY_KAFKA_PASSWORD\n              valueFrom:\n                secretKeyRef:\n                  name: \"{{=((inputs.parameters.kafkaAuthType == 'scram-sha-512') ? (inputs.parameters.kafkaSecretName) : ('empty'))}}\"\n                  key: password\n                  optional: {{=!(inputs.parameters.kafkaAuthType == 'scram-sha-512')}}\n          volumeMounts:\n            - name: kafka-auth-config\n              mountPath: /config/kafka-auth\n              readOnly: true\n            - name: kafka-ca\n              mountPath: /config/kafka-ca\n              readOnly: true\n            - name: tls-certs\n              mountPath: /etc/proxy-tls\n              readOnly: true\n      volumes:\n        - name: kafka-auth-config\n          configMap:\n            name: \"{{inputs.parameters.kafkaAuthConfigMapName}}\"\n        - name: kafka-ca\n          secret:\n            secretName: \"{{=((inputs.parameters.kafkaAuthType == 'scram-sha-512') ? (inputs.parameters.kafkaCaSecretName) : ('empty'))}}\"\n            optional: {{=!(inputs.parameters.kafkaAuthType == 'scram-sha-512')}}\n        - name: tls-certs\n          secret:\n            secretName: \"{{inputs.parameters.tlsSecretName}}\"\n",
          "action": "apply",
          "setOwnerReference": false,
          "successCondition": "status.readyReplicas > 0"
        },
        "retryStrategy": {
          "limit": "6",
          "retryPolicy": "OnError",
          "backoff": {
            "duration": "10",
            "factor": "2",
            "cap": "60"
          }
        },
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "createkafkaclientpropertiesconfigmap",
        "inputs": {
          "parameters": [
            {
              "name": "name"
            }
          ]
        },
        "resource": {
          "manifest": "apiVersion: v1\nkind: ConfigMap\nmetadata:\n  name: \"{{inputs.parameters.name}}\"\ndata:\n  client.properties: |-\n    ssl.truststore.type=PEM\n    ssl.truststore.location=/config/kafka-ca/ca.crt\n",
          "action": "apply",
          "setOwnerReference": false
        },
        "retryStrategy": {
          "limit": "6",
          "retryPolicy": "OnError",
          "backoff": {
            "duration": "10",
            "factor": "2",
            "cap": "60"
          }
        },
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "provisionproxycert",
        "inputs": {
          "parameters": [
            {
              "name": "certName"
            },
            {
              "name": "secretName"
            },
            {
              "name": "issuerName"
            },
            {
              "name": "issuerKind"
            },
            {
              "name": "issuerGroup"
            },
            {
              "name": "dnsNames"
            },
            {
              "name": "duration"
            },
            {
              "name": "renewBefore"
            }
          ]
        },
        "resource": {
          "manifest": "apiVersion: cert-manager.io/v1\nkind: Certificate\nmetadata:\n  name: \"{{inputs.parameters.certName}}\"\nspec:\n  secretName: \"{{inputs.parameters.secretName}}\"\n  issuerRef:\n    name: \"{{inputs.parameters.issuerName}}\"\n    kind: \"{{inputs.parameters.issuerKind}}\"\n    group: \"{{inputs.parameters.issuerGroup}}\"\n  dnsNames: {{inputs.parameters.dnsNames}}\n  duration: \"{{inputs.parameters.duration}}\"\n  renewBefore: \"{{inputs.parameters.renewBefore}}\"\n",
          "action": "apply",
          "setOwnerReference": false
        },
        "retryStrategy": {
          "limit": "6",
          "retryPolicy": "OnError",
          "backoff": {
            "duration": "10",
            "factor": "2",
            "cap": "60"
          }
        },
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "waitforcertready",
        "inputs": {
          "parameters": [
            {
              "name": "certName"
            }
          ]
        },
        "resource": {
          "manifest": "apiVersion: cert-manager.io/v1\nkind: Certificate\nmetadata:\n  name: \"{{inputs.parameters.certName}}\"\n",
          "action": "get",
          "successCondition": "status.conditions.0.status == True",
          "failureCondition": "status.conditions.0.status == False"
        },
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "setupproxy",
        "inputs": {
          "parameters": [
            {
              "name": "proxyConfig"
            },
            {
              "name": "kafkaClusterName"
            },
            {
              "name": "kafkaTopicName"
            },
            {
              "name": "proxyName"
            },
            {
              "name": "listenPort"
            },
            {
              "name": "podReplicas"
            },
            {
              "name": "crdName"
            },
            {
              "name": "crdUid"
            },
            {
              "name": "resolvedKafkaConnection",
              "value": ""
            },
            {
              "name": "resolvedKafkaListenerName",
              "value": ""
            },
            {
              "name": "resolvedKafkaAuthType",
              "value": ""
            },
            {
              "name": "imageCaptureProxyLocation"
            },
            {
              "name": "imageCaptureProxyPullPolicy"
            }
          ]
        },
        "steps": [
          [
            {
              "templateRef": {
                "template": "createkafkatopicwithretry",
                "name": "setup-kafka"
              },
              "arguments": {
                "parameters": [
                  {
                    "name": "crdName",
                    "value": "{{inputs.parameters.crdName}}"
                  },
                  {
                    "name": "crdUid",
                    "value": "{{inputs.parameters.crdUid}}"
                  },
                  {
                    "name": "clusterName",
                    "value": "{{inputs.parameters.kafkaClusterName}}"
                  },
                  {
                    "name": "topicName",
                    "value": "{{inputs.parameters.kafkaTopicName}}"
                  },
                  {
                    "name": "partitions",
                    "value": "{{=fromJSON(inputs.parameters.proxyConfig)['kafkaConfig']['topicSpecOverrides']['partitions']}}"
                  },
                  {
                    "name": "replicas",
                    "value": "{{=fromJSON(inputs.parameters.proxyConfig)['kafkaConfig']['topicSpecOverrides']['replicas']}}"
                  },
                  {
                    "name": "topicConfig",
                    "value": "{{=toJSON(fromJSON(inputs.parameters.proxyConfig)['kafkaConfig']['topicSpecOverrides']['config'])}}"
                  },
                  {
                    "name": "retryGroupName_view",
                    "value": "{{='KafkaTopic: '+inputs.parameters.kafkaTopicName}}"
                  }
                ]
              },
              "name": "createKafkaTopic"
            }
          ],
          [
            {
              "template": "createkafkaclientpropertiesconfigmap",
              "arguments": {
                "parameters": [
                  {
                    "name": "name",
                    "value": "{{=inputs.parameters.proxyName+'-kafka-auth'}}"
                  }
                ]
              },
              "name": "createKafkaClientConfig"
            }
          ],
          [
            {
              "template": "deployproxyservice",
              "arguments": {
                "parameters": [
                  {
                    "name": "proxyName",
                    "value": "{{inputs.parameters.proxyName}}"
                  },
                  {
                    "name": "listenPort",
                    "value": "{{inputs.parameters.listenPort}}"
                  },
                  {
                    "name": "internetFacing",
                    "value": "{{=sprig.dig('internetFacing', false, fromJSON(inputs.parameters.proxyConfig)['proxyConfig'])}}"
                  },
                  {
                    "name": "crdName",
                    "value": "{{inputs.parameters.crdName}}"
                  },
                  {
                    "name": "crdUid",
                    "value": "{{inputs.parameters.crdUid}}"
                  }
                ]
              },
              "name": "deployService"
            },
            {
              "template": "provisionproxycert",
              "when": "{{=sprig.dig('tls', 'mode', '', fromJSON(inputs.parameters.proxyConfig)['proxyConfig']) == 'certManager'}}",
              "arguments": {
                "parameters": [
                  {
                    "name": "certName",
                    "value": "{{=inputs.parameters.proxyName+'-tls'}}"
                  },
                  {
                    "name": "secretName",
                    "value": "{{=inputs.parameters.proxyName+'-tls'}}"
                  },
                  {
                    "name": "issuerName",
                    "value": "{{=sprig.dig('tls', 'issuerRef', 'name', '', fromJSON(inputs.parameters.proxyConfig)['proxyConfig'])}}"
                  },
                  {
                    "name": "issuerKind",
                    "value": "{{=sprig.dig('tls', 'issuerRef', 'kind', 'ClusterIssuer', fromJSON(inputs.parameters.proxyConfig)['proxyConfig'])}}"
                  },
                  {
                    "name": "issuerGroup",
                    "value": "{{=sprig.dig('tls', 'issuerRef', 'group', 'cert-manager.io', fromJSON(inputs.parameters.proxyConfig)['proxyConfig'])}}"
                  },
                  {
                    "name": "dnsNames",
                    "value": "{{=toJSON(sprig.dig('tls', 'dnsNames', [], fromJSON(inputs.parameters.proxyConfig)['proxyConfig']))}}"
                  },
                  {
                    "name": "duration",
                    "value": "{{=sprig.dig('tls', 'duration', '2160h', fromJSON(inputs.parameters.proxyConfig)['proxyConfig'])}}"
                  },
                  {
                    "name": "renewBefore",
                    "value": "{{=sprig.dig('tls', 'renewBefore', '360h', fromJSON(inputs.parameters.proxyConfig)['proxyConfig'])}}"
                  }
                ]
              },
              "name": "provisionCert"
            }
          ],
          [
            {
              "template": "waitforcertready",
              "when": "{{=sprig.dig('tls', 'mode', '', fromJSON(inputs.parameters.proxyConfig)['proxyConfig']) == 'certManager'}}",
              "arguments": {
                "parameters": [
                  {
                    "name": "certName",
                    "value": "{{=inputs.parameters.proxyName+'-tls'}}"
                  }
                ]
              },
              "name": "waitForCert"
            }
          ],
          [
            {
              "template": "deployproxydeployment",
              "when": "{{=!(sprig.dig('tls', 'mode', '', fromJSON(inputs.parameters.proxyConfig)['proxyConfig']) == 'certManager' || sprig.dig('tls', 'mode', '', fromJSON(inputs.parameters.proxyConfig)['proxyConfig']) == 'existingSecret')}}",
              "arguments": {
                "parameters": [
                  {
                    "name": "proxyName",
                    "value": "{{=fromJSON(inputs.parameters.proxyConfig)['name']}}"
                  },
                  {
                    "name": "listenPort",
                    "value": "{{inputs.parameters.listenPort}}"
                  },
                  {
                    "name": "podReplicas",
                    "value": "{{inputs.parameters.podReplicas}}"
                  },
                  {
                    "name": "crdName",
                    "value": "{{inputs.parameters.crdName}}"
                  },
                  {
                    "name": "crdUid",
                    "value": "{{inputs.parameters.crdUid}}"
                  },
                  {
                    "name": "imageCaptureProxyLocation",
                    "value": "{{inputs.parameters.imageCaptureProxyLocation}}"
                  },
                  {
                    "name": "imageCaptureProxyPullPolicy",
                    "value": "{{inputs.parameters.imageCaptureProxyPullPolicy}}"
                  },
                  {
                    "name": "kafkaAuthConfigMapName",
                    "value": "{{=inputs.parameters.proxyName+'-kafka-auth'}}"
                  },
                  {
                    "name": "kafkaAuthType",
                    "value": "{{=((!(inputs.parameters.resolvedKafkaAuthType == '')) ? (inputs.parameters.resolvedKafkaAuthType) : (fromJSON(inputs.parameters.proxyConfig)['kafkaConfig']['authType']))}}"
                  },
                  {
                    "name": "kafkaSecretName",
                    "value": "{{=fromJSON(inputs.parameters.proxyConfig)['kafkaConfig']['secretName']}}"
                  },
                  {
                    "name": "kafkaCaSecretName",
                    "value": "{{=fromJSON(inputs.parameters.proxyConfig)['kafkaConfig']['caSecretName']}}"
                  },
                  {
                    "name": "resources",
                    "value": "{{=toJSON(fromJSON(inputs.parameters.proxyConfig)['proxyConfig']['resources'])}}"
                  },
                  {
                    "name": "jsonConfig",
                    "value": "{{=toJSON(sprig.merge(sprig.omit(fromJSON(inputs.parameters.proxyConfig)['proxyConfig'], 'loggingConfigurationOverrideConfigMap', 'internetFacing', 'podReplicas', 'resources'), sprig.merge(((sprig.dig('proxyConfig', 'noCapture', false, fromJSON(inputs.parameters.proxyConfig))) ? (sprig.dict()) : (sprig.dict(\"kafkaConnection\", ((!(inputs.parameters.resolvedKafkaConnection == '')) ? (inputs.parameters.resolvedKafkaConnection) : (fromJSON(inputs.parameters.proxyConfig)['kafkaConfig']['kafkaConnection']))))), sprig.merge(sprig.dict(\"destinationUri\", fromJSON(inputs.parameters.proxyConfig)['sourceEndpoint'], \"insecureDestination\", fromJSON(inputs.parameters.proxyConfig)['sourceAllowInsecure'], \"kafkaTopic\", jsonpath(inputs.parameters.proxyConfig, '$.kafkaConfig.kafkaTopic'), \"kafkaListenerName\", ((!(inputs.parameters.resolvedKafkaListenerName == '')) ? (inputs.parameters.resolvedKafkaListenerName) : (fromJSON(inputs.parameters.proxyConfig)['kafkaConfig']['listenerName'])), \"kafkaAuthType\", ((!(inputs.parameters.resolvedKafkaAuthType == '')) ? (inputs.parameters.resolvedKafkaAuthType) : (fromJSON(inputs.parameters.proxyConfig)['kafkaConfig']['authType'])), \"kafkaSecretName\", fromJSON(inputs.parameters.proxyConfig)['kafkaConfig']['secretName'], \"kafkaUserName\", fromJSON(inputs.parameters.proxyConfig)['kafkaConfig']['kafkaUserName']), ((((!(inputs.parameters.resolvedKafkaAuthType == '')) ? (inputs.parameters.resolvedKafkaAuthType) : (fromJSON(inputs.parameters.proxyConfig)['kafkaConfig']['authType'])) == 'scram-sha-512') ? (sprig.dict(\"kafkaPropertyFile\", '/config/kafka-auth/client.properties')) : (sprig.dict()))))))}}"
                  }
                ]
              },
              "name": "deployProxyNoTls"
            },
            {
              "template": "deployproxydeploymentwithtls",
              "when": "{{=sprig.dig('tls', 'mode', '', fromJSON(inputs.parameters.proxyConfig)['proxyConfig']) == 'certManager' || sprig.dig('tls', 'mode', '', fromJSON(inputs.parameters.proxyConfig)['proxyConfig']) == 'existingSecret'}}",
              "arguments": {
                "parameters": [
                  {
                    "name": "proxyName",
                    "value": "{{=fromJSON(inputs.parameters.proxyConfig)['name']}}"
                  },
                  {
                    "name": "listenPort",
                    "value": "{{inputs.parameters.listenPort}}"
                  },
                  {
                    "name": "podReplicas",
                    "value": "{{inputs.parameters.podReplicas}}"
                  },
                  {
                    "name": "crdName",
                    "value": "{{inputs.parameters.crdName}}"
                  },
                  {
                    "name": "crdUid",
                    "value": "{{inputs.parameters.crdUid}}"
                  },
                  {
                    "name": "imageCaptureProxyLocation",
                    "value": "{{inputs.parameters.imageCaptureProxyLocation}}"
                  },
                  {
                    "name": "imageCaptureProxyPullPolicy",
                    "value": "{{inputs.parameters.imageCaptureProxyPullPolicy}}"
                  },
                  {
                    "name": "kafkaAuthConfigMapName",
                    "value": "{{=inputs.parameters.proxyName+'-kafka-auth'}}"
                  },
                  {
                    "name": "kafkaAuthType",
                    "value": "{{=((!(inputs.parameters.resolvedKafkaAuthType == '')) ? (inputs.parameters.resolvedKafkaAuthType) : (fromJSON(inputs.parameters.proxyConfig)['kafkaConfig']['authType']))}}"
                  },
                  {
                    "name": "kafkaSecretName",
                    "value": "{{=fromJSON(inputs.parameters.proxyConfig)['kafkaConfig']['secretName']}}"
                  },
                  {
                    "name": "kafkaCaSecretName",
                    "value": "{{=fromJSON(inputs.parameters.proxyConfig)['kafkaConfig']['caSecretName']}}"
                  },
                  {
                    "name": "resources",
                    "value": "{{=toJSON(fromJSON(inputs.parameters.proxyConfig)['proxyConfig']['resources'])}}"
                  },
                  {
                    "name": "tlsSecretName",
                    "value": "{{=((sprig.dig('tls', 'mode', '', fromJSON(inputs.parameters.proxyConfig)['proxyConfig']) == 'certManager') ? (inputs.parameters.proxyName+'-tls') : (((sprig.dig('tls', 'mode', '', fromJSON(inputs.parameters.proxyConfig)['proxyConfig']) == 'existingSecret') ? (sprig.dig('tls', 'secretName', '', fromJSON(inputs.parameters.proxyConfig)['proxyConfig'])) : (''))))}}"
                  },
