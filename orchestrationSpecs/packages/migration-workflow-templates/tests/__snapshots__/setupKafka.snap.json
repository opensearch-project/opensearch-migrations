{
  "apiVersion": "argoproj.io/v1alpha1",
  "kind": "WorkflowTemplate",
  "metadata": {
    "name": "setup-kafka"
  },
  "spec": {
    "serviceAccountName": "argo-workflow-executor",
    "parallelism": 100,
    "arguments": {
      "parameters": [
        {
          "name": "s3SnapshotConfigMap",
          "value": "s3-snapshot-config"
        },
        {
          "name": "imageConfigMapName",
          "value": "migration-image-config"
        },
        {
          "name": "approvalConfigMapName",
          "value": "approval-config"
        }
      ]
    },
    "templates": [
      {
        "name": "deploykafkanodepool",
        "inputs": {
          "parameters": [
            {
              "name": "clusterName"
            },
            {
              "name": "clusterConfig"
            }
          ]
        },
        "resource": {
          "manifest": "apiVersion: kafka.strimzi.io/v1\nkind: KafkaNodePool\nmetadata:\n  name: dual-role\n  labels:\n    strimzi.io/cluster: \"{{inputs.parameters.clusterName}}\"\nspec: {{=sprig.merge(sprig.dict(\"replicas\", 1, \"roles\", [\"controller\",\"broker\"], \"storage\", sprig.dict(\"type\", 'persistent-claim', \"size\", '1Gi', \"deleteClaim\", true)), sprig.dig('nodePoolSpecOverrides', {}, fromJSON(inputs.parameters.clusterConfig)))}}\n",
          "action": "apply",
          "setOwnerReference": false
        },
        "retryStrategy": {
          "limit": "6",
          "retryPolicy": "Always",
          "backoff": {
            "duration": "10",
            "factor": "2",
            "cap": "60"
          }
        },
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "deploykafkaclusterkraft",
        "inputs": {
          "parameters": [
            {
              "name": "clusterName"
            },
            {
              "name": "version"
            },
            {
              "name": "clusterConfig"
            }
          ]
        },
        "resource": {
          "manifest": "apiVersion: kafka.strimzi.io/v1\nkind: Kafka\nmetadata:\n  name: \"{{inputs.parameters.clusterName}}\"\n  annotations:\n    strimzi.io/node-pools: enabled\n    strimzi.io/kraft: enabled\nspec: {{=sprig.merge(sprig.omit(sprig.dig('clusterSpecOverrides', {}, fromJSON(inputs.parameters.clusterConfig)), 'kafka', 'entityOperator'), sprig.dict(\"kafka\", sprig.merge(sprig.merge(sprig.dict(\"version\", inputs.parameters.version, \"metadataVersion\", '4.0-IV3', \"readinessProbe\", {\"initialDelaySeconds\":1,\"periodSeconds\":2,\"timeoutSeconds\":2,\"failureThreshold\":1}, \"livenessProbe\", {\"initialDelaySeconds\":1,\"periodSeconds\":2,\"timeoutSeconds\":2,\"failureThreshold\":2}, \"listeners\", [{\"name\":\"plain\",\"port\":9092,\"type\":\"internal\",\"tls\":false},{\"name\":\"tls\",\"port\":9093,\"type\":\"internal\",\"tls\":true}], \"config\", {\"auto.create.topics.enable\":false,\"offsets.topic.replication.factor\":1,\"transaction.state.log.replication.factor\":1,\"transaction.state.log.min.isr\":1,\"default.replication.factor\":1,\"min.insync.replicas\":1}), sprig.dig('clusterSpecOverrides', 'kafka', {}, fromJSON(inputs.parameters.clusterConfig))), sprig.dict(\"version\", inputs.parameters.version, \"metadataVersion\", '4.0-IV3', \"listeners\", [{\"name\":\"plain\",\"port\":9092,\"type\":\"internal\",\"tls\":false},{\"name\":\"tls\",\"port\":9093,\"type\":\"internal\",\"tls\":true}])), \"entityOperator\", {\"topicOperator\":{},\"userOperator\":{}}))}}\n",
          "action": "apply",
          "setOwnerReference": false,
          "successCondition": "status.listeners"
        },
        "retryStrategy": {
          "limit": "6",
          "retryPolicy": "Always",
          "backoff": {
            "duration": "10",
            "factor": "2",
            "cap": "60"
          }
        },
        "outputs": {
          "parameters": [
            {
              "name": "brokers",
              "valueFrom": {
                "jsonPath": "{.status.listeners[?(@.name=='plain')].bootstrapServers}"
              }
            }
          ]
        }
      },
      {
        "name": "deploykafkacluster",
        "inputs": {
          "parameters": [
            {
              "name": "clusterName"
            },
            {
              "name": "version"
            },
            {
              "name": "clusterConfig"
            }
          ]
        },
        "steps": [
          [
            {
              "template": "deploykafkanodepool",
              "arguments": {
                "parameters": [
                  {
                    "name": "clusterName",
                    "value": "{{inputs.parameters.clusterName}}"
                  },
                  {
                    "name": "clusterConfig",
                    "value": "{{inputs.parameters.clusterConfig}}"
                  }
                ]
              },
              "name": "deployPool"
            }
          ],
          [
            {
              "template": "deploykafkaclusterkraft",
              "arguments": {
                "parameters": [
                  {
                    "name": "clusterName",
                    "value": "{{inputs.parameters.clusterName}}"
                  },
                  {
                    "name": "version",
                    "value": "{{inputs.parameters.version}}"
                  },
                  {
                    "name": "clusterConfig",
                    "value": "{{inputs.parameters.clusterConfig}}"
                  }
                ]
              },
              "name": "deployCluster"
            }
          ]
        ],
        "outputs": {
          "parameters": [
            {
              "name": "bootstrapServers",
              "valueFrom": {
                "expression": "steps.deployCluster.outputs.parameters.brokers"
              }
            }
          ]
        }
      },
      {
        "name": "createkafkatopic",
        "inputs": {
          "parameters": [
            {
              "name": "clusterName"
            },
            {
              "name": "topicName"
            },
            {
              "name": "clusterConfig"
            }
          ]
        },
        "resource": {
          "manifest": "apiVersion: kafka.strimzi.io/v1\nkind: KafkaTopic\nmetadata:\n  name: \"{{inputs.parameters.topicName}}\"\n  labels:\n    strimzi.io/cluster: \"{{inputs.parameters.clusterName}}\"\nspec: {{=sprig.merge(sprig.dict(\"partitions\", 1, \"replicas\", 1, \"config\", {\"retention.ms\":604800000,\"segment.bytes\":1073741824}), sprig.dig('topicSpecOverrides', {}, fromJSON(inputs.parameters.clusterConfig)))}}\n",
          "action": "apply",
          "setOwnerReference": false,
          "successCondition": "status.topicName"
        },
        "retryStrategy": {
          "limit": "6",
          "retryPolicy": "Always",
          "backoff": {
            "duration": "10",
            "factor": "2",
            "cap": "60"
          }
        },
        "outputs": {
          "parameters": [
            {
              "name": "topicName",
              "valueFrom": {
                "jsonPath": "{.status.topicName}"
              }
            }
          ]
        }
      },
      {
        "name": "suspendforretry",
        "inputs": {
          "parameters": [
            {
              "name": "name"
            }
          ]
        },
        "suspend": {},
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "deploykafkanodepoolwithretry",
        "inputs": {
          "parameters": [
            {
              "name": "clusterName"
            },
            {
              "name": "clusterConfig"
            },
            {
              "name": "retryGroupName_view",
              "value": "Apply"
            }
          ]
        },
        "steps": [
          [
            {
              "template": "deploykafkanodepool",
              "arguments": {
                "parameters": [
                  {
                    "name": "clusterName",
                    "value": "{{inputs.parameters.clusterName}}"
                  },
                  {
                    "name": "clusterConfig",
                    "value": "{{inputs.parameters.clusterConfig}}"
                  }
                ]
              },
              "name": "tryApply",
              "continueOn": {
                "failed": true
              }
            }
          ],
          [
            {
              "template": "suspendforretry",
              "when": "{{=steps.tryApply.status == 'Failed'}}",
              "arguments": {
                "parameters": [
                  {
                    "name": "name",
                    "value": "KafkaNodePool"
                  }
                ]
              },
              "name": "waitForFix"
            }
          ],
          [
            {
              "template": "deploykafkanodepoolwithretry",
              "when": "{{=steps.waitForFix.status == 'Succeeded'}}",
              "arguments": {
                "parameters": [
                  {
                    "name": "clusterName",
                    "value": "{{inputs.parameters.clusterName}}"
                  },
                  {
                    "name": "clusterConfig",
                    "value": "{{inputs.parameters.clusterConfig}}"
                  },
                  {
                    "name": "retryGroupName_view",
                    "value": "{{inputs.parameters.retryGroupName_view}}"
                  }
                ]
              },
              "name": "retryLoop"
            }
          ]
        ],
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "deploykafkaclusterkraftwithretry",
        "inputs": {
          "parameters": [
            {
              "name": "clusterName"
            },
            {
              "name": "version"
            },
            {
              "name": "clusterConfig"
            },
            {
              "name": "retryGroupName_view",
              "value": "Apply"
            }
          ]
        },
        "steps": [
          [
            {
              "template": "deploykafkaclusterkraft",
              "arguments": {
                "parameters": [
                  {
                    "name": "clusterName",
                    "value": "{{inputs.parameters.clusterName}}"
                  },
                  {
                    "name": "version",
                    "value": "{{inputs.parameters.version}}"
                  },
                  {
                    "name": "clusterConfig",
                    "value": "{{inputs.parameters.clusterConfig}}"
                  }
                ]
              },
              "name": "tryApply",
              "continueOn": {
                "failed": true
              }
            }
          ],
          [
            {
              "template": "suspendforretry",
              "when": "{{=steps.tryApply.status == 'Failed'}}",
              "arguments": {
                "parameters": [
                  {
                    "name": "name",
                    "value": "KafkaCluster"
                  }
                ]
              },
              "name": "waitForFix"
            }
          ],
          [
            {
              "template": "deploykafkaclusterkraftwithretry",
              "when": "{{=steps.waitForFix.status == 'Succeeded'}}",
              "arguments": {
                "parameters": [
                  {
                    "name": "clusterName",
                    "value": "{{inputs.parameters.clusterName}}"
                  },
                  {
                    "name": "version",
                    "value": "{{inputs.parameters.version}}"
                  },
                  {
                    "name": "clusterConfig",
                    "value": "{{inputs.parameters.clusterConfig}}"
                  },
                  {
                    "name": "retryGroupName_view",
                    "value": "{{inputs.parameters.retryGroupName_view}}"
                  }
                ]
              },
              "name": "retryLoop"
            }
          ]
        ],
        "outputs": {
          "parameters": [
            {
              "name": "brokers",
              "valueFrom": {
                "expression": "steps.tryApply.outputs.parameters.brokers"
              }
            }
          ]
        }
      },
      {
        "name": "createkafkatopicwithretry",
        "inputs": {
          "parameters": [
            {
              "name": "clusterName"
            },
            {
              "name": "topicName"
            },
            {
              "name": "clusterConfig"
            },
            {
              "name": "retryGroupName_view",
              "value": "Apply"
            }
          ]
        },
        "steps": [
          [
            {
              "template": "createkafkatopic",
              "arguments": {
                "parameters": [
                  {
                    "name": "clusterName",
                    "value": "{{inputs.parameters.clusterName}}"
                  },
                  {
                    "name": "topicName",
                    "value": "{{inputs.parameters.topicName}}"
                  },
                  {
                    "name": "clusterConfig",
                    "value": "{{inputs.parameters.clusterConfig}}"
                  }
                ]
              },
              "name": "tryApply",
              "continueOn": {
                "failed": true
              }
            }
          ],
          [
            {
              "template": "suspendforretry",
              "when": "{{=steps.tryApply.status == 'Failed'}}",
              "arguments": {
                "parameters": [
                  {
                    "name": "name",
                    "value": "KafkaTopic"
                  }
                ]
              },
              "name": "waitForFix"
            }
          ],
          [
            {
              "template": "createkafkatopicwithretry",
              "when": "{{=steps.waitForFix.status == 'Succeeded'}}",
              "arguments": {
                "parameters": [
                  {
                    "name": "clusterName",
                    "value": "{{inputs.parameters.clusterName}}"
                  },
                  {
                    "name": "topicName",
                    "value": "{{inputs.parameters.topicName}}"
                  },
                  {
                    "name": "clusterConfig",
                    "value": "{{inputs.parameters.clusterConfig}}"
                  },
                  {
                    "name": "retryGroupName_view",
                    "value": "{{inputs.parameters.retryGroupName_view}}"
                  }
                ]
              },
              "name": "retryLoop"
            }
          ]
        ],
        "outputs": {
          "parameters": [
            {
              "name": "topicName",
              "valueFrom": {
                "expression": "steps.tryApply.outputs.parameters.topicName"
              }
            }
          ]
        }
      },
      {
        "name": "deploykafkaclusterwithretry",
        "inputs": {
          "parameters": [
            {
              "name": "clusterName"
            },
            {
              "name": "version"
            },
            {
              "name": "clusterConfig"
            }
          ]
        },
        "steps": [
          [
            {
              "template": "deploykafkanodepoolwithretry",
              "arguments": {
                "parameters": [
                  {
                    "name": "clusterName",
                    "value": "{{inputs.parameters.clusterName}}"
                  },
                  {
                    "name": "clusterConfig",
                    "value": "{{inputs.parameters.clusterConfig}}"
                  },
                  {
                    "name": "retryGroupName_view",
                    "value": "{{='KafkaNodePool: '+inputs.parameters.clusterName}}"
                  }
                ]
              },
              "name": "deployPool"
            }
          ],
          [
            {
              "template": "deploykafkaclusterkraftwithretry",
              "arguments": {
                "parameters": [
                  {
                    "name": "clusterName",
                    "value": "{{inputs.parameters.clusterName}}"
                  },
                  {
                    "name": "version",
                    "value": "{{inputs.parameters.version}}"
                  },
                  {
                    "name": "clusterConfig",
                    "value": "{{inputs.parameters.clusterConfig}}"
                  },
                  {
                    "name": "retryGroupName_view",
                    "value": "{{='KafkaCluster: '+inputs.parameters.clusterName}}"
                  }
                ]
              },
              "name": "deployCluster"
            }
          ]
        ],
        "outputs": {
          "parameters": [
            {
              "name": "bootstrapServers",
              "valueFrom": {
                "expression": "steps.deployCluster.outputs.parameters.brokers"
              }
            }
          ]
        }
      }
    ]
  }
}
