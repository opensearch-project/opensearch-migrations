{
  "apiVersion": "argoproj.io/v1alpha1",
  "kind": "WorkflowTemplate",
  "metadata": {
    "name": "setup-kafka"
  },
  "spec": {
    "serviceAccountName": "argo-workflow-executor",
    "parallelism": 100,
    "arguments": {
      "parameters": [
        {
          "name": "s3SnapshotConfigMap",
          "value": "s3-snapshot-config"
        },
        {
          "name": "gcsSnapshotConfigMap",
          "value": "gcs-snapshot-config"
        },
        {
          "name": "imageConfigMapName",
          "value": "migration-image-config"
        },
        {
          "name": "migrationRunNumber",
          "value": "0"
        },
        {
          "name": "workflowScriptsRoot",
          "value": "/root/workflows/.workflowScripts"
        }
      ]
    },
    "templates": [
      {
        "name": "diagnosekafkaclusternotready",
        "inputs": {
          "parameters": [
            {
              "name": "resourceName"
            },
            {
              "name": "imageMigrationConsoleLocation"
            },
            {
              "name": "imageMigrationConsolePullPolicy"
            }
          ]
        },
        "container": {
          "env": [
            {
              "name": "NAMESPACE",
              "value": "{{workflow.namespace}}"
            },
            {
              "name": "KAFKA_CLUSTER_NAME",
              "value": "{{inputs.parameters.resourceName}}"
            },
            {
              "name": "TIMEOUT_SECONDS",
              "value": "2700"
            },
            {
              "name": "DIAGNOSTIC_LOG_PATH",
              "value": "/tmp/kafka-readiness-diagnostics.log"
            },
            {
              "name": "WORKFLOW_SCRIPTS_ROOT",
              "value": "{{workflow.parameters.workflowScriptsRoot}}"
            }
          ],
          "image": "{{inputs.parameters.imageMigrationConsoleLocation}}",
          "imagePullPolicy": "{{inputs.parameters.imageMigrationConsolePullPolicy}}",
          "command": [
            "/bin/bash",
            "-lc"
          ],
          "resources": {
            "limits": {
              "cpu": "500m",
              "memory": "500Mi"
            },
            "requests": {
              "cpu": "500m",
              "memory": "500Mi"
            }
          },
          "args": [
            "exec \"${WORKFLOW_SCRIPTS_ROOT}/diagnoseKafkaClusterNotReady.sh\""
          ]
        },
        "metadata": {
          "annotations": {
            "karpenter.sh/do-not-disrupt": "true"
          }
        },
        "activeDeadlineSeconds": 300,
        "retryStrategy": {
          "limit": "3",
          "retryPolicy": "Always",
          "backoff": {
            "duration": "10",
            "factor": "2",
            "cap": "60"
          }
        },
        "outputs": {
          "parameters": [],
          "artifacts": [
            {
              "name": "kafkaReadinessDiagnostics",
              "path": "/tmp/kafka-readiness-diagnostics.log",
              "archive": {
                "none": {}
              },
              "s3": {
                "key": "{{='diagnostics/'+workflow.uid+'/kafkaReadinessDiagnostics'}}"
              }
            }
          ]
        }
      },
      {
        "name": "failkafkaclusterreadywait",
        "inputs": {
          "parameters": [
            {
              "name": "resourceName"
            },
            {
              "name": "imageMigrationConsoleLocation"
            },
            {
              "name": "imageMigrationConsolePullPolicy"
            }
          ]
        },
        "container": {
          "env": [
            {
              "name": "KAFKA_CLUSTER_NAME",
              "value": "{{inputs.parameters.resourceName}}"
            }
          ],
          "image": "{{inputs.parameters.imageMigrationConsoleLocation}}",
          "imagePullPolicy": "{{inputs.parameters.imageMigrationConsolePullPolicy}}",
          "command": [
            "/bin/bash",
            "-lc"
          ],
          "resources": {
            "limits": {
              "cpu": "500m",
              "memory": "500Mi"
            },
            "requests": {
              "cpu": "500m",
              "memory": "500Mi"
            }
          },
          "args": [
            "\nset -euo pipefail\necho \"Kafka/$KAFKA_CLUSTER_NAME did not become Ready; diagnostics were collected in the kafkaReadinessDiagnostics artifact and diagnostic pod logs\" >&2\nexit 1\n"
          ]
        },
        "metadata": {
          "annotations": {
            "karpenter.sh/do-not-disrupt": "true"
          }
        },
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "waitforkafkaclusterready",
        "inputs": {
          "parameters": [
            {
              "name": "resourceName"
            },
            {
              "name": "imageMigrationConsoleLocation"
            },
            {
              "name": "imageMigrationConsolePullPolicy"
            }
          ]
        },
        "steps": [
          [
            {
              "templateRef": {
                "template": "waitforkafkaclusterreadyresource",
                "name": "resource-management"
              },
              "arguments": {
                "parameters": [
                  {
                    "name": "resourceName",
                    "value": "{{inputs.parameters.resourceName}}"
                  },
                  {
                    "name": "imageMigrationConsoleLocation",
                    "value": "{{inputs.parameters.imageMigrationConsoleLocation}}"
                  },
                  {
                    "name": "imageMigrationConsolePullPolicy",
                    "value": "{{inputs.parameters.imageMigrationConsolePullPolicy}}"
                  }
                ]
              },
              "name": "waitForReady",
              "continueOn": {
                "failed": true,
                "error": true
              }
            }
          ],
          [
            {
              "template": "diagnosekafkaclusternotready",
              "when": "{{=steps.waitForReady.status == 'Failed' || steps.waitForReady.status == 'Error'}}",
              "arguments": {
                "parameters": [
                  {
                    "name": "resourceName",
                    "value": "{{inputs.parameters.resourceName}}"
                  },
                  {
                    "name": "imageMigrationConsoleLocation",
                    "value": "{{inputs.parameters.imageMigrationConsoleLocation}}"
                  },
                  {
                    "name": "imageMigrationConsolePullPolicy",
                    "value": "{{inputs.parameters.imageMigrationConsolePullPolicy}}"
                  }
                ]
              },
              "name": "diagnoseFailure"
            }
          ],
          [
            {
              "template": "failkafkaclusterreadywait",
              "when": "{{=steps.waitForReady.status == 'Failed' || steps.waitForReady.status == 'Error'}}",
              "arguments": {
                "parameters": [
                  {
                    "name": "resourceName",
                    "value": "{{inputs.parameters.resourceName}}"
                  },
                  {
                    "name": "imageMigrationConsoleLocation",
                    "value": "{{inputs.parameters.imageMigrationConsoleLocation}}"
                  },
                  {
                    "name": "imageMigrationConsolePullPolicy",
                    "value": "{{inputs.parameters.imageMigrationConsolePullPolicy}}"
                  }
                ]
              },
              "name": "failAfterDiagnostics"
            }
          ]
        ],
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "waitforkafkacluster",
        "inputs": {
          "parameters": [
            {
              "name": "resourceName"
            },
            {
              "name": "imageMigrationConsoleLocation"
            },
            {
              "name": "imageMigrationConsolePullPolicy"
            }
          ]
        },
        "steps": [
          [
            {
              "templateRef": {
                "template": "waitforkafkaclustercreated",
                "name": "resource-management"
              },
              "arguments": {
                "parameters": [
                  {
                    "name": "resourceName",
                    "value": "{{inputs.parameters.resourceName}}"
                  },
                  {
                    "name": "imageMigrationConsoleLocation",
                    "value": "{{inputs.parameters.imageMigrationConsoleLocation}}"
                  },
                  {
                    "name": "imageMigrationConsolePullPolicy",
                    "value": "{{inputs.parameters.imageMigrationConsolePullPolicy}}"
                  }
                ]
              },
              "name": "waitForCreation"
            }
          ],
          [
            {
              "template": "waitforkafkaclusterready",
              "arguments": {
                "parameters": [
                  {
                    "name": "resourceName",
                    "value": "{{inputs.parameters.resourceName}}"
                  },
                  {
                    "name": "imageMigrationConsoleLocation",
                    "value": "{{inputs.parameters.imageMigrationConsoleLocation}}"
                  },
                  {
                    "name": "imageMigrationConsolePullPolicy",
                    "value": "{{inputs.parameters.imageMigrationConsolePullPolicy}}"
                  }
                ]
              },
              "name": "waitForReady"
            }
          ]
        ],
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "deploykafkanodepool",
        "inputs": {
          "parameters": [
            {
              "name": "clusterName"
            },
            {
              "name": "nodePoolSpec"
            },
            {
              "name": "migrationRunNumber"
            },
            {
              "name": "ownerUid"
            }
          ]
        },
        "resource": {
          "manifest": "apiVersion: kafka.strimzi.io/v1\nkind: KafkaNodePool\nmetadata:\n  name: dual-role\n  ownerReferences:\n    - apiVersion: migrations.opensearch.org/v1alpha1\n      kind: KafkaCluster\n      name: {{=toJSON(inputs.parameters.clusterName)}}\n      uid: {{=toJSON(inputs.parameters.ownerUid)}}\n      controller: true\n      blockOwnerDeletion: true\n  labels:\n    strimzi.io/cluster: {{=toJSON(inputs.parameters.clusterName)}}\n    workflows.argoproj.io/workflow: {{=toJSON(workflow.name)}}\n    migrations.opensearch.org/run-number: {{=toJSON(inputs.parameters.migrationRunNumber)}}\n    migrations.opensearch.org/kafka-cluster: {{=toJSON(inputs.parameters.clusterName)}}\nspec: {{=sprig.merge(fromJSON(inputs.parameters.nodePoolSpec), sprig.dict(\"resources\", sprig.dict(\"limits\", sprig.dict(\"cpu\", '1000m', \"memory\", '2048Mi'), \"requests\", sprig.dict(\"cpu\", '1000m', \"memory\", '2048Mi'))))}}\n",
          "action": "apply",
          "setOwnerReference": false
        },
        "retryStrategy": {
          "limit": "6",
          "retryPolicy": "OnError",
          "backoff": {
            "duration": "10",
            "factor": "2",
            "cap": "60"
          }
        },
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "deploykafkaclusterkraftnoauth",
        "inputs": {
          "parameters": [
            {
              "name": "clusterName"
            },
            {
              "name": "kafkaSpec"
            },
            {
              "name": "migrationRunNumber"
            },
            {
              "name": "ownerUid"
            }
          ]
        },
        "resource": {
          "manifest": "apiVersion: kafka.strimzi.io/v1\nkind: Kafka\nmetadata:\n  name: {{=toJSON(inputs.parameters.clusterName)}}\n  ownerReferences:\n    - apiVersion: migrations.opensearch.org/v1alpha1\n      kind: KafkaCluster\n      name: {{=toJSON(inputs.parameters.clusterName)}}\n      uid: {{=toJSON(inputs.parameters.ownerUid)}}\n      controller: true\n      blockOwnerDeletion: true\n  labels:\n    strimzi.io/cluster: {{=toJSON(inputs.parameters.clusterName)}}\n    workflows.argoproj.io/workflow: {{=toJSON(workflow.name)}}\n    migrations.opensearch.org/run-number: {{=toJSON(inputs.parameters.migrationRunNumber)}}\n    migrations.opensearch.org/kafka-cluster: {{=toJSON(inputs.parameters.clusterName)}}\n  annotations:\n    strimzi.io/node-pools: enabled\n    strimzi.io/kraft: enabled\nspec:\n  kafka: {{=fromJSON(inputs.parameters.kafkaSpec)}}\n  entityOperator:\n    topicOperator:\n      resources:\n        limits:\n          cpu: 500m\n          memory: 512Mi\n        requests:\n          cpu: 500m\n          memory: 512Mi\n    userOperator:\n      resources:\n        limits:\n          cpu: 500m\n          memory: 512Mi\n        requests:\n          cpu: 500m\n          memory: 512Mi\n",
          "action": "apply",
          "setOwnerReference": false
        },
        "retryStrategy": {
          "limit": "6",
          "retryPolicy": "OnError",
          "backoff": {
            "duration": "10",
            "factor": "2",
            "cap": "60"
          }
        },
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "deploykafkaclusterkraftscram",
        "inputs": {
          "parameters": [
            {
              "name": "clusterName"
            },
            {
              "name": "kafkaSpec"
            },
            {
              "name": "migrationRunNumber"
            },
            {
              "name": "ownerUid"
            }
          ]
        },
        "resource": {
          "manifest": "apiVersion: kafka.strimzi.io/v1\nkind: Kafka\nmetadata:\n  name: {{=toJSON(inputs.parameters.clusterName)}}\n  ownerReferences:\n    - apiVersion: migrations.opensearch.org/v1alpha1\n      kind: KafkaCluster\n      name: {{=toJSON(inputs.parameters.clusterName)}}\n      uid: {{=toJSON(inputs.parameters.ownerUid)}}\n      controller: true\n      blockOwnerDeletion: true\n  labels:\n    strimzi.io/cluster: {{=toJSON(inputs.parameters.clusterName)}}\n    workflows.argoproj.io/workflow: {{=toJSON(workflow.name)}}\n    migrations.opensearch.org/run-number: {{=toJSON(inputs.parameters.migrationRunNumber)}}\n    migrations.opensearch.org/kafka-cluster: {{=toJSON(inputs.parameters.clusterName)}}\n  annotations:\n    strimzi.io/node-pools: enabled\n    strimzi.io/kraft: enabled\nspec:\n  kafka: {{=fromJSON(inputs.parameters.kafkaSpec)}}\n  entityOperator:\n    topicOperator:\n      resources:\n        limits:\n          cpu: 500m\n          memory: 512Mi\n        requests:\n          cpu: 500m\n          memory: 512Mi\n    userOperator:\n      resources:\n        limits:\n          cpu: 500m\n          memory: 512Mi\n        requests:\n          cpu: 500m\n          memory: 512Mi\n",
          "action": "apply",
          "setOwnerReference": false
        },
        "retryStrategy": {
          "limit": "6",
          "retryPolicy": "OnError",
          "backoff": {
            "duration": "10",
            "factor": "2",
            "cap": "60"
          }
        },
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "deploykafkacluster",
        "inputs": {
          "parameters": [
            {
              "name": "clusterName"
            },
            {
              "name": "version"
            },
            {
              "name": "clusterConfig"
            },
            {
              "name": "migrationRunNumber"
            },
            {
              "name": "ownerUid"
            },
            {
              "name": "imageMigrationConsoleLocation"
            },
            {
              "name": "imageMigrationConsolePullPolicy"
            }
          ]
        },
        "steps": [
          [
            {
              "template": "deploykafkaclusterkraftnoauth",
              "when": "{{=!(sprig.dig('auth', 'type', 'none', fromJSON(inputs.parameters.clusterConfig)) == 'scram-sha-512')}}",
              "arguments": {
                "parameters": [
                  {
                    "name": "clusterName",
                    "value": "{{inputs.parameters.clusterName}}"
                  },
                  {
                    "name": "kafkaSpec",
                    "value": "{{=toJSON(sprig.merge(sprig.dict(\"version\", inputs.parameters.version, \"metadataVersion\", '4.0-IV3', \"listeners\", [sprig.dict(\"name\", 'plain', \"port\", 9092, \"type\", 'internal', \"tls\", false), sprig.dict(\"name\", 'tls', \"port\", 9093, \"type\", 'internal', \"tls\", true)]), sprig.dig('clusterSpecOverrides', 'kafka', sprig.dict(), fromJSON(inputs.parameters.clusterConfig))))}}"
                  },
                  {
                    "name": "migrationRunNumber",
                    "value": "{{inputs.parameters.migrationRunNumber}}"
                  },
                  {
                    "name": "ownerUid",
                    "value": "{{inputs.parameters.ownerUid}}"
                  }
                ]
              },
              "name": "deployNoAuthCluster"
            }
          ],
          [
            {
              "template": "deploykafkaclusterkraftscram",
              "when": "{{=sprig.dig('auth', 'type', 'none', fromJSON(inputs.parameters.clusterConfig)) == 'scram-sha-512'}}",
              "arguments": {
                "parameters": [
                  {
                    "name": "clusterName",
                    "value": "{{inputs.parameters.clusterName}}"
                  },
                  {
                    "name": "kafkaSpec",
                    "value": "{{=toJSON(sprig.merge(sprig.dict(\"version\", inputs.parameters.version, \"metadataVersion\", '4.0-IV3', \"listeners\", [sprig.dict(\"name\", 'tls', \"port\", 9093, \"type\", 'internal', \"tls\", true, \"authentication\", sprig.dict(\"type\", 'scram-sha-512'))]), sprig.dig('clusterSpecOverrides', 'kafka', sprig.dict(), fromJSON(inputs.parameters.clusterConfig))))}}"
                  },
                  {
                    "name": "migrationRunNumber",
                    "value": "{{inputs.parameters.migrationRunNumber}}"
                  },
                  {
                    "name": "ownerUid",
                    "value": "{{inputs.parameters.ownerUid}}"
                  }
                ]
              },
              "name": "deployScramCluster"
            }
          ],
          [
            {
              "template": "waitforkafkaclusterready",
              "arguments": {
                "parameters": [
                  {
                    "name": "imageMigrationConsoleLocation",
                    "value": "{{inputs.parameters.imageMigrationConsoleLocation}}"
                  },
                  {
                    "name": "imageMigrationConsolePullPolicy",
                    "value": "{{inputs.parameters.imageMigrationConsolePullPolicy}}"
                  },
                  {
                    "name": "resourceName",
                    "value": "{{inputs.parameters.clusterName}}"
                  }
                ]
              },
              "name": "waitForClusterReady"
            }
          ]
        ],
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "createkafkatopic",
        "inputs": {
          "parameters": [
            {
              "name": "clusterName"
            },
            {
              "name": "topicName"
            },
            {
              "name": "migrationRunNumber"
            },
            {
              "name": "ownerUid"
            },
            {
              "name": "sourceLabel"
            },
            {
              "name": "partitions"
            },
            {
              "name": "replicas"
            },
            {
              "name": "topicConfig"
            }
          ]
        },
        "resource": {
          "manifest": "apiVersion: kafka.strimzi.io/v1\nkind: KafkaTopic\nmetadata:\n  name: {{=toJSON(inputs.parameters.topicName)}}\n  ownerReferences:\n    - apiVersion: migrations.opensearch.org/v1alpha1\n      kind: KafkaCluster\n      name: {{=toJSON(inputs.parameters.clusterName)}}\n      uid: {{=toJSON(inputs.parameters.ownerUid)}}\n      controller: true\n      blockOwnerDeletion: true\n  labels:\n    strimzi.io/cluster: {{=toJSON(inputs.parameters.clusterName)}}\n    workflows.argoproj.io/workflow: {{=toJSON(workflow.name)}}\n    migrations.opensearch.org/run-number: {{=toJSON(inputs.parameters.migrationRunNumber)}}\n    migrations.opensearch.org/kafka-cluster: {{=toJSON(inputs.parameters.clusterName)}}\n    migrations.opensearch.org/source: {{=toJSON(inputs.parameters.sourceLabel)}}\nspec:\n  partitions: {{inputs.parameters.partitions}}\n  replicas: {{inputs.parameters.replicas}}\n  config: {{=fromJSON(inputs.parameters.topicConfig)}}\n",
          "action": "apply",
          "setOwnerReference": false
        },
        "retryStrategy": {
          "limit": "6",
          "retryPolicy": "OnError",
          "backoff": {
            "duration": "10",
            "factor": "2",
            "cap": "60"
          }
        },
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "createkafkauser",
        "inputs": {
          "parameters": [
            {
              "name": "clusterName"
            },
            {
              "name": "userSpec"
            },
            {
              "name": "migrationRunNumber"
            },
            {
              "name": "ownerUid"
            }
          ]
        },
        "resource": {
          "manifest": "apiVersion: kafka.strimzi.io/v1\nkind: KafkaUser\nmetadata:\n  name: {{=toJSON(inputs.parameters.clusterName+'-migration-app')}}\n  ownerReferences:\n    - apiVersion: migrations.opensearch.org/v1alpha1\n      kind: KafkaCluster\n      name: {{=toJSON(inputs.parameters.clusterName)}}\n      uid: {{=toJSON(inputs.parameters.ownerUid)}}\n      controller: true\n      blockOwnerDeletion: true\n  labels:\n    strimzi.io/cluster: {{=toJSON(inputs.parameters.clusterName)}}\n    workflows.argoproj.io/workflow: {{=toJSON(workflow.name)}}\n    migrations.opensearch.org/run-number: {{=toJSON(inputs.parameters.migrationRunNumber)}}\n    migrations.opensearch.org/kafka-cluster: {{=toJSON(inputs.parameters.clusterName)}}\nspec: {{=fromJSON(inputs.parameters.userSpec)}}\n",
          "action": "apply",
          "setOwnerReference": false
        },
        "retryStrategy": {
          "limit": "6",
          "retryPolicy": "OnError",
          "backoff": {
            "duration": "10",
            "factor": "2",
            "cap": "60"
          }
        },
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "deploykafkaclusterandtopics",
        "inputs": {
          "parameters": [
            {
              "name": "clusterName"
            },
            {
              "name": "version"
            },
            {
              "name": "clusterConfig"
            },
            {
              "name": "ownerUid"
            },
            {
              "name": "imageMigrationConsoleLocation"
            },
            {
              "name": "imageMigrationConsolePullPolicy"
            }
          ]
        },
        "steps": [
          [
            {
              "template": "deploykafkanodepool",
              "arguments": {
                "parameters": [
                  {
                    "name": "clusterName",
                    "value": "{{inputs.parameters.clusterName}}"
                  },
                  {
                    "name": "nodePoolSpec",
                    "value": "{{=toJSON(sprig.dig('nodePoolSpecOverrides', sprig.dict(), fromJSON(inputs.parameters.clusterConfig)))}}"
                  },
                  {
                    "name": "migrationRunNumber",
                    "value": "{{workflow.parameters.migrationRunNumber}}"
                  },
                  {
                    "name": "ownerUid",
                    "value": "{{inputs.parameters.ownerUid}}"
                  }
                ]
              },
              "name": "deployNodePool"
            }
          ],
          [
            {
              "template": "deploykafkacluster",
              "arguments": {
                "parameters": [
                  {
                    "name": "clusterName",
                    "value": "{{inputs.parameters.clusterName}}"
                  },
                  {
                    "name": "version",
                    "value": "{{inputs.parameters.version}}"
                  },
                  {
                    "name": "clusterConfig",
                    "value": "{{inputs.parameters.clusterConfig}}"
                  },
                  {
                    "name": "ownerUid",
                    "value": "{{inputs.parameters.ownerUid}}"
                  },
                  {
                    "name": "imageMigrationConsoleLocation",
                    "value": "{{inputs.parameters.imageMigrationConsoleLocation}}"
                  },
                  {
                    "name": "imageMigrationConsolePullPolicy",
                    "value": "{{inputs.parameters.imageMigrationConsolePullPolicy}}"
                  },
                  {
                    "name": "migrationRunNumber",
                    "value": "{{workflow.parameters.migrationRunNumber}}"
                  }
                ]
              },
              "name": "deployCluster"
            }
          ],
          [
            {
              "template": "createkafkauser",
              "when": "{{=sprig.dig('auth', 'type', 'none', fromJSON(inputs.parameters.clusterConfig)) == 'scram-sha-512'}}",
              "arguments": {
                "parameters": [
                  {
                    "name": "clusterName",
                    "value": "{{inputs.parameters.clusterName}}"
                  },
                  {
                    "name": "userSpec",
                    "value": "{{=toJSON(sprig.dict(\"authentication\", sprig.dict(\"type\", sprig.dig('auth', 'type', 'none', fromJSON(inputs.parameters.clusterConfig)))))}}"
                  },
                  {
                    "name": "migrationRunNumber",
                    "value": "{{workflow.parameters.migrationRunNumber}}"
                  },
                  {
                    "name": "ownerUid",
                    "value": "{{inputs.parameters.ownerUid}}"
                  }
                ]
              },
              "name": "deployKafkaUser"
            }
          ],
          [
            {
              "templateRef": {
                "template": "waitforsecretkey",
                "name": "resource-management"
              },
              "when": "{{=sprig.dig('auth', 'type', 'none', fromJSON(inputs.parameters.clusterConfig)) == 'scram-sha-512'}}",
              "arguments": {
                "parameters": [
                  {
                    "name": "secretName",
                    "value": "{{=inputs.parameters.clusterName+'-migration-app'}}"
                  },
                  {
                    "name": "secretKey",
                    "value": "password"
                  }
                ]
              },
              "name": "waitForKafkaUserSecret"
            }
          ]
        ],
        "outputs": {
          "parameters": []
        }
      }
    ]
  }
}
