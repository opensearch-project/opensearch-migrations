{
  "apiVersion": "argoproj.io/v1alpha1",
  "kind": "WorkflowTemplate",
  "metadata": {
    "name": "setup-kafka"
  },
  "spec": {
    "serviceAccountName": "argo-workflow-executor",
    "parallelism": 100,
    "arguments": {
      "parameters": [
        {
          "name": "s3SnapshotConfigMap",
          "value": "s3-snapshot-config"
        },
        {
          "name": "imageConfigMapName",
          "value": "migration-image-config"
        },
        {
          "name": "approvalConfigMapName",
          "value": "approval-config"
        }
      ]
    },
    "templates": [
      {
        "name": "deploykafkanodepool",
        "inputs": {
          "parameters": [
            {
              "name": "clusterName"
            },
            {
              "name": "nodePoolSpec"
            }
          ]
        },
        "resource": {
          "manifest": "apiVersion: kafka.strimzi.io/v1\nkind: KafkaNodePool\nmetadata:\n  name: dual-role\n  labels:\n    strimzi.io/cluster: \"{{inputs.parameters.clusterName}}\"\nspec: {{inputs.parameters.nodePoolSpec}}\n",
          "action": "apply",
          "setOwnerReference": false
        },
        "retryStrategy": {
          "limit": "6",
          "retryPolicy": "Always",
          "backoff": {
            "duration": "10",
            "factor": "2",
            "cap": "60"
          }
        },
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "deploykafkaclusterkraftnoauth",
        "inputs": {
          "parameters": [
            {
              "name": "clusterName"
            },
            {
              "name": "kafkaSpec"
            }
          ]
        },
        "resource": {
          "manifest": "apiVersion: kafka.strimzi.io/v1\nkind: Kafka\nmetadata:\n  name: \"{{inputs.parameters.clusterName}}\"\n  annotations:\n    strimzi.io/node-pools: enabled\n    strimzi.io/kraft: enabled\nspec:\n  kafka: {{inputs.parameters.kafkaSpec}}\n  entityOperator:\n    topicOperator: {}\n    userOperator: {}\n",
          "action": "apply",
          "setOwnerReference": false,
          "successCondition": "status.listeners"
        },
        "retryStrategy": {
          "limit": "6",
          "retryPolicy": "Always",
          "backoff": {
            "duration": "10",
            "factor": "2",
            "cap": "60"
          }
        },
        "outputs": {
          "parameters": [
            {
              "name": "brokers",
              "valueFrom": {
                "jsonPath": "{.status.listeners[?(@.name=='plain')].bootstrapServers}"
              }
            }
          ]
        }
      },
      {
        "name": "deploykafkaclusterkraftscram",
        "inputs": {
          "parameters": [
            {
              "name": "clusterName"
            },
            {
              "name": "kafkaSpec"
            }
          ]
        },
        "resource": {
          "manifest": "apiVersion: kafka.strimzi.io/v1\nkind: Kafka\nmetadata:\n  name: \"{{inputs.parameters.clusterName}}\"\n  annotations:\n    strimzi.io/node-pools: enabled\n    strimzi.io/kraft: enabled\nspec:\n  kafka: {{inputs.parameters.kafkaSpec}}\n  entityOperator:\n    topicOperator: {}\n    userOperator: {}\n",
          "action": "apply",
          "setOwnerReference": false,
          "successCondition": "status.listeners"
        },
        "retryStrategy": {
          "limit": "6",
          "retryPolicy": "Always",
          "backoff": {
            "duration": "10",
            "factor": "2",
            "cap": "60"
          }
        },
        "outputs": {
          "parameters": [
            {
              "name": "brokers",
              "valueFrom": {
                "jsonPath": "{.status.listeners[?(@.name=='tls')].bootstrapServers}"
              }
            }
          ]
        }
      },
      {
        "name": "deploykafkacluster",
        "inputs": {
          "parameters": [
            {
              "name": "clusterName"
            },
            {
              "name": "version"
            },
            {
              "name": "clusterConfig"
            }
          ]
        },
        "steps": [
          [
            {
              "template": "deploykafkaclusterkraftnoauth",
              "when": "{{=!(sprig.dig('auth', 'type', 'none', fromJSON(inputs.parameters.clusterConfig)) == 'scram-sha-512')}}",
              "arguments": {
                "parameters": [
                  {
                    "name": "clusterName",
                    "value": "{{inputs.parameters.clusterName}}"
                  },
                  {
                    "name": "kafkaSpec",
                    "value": "{{=toJSON(sprig.merge(sprig.dict(\"version\", inputs.parameters.version, \"metadataVersion\", '4.0-IV3', \"listeners\", [sprig.dict(\"name\", 'plain', \"port\", 9092, \"type\", 'internal', \"tls\", false), sprig.dict(\"name\", 'tls', \"port\", 9093, \"type\", 'internal', \"tls\", true)]), sprig.dig('clusterSpecOverrides', 'kafka', sprig.dict(), fromJSON(inputs.parameters.clusterConfig))))}}"
                  }
                ]
              },
              "name": "deployNoAuthCluster"
            }
          ],
          [
            {
              "template": "deploykafkaclusterkraftscram",
              "when": "{{=sprig.dig('auth', 'type', 'none', fromJSON(inputs.parameters.clusterConfig)) == 'scram-sha-512'}}",
              "arguments": {
                "parameters": [
                  {
                    "name": "clusterName",
                    "value": "{{inputs.parameters.clusterName}}"
                  },
                  {
                    "name": "kafkaSpec",
                    "value": "{{=toJSON(sprig.merge(sprig.dict(\"version\", inputs.parameters.version, \"metadataVersion\", '4.0-IV3', \"listeners\", [sprig.dict(\"name\", 'tls', \"port\", 9093, \"type\", 'internal', \"tls\", true, \"authentication\", sprig.dict(\"type\", 'scram-sha-512'))]), sprig.dig('clusterSpecOverrides', 'kafka', sprig.dict(), fromJSON(inputs.parameters.clusterConfig))))}}"
                  }
                ]
              },
              "name": "deployScramCluster"
            }
          ]
        ],
        "outputs": {
          "parameters": [
            {
              "name": "bootstrapServers",
              "valueFrom": {
                "expression": "((sprig.dig('auth', 'type', 'none', fromJSON(inputs.parameters.clusterConfig)) == 'scram-sha-512') ? (steps.deployScramCluster.outputs.parameters.brokers) : (steps.deployNoAuthCluster.outputs.parameters.brokers))"
              }
            }
          ]
        }
      },
      {
        "name": "createkafkatopic",
        "inputs": {
          "parameters": [
            {
              "name": "clusterName"
            },
            {
              "name": "topicName"
            },
            {
              "name": "partitions"
            },
            {
              "name": "replicas"
            },
            {
              "name": "topicConfig"
            }
          ]
        },
        "resource": {
          "manifest": "apiVersion: kafka.strimzi.io/v1\nkind: KafkaTopic\nmetadata:\n  name: \"{{inputs.parameters.topicName}}\"\n  labels:\n    strimzi.io/cluster: \"{{inputs.parameters.clusterName}}\"\nspec:\n  partitions: {{inputs.parameters.partitions}}\n  replicas: {{inputs.parameters.replicas}}\n  config: {{inputs.parameters.topicConfig}}\n",
          "action": "apply",
          "setOwnerReference": false,
          "successCondition": "status.topicName"
        },
        "retryStrategy": {
          "limit": "6",
          "retryPolicy": "Always",
          "backoff": {
            "duration": "10",
            "factor": "2",
            "cap": "60"
          }
        },
        "outputs": {
          "parameters": [
            {
              "name": "topicName",
              "valueFrom": {
                "jsonPath": "{.status.topicName}"
              }
            }
          ]
        }
      },
      {
        "name": "createkafkauser",
        "inputs": {
          "parameters": [
            {
              "name": "clusterName"
            },
            {
              "name": "userSpec"
            }
          ]
        },
        "resource": {
          "manifest": "apiVersion: kafka.strimzi.io/v1\nkind: KafkaUser\nmetadata:\n  name: \"{{=inputs.parameters.clusterName+'-migration-app'}}\"\n  labels:\n    strimzi.io/cluster: \"{{inputs.parameters.clusterName}}\"\nspec: {{inputs.parameters.userSpec}}\n",
          "action": "apply",
          "setOwnerReference": false,
          "successCondition": "status.conditions"
        },
        "retryStrategy": {
          "limit": "6",
          "retryPolicy": "Always",
          "backoff": {
            "duration": "10",
            "factor": "2",
            "cap": "60"
          }
        },
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "suspendforretry",
        "inputs": {
          "parameters": [
            {
              "name": "name"
            }
          ]
        },
        "suspend": {},
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "deploykafkanodepoolwithretry",
        "inputs": {
          "parameters": [
            {
              "name": "clusterName"
            },
            {
              "name": "clusterConfig"
            },
            {
              "name": "retryGroupName_view",
              "value": "Apply"
            }
          ]
        },
        "steps": [
          [
            {
              "template": "deploykafkanodepool",
              "arguments": {
                "parameters": [
                  {
                    "name": "clusterName",
                    "value": "{{inputs.parameters.clusterName}}"
                  },
                  {
                    "name": "nodePoolSpec",
                    "value": "{{=toJSON(sprig.dig('nodePoolSpecOverrides', sprig.dict(), fromJSON(inputs.parameters.clusterConfig)))}}"
                  }
                ]
              },
              "name": "tryApply",
              "continueOn": {
                "failed": true
              }
            }
          ],
          [
            {
              "template": "suspendforretry",
              "when": "{{=steps.tryApply.status == 'Failed'}}",
              "arguments": {
                "parameters": [
                  {
                    "name": "name",
                    "value": "KafkaNodePool"
                  }
                ]
              },
              "name": "waitForFix"
            }
          ],
          [
            {
              "template": "deploykafkanodepoolwithretry",
              "when": "{{=steps.waitForFix.status == 'Succeeded'}}",
              "arguments": {
                "parameters": [
                  {
                    "name": "clusterName",
                    "value": "{{inputs.parameters.clusterName}}"
                  },
                  {
                    "name": "clusterConfig",
                    "value": "{{inputs.parameters.clusterConfig}}"
                  },
                  {
                    "name": "retryGroupName_view",
                    "value": "{{inputs.parameters.retryGroupName_view}}"
                  }
                ]
              },
              "name": "retryLoop"
            }
          ]
        ],
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "deploykafkaclusterkraftwithretry",
        "inputs": {
          "parameters": [
            {
              "name": "clusterName"
            },
            {
              "name": "version"
            },
            {
              "name": "clusterConfig"
            },
            {
              "name": "retryGroupName_view",
              "value": "Apply"
            }
          ]
        },
        "steps": [
          [
            {
              "template": "deploykafkacluster",
              "arguments": {
                "parameters": [
                  {
                    "name": "clusterName",
                    "value": "{{inputs.parameters.clusterName}}"
                  },
                  {
                    "name": "version",
                    "value": "{{inputs.parameters.version}}"
                  },
                  {
                    "name": "clusterConfig",
                    "value": "{{inputs.parameters.clusterConfig}}"
                  }
                ]
              },
              "name": "tryApply",
              "continueOn": {
                "failed": true
              }
            }
          ],
          [
            {
              "template": "suspendforretry",
              "when": "{{=steps.tryApply.status == 'Failed'}}",
              "arguments": {
                "parameters": [
                  {
                    "name": "name",
                    "value": "KafkaCluster"
                  }
                ]
              },
              "name": "waitForFix"
            }
          ],
          [
            {
              "template": "deploykafkaclusterkraftwithretry",
              "when": "{{=steps.waitForFix.status == 'Succeeded'}}",
              "arguments": {
                "parameters": [
                  {
                    "name": "clusterName",
                    "value": "{{inputs.parameters.clusterName}}"
                  },
                  {
                    "name": "version",
                    "value": "{{inputs.parameters.version}}"
                  },
                  {
                    "name": "clusterConfig",
                    "value": "{{inputs.parameters.clusterConfig}}"
                  },
                  {
                    "name": "retryGroupName_view",
                    "value": "{{inputs.parameters.retryGroupName_view}}"
                  }
                ]
              },
              "name": "retryLoop"
            }
          ]
        ],
        "outputs": {
          "parameters": [
            {
              "name": "brokers",
              "valueFrom": {
                "expression": "steps.tryApply.outputs.parameters.bootstrapServers"
              }
            }
          ]
        }
      },
      {
        "name": "createkafkatopicwithretry",
        "inputs": {
          "parameters": [
            {
              "name": "clusterName"
            },
            {
              "name": "topicName"
            },
            {
              "name": "partitions"
            },
            {
              "name": "replicas"
            },
            {
              "name": "topicConfig"
            },
            {
              "name": "retryGroupName_view",
              "value": "Apply"
            }
          ]
        },
        "steps": [
          [
            {
              "template": "createkafkatopic",
              "arguments": {
                "parameters": [
                  {
                    "name": "clusterName",
                    "value": "{{inputs.parameters.clusterName}}"
                  },
                  {
                    "name": "topicName",
                    "value": "{{inputs.parameters.topicName}}"
                  },
                  {
                    "name": "partitions",
                    "value": "{{inputs.parameters.partitions}}"
                  },
                  {
                    "name": "replicas",
                    "value": "{{inputs.parameters.replicas}}"
                  },
                  {
                    "name": "topicConfig",
                    "value": "{{inputs.parameters.topicConfig}}"
                  }
                ]
              },
              "name": "tryApply",
              "continueOn": {
                "failed": true
              }
            }
          ],
          [
            {
              "template": "suspendforretry",
              "when": "{{=steps.tryApply.status == 'Failed'}}",
              "arguments": {
                "parameters": [
                  {
                    "name": "name",
                    "value": "KafkaTopic"
                  }
                ]
              },
              "name": "waitForFix"
            }
          ],
          [
            {
              "template": "createkafkatopicwithretry",
              "when": "{{=steps.waitForFix.status == 'Succeeded'}}",
              "arguments": {
                "parameters": [
                  {
                    "name": "clusterName",
                    "value": "{{inputs.parameters.clusterName}}"
                  },
                  {
                    "name": "topicName",
                    "value": "{{inputs.parameters.topicName}}"
                  },
                  {
                    "name": "partitions",
                    "value": "{{inputs.parameters.partitions}}"
                  },
                  {
                    "name": "replicas",
                    "value": "{{inputs.parameters.replicas}}"
                  },
                  {
                    "name": "topicConfig",
                    "value": "{{inputs.parameters.topicConfig}}"
                  },
                  {
                    "name": "retryGroupName_view",
                    "value": "{{inputs.parameters.retryGroupName_view}}"
                  }
                ]
              },
              "name": "retryLoop"
            }
          ]
        ],
        "outputs": {
          "parameters": [
            {
              "name": "topicName",
              "valueFrom": {
                "expression": "steps.tryApply.outputs.parameters.topicName"
              }
            }
          ]
        }
      },
      {
        "name": "createkafkauserwithretry",
        "inputs": {
          "parameters": [
            {
              "name": "clusterName"
            },
            {
              "name": "clusterConfig"
            },
            {
              "name": "retryGroupName_view",
              "value": "Apply"
            }
          ]
        },
        "steps": [
          [
            {
              "template": "createkafkauser",
              "arguments": {
                "parameters": [
                  {
                    "name": "clusterName",
                    "value": "{{inputs.parameters.clusterName}}"
                  },
                  {
                    "name": "userSpec",
                    "value": "{{=toJSON(sprig.dict(\"authentication\", sprig.dict(\"type\", sprig.dig('auth', 'type', 'none', fromJSON(inputs.parameters.clusterConfig)))))}}"
                  }
                ]
              },
              "name": "tryApply",
              "continueOn": {
                "failed": true
              }
            }
          ],
          [
            {
              "template": "suspendforretry",
              "when": "{{=steps.tryApply.status == 'Failed'}}",
              "arguments": {
                "parameters": [
                  {
                    "name": "name",
                    "value": "KafkaUser"
                  }
                ]
              },
              "name": "waitForFix"
            }
          ],
          [
            {
              "template": "createkafkauserwithretry",
              "when": "{{=steps.waitForFix.status == 'Succeeded'}}",
              "arguments": {
                "parameters": [
                  {
                    "name": "clusterName",
                    "value": "{{inputs.parameters.clusterName}}"
                  },
                  {
                    "name": "clusterConfig",
                    "value": "{{inputs.parameters.clusterConfig}}"
                  },
                  {
                    "name": "retryGroupName_view",
                    "value": "{{inputs.parameters.retryGroupName_view}}"
                  }
                ]
              },
              "name": "retryLoop"
            }
          ]
        ],
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "deploykafkaclusterwithretry",
        "inputs": {
          "parameters": [
            {
              "name": "clusterName"
            },
            {
              "name": "version"
            },
            {
              "name": "clusterConfig"
            }
          ]
        },
        "steps": [
          [
            {
              "template": "deploykafkanodepoolwithretry",
              "arguments": {
                "parameters": [
                  {
                    "name": "clusterName",
                    "value": "{{inputs.parameters.clusterName}}"
                  },
                  {
                    "name": "clusterConfig",
                    "value": "{{inputs.parameters.clusterConfig}}"
                  },
                  {
                    "name": "retryGroupName_view",
                    "value": "{{='KafkaNodePool: '+inputs.parameters.clusterName}}"
                  }
                ]
              },
              "name": "deployPool"
            }
          ],
          [
            {
              "template": "deploykafkaclusterkraftwithretry",
              "arguments": {
                "parameters": [
                  {
                    "name": "clusterName",
                    "value": "{{inputs.parameters.clusterName}}"
                  },
                  {
                    "name": "version",
                    "value": "{{inputs.parameters.version}}"
                  },
                  {
                    "name": "clusterConfig",
                    "value": "{{inputs.parameters.clusterConfig}}"
                  },
                  {
                    "name": "retryGroupName_view",
                    "value": "{{='KafkaCluster: '+inputs.parameters.clusterName}}"
                  }
                ]
              },
              "name": "deployCluster"
            }
          ],
          [
            {
              "template": "createkafkauserwithretry",
              "when": "{{=sprig.dig('auth', 'type', 'none', fromJSON(inputs.parameters.clusterConfig)) == 'scram-sha-512'}}",
              "arguments": {
                "parameters": [
                  {
                    "name": "clusterName",
                    "value": "{{inputs.parameters.clusterName}}"
                  },
                  {
                    "name": "clusterConfig",
                    "value": "{{inputs.parameters.clusterConfig}}"
                  },
                  {
                    "name": "retryGroupName_view",
                    "value": "{{='KafkaUser: '+inputs.parameters.clusterName}}"
                  }
                ]
              },
              "name": "createKafkaUser"
            }
          ]
        ],
        "outputs": {
          "parameters": [
            {
              "name": "bootstrapServers",
              "valueFrom": {
                "expression": "steps.deployCluster.outputs.parameters.brokers"
              }
            }
          ]
        }
      }
    ]
  }
}
