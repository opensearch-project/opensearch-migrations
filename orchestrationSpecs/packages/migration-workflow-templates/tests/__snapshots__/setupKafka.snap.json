{
  "apiVersion": "argoproj.io/v1alpha1",
  "kind": "WorkflowTemplate",
  "metadata": {
    "name": "setup-kafka"
  },
  "spec": {
    "serviceAccountName": "argo-workflow-executor",
    "parallelism": 100,
    "arguments": {
      "parameters": [
        {
          "name": "s3SnapshotConfigMap",
          "value": "s3-snapshot-config"
        },
        {
          "name": "imageConfigMapName",
          "value": "migration-image-config"
        },
        {
          "name": "approvalConfigMapName",
          "value": "approval-config"
        }
      ]
    },
    "templates": [
      {
        "name": "deploykafkanodepool",
        "inputs": {
          "parameters": [
            {
              "name": "clusterName"
            },
            {
              "name": "clusterConfig"
            }
          ]
        },
        "resource": {
          "manifest": "apiVersion: kafka.strimzi.io/v1\nkind: KafkaNodePool\nmetadata:\n  name: dual-role\n  labels:\n    strimzi.io/cluster: \"{{inputs.parameters.clusterName}}\"\nspec: {{=sprig.merge(sprig.dict(\"replicas\", 1, \"roles\", [\"controller\",\"broker\"], \"storage\", sprig.dict(\"type\", 'persistent-claim', \"size\", '1Gi', \"deleteClaim\", true)), sprig.dig('nodePoolSpecOverrides', {}, fromJSON(inputs.parameters.clusterConfig)))}}\n",
          "action": "apply",
          "setOwnerReference": false
        },
        "retryStrategy": {
          "limit": "6",
          "retryPolicy": "Always",
          "backoff": {
            "duration": "10",
            "factor": "2",
            "cap": "60"
          }
        },
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "deploykafkaclusterkraftnoauth",
        "inputs": {
          "parameters": [
            {
              "name": "clusterName"
            },
            {
              "name": "version"
            },
            {
              "name": "clusterConfig"
            }
          ]
        },
        "resource": {
          "manifest": "apiVersion: kafka.strimzi.io/v1\nkind: Kafka\nmetadata:\n  name: \"{{inputs.parameters.clusterName}}\"\n  annotations:\n    strimzi.io/node-pools: enabled\n    strimzi.io/kraft: enabled\nspec:\n  kafka:\n    version: \"{{inputs.parameters.version}}\"\n    metadataVersion: 4.0-IV3\n    readinessProbe:\n      initialDelaySeconds: 1\n      periodSeconds: 2\n      timeoutSeconds: 2\n      failureThreshold: 1\n    livenessProbe:\n      initialDelaySeconds: 1\n      periodSeconds: 2\n      timeoutSeconds: 2\n      failureThreshold: 2\n    listeners:\n      - name: plain\n        port: 9092\n        type: internal\n        tls: false\n      - name: tls\n        port: 9093\n        type: internal\n        tls: true\n    config: {{=sprig.merge({\"auto.create.topics.enable\":false,\"offsets.topic.replication.factor\":1,\"transaction.state.log.replication.factor\":1,\"transaction.state.log.min.isr\":1,\"default.replication.factor\":1,\"min.insync.replicas\":1}, sprig.dig('clusterSpecOverrides', 'kafka', 'config', {}, fromJSON(inputs.parameters.clusterConfig)))}}\n  entityOperator:\n    topicOperator: {}\n    userOperator: {}\n",
          "action": "apply",
          "setOwnerReference": false,
          "successCondition": "status.listeners"
        },
        "retryStrategy": {
          "limit": "6",
          "retryPolicy": "Always",
          "backoff": {
            "duration": "10",
            "factor": "2",
            "cap": "60"
          }
        },
        "outputs": {
          "parameters": [
            {
              "name": "brokers",
              "valueFrom": {
                "jsonPath": "{.status.listeners[?(@.name=='plain')].bootstrapServers}"
              }
            }
          ]
        }
      },
      {
        "name": "deploykafkaclusterkraftscram",
        "inputs": {
          "parameters": [
            {
              "name": "clusterName"
            },
            {
              "name": "version"
            },
            {
              "name": "clusterConfig"
            }
          ]
        },
        "resource": {
          "manifest": "apiVersion: kafka.strimzi.io/v1\nkind: Kafka\nmetadata:\n  name: \"{{inputs.parameters.clusterName}}\"\n  annotations:\n    strimzi.io/node-pools: enabled\n    strimzi.io/kraft: enabled\nspec:\n  kafka:\n    version: \"{{inputs.parameters.version}}\"\n    metadataVersion: 4.0-IV3\n    readinessProbe:\n      initialDelaySeconds: 1\n      periodSeconds: 2\n      timeoutSeconds: 2\n      failureThreshold: 1\n    livenessProbe:\n      initialDelaySeconds: 1\n      periodSeconds: 2\n      timeoutSeconds: 2\n      failureThreshold: 2\n    listeners:\n      - name: tls\n        port: 9093\n        type: internal\n        tls: true\n        authentication:\n          type: scram-sha-512\n    config: {{=sprig.merge({\"auto.create.topics.enable\":false,\"offsets.topic.replication.factor\":1,\"transaction.state.log.replication.factor\":1,\"transaction.state.log.min.isr\":1,\"default.replication.factor\":1,\"min.insync.replicas\":1}, sprig.dig('clusterSpecOverrides', 'kafka', 'config', {}, fromJSON(inputs.parameters.clusterConfig)))}}\n  entityOperator:\n    topicOperator: {}\n    userOperator: {}\n",
          "action": "apply",
          "setOwnerReference": false,
          "successCondition": "status.listeners"
        },
        "retryStrategy": {
          "limit": "6",
          "retryPolicy": "Always",
          "backoff": {
            "duration": "10",
            "factor": "2",
            "cap": "60"
          }
        },
        "outputs": {
          "parameters": [
            {
              "name": "brokers",
              "valueFrom": {
                "jsonPath": "{.status.listeners[?(@.name=='tls')].bootstrapServers}"
              }
            }
          ]
        }
      },
      {
        "name": "deploykafkacluster",
        "inputs": {
          "parameters": [
            {
              "name": "clusterName"
            },
            {
              "name": "version"
            },
            {
              "name": "clusterConfig"
            }
          ]
        },
        "steps": [
          [
            {
              "template": "deploykafkaclusterkraftnoauth",
              "when": "{{=!(sprig.dig('auth', 'type', 'none', fromJSON(inputs.parameters.clusterConfig)) == 'scram-sha-512')}}",
              "arguments": {
                "parameters": [
                  {
                    "name": "clusterName",
                    "value": "{{inputs.parameters.clusterName}}"
                  },
                  {
                    "name": "version",
                    "value": "{{inputs.parameters.version}}"
                  },
                  {
                    "name": "clusterConfig",
                    "value": "{{inputs.parameters.clusterConfig}}"
                  }
                ]
              },
              "name": "deployNoAuthCluster"
            }
          ],
          [
            {
              "template": "deploykafkaclusterkraftscram",
              "when": "{{=sprig.dig('auth', 'type', 'none', fromJSON(inputs.parameters.clusterConfig)) == 'scram-sha-512'}}",
              "arguments": {
                "parameters": [
                  {
                    "name": "clusterName",
                    "value": "{{inputs.parameters.clusterName}}"
                  },
                  {
                    "name": "version",
                    "value": "{{inputs.parameters.version}}"
                  },
                  {
                    "name": "clusterConfig",
                    "value": "{{inputs.parameters.clusterConfig}}"
                  }
                ]
              },
              "name": "deployScramCluster"
            }
          ]
        ],
        "outputs": {
          "parameters": [
            {
              "name": "bootstrapServers",
              "valueFrom": {
                "expression": "((sprig.dig('auth', 'type', 'none', fromJSON(inputs.parameters.clusterConfig)) == 'scram-sha-512') ? (steps.deployScramCluster.outputs.parameters.brokers) : (steps.deployNoAuthCluster.outputs.parameters.brokers))"
              }
            }
          ]
        }
      },
      {
        "name": "createkafkatopic",
        "inputs": {
          "parameters": [
            {
              "name": "clusterName"
            },
            {
              "name": "topicName"
            },
            {
              "name": "clusterConfig"
            }
          ]
        },
        "resource": {
          "manifest": "apiVersion: kafka.strimzi.io/v1\nkind: KafkaTopic\nmetadata:\n  name: \"{{inputs.parameters.topicName}}\"\n  labels:\n    strimzi.io/cluster: \"{{inputs.parameters.clusterName}}\"\nspec: {{=sprig.merge(sprig.dict(\"partitions\", 1, \"replicas\", 1, \"config\", {\"retention.ms\":604800000,\"segment.bytes\":1073741824}), sprig.dig('topicSpecOverrides', {}, fromJSON(inputs.parameters.clusterConfig)))}}\n",
          "action": "apply",
          "setOwnerReference": false,
          "successCondition": "status.topicName"
        },
        "retryStrategy": {
          "limit": "6",
          "retryPolicy": "Always",
          "backoff": {
            "duration": "10",
            "factor": "2",
            "cap": "60"
          }
        },
        "outputs": {
          "parameters": [
            {
              "name": "topicName",
              "valueFrom": {
                "jsonPath": "{.status.topicName}"
              }
            }
          ]
        }
      },
      {
        "name": "createkafkauser",
        "inputs": {
          "parameters": [
            {
              "name": "clusterName"
            },
            {
              "name": "clusterConfig"
            }
          ]
        },
        "resource": {
          "manifest": "apiVersion: kafka.strimzi.io/v1\nkind: KafkaUser\nmetadata:\n  name: \"{{=inputs.parameters.clusterName+'-migration-app'}}\"\n  labels:\n    strimzi.io/cluster: \"{{inputs.parameters.clusterName}}\"\nspec: {{=sprig.dict(\"authentication\", sprig.dict(\"type\", sprig.dig('auth', 'type', 'none', fromJSON(inputs.parameters.clusterConfig))))}}\n",
          "action": "apply",
          "setOwnerReference": false,
          "successCondition": "status.conditions"
        },
        "retryStrategy": {
          "limit": "6",
          "retryPolicy": "Always",
          "backoff": {
            "duration": "10",
            "factor": "2",
            "cap": "60"
          }
        },
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "suspendforretry",
        "inputs": {
          "parameters": [
            {
              "name": "name"
            }
          ]
        },
        "suspend": {},
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "deploykafkanodepoolwithretry",
        "inputs": {
          "parameters": [
            {
              "name": "clusterName"
            },
            {
              "name": "clusterConfig"
            },
            {
              "name": "retryGroupName_view",
              "value": "Apply"
            }
          ]
        },
        "steps": [
          [
            {
              "template": "deploykafkanodepool",
              "arguments": {
                "parameters": [
                  {
                    "name": "clusterName",
                    "value": "{{inputs.parameters.clusterName}}"
                  },
                  {
                    "name": "clusterConfig",
                    "value": "{{inputs.parameters.clusterConfig}}"
                  }
                ]
              },
              "name": "tryApply",
              "continueOn": {
                "failed": true
              }
            }
          ],
          [
            {
              "template": "suspendforretry",
              "when": "{{=steps.tryApply.status == 'Failed'}}",
              "arguments": {
                "parameters": [
                  {
                    "name": "name",
                    "value": "KafkaNodePool"
                  }
                ]
              },
              "name": "waitForFix"
            }
          ],
          [
            {
              "template": "deploykafkanodepoolwithretry",
              "when": "{{=steps.waitForFix.status == 'Succeeded'}}",
              "arguments": {
                "parameters": [
                  {
                    "name": "clusterName",
                    "value": "{{inputs.parameters.clusterName}}"
                  },
                  {
                    "name": "clusterConfig",
                    "value": "{{inputs.parameters.clusterConfig}}"
                  },
                  {
                    "name": "retryGroupName_view",
                    "value": "{{inputs.parameters.retryGroupName_view}}"
                  }
                ]
              },
              "name": "retryLoop"
            }
          ]
        ],
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "deploykafkaclusterkraftwithretry",
        "inputs": {
          "parameters": [
            {
              "name": "clusterName"
            },
            {
              "name": "version"
            },
            {
              "name": "clusterConfig"
            },
            {
              "name": "retryGroupName_view",
              "value": "Apply"
            }
          ]
        },
        "steps": [
          [
            {
              "template": "deploykafkacluster",
              "arguments": {
                "parameters": [
                  {
                    "name": "clusterName",
                    "value": "{{inputs.parameters.clusterName}}"
                  },
                  {
                    "name": "version",
                    "value": "{{inputs.parameters.version}}"
                  },
                  {
                    "name": "clusterConfig",
                    "value": "{{inputs.parameters.clusterConfig}}"
                  }
                ]
              },
              "name": "tryApply",
              "continueOn": {
                "failed": true
              }
            }
          ],
          [
            {
              "template": "suspendforretry",
              "when": "{{=steps.tryApply.status == 'Failed'}}",
              "arguments": {
                "parameters": [
                  {
                    "name": "name",
                    "value": "KafkaCluster"
                  }
                ]
              },
              "name": "waitForFix"
            }
          ],
          [
            {
              "template": "deploykafkaclusterkraftwithretry",
              "when": "{{=steps.waitForFix.status == 'Succeeded'}}",
              "arguments": {
                "parameters": [
                  {
                    "name": "clusterName",
                    "value": "{{inputs.parameters.clusterName}}"
                  },
                  {
                    "name": "version",
                    "value": "{{inputs.parameters.version}}"
                  },
                  {
                    "name": "clusterConfig",
                    "value": "{{inputs.parameters.clusterConfig}}"
                  },
                  {
                    "name": "retryGroupName_view",
                    "value": "{{inputs.parameters.retryGroupName_view}}"
                  }
                ]
              },
              "name": "retryLoop"
            }
          ]
        ],
        "outputs": {
          "parameters": [
            {
              "name": "brokers",
              "valueFrom": {
                "expression": "steps.tryApply.outputs.parameters.bootstrapServers"
              }
            }
          ]
        }
      },
      {
        "name": "createkafkatopicwithretry",
        "inputs": {
          "parameters": [
            {
              "name": "clusterName"
            },
            {
              "name": "topicName"
            },
            {
              "name": "clusterConfig"
            },
            {
              "name": "retryGroupName_view",
              "value": "Apply"
            }
          ]
        },
        "steps": [
          [
            {
              "template": "createkafkatopic",
              "arguments": {
                "parameters": [
                  {
                    "name": "clusterName",
                    "value": "{{inputs.parameters.clusterName}}"
                  },
                  {
                    "name": "topicName",
                    "value": "{{inputs.parameters.topicName}}"
                  },
                  {
                    "name": "clusterConfig",
                    "value": "{{inputs.parameters.clusterConfig}}"
                  }
                ]
              },
              "name": "tryApply",
              "continueOn": {
                "failed": true
              }
            }
          ],
          [
            {
              "template": "suspendforretry",
              "when": "{{=steps.tryApply.status == 'Failed'}}",
              "arguments": {
                "parameters": [
                  {
                    "name": "name",
                    "value": "KafkaTopic"
                  }
                ]
              },
              "name": "waitForFix"
            }
          ],
          [
            {
              "template": "createkafkatopicwithretry",
              "when": "{{=steps.waitForFix.status == 'Succeeded'}}",
              "arguments": {
                "parameters": [
                  {
                    "name": "clusterName",
                    "value": "{{inputs.parameters.clusterName}}"
                  },
                  {
                    "name": "topicName",
                    "value": "{{inputs.parameters.topicName}}"
                  },
                  {
                    "name": "clusterConfig",
                    "value": "{{inputs.parameters.clusterConfig}}"
                  },
                  {
                    "name": "retryGroupName_view",
                    "value": "{{inputs.parameters.retryGroupName_view}}"
                  }
                ]
              },
              "name": "retryLoop"
            }
          ]
        ],
        "outputs": {
          "parameters": [
            {
              "name": "topicName",
              "valueFrom": {
                "expression": "steps.tryApply.outputs.parameters.topicName"
              }
            }
          ]
        }
      },
      {
        "name": "createkafkauserwithretry",
        "inputs": {
          "parameters": [
            {
              "name": "clusterName"
            },
            {
              "name": "clusterConfig"
            },
            {
              "name": "retryGroupName_view",
              "value": "Apply"
            }
          ]
        },
        "steps": [
          [
            {
              "template": "createkafkauser",
              "arguments": {
                "parameters": [
                  {
                    "name": "clusterName",
                    "value": "{{inputs.parameters.clusterName}}"
                  },
                  {
                    "name": "clusterConfig",
                    "value": "{{inputs.parameters.clusterConfig}}"
                  }
                ]
              },
              "name": "tryApply",
              "continueOn": {
                "failed": true
              }
            }
          ],
          [
            {
              "template": "suspendforretry",
              "when": "{{=steps.tryApply.status == 'Failed'}}",
              "arguments": {
                "parameters": [
                  {
                    "name": "name",
                    "value": "KafkaUser"
                  }
                ]
              },
              "name": "waitForFix"
            }
          ],
          [
            {
              "template": "createkafkauserwithretry",
              "when": "{{=steps.waitForFix.status == 'Succeeded'}}",
              "arguments": {
                "parameters": [
                  {
                    "name": "clusterName",
                    "value": "{{inputs.parameters.clusterName}}"
                  },
                  {
                    "name": "clusterConfig",
                    "value": "{{inputs.parameters.clusterConfig}}"
                  },
                  {
                    "name": "retryGroupName_view",
                    "value": "{{inputs.parameters.retryGroupName_view}}"
                  }
                ]
              },
              "name": "retryLoop"
            }
          ]
        ],
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "deploykafkaclusterwithretry",
        "inputs": {
          "parameters": [
            {
              "name": "clusterName"
            },
            {
              "name": "version"
            },
            {
              "name": "clusterConfig"
            }
          ]
        },
        "steps": [
          [
            {
              "template": "deploykafkanodepoolwithretry",
              "arguments": {
                "parameters": [
                  {
                    "name": "clusterName",
                    "value": "{{inputs.parameters.clusterName}}"
                  },
                  {
                    "name": "clusterConfig",
                    "value": "{{inputs.parameters.clusterConfig}}"
                  },
                  {
                    "name": "retryGroupName_view",
                    "value": "{{='KafkaNodePool: '+inputs.parameters.clusterName}}"
                  }
                ]
              },
              "name": "deployPool"
            }
          ],
          [
            {
              "template": "deploykafkaclusterkraftwithretry",
              "arguments": {
                "parameters": [
                  {
                    "name": "clusterName",
                    "value": "{{inputs.parameters.clusterName}}"
                  },
                  {
                    "name": "version",
                    "value": "{{inputs.parameters.version}}"
                  },
                  {
                    "name": "clusterConfig",
                    "value": "{{inputs.parameters.clusterConfig}}"
                  },
                  {
                    "name": "retryGroupName_view",
                    "value": "{{='KafkaCluster: '+inputs.parameters.clusterName}}"
                  }
                ]
              },
              "name": "deployCluster"
            }
          ],
          [
            {
              "template": "createkafkauserwithretry",
              "when": "{{=sprig.dig('auth', 'type', 'none', fromJSON(inputs.parameters.clusterConfig)) == 'scram-sha-512'}}",
              "arguments": {
                "parameters": [
                  {
                    "name": "clusterName",
                    "value": "{{inputs.parameters.clusterName}}"
                  },
                  {
                    "name": "clusterConfig",
                    "value": "{{inputs.parameters.clusterConfig}}"
                  },
                  {
                    "name": "retryGroupName_view",
                    "value": "{{='KafkaUser: '+inputs.parameters.clusterName}}"
                  }
                ]
              },
              "name": "createKafkaUser"
            }
          ]
        ],
        "outputs": {
          "parameters": [
            {
              "name": "bootstrapServers",
              "valueFrom": {
                "expression": "steps.deployCluster.outputs.parameters.brokers"
              }
            }
          ]
        }
      }
    ]
  }
}
