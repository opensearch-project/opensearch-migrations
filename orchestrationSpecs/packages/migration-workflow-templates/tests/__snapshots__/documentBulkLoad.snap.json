{
  "apiVersion": "argoproj.io/v1alpha1",
  "kind": "WorkflowTemplate",
  "metadata": {
    "name": "document-bulk-load"
  },
  "spec": {
    "serviceAccountName": "argo-workflow-executor",
    "parallelism": 100,
    "arguments": {
      "parameters": [
        {
          "name": "s3SnapshotConfigMap",
          "value": "s3-snapshot-config"
        },
        {
          "name": "gcsSnapshotConfigMap",
          "value": "gcs-snapshot-config"
        },
        {
          "name": "imageConfigMapName",
          "value": "migration-image-config"
        },
        {
          "name": "migrationRunNumber",
          "value": "0"
        },
        {
          "name": "workflowScriptsRoot",
          "value": "/root/workflows/.workflowScripts"
        }
      ]
    },
    "templates": [
      {
        "name": "applyrfsdonecronjob",
        "inputs": {
          "parameters": [
            {
              "name": "sessionName"
            },
            {
              "name": "crdName"
            },
            {
              "name": "crdUid"
            },
            {
              "name": "configChecksum"
            },
            {
              "name": "checksumForReplayer"
            },
            {
              "name": "usesDedicatedCoordinator"
            },
            {
              "name": "fromSnapshotMigrationK8sLabel"
            },
            {
              "name": "consoleConfigContents"
            },
            {
              "name": "imageMigrationConsoleLocation"
            },
            {
              "name": "imageMigrationConsolePullPolicy"
            }
          ]
        },
        "container": {
          "env": [
            {
              "name": "CRONJOB_NAME",
              "value": "{{=inputs.parameters.sessionName+'-rfs-done'}}"
            },
            {
              "name": "SESSION_NAME",
              "value": "{{inputs.parameters.sessionName}}"
            },
            {
              "name": "WORKFLOW_NAME",
              "value": "{{workflow.name}}"
            },
            {
              "name": "WORKFLOW_UID",
              "value": "{{workflow.uid}}"
            },
            {
              "name": "PARENT_WORKFLOW_NAME",
              "value": "{{workflow.name}}"
            },
            {
              "name": "PARENT_WORKFLOW_UID",
              "value": "{{workflow.uid}}"
            },
            {
              "name": "SNAPSHOT_MIGRATION_NAME",
              "value": "{{inputs.parameters.crdName}}"
            },
            {
              "name": "SM_UID",
              "value": "{{inputs.parameters.crdUid}}"
            },
            {
              "name": "CONFIG_CHECKSUM",
              "value": "{{inputs.parameters.configChecksum}}"
            },
            {
              "name": "CHECKSUM_FOR_REPLAYER",
              "value": "{{inputs.parameters.checksumForReplayer}}"
            },
            {
              "name": "RFS_DEPLOYMENT_NAME",
              "value": "{{=inputs.parameters.sessionName+'-rfs'}}"
            },
            {
              "name": "RFS_COORDINATOR_NAME",
              "value": "{{=inputs.parameters.sessionName+'-rfs-coordinator'}}"
            },
            {
              "name": "USES_DEDICATED_COORDINATOR",
              "value": "{{inputs.parameters.usesDedicatedCoordinator}}"
            },
            {
              "name": "CONSOLE_IMAGE",
              "value": "{{inputs.parameters.imageMigrationConsoleLocation}}"
            },
            {
              "name": "CONSOLE_IMAGE_PULL_POLICY",
              "value": "{{inputs.parameters.imageMigrationConsolePullPolicy}}"
            },
            {
              "name": "FROM_SNAPSHOT_MIGRATION_LABEL",
              "value": "{{inputs.parameters.fromSnapshotMigrationK8sLabel}}"
            },
            {
              "name": "CONSOLE_CONFIG_BASE64",
              "value": "{{=toBase64(inputs.parameters.consoleConfigContents)}}"
            },
            {
              "name": "RFS_MONITOR_WORKFLOW_UID_LABEL",
              "value": "migrations.opensearch.org/rfs-monitor-workflow-uid"
            },
            {
              "name": "RFS_MONITOR_SESSION_LABEL",
              "value": "migrations.opensearch.org/rfs-monitor-session"
            },
            {
              "name": "WORKFLOW_SCRIPTS_ROOT",
              "value": "{{workflow.parameters.workflowScriptsRoot}}"
            }
          ],
          "image": "{{inputs.parameters.imageMigrationConsoleLocation}}",
          "imagePullPolicy": "{{inputs.parameters.imageMigrationConsolePullPolicy}}",
          "resources": {
            "limits": {
              "cpu": "500m",
              "memory": "500Mi"
            },
            "requests": {
              "cpu": "500m",
              "memory": "500Mi"
            }
          },
          "command": [
            "/bin/bash",
            "-lc"
          ],
          "args": [
            "exec \"${WORKFLOW_SCRIPTS_ROOT}/applyRfsMonitorCronJob.sh\""
          ]
        },
        "metadata": {
          "annotations": {
            "karpenter.sh/do-not-disrupt": "true"
          }
        },
        "retryStrategy": {
          "limit": "5",
          "retryPolicy": "Always",
          "backoff": {
            "duration": "2",
            "factor": "2",
            "cap": "30"
          }
        },
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "createrfspoddisruptionbudget",
        "inputs": {
          "parameters": [
            {
              "name": "sessionName"
            },
            {
              "name": "rfsJsonConfig"
            },
            {
              "name": "targetBasicCredsSecretNameOrEmpty"
            },
            {
              "name": "coordinatorBasicCredsSecretNameOrEmpty"
            },
            {
              "name": "podReplicas"
            },
            {
              "name": "minPodReplicas"
            },
            {
              "name": "jvmArgs"
            },
            {
              "name": "loggingConfigurationOverrideConfigMap"
            },
            {
              "name": "fileSourceVolumes"
            },
            {
              "name": "fileSourceVolumeMounts"
            },
            {
              "name": "useLocalStack",
              "description": "Only used for local testing"
            },
            {
              "name": "resources"
            },
            {
              "name": "crdName"
            },
            {
              "name": "crdUid"
            },
            {
              "name": "sourceK8sLabel"
            },
            {
              "name": "targetK8sLabel"
            },
            {
              "name": "snapshotK8sLabel"
            },
            {
              "name": "fromSnapshotMigrationK8sLabel"
            },
            {
              "name": "taskK8sLabel",
              "value": "reindexFromSnapshot"
            },
            {
              "name": "imageReindexFromSnapshotLocation"
            },
            {
              "name": "imageReindexFromSnapshotPullPolicy"
            }
          ]
        },
        "resource": {
          "manifest": "apiVersion: policy/v1\nkind: PodDisruptionBudget\nmetadata:\n  name: {{=toJSON(inputs.parameters.sessionName+'-rfs')}}\n  ownerReferences:\n    - apiVersion: migrations.opensearch.org/v1alpha1\n      kind: SnapshotMigration\n      name: {{=toJSON(inputs.parameters.crdName)}}\n      uid: {{=toJSON(inputs.parameters.crdUid)}}\n      controller: false\n      blockOwnerDeletion: true\n  labels:\n    workflows.argoproj.io/workflow: {{=toJSON(workflow.name)}}\n    migrations.opensearch.org/source: {{=toJSON(inputs.parameters.sourceK8sLabel)}}\n    migrations.opensearch.org/target: {{=toJSON(inputs.parameters.targetK8sLabel)}}\n    migrations.opensearch.org/snapshot: {{=toJSON(inputs.parameters.snapshotK8sLabel)}}\n    migrations.opensearch.org/from-snapshot-migration: {{=toJSON(inputs.parameters.fromSnapshotMigrationK8sLabel)}}\n    migrations.opensearch.org/task: {{=toJSON(inputs.parameters.taskK8sLabel)}}\nspec:\n  minAvailable: {{=fromJSON(inputs.parameters.minPodReplicas)}}\n  selector:\n    matchLabels:\n      app: bulk-loader\n      deployment-name: {{=toJSON(inputs.parameters.sessionName+'-rfs')}}\n",
          "action": "apply",
          "setOwnerReference": false
        },
        "retryStrategy": {
          "limit": "6",
          "retryPolicy": "OnError",
          "backoff": {
            "duration": "10",
            "factor": "2",
            "cap": "60"
          }
        },
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "createrfsdeployment",
        "inputs": {
          "parameters": [
            {
              "name": "sessionName"
            },
            {
              "name": "rfsJsonConfig"
            },
            {
              "name": "targetBasicCredsSecretNameOrEmpty"
            },
            {
              "name": "coordinatorBasicCredsSecretNameOrEmpty"
            },
            {
              "name": "podReplicas"
            },
            {
              "name": "minPodReplicas"
            },
            {
              "name": "jvmArgs"
            },
            {
              "name": "loggingConfigurationOverrideConfigMap"
