            },
            {
              "name": "imageReindexFromSnapshotLocation"
            },
            {
              "name": "imageReindexFromSnapshotPullPolicy"
            }
          ]
        },
        "resource": {
          "manifest": "apiVersion: apps/v1\nkind: Deployment\nmetadata:\n  name: {{=toJSON(inputs.parameters.sessionName+'-rfs')}}\n  ownerReferences:\n    - apiVersion: migrations.opensearch.org/v1alpha1\n      kind: SnapshotMigration\n      name: {{=toJSON(inputs.parameters.crdName)}}\n      uid: {{=toJSON(inputs.parameters.crdUid)}}\n      controller: false\n      blockOwnerDeletion: true\n  labels:\n    workflows.argoproj.io/workflow: {{=toJSON(workflow.name)}}\n    migrations.opensearch.org/source: {{=toJSON(inputs.parameters.sourceK8sLabel)}}\n    migrations.opensearch.org/target: {{=toJSON(inputs.parameters.targetK8sLabel)}}\n    migrations.opensearch.org/snapshot: {{=toJSON(inputs.parameters.snapshotK8sLabel)}}\n    migrations.opensearch.org/from-snapshot-migration: {{=toJSON(inputs.parameters.fromSnapshotMigrationK8sLabel)}}\n    migrations.opensearch.org/task: {{=toJSON(inputs.parameters.taskK8sLabel)}}\nspec:\n  replicas: {{=fromJSON(inputs.parameters.podReplicas)}}\n  strategy:\n    type: RollingUpdate\n    rollingUpdate:\n      maxUnavailable: 1\n      maxSurge: 1\n  selector:\n    matchLabels:\n      app: bulk-loader\n      deployment-name: {{=toJSON(inputs.parameters.sessionName+'-rfs')}}\n  template:\n    metadata:\n      labels:\n        app: bulk-loader\n        deployment-name: {{=toJSON(inputs.parameters.sessionName+'-rfs')}}\n        workflows.argoproj.io/workflow: {{=toJSON(workflow.name)}}\n        migrations.opensearch.org/source: {{=toJSON(inputs.parameters.sourceK8sLabel)}}\n        migrations.opensearch.org/target: {{=toJSON(inputs.parameters.targetK8sLabel)}}\n        migrations.opensearch.org/snapshot: {{=toJSON(inputs.parameters.snapshotK8sLabel)}}\n        migrations.opensearch.org/from-snapshot-migration: {{=toJSON(inputs.parameters.fromSnapshotMigrationK8sLabel)}}\n        migrations.opensearch.org/task: {{=toJSON(inputs.parameters.taskK8sLabel)}}\n    spec:\n      serviceAccountName: argo-workflow-executor\n      containers:\n        - name: bulk-loader\n          image: {{=toJSON(inputs.parameters.imageReindexFromSnapshotLocation)}}\n          imagePullPolicy: {{=toJSON(inputs.parameters.imageReindexFromSnapshotPullPolicy)}}\n          command:\n            - /rfs-app/runJavaWithClasspathWithRepeat.sh\n          args:\n            - org.opensearch.migrations.RfsMigrateDocuments\n            - ---INLINE-JSON\n            - \"{{=toBase64(inputs.parameters.rfsJsonConfig)}}\"\n          resources: {{=fromJSON(inputs.parameters.resources)}}\n          env:\n            - name: TARGET_USERNAME\n              valueFrom:\n                secretKeyRef:\n                  name: {{=toJSON(((0 == len(inputs.parameters.targetBasicCredsSecretNameOrEmpty)) ? ('empty') : (inputs.parameters.targetBasicCredsSecretNameOrEmpty)))}}\n                  key: username\n                  optional: true\n            - name: TARGET_PASSWORD\n              valueFrom:\n                secretKeyRef:\n                  name: {{=toJSON(((0 == len(inputs.parameters.targetBasicCredsSecretNameOrEmpty)) ? ('empty') : (inputs.parameters.targetBasicCredsSecretNameOrEmpty)))}}\n                  key: password\n                  optional: true\n            - name: COORDINATOR_USERNAME\n              valueFrom:\n                secretKeyRef:\n                  name: {{=toJSON(((0 == len(inputs.parameters.coordinatorBasicCredsSecretNameOrEmpty)) ? ('empty') : (inputs.parameters.coordinatorBasicCredsSecretNameOrEmpty)))}}\n                  key: username\n                  optional: true\n            - name: COORDINATOR_PASSWORD\n              valueFrom:\n                secretKeyRef:\n                  name: {{=toJSON(((0 == len(inputs.parameters.coordinatorBasicCredsSecretNameOrEmpty)) ? ('empty') : (inputs.parameters.coordinatorBasicCredsSecretNameOrEmpty)))}}\n                  key: password\n                  optional: true\n            - name: FAILED_REQUESTS_LOGGER_LEVEL\n              value: \"OFF\"\n            - name: CONSOLE_LOG_FORMAT\n              value: json\n            - name: JDK_JAVA_OPTIONS\n              value: {{=toJSON(inputs.parameters.jvmArgs + ' ' + ((!(0 == len(inputs.parameters.loggingConfigurationOverrideConfigMap))) ? ('-Dlog4j2.configurationFile=/config/logConfiguration/configuration') : ('')))}}\n            - name: AWS_SHARED_CREDENTIALS_FILE\n              value: {{=toJSON(((fromJSON(inputs.parameters.useLocalStack)) ? ('/config/credentials/configuration') : ('')))}}\n          volumeMounts: {{=sprig.concat([sprig.dict(\"name\", 'log4j-configuration', \"mountPath\", '/config/logConfiguration', \"readOnly\", true), sprig.dict(\"name\", 'localstack-test-creds', \"mountPath\", '/config/credentials', \"readOnly\", true)], fromJSON(inputs.parameters.fileSourceVolumeMounts))}}\n      volumes: {{=sprig.concat([sprig.dict(\"name\", 'log4j-configuration', \"configMap\", sprig.dict(\"name\", sprig.default('default-log4j-config', inputs.parameters.loggingConfigurationOverrideConfigMap), \"optional\", !(!(0 == len(inputs.parameters.loggingConfigurationOverrideConfigMap))))), sprig.dict(\"name\", 'localstack-test-creds', \"configMap\", sprig.dict(\"name\", 'localstack-test-creds', \"optional\", !(fromJSON(inputs.parameters.useLocalStack))))], fromJSON(inputs.parameters.fileSourceVolumes))}}\n",
          "action": "apply",
          "setOwnerReference": false
        },
        "retryStrategy": {
          "limit": "6",
          "retryPolicy": "OnError",
          "backoff": {
            "duration": "10",
            "factor": "2",
            "cap": "60"
          }
        },
        "outputs": {
          "parameters": []
        }
      },
      {
        "name": "starthistoricalbackfill",
        "inputs": {
          "parameters": [
            {
              "name": "sessionName"
