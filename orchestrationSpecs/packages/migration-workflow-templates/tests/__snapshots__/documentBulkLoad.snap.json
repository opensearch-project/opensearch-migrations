            },
            {
              "name": "resources"
            },
            {
              "name": "crdName"
            },
            {
              "name": "crdUid"
            },
            {
              "name": "sourceK8sLabel"
            },
            {
              "name": "targetK8sLabel"
            },
            {
              "name": "snapshotK8sLabel"
            },
            {
              "name": "fromSnapshotMigrationK8sLabel"
            },
            {
              "name": "taskK8sLabel",
              "value": "reindexFromSnapshot"
            },
            {
              "name": "imageReindexFromSnapshotLocation"
            },
            {
              "name": "imageReindexFromSnapshotPullPolicy"
            }
          ]
        },
        "steps": [
          [
            {
              "template": "createrfspoddisruptionbudget",
              "arguments": {
                "parameters": [
                  {
                    "name": "sessionName",
                    "value": "{{inputs.parameters.sessionName}}"
                  },
                  {
                    "name": "rfsJsonConfig",
                    "value": "{{inputs.parameters.rfsJsonConfig}}"
                  },
                  {
                    "name": "targetBasicCredsSecretNameOrEmpty",
                    "value": "{{inputs.parameters.targetBasicCredsSecretNameOrEmpty}}"
                  },
                  {
                    "name": "coordinatorBasicCredsSecretNameOrEmpty",
                    "value": "{{inputs.parameters.coordinatorBasicCredsSecretNameOrEmpty}}"
                  },
                  {
                    "name": "podReplicas",
                    "value": "{{inputs.parameters.podReplicas}}"
                  },
                  {
                    "name": "minPodReplicas",
                    "value": "{{inputs.parameters.minPodReplicas}}"
                  },
                  {
                    "name": "jvmArgs",
                    "value": "{{inputs.parameters.jvmArgs}}"
                  },
                  {
                    "name": "loggingConfigurationOverrideConfigMap",
                    "value": "{{inputs.parameters.loggingConfigurationOverrideConfigMap}}"
                  },
                  {
                    "name": "fileSourceVolumes",
                    "value": "{{inputs.parameters.fileSourceVolumes}}"
                  },
                  {
                    "name": "fileSourceVolumeMounts",
                    "value": "{{inputs.parameters.fileSourceVolumeMounts}}"
                  },
                  {
                    "name": "useLocalStack",
                    "value": "{{inputs.parameters.useLocalStack}}"
                  },
                  {
                    "name": "resources",
                    "value": "{{inputs.parameters.resources}}"
                  },
                  {
                    "name": "crdName",
                    "value": "{{inputs.parameters.crdName}}"
                  },
                  {
                    "name": "crdUid",
                    "value": "{{inputs.parameters.crdUid}}"
                  },
                  {
                    "name": "sourceK8sLabel",
                    "value": "{{inputs.parameters.sourceK8sLabel}}"
                  },
                  {
                    "name": "targetK8sLabel",
                    "value": "{{inputs.parameters.targetK8sLabel}}"
                  },
                  {
                    "name": "snapshotK8sLabel",
                    "value": "{{inputs.parameters.snapshotK8sLabel}}"
                  },
                  {
                    "name": "fromSnapshotMigrationK8sLabel",
                    "value": "{{inputs.parameters.fromSnapshotMigrationK8sLabel}}"
                  },
                  {
                    "name": "taskK8sLabel",
                    "value": "{{inputs.parameters.taskK8sLabel}}"
                  },
                  {
                    "name": "imageReindexFromSnapshotLocation",
                    "value": "{{inputs.parameters.imageReindexFromSnapshotLocation}}"
                  },
                  {
                    "name": "imageReindexFromSnapshotPullPolicy",
                    "value": "{{inputs.parameters.imageReindexFromSnapshotPullPolicy}}"
                  }
                ]
              },
              "name": "createPodDisruptionBudget"
            }
          ],
          [
            {
              "template": "createrfsdeployment",
              "arguments": {
                "parameters": [
                  {
                    "name": "sessionName",
                    "value": "{{inputs.parameters.sessionName}}"
                  },
                  {
                    "name": "rfsJsonConfig",
                    "value": "{{inputs.parameters.rfsJsonConfig}}"
                  },
                  {
                    "name": "targetBasicCredsSecretNameOrEmpty",
                    "value": "{{inputs.parameters.targetBasicCredsSecretNameOrEmpty}}"
                  },
                  {
                    "name": "coordinatorBasicCredsSecretNameOrEmpty",
                    "value": "{{inputs.parameters.coordinatorBasicCredsSecretNameOrEmpty}}"
                  },
                  {
                    "name": "podReplicas",
                    "value": "{{inputs.parameters.podReplicas}}"
                  },
                  {
                    "name": "minPodReplicas",
                    "value": "{{inputs.parameters.minPodReplicas}}"
                  },
                  {
                    "name": "jvmArgs",
                    "value": "{{inputs.parameters.jvmArgs}}"
                  },
                  {
                    "name": "loggingConfigurationOverrideConfigMap",
                    "value": "{{inputs.parameters.loggingConfigurationOverrideConfigMap}}"
                  },
                  {
                    "name": "fileSourceVolumes",
                    "value": "{{inputs.parameters.fileSourceVolumes}}"
                  },
                  {
                    "name": "fileSourceVolumeMounts",
                    "value": "{{inputs.parameters.fileSourceVolumeMounts}}"
                  },
                  {
                    "name": "useLocalStack",
                    "value": "{{inputs.parameters.useLocalStack}}"
                  },
                  {
                    "name": "resources",
                    "value": "{{inputs.parameters.resources}}"
                  },
                  {
                    "name": "crdName",
                    "value": "{{inputs.parameters.crdName}}"
                  },
                  {
                    "name": "crdUid",
                    "value": "{{inputs.parameters.crdUid}}"
                  },
                  {
                    "name": "sourceK8sLabel",
                    "value": "{{inputs.parameters.sourceK8sLabel}}"
                  },
                  {
                    "name": "targetK8sLabel",
