              "name": "resources"
            },
            {
              "name": "crdName"
            },
            {
              "name": "crdUid"
            },
            {
              "name": "sourceK8sLabel"
            },
            {
              "name": "targetK8sLabel"
            },
            {
              "name": "snapshotK8sLabel"
            },
            {
              "name": "fromSnapshotMigrationK8sLabel"
            },
            {
              "name": "taskK8sLabel",
